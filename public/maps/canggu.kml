            <value><![CDATA[https://mymaps.usercontent.google.com/hostedimage/m/*/3AE5a_Gzao2NuCQOhbDAAgYvRN1VCSqQU8RnZJdnoBgWoiZM1r4cQY_6hR1kohBC0YfV2MDIu0EE1pk3sajMsSrnRcoraE7zSoKGsX7yG06SdySshyS2E0sAUl5nBuBWfz0hSz4Ftdm1Sv6BzIeYcXPNlXWoNxNYDQQAN6tXAA6pwV4Ay45ubJlSz7a70fTrxcApOiWeuU9zpkPLNIT3Cwzn0fPHgUalmMGo0fneuCEwabkNvngWTAl5dVwUYWC_-dw?authuser=0&fife=s16383]]></value>
