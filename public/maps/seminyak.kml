            <value><![CDATA[https://mymaps.usercontent.google.com/hostedimage/m/*/3AL_Y2X5Ny0NQWgb6ledD9Id-z5xgj4FL7hX84eUTjdVw-SXZjIOexRZrr1s5xyXaYR-OAg5UK3S7Zztrdct9kkKpwWskAzBrxVhYBtDYVWXK7dsDfI2oFjXT1pg_-ygL95FIFAsvYCAuhzRTp0t7MOLK0c_9m7qxfnJ8DJ1bMHNe9nScg7rsFyiRHlFtn40R2d2Tq0pIFN2aVFQNkjPC9aBoEO5ldP7OJAHxoz4-pi2XtBOG3ipVBKzBw3NjUeo?authuser=0&fife=s16383]]></value>
