    <Folder>
      <name>Sanur 的著名海灘</name>
      <Placemark>
        <name>Pantai Sindhu</name>
        <description><![CDATA[最多小販、人潮的沙灘<br><br>請參考網誌詳細介紹：https://gobaligo.id/go/sanur-guide]]></description>
        <styleUrl>#icon-1899-0288D1</styleUrl>
        <Point>
          <coordinates>
            115.2645885,-8.6843724,0
          </coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>Pantai Karang</name>
        <description><![CDATA[最熱門水上活動地點<br>https://gobaligo.id/go/sanur-guide]]></description>
