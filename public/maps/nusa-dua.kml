            <value><![CDATA[https://mymaps.usercontent.google.com/hostedimage/m/*/3AE5a_GwqpG9rAgzKMgS9r1qiMhrDCPf0OnDEN046qxbpY2EwJRzS6MDkHETxF5vgm2OPncre1luCIjCjp188qGHDmlSou7QgnYjmtZH4qcn9El1DtY-ES-Q2ggmFP7kG3QqgYsoNz3xGcr7DwhMUSHRimUBjjr8VBcAHBLAmzYVOLWu3k9Ia8yygvRZVp2dFVg_RaSFVLcn-1fPgwHlPK_yRIkaB1JIRZfxjtipBpUwAevGnyIpN_YgzpPynHLM?authuser=0&fife=s16383]]></value>
