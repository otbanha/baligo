            <value><![CDATA[https://mymaps.usercontent.google.com/hostedimage/m/*/3AL_Y2X56Q5hPHuO6hW1IvYxoz-ScGFrKYCmg_FukJd4FNek-FiEwYO5iAPCDrVA8iHGKO0hx9PNxTIx-3NA5Ecmn9oZTFFxgxXi12OFR6ZmSvzSZUBmumq5-qlnzVxDAugO-SuErGmlnoaI2eRudxTLX7zIsA2anUUmKuDn8oMgBddMzFwPkuNvtzvZAiHOGbDfaUIyY5uhq2QiWQYiJwQVgc5DdxYUzziJ7DPtQXVn5kBFhy1HKJ9Sp0eoLUjo?authuser=0&fife=s16383]]></value>
