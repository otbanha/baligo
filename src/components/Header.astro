---
import { SITE_TITLE } from '../consts';
import LanguageSwitcher from './LanguageSwitcher.astro';
import ScrollReveal from './ScrollReveal.astro';

interface Props {
  lang?: string;
  slug?: string;
}
const { lang, slug } = Astro.props;

const homeUrl = lang === 'en' ? '/en/blog/' :
                lang === 'zh-cn' ? '/zh-cn/blog/' :
                lang === 'zh-hk' ? '/zh-hk/blog/' : '/blog/?lang=tw';

const searchPlaceholder = lang === 'en'    ? '🔍 Search articles...' :
                          lang === 'zh-cn' ? '🔍 搜索文章...' :
                          lang === 'zh-hk' ? '🔍 搜尋文章...' :
                                             '🔍 搜尋文章...';

const closeLabel = lang === 'en' ? 'Close search' : '關閉搜尋';
const searchLabel = lang === 'en' ? 'Search' : '搜尋';
const inputPlaceholder = lang === 'en' ? 'Search 600+ Bali travel articles...' : '搜尋 600+ 篇峇里島旅遊文章...';
---

<ScrollReveal />
<header>
  <nav>
    <div class="brand">
      <a href={homeUrl}>
        <img src="/favicon-32x32.png" alt="logo" class="logo-icon" />
        <span class="logo-text">
          <span class="logo-line1">Go Bali Go</span>
          <span class="logo-line2">峇里島旅遊攻略</span>
        </span>
      </a>
    </div>

    <!-- 搜尋觸發器（點擊開啟 Pagefind modal） -->
    <div class="search-right">
      <button type="button" id="search-trigger" class="search-input" aria-label="開啟搜尋">
        {searchPlaceholder}
      </button>
    </div>

    <a href="/bookmarks/" class="bk-icon" id="bk-icon-link" aria-label="我的書籤" title="我的書籤">
      🔖<span class="bk-badge" id="bk-badge" hidden></span>
    </a>

    <LanguageSwitcher currentLang={lang ?? 'blog'} slug={slug ?? ''} />
  </nav>
</header>

<!-- Google 本站搜尋 Modal -->
<div id="search-modal" class="search-modal" hidden aria-modal="true" role="dialog" aria-label={closeLabel}>
  <div class="search-modal-backdrop" id="search-backdrop"></div>
  <div class="search-modal-box">
    <form id="google-search-form" class="search-form">
      <input
        type="search"
        id="google-search-input"
        class="google-search-input"
        placeholder={inputPlaceholder}
        autocomplete="off"
        autocorrect="off"
        spellcheck="false"
      />
      <button type="submit" class="google-search-btn">{searchLabel}</button>
      <button type="button" class="search-close-btn" id="search-close" aria-label={closeLabel}>✕</button>
    </form>
    <p class="search-hint">Powered by Google</p>
  </div>
</div>

<script>
  // 書籤數量 badge
  (function () {
    try {
      const saved = JSON.parse(localStorage.getItem('bk') || '{}');
      const count = Object.keys(saved).length;
      const badge = document.getElementById('bk-badge');
      if (badge && count > 0) {
        badge.textContent = String(count);
        badge.hidden = false;
      }
    } catch {}
  })();
</script>

<script>
  function openModal() {
    const modal = document.getElementById('search-modal');
    if (!modal) return;
    modal.hidden = false;
    document.body.style.overflow = 'hidden';
    setTimeout(() => {
      const input = document.getElementById('google-search-input');
      if (input) input.focus();
    }, 50);
  }

  function closeModal() {
    const modal = document.getElementById('search-modal');
    if (!modal) return;
    modal.hidden = true;
    document.body.style.overflow = '';
  }

  document.getElementById('search-trigger')?.addEventListener('click', openModal);
  document.getElementById('search-close')?.addEventListener('click', closeModal);
  document.getElementById('search-backdrop')?.addEventListener('click', closeModal);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

  document.getElementById('google-search-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const q = (document.getElementById('google-search-input') as HTMLInputElement)?.value.trim();
    if (q) {
      window.open('https://www.google.com/search?q=site:gobaligo.id+' + encodeURIComponent(q), '_blank');
      closeModal();
    }
  });
</script>

<style>
header {
  background: var(--ocean);
  border-bottom: 2px solid var(--gold);
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2px 20px rgba(0,0,0,0.3);
}

nav {
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 1.5em;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 64px;
  gap: 1.5em;
}

.brand a {
  display: flex;
  align-items: center;
  gap: 0.5em;
  text-decoration: none;
  color: var(--white);
  white-space: nowrap;
}

.logo-icon {
  width: 32px;
  height: 32px;
  border-radius: 4px;
}

.logo-text {
  font-family: 'Playfair Display', serif;
  font-size: 1.5em;
  font-weight: 700;
  color: var(--gold-light);
  letter-spacing: 0.02em;
  display: block;
}

.logo-line1 { display: block; }
.logo-line2 { display: none; }

.search-right {
  width: 360px;
  flex-shrink: 0;
}

/* 搜尋觸發按鈕：外觀與舊 input 完全相同 */
button.search-input {
  display: block;
  width: 100%;
  background: rgba(255,255,255,0.12);
  border: 1px solid rgba(197,160,89,0.4);
  color: rgba(255,255,255,0.5);
  border-radius: 8px;
  font-size: 0.88em;
  padding: 0.5em 1em;
  font-family: inherit;
  box-sizing: border-box;
  text-align: left;
  cursor: pointer;
  transition: background 0.2s, border-color 0.2s;
}
button.search-input:hover,
button.search-input:focus {
  outline: none;
  border-color: var(--gold);
  background: rgba(255,255,255,0.18);
  color: rgba(255,255,255,0.7);
}

/* ── Search Modal ─────────────────────────────────────── */
.search-modal {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding-top: 80px;
}
.search-modal[hidden] { display: none; }

.search-modal-backdrop {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.65);
  backdrop-filter: blur(4px);
}

.search-modal-box {
  position: relative;
  width: 100%;
  max-width: 640px;
  margin: 0 1em;
  background: var(--white, #fff);
  border-radius: 12px;
  box-shadow: 0 20px 60px rgba(0,0,0,0.4);
}

.search-close-btn {
  flex-shrink: 0;
  background: none;
  border: none;
  font-size: 1.2em;
  color: #666;
  cursor: pointer;
  padding: 0.3em 0.5em;
  line-height: 1;
  border-radius: 4px;
}
.search-close-btn:hover { background: #eee; color: #333; }

.search-hint {
  margin: 0.4em 1em 0.8em;
  font-size: 0.75em;
  color: #aaa;
  text-align: right;
}

.search-form {
  display: flex;
  align-items: center;
  gap: 0.5em;
  padding: 1em;
}

.google-search-input {
  flex: 1;
  min-width: 0;
  border: 1.5px solid #c5a059;
  border-radius: 8px;
  padding: 0.6em 1em;
  font-size: 1em;
  font-family: inherit;
  outline: none;
  color: #1a1a1a;
}
.google-search-input:focus {
  border-color: #0a1628;
  box-shadow: 0 0 0 3px rgba(10,22,40,0.1);
}

.google-search-btn {
  flex-shrink: 0;
  background: #0a1628;
  color: #fff;
  border: none;
  border-radius: 8px;
  padding: 0.6em 1.2em;
  font-size: 0.95em;
  font-family: inherit;
  cursor: pointer;
  white-space: nowrap;
}
.google-search-btn:hover { background: #c5a059; }

.bk-icon {
  position: relative;
  font-size: 1.3em;
  text-decoration: none;
  line-height: 1;
  flex-shrink: 0;
}
.bk-badge {
  position: absolute;
  top: -6px;
  right: -8px;
  background: #ef4444;
  color: #fff;
  font-size: 0.45em;
  font-weight: 700;
  min-width: 1.4em;
  height: 1.4em;
  border-radius: 999px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 0.2em;
  line-height: 1;
}

@media (max-width: 600px) {
  header { height: auto; }
  nav {
    flex-wrap: wrap;
    height: auto;
    padding: 0.45em 1em;
    gap: 0.4em;
  }
  .brand { width: 100%; }
  .brand a { gap: 0.4em; }
  .logo-text { font-size: 1em; line-height: 1.2; }
  .logo-line2 { display: block; font-size: 0.72em; opacity: 0.85; }
  .search-right { flex: 1; min-width: 0; width: auto; }
  .search-modal { padding-top: 20px; }
  :global(.lang-switcher) { flex-shrink: 0; }
  :global(.lang-current) { padding: 0.3em 0.5em; font-size: 0.8rem; }
  :global(.lang-globe) { display: none; }
  .bk-icon { font-size: 1.1em; }
}
</style>