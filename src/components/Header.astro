---
import { SITE_TITLE } from '../consts';
import LanguageSwitcher from './LanguageSwitcher.astro';
import ScrollReveal from './ScrollReveal.astro';

interface Props {
  lang?: string;
  slug?: string;
}
const { lang, slug } = Astro.props;

const homeUrl = lang === 'en' ? '/en/blog/' :
                lang === 'zh-cn' ? '/zh-cn/blog/' :
                lang === 'zh-hk' ? '/zh-hk/blog/' : '/blog/';

const searchPlaceholder = lang === 'en'    ? '🔍 Search Go Bali Go...' :
                          lang === 'zh-cn' ? '🔍 搜索巴厘岛攻略...' :
                          lang === 'zh-hk' ? '🔍 搜尋峇里島攻略...' :
                                             '🔍 搜尋峇里島攻略...';

const searchSite = lang === 'en'    ? 'gobaligo.id/en/blog' :
                   lang === 'zh-cn' ? 'gobaligo.id/zh-cn/blog' :
                   lang === 'zh-hk' ? 'gobaligo.id/zh-hk/blog' :
                                      'gobaligo.id/blog';
---

<ScrollReveal />
<header>
  <nav>
    <div class="brand">
      <a href={homeUrl}>
        <img src="/favicon-32x32.png" alt="logo" class="logo-icon" />
        <span class="logo-text">{SITE_TITLE}</span>
      </a>
    </div>

    <form class="search-right" action="https://www.google.com/search" method="get" target="_blank">
      <input type="hidden" name="sitesearch" value={searchSite} />
      <input
        type="text"
        name="q"
        class="search-input"
        placeholder={searchPlaceholder}
      />
    </form>

    <LanguageSwitcher currentLang={lang ?? 'blog'} slug={slug ?? ''} />
  </nav>
</header>

<style>
header {
  background: var(--ocean);
  border-bottom: 2px solid var(--gold);
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2px 20px rgba(0,0,0,0.3);
}

nav {
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 1.5em;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 64px;
  gap: 1.5em;
}

.brand a {
  display: flex;
  align-items: center;
  gap: 0.5em;
  text-decoration: none;
  color: var(--white);
  white-space: nowrap;
}

.logo-icon {
  width: 32px;
  height: 32px;
  border-radius: 4px;
}

.logo-text {
  font-family: 'Playfair Display', serif;
  font-size: 1.5em;
  font-weight: 700;
  color: var(--gold-light);
  letter-spacing: 0.02em;
}

.search-right {
  width: 360px;
  flex-shrink: 0;
}

.search-input {
  width: 100%;
  background: rgba(255,255,255,0.12);
  border: 1px solid rgba(197,160,89,0.4);
  color: white;
  border-radius: 8px;
  font-size: 0.88em;
  padding: 0.5em 1em;
  font-family: inherit;
  box-sizing: border-box;
}

.search-input::placeholder {
  color: rgba(255,255,255,0.5);
}

.search-input:focus {
  outline: none;
  border-color: var(--gold);
  background: rgba(255,255,255,0.18);
}

@media (max-width: 600px) {
  .logo-text { font-size: 1em; }
  .search-right { width: 180px; }
  nav { padding: 0 1em; }
  /* 手機版隱藏語言切換選單 */
  :global(.lang-switcher) { display: none !important; }
}

@media (max-width: 400px) {
  .logo-text { display: none; }
  .search-right { width: auto; flex: 1; min-width: 0; }
}
</style>