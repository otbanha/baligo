---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
  <nav>
    <div class="brand">
      <a href="/blog">
        <span class="logo-icon">🌴</span>
        <span class="logo-text">{SITE_TITLE}</span>
      </a>
    </div>
    <div class="nav-links">
      <HeaderLink href="/blog">文章</HeaderLink>
      <HeaderLink href="/about">關於</HeaderLink>
    </div>
  </nav>
</header>

<style>
header {
  background: var(--ocean);
  border-bottom: 2px solid var(--gold);
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2px 20px rgba(0,0,0,0.3);
}

nav {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 1.5em;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 64px;
}

.brand a {
  display: flex;
  align-items: center;
  gap: 0.5em;
  text-decoration: none;
  color: var(--white);
}

.logo-icon {
  font-size: 1.4em;
}

.logo-text {
  font-family: 'Playfair Display', serif;
  font-size: 1.2em;
  font-weight: 700;
  color: var(--gold-light);
  letter-spacing: 0.02em;
}

.nav-links {
  display: flex;
  align-items: center;
  gap: 0.2em;
}

.nav-links :global(a) {
  color: rgba(255,255,255,0.8);
  text-decoration: none;
  padding: 0.4em 1em;
  border-radius: 6px;
  font-size: 0.95em;
  font-weight: 500;
  letter-spacing: 0.03em;
  transition: all 0.2s;
}

.nav-links :global(a:hover),
.nav-links :global(a.active) {
  color: var(--gold-light);
  background: rgba(201, 168, 76, 0.15);
}

@media (max-width: 600px) {
  .logo-text {
    font-size: 1em;
  }
  nav {
    padding: 0 1em;
  }
}
</style>