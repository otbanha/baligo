---

<main id="planner">

  <!-- Hero -->
  <div class="planner-hero">
    <div class="hero-inner">
      <div class="hero-badge">{T.badge}</div>
      <h1>{T.title}</h1>
      <p>{T.subtitle}</p>
    </div>
  </div>

  <!-- Wizard -->
  <div class="wizard-wrap">

    <!-- Steps nav -->
    <div class="steps-nav">
      <div class="snav-item active" id="snav-1">
        <span class="snav-num">1</span>
        <span class="snav-label">{T.nav1}</span>
      </div>
      <div class="snav-line"></div>
      <div class="snav-item" id="snav-2">
        <span class="snav-num">2</span>
        <span class="snav-label">{T.nav2}</span>
      </div>
      <div class="snav-line"></div>
      <div class="snav-item" id="snav-3">
        <span class="snav-num">3</span>
        <span class="snav-label">{T.nav3}</span>
      </div>
    </div>

    <!-- Step 1 -->
    <div class="step" id="step-1">
      <h2 class="step-title">{T.s1title}</h2>

      <div class="q-block">
        <div class="q-label">{T.q1}</div>
        <div class="chips single" id="q-companion">
          <button class="chip" data-val="solo">{T.c_solo}</button>
          <button class="chip" data-val="couple">{T.c_couple}</button>
          <button class="chip" data-val="family">{T.c_family}</button>
          <button class="chip" data-val="friends">{T.c_friends}</button>
          <button class="chip" data-val="elder">{T.c_elder}</button>
          <button class="chip" data-val="group">{T.c_group}</button>
        </div>
      </div>

      <div class="q-block">
        <div class="q-label">{T.q2}</div>
        <div class="chips single" id="q-days">
          <button class="chip" data-val="4">{T.d4}</button>
          <button class="chip" data-val="5">{T.d5}</button>
          <button class="chip" data-val="68">{T.d68}</button>
          <button class="chip" data-val="9">{T.d9}</button>
        </div>
      </div>

      <div class="q-block">
        <div class="q-label">{T.q3} <span class="q-hint">{T.q3hint}</span></div>
        <div class="chips multi" id="q-interests">
          <button class="chip" data-val="beach">{T.i_beach}</button>
          <button class="chip" data-val="surf">{T.i_surf}</button>
          <button class="chip" data-val="culture">{T.i_culture}</button>
          <button class="chip" data-val="spa">{T.i_spa}</button>
          <button class="chip" data-val="food">{T.i_food}</button>
          <button class="chip" data-val="shop">{T.i_shop}</button>
          <button class="chip" data-val="yoga">{T.i_yoga}</button>
          <button class="chip" data-val="night">{T.i_night}</button>
          <button class="chip" data-val="kids">{T.i_kids}</button>
          <button class="chip" data-val="snorkel">{T.i_snorkel}</button>
          <button class="chip" data-val="nature">{T.i_nature}</button>
          <button class="chip" data-val="photo">{T.i_photo}</button>
          <button class="chip" data-val="rafting">{T.i_rafting}</button>
          <button class="chip" data-val="atv">{T.i_atv}</button>
          <button class="chip" data-val="beachclub">{T.i_beachclub}</button>
          <button class="chip" data-val="volcano">{T.i_volcano}</button>
          <button class="chip" data-val="performance">{T.i_performance}</button>
        </div>
      </div>

      <div class="q-block">
        <div class="q-label">{T.q4}</div>
        <div class="chips single" id="q-budget">
          <button class="chip" data-val="budget">{T.b_budget}</button>
          <button class="chip" data-val="mid">{T.b_mid}</button>
          <button class="chip" data-val="luxury">{T.b_luxury}</button>
        </div>
      </div>

      <div class="step-actions">
        <button class="btn-next" id="btn-1-next">{T.btnNext1}</button>
      </div>
    </div>

    <!-- Step 2 -->
    <div class="step hidden" id="step-2">
      <h2 class="step-title">{T.s2title}</h2>

      <div class="q-block">
        <div class="q-label">{T.q5} <span class="q-hint">{T.q5hint}</span></div>
        <div class="chips multi" id="q-areas">
          <button class="chip" data-val="kuta">{T.a_kuta}</button>
          <button class="chip" data-val="seminyak">{T.a_seminyak}</button>
          <button class="chip" data-val="canggu">{T.a_canggu}</button>
          <button class="chip" data-val="ubud">{T.a_ubud}</button>
          <button class="chip" data-val="jimbaran">{T.a_jimbaran}</button>
          <button class="chip" data-val="uluwatu">{T.a_uluwatu}</button>
          <button class="chip" data-val="nusadua">{T.a_nusadua}</button>
          <button class="chip" data-val="sanur">{T.a_sanur}</button>
          <button class="chip" data-val="penida">{T.a_penida}</button>
          <button class="chip" data-val="east">{T.a_east}</button>
        </div>
      </div>

      <div class="q-block">
        <div class="q-label">
          {T.q6} <span class="q-hint">{T.q6hint}</span>
        </div>
        <textarea id="q-itinerary" rows="9" placeholder={T.placeholder}></textarea>
      </div>

      <div class="step-actions">
        <button class="btn-back" id="btn-2-back">{T.btnBack}</button>
        <button class="btn-next" id="btn-2-next">{T.btnNext2}</button>
      </div>
    </div>

    <!-- Step 3 -->
    <div class="step hidden" id="step-3">

      <div class="results-header">
        <h2 class="step-title">{T.s3title}</h2>
        <p id="results-summary" class="results-summary"></p>
      </div>

      <div class="empty-alert hidden" id="empty-alert">
        <span>📌</span>
        <span id="empty-alert-text"></span>
      </div>

      <div id="route-tip"></div>
      <div id="region-sections"></div>
      <div id="interest-extras"></div>
      <div id="accom-section"></div>

      <!-- Must-Read -->
      <div class="results-section highlight">
        <h3 class="section-title">{T.secMustRead}</h3>
        <div class="article-grid">
          <a href="/blog/2023-12-06-65708c78fd89780001f418c2/" class="acard" target="_blank" rel="noopener">
            <span class="acard-tag">{T.tagNewbie}</span>
            <p class="acard-title">【2026 峇里島自由行】7 步驟輕鬆規劃完美旅程</p>
            <span class="acard-arrow">→</span>
          </a>
          <a href="/blog/2025-01-07-672e2c1afd897800014c3fbc/" class="acard" target="_blank" rel="noopener">
            <span class="acard-tag">{T.tagQA}</span>
            <p class="acard-title">99% 遊客都在偷偷搜尋的超尷尬 41 個問題大解答</p>
            <span class="acard-arrow">→</span>
          </a>
          <a href="/blog/2024-03-18-65ba3bfefd89780001650f07/" class="acard" target="_blank" rel="noopener">
            <span class="acard-tag">{T.tagRoute}</span>
            <p class="acard-title">【這樣玩居然不塞車！】8 天 7 夜爽玩峇里島全方位攻略</p>
