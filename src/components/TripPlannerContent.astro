// ── State ─────────────────────────────────────────────────────────────
const state = { companion:'', days:'', interests:[], budget:'', areas:[], itinerary:'' };

// ── Chip Selection ────────────────────────────────────────────────────
document.querySelectorAll('.chips').forEach(group => {
  const isMulti = group.classList.contains('multi');
  group.addEventListener('click', e => {
    const chip = e.target.closest('.chip');
    if (!chip) return;
    if (isMulti) chip.classList.toggle('selected');
    else { group.querySelectorAll('.chip').forEach(c => c.classList.remove('selected')); chip.classList.add('selected'); }
  });
});

// ── Navigation ────────────────────────────────────────────────────────
function getVals(id) { return [...document.querySelectorAll(`#${id} .chip.selected`)].map(c => c.dataset.val); }

function setNav(n) {
  document.querySelectorAll('.snav-item').forEach((el, i) => {
    el.classList.toggle('active', i + 1 <= n);
    el.classList.toggle('done', i + 1 < n);
  });
}

function showStep(n) {
  document.querySelectorAll('.step').forEach((s, i) => s.classList.toggle('hidden', i + 1 !== n));
  setNav(n);
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

document.getElementById('btn-1-next').addEventListener('click', () => {
  Object.assign(state, { companion: getVals('q-companion')[0]||'', days: getVals('q-days')[0]||'', interests: getVals('q-interests'), budget: getVals('q-budget')[0]||'' });
  showStep(2);
});
document.getElementById('btn-2-back').addEventListener('click', () => showStep(1));
document.getElementById('btn-2-next').addEventListener('click', () => {
  Object.assign(state, { areas: getVals('q-areas'), itinerary: document.getElementById('q-itinerary').value.trim() });
  buildResults();
  showStep(3);
});
document.getElementById('btn-restart').addEventListener('click', () => {
  document.querySelectorAll('.chip').forEach(c => c.classList.remove('selected'));
  document.getElementById('q-itinerary').value = '';
  Object.assign(state, { companion:'', days:'', interests:[], budget:'', areas:[], itinerary:'' });
  showStep(1);
});

// ── Itinerary Analysis ────────────────────────────────────────────────
function analyzeItinerary(text) {
  if (!text) return { mentionedAreas: [], emptyDays: [] };
  const emptyKws = ['???','待定','tbd','空白','未定','不知道','唔知','還沒想','未排','no plan'];
  const found = new Set();
  const emptyDays = [];
  text.split('\n').forEach(line => {
    const lo = line.toLowerCase();
    for (const [key, reg] of Object.entries(REGIONS)) {
      if (reg.keywords.some(kw => lo.includes(kw.toLowerCase()))) found.add(key);
    }
    const dm = line.match(/[Dd](\d+)|第\s*(\d+)\s*[天日]|[Dd]ay\s*(\d+)/);
    if (dm && emptyKws.some(kw => lo.includes(kw.toLowerCase()))) {
      emptyDays.push(LS.emptyDayPre + (dm[1]??dm[2]??dm[3]) + LS.emptyDaySuf);
    }
  });
  return { mentionedAreas: [...found], emptyDays };
}

