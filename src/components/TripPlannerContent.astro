---

<main id="planner">

  <!-- Hero -->
  <div class="planner-hero">
    <div class="hero-inner">
      <div class="hero-badge">{T.badge}</div>
      <h1>{T.title}</h1>
      <p>{T.subtitle}</p>
    </div>
  </div>

  <!-- Wizard -->
  <div class="wizard-wrap">

    <!-- Steps nav -->
    <div class="steps-nav">
      <div class="snav-item active" id="snav-1">
        <span class="snav-num">1</span>
        <span class="snav-label">{T.nav1}</span>
      </div>
      <div class="snav-line"></div>
      <div class="snav-item" id="snav-2">
        <span class="snav-num">2</span>
        <span class="snav-label">{T.nav2}</span>
      </div>
      <div class="snav-line"></div>
      <div class="snav-item" id="snav-3">
        <span class="snav-num">3</span>
        <span class="snav-label">{T.nav3}</span>
      </div>
    </div>

    <!-- Step 1 -->
    <div class="step" id="step-1">
      <h2 class="step-title">{T.s1title}</h2>

      <div class="q-block">
        <div class="q-label">{T.q1}</div>
        <div class="chips single" id="q-companion">
          <button class="chip" data-val="solo">{T.c_solo}</button>
          <button class="chip" data-val="couple">{T.c_couple}</button>
          <button class="chip" data-val="family">{T.c_family}</button>
          <button class="chip" data-val="friends">{T.c_friends}</button>
          <button class="chip" data-val="elder">{T.c_elder}</button>
          <button class="chip" data-val="group">{T.c_group}</button>
        </div>
      </div>

      <div class="q-block">
        <div class="q-label">{T.q2}</div>
        <div class="chips single" id="q-days">
          <button class="chip" data-val="4">{T.d4}</button>
          <button class="chip" data-val="5">{T.d5}</button>
          <button class="chip" data-val="68">{T.d68}</button>
          <button class="chip" data-val="9">{T.d9}</button>
        </div>
      </div>

      <div class="q-block">
        <div class="q-label">{T.q_spots} <span class="q-hint">{T.q_spots_hint}</span></div>
        <div class="spots-region-group">
          <div class="spots-region-label">{T.spots_ubud}</div>
          <div class="chips multi" id="q-spots-ubud">
