// ── State ─────────────────────────────────────────────────────────────
const state = { companion:'', days:'', interests:[], budget:'', areas:[], itinerary:'', allSpots:[] };

// ── LocalStorage Operations ────────────────────────────────────────────
function saveState() {
  const saved = { companion: state.companion, days: state.days, interests: state.interests, budget: state.budget, areas: state.areas, itinerary: state.itinerary, allSpots: state.allSpots, timestamp: new Date().toISOString() };
  localStorage.setItem('tripPlannerState', JSON.stringify(saved));
}

function loadSavedState() {
  const saved = localStorage.getItem('tripPlannerState');
  if (!saved) return null;
  try { return JSON.parse(saved); } catch (e) { return null; }
}

function showRestoreButton() {
  const saved = loadSavedState();
  if (!saved) return;
  const restoreBtn = document.createElement('button');
  restoreBtn.className = 'btn-restore';
  restoreBtn.id = 'btn-restore';
  restoreBtn.textContent = clientT.btnRestore;
  restoreBtn.addEventListener('click', () => {
    document.querySelectorAll('.chip').forEach(c => c.classList.remove('selected'));
    document.getElementById('q-itinerary').value = '';

    // Restore all state
    if (saved.companion) { state.companion = saved.companion; document.querySelector(`#q-companion .chip[data-val="${saved.companion}"]`)?.classList.add('selected'); }
    if (saved.days) { state.days = saved.days; document.querySelector(`#q-days .chip[data-val="${saved.days}"]`)?.classList.add('selected'); }
    saved.interests.forEach(v => { state.interests.push(v); document.querySelector(`#q-interests .chip[data-val="${v}"]`)?.classList.add('selected'); });
    if (saved.budget) { state.budget = saved.budget; document.querySelector(`#q-budget .chip[data-val="${saved.budget}"]`)?.classList.add('selected'); }
    state.allSpots = saved.allSpots;
    saved.allSpots.forEach(v => { document.querySelector(`[id^="q-spots-"] .chip[data-val="${v}"]`)?.classList.add('selected'); });

    showStep(2);
  });

  const actions = document.querySelector('#step-1 .step-actions');
  if (actions) {
    actions.insertBefore(restoreBtn, actions.firstChild);
  }
}

function buildTripUrl() {
  const params = new URLSearchParams();
  if (state.companion) params.set('c', state.companion);
  if (state.days) params.set('d', state.days);
  if (state.interests.length) params.set('i', state.interests.join(','));
  if (state.budget) params.set('b', state.budget);
  if (state.areas.length) params.set('a', state.areas.join(','));
  if (state.allSpots.length) params.set('s', state.allSpots.join(','));
  // Use /share/ so LINE/social scrapers see a friendly OG title instead of the tool name
  return `${window.location.origin}/share/?${params.toString()}`;
}

function importFromJSON() {
  const input = document.createElement('input');
  input.type = 'file';
  input.accept = '.json';
  input.addEventListener('change', (e) => {
    const file = e.target.files?.[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = (event) => {
      try {
        const imported = JSON.parse(event.target?.result || '{}');

        // Clear current state
        document.querySelectorAll('.chip').forEach(c => c.classList.remove('selected'));
        document.getElementById('q-itinerary').value = '';
        Object.assign(state, { companion:'', days:'', interests:[], budget:'', areas:[], itinerary:'', allSpots:[] });

        // Restore imported state
        if (imported.companion) { state.companion = imported.companion; document.querySelector(`#q-companion .chip[data-val="${imported.companion}"]`)?.classList.add('selected'); }
        if (imported.days) { state.days = imported.days; document.querySelector(`#q-days .chip[data-val="${imported.days}"]`)?.classList.add('selected'); }
        if (Array.isArray(imported.interests)) {
          state.interests = imported.interests;
          imported.interests.forEach(v => { document.querySelector(`#q-interests .chip[data-val="${v}"]`)?.classList.add('selected'); });
        }
        if (imported.budget) { state.budget = imported.budget; document.querySelector(`#q-budget .chip[data-val="${imported.budget}"]`)?.classList.add('selected'); }
        if (Array.isArray(imported.allSpots)) {
          state.allSpots = imported.allSpots;
          imported.allSpots.forEach(v => { document.querySelector(`[id^="q-spots-"] .chip[data-val="${v}"]`)?.classList.add('selected'); });
        }
        if (imported.itinerary) { state.itinerary = imported.itinerary; document.getElementById('q-itinerary').value = imported.itinerary; }
        if (Array.isArray(imported.areas)) {
          state.areas = imported.areas;
          imported.areas.forEach(v => { document.querySelector(`#q-areas .chip[data-val="${v}"]`)?.classList.add('selected'); });
        }

        saveState();
        showStep(2);
      } catch (err) {
        alert('❌ JSON 檔案格式錯誤，請檢查檔案');
      }
    };
    reader.readAsText(file);
  });
  input.click();
}

// ── Load shared parameters from URL ────────────────────────────────────
function loadSharedState() {
  const params = new URLSearchParams(window.location.search);
  const c = params.get('c'); if (c) { state.companion = c; document.querySelector(`#q-companion .chip[data-val="${c}"]`)?.classList.add('selected'); }
  const d = params.get('d'); if (d) { state.days = d; document.querySelector(`#q-days .chip[data-val="${d}"]`)?.classList.add('selected'); }
  const i = params.get('i'); if (i) { i.split(',').forEach(v => { state.interests.push(v); document.querySelector(`#q-interests .chip[data-val="${v}"]`)?.classList.add('selected'); }); }
  const b = params.get('b'); if (b) { state.budget = b; document.querySelector(`#q-budget .chip[data-val="${b}"]`)?.classList.add('selected'); }
  const a = params.get('a'); if (a) { a.split(',').forEach(v => { state.areas.push(v); document.querySelector(`#q-areas .chip[data-val="${v}"]`)?.classList.add('selected'); }); }
  const s = params.get('s'); if (s) { state.allSpots = s.split(','); s.split(',').forEach(v => { document.querySelector(`[id^="q-spots-"] .chip[data-val="${v}"]`)?.classList.add('selected'); }); }
  if (c || d || i || b || a || s) { buildResults(); showStep(3); } // Jump to results if params provided
}

