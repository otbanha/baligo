function buildTargetAreas(mentioned) {
  const chosen = new Set([...state.areas, ...mentioned]);
  chosen.delete('undecided');
  if (chosen.size === 0) {
    const map = {
      surf:['kuta','canggu'], culture:['ubud','east'], spa:['ubud','seminyak'],
      food:['seminyak','jimbaran'], shop:['seminyak','kuta'], yoga:['ubud','canggu'],
      snorkel:['penida','sanur'], beach:['nusadua','uluwatu'], night:['kuta','seminyak'],
      photo:['ubud','uluwatu'], kids:['nusadua','sanur'], nature:['ubud','east'],
      atv:['ubud','canggu'], rafting:['ubud','canggu'], beachclub:['seminyak','canggu','nusadua'],
      volcano:['east'], performance:['uluwatu','ubud'],
    };
    state.interests.forEach(i => (map[i]||[]).forEach(a => chosen.add(a)));
    if (state.companion === 'family') { chosen.add('nusadua'); chosen.add('sanur'); }
    if (state.companion === 'couple') { chosen.add('jimbaran'); chosen.add('seminyak'); }
    if (state.companion === 'elder') { chosen.add('nusadua'); chosen.add('sanur'); chosen.add('jimbaran'); }
    if (state.companion === 'group') { chosen.add('ubud'); chosen.add('kuta'); }
    if (state.budget === 'luxury')    { chosen.add('nusadua'); chosen.add('seminyak'); }
    if (chosen.size === 0) ['kuta','ubud','seminyak'].forEach(a => chosen.add(a));
  }
  const days = parseInt(state.days) || 5;
  if (days <= 3 && chosen.size > 3) {
    const sorted = [...chosen].sort((a,b) => {
      const sa = (REGIONS[a]?.interestMatch||[]).filter(i=>state.interests.includes(i)).length;
      const sb = (REGIONS[b]?.interestMatch||[]).filter(i=>state.interests.includes(i)).length;
      return sb-sa;
    });
    return sorted.slice(0,3);
  }
  return [...chosen];
}

// ── HTML Builders ─────────────────────────────────────────────────────
// Card format — used in highlight sections (Must-Read, Accom, Global)
function cardHtml({title,url,tag}) {
  return `<a href="${url}" class="acard" target="_blank" rel="noopener"><span class="acard-tag">${tag}</span><p class="acard-title">${title}</p><span class="acard-arrow">→</span></a>`;
}

// List item format — used in region sections and interest extras
function listItemHtml({title,url,tag}) {
  return `<a href="${url}" class="alist-item" target="_blank" rel="noopener"><img src="/favicon-16x16.png" class="alist-favicon" alt="" aria-hidden="true"><span class="alist-tag">${tag}</span><span class="alist-title">${title}</span><span class="alist-arrow">→</span></a>`;
}

function regionSection(key) {
  const r = REGIONS[key]; if(!r) return '';
  const desc = LS.regionDescs?.[key] || '';
  const items = [listItemHtml(r.guide), ...r.spots.map(listItemHtml)].join('');
  return `<div class="results-section region-section"><h3 class="section-title region-title"><span>${r.emoji}</span>${r.name}<span class="region-desc">${desc}</span></h3><div class="article-list">${items}</div></div>`;
}

function extraSection(key) {
  const ex = INTEREST_EXTRAS[key]; if(!ex) return '';
  const title = LS.extras?.[key] || key;
  return `<div class="results-section"><h3 class="section-title">${title}</h3><div class="article-list">${ex.articles.map(listItemHtml).join('')}</div></div>`;
}

function buildAccomSection(areas) {
  const items = [];
  areas.forEach(key => { const list = ACCOM_BY_REGION[key]; if (list) items.push(...list); });
  if (items.length === 0) return '';
  const title = LS.secAccom || '🏨 住宿推薦';
  return `<div class="results-section highlight"><h3 class="section-title">${title}</h3><div class="article-grid">${items.map(cardHtml).join('')}</div></div>`;
}

function buildRouteTip(areas) {
  const ordered = ROUTE_FLOW.filter(a => areas.includes(a));
  if (ordered.length < 2) return '';
  const lastArea = ordered[ordered.length - 1];
  const showWarning = AIRPORT_FAR_AREAS.has(lastArea);
  const steps = ordered.map(a => `<span class="route-step">${REGIONS[a].emoji} ${REGIONS[a].name}</span>`);
  const warningHtml = showWarning && LS.airportWarning
    ? `<div class="route-warning">${LS.airportWarning} <a href="${LS.airportWarningUrl}" target="_blank" rel="noopener">${LS.airportWarningLink}</a></div>`
    : '';
  return `<div class="route-tip-box"><div class="route-tip-label">${LS.routeLabel}</div><div class="route-flow"><span class="route-step route-airport">${LS.airport}</span><span class="route-arrow">→</span>${steps.join('<span class="route-arrow">→</span>')}<span class="route-arrow">→</span><span class="route-step route-airport">${LS.airport}</span></div><div class="route-tip-note">${LS.routeNote}<a href="/blog/2024-03-18-65ba3bfefd89780001650f07/" target="_blank" rel="noopener">${LS.routeLink}</a></div>${warningHtml}</div>`;
}

// ── Build Results ─────────────────────────────────────────────────────
function buildResults() {
  const { mentionedAreas, emptyDays } = analyzeItinerary(state.itinerary);
  const areas = buildTargetAreas(mentionedAreas);

  // Summary
  const cLabel = LS.companionMap?.[state.companion] || '';
  const dLabel = LS.daysMap?.[state.days] || '';
  const parts = [cLabel, dLabel].filter(Boolean);
  document.getElementById('results-summary').textContent =
    parts.length ? LS.summaryTpl(parts) : LS.summaryFallback;

  // Empty day alert
  const alertEl = document.getElementById('empty-alert');
  if (emptyDays.length) {
    document.getElementById('empty-alert-text').textContent = LS.emptyTpl(emptyDays);
    alertEl.classList.remove('hidden');
  } else {
    alertEl.classList.add('hidden');
  }

  // Sections
  document.getElementById('route-tip').innerHTML = buildRouteTip(areas);
  document.getElementById('region-sections').innerHTML = areas.map(regionSection).join('');

  // Extras
  const extraKeys = [];
  if (state.interests.includes('surf') || state.areas.includes('kuta') || state.areas.includes('canggu')) extraKeys.push('surf');
  if (state.interests.includes('kids') || state.companion === 'family') extraKeys.push('kids');
  if (state.interests.includes('snorkel') || state.areas.includes('penida')) extraKeys.push('snorkel');
  if (state.interests.includes('nature')) extraKeys.push('nature');
  const hasAtv = state.interests.includes('atv');
  const hasRafting = state.interests.includes('rafting');
  if (hasAtv && hasRafting) {
    extraKeys.push('atv_rafting');
  } else {
    if (hasAtv) extraKeys.push('atv');
    if (hasRafting) extraKeys.push('rafting');
  }
  if (state.interests.includes('beachclub')) extraKeys.push('beachclub');
  if (state.interests.includes('volcano')) extraKeys.push('volcano');
  if (state.interests.includes('performance')) extraKeys.push('performance');
  if (state.companion === 'couple') extraKeys.push('romance');
  if (state.companion === 'elder') extraKeys.push('elder');
  if (state.companion === 'group') extraKeys.push('group');
  const days = parseInt(state.days) || 5;
  if (days <= 4 || state.interests.length === 0) extraKeys.push('klook');
  document.getElementById('interest-extras').innerHTML = [...new Set(extraKeys)].map(extraSection).join('');

  // Accommodation section
  document.getElementById('accom-section').innerHTML = buildAccomSection(areas);

  // Global picks — shuffle and show 12 of 19
  const shuffled = [...GLOBAL_PICKS].sort(() => Math.random() - 0.5);
  document.getElementById('global-picks-grid').innerHTML = shuffled.slice(0, 12).map(cardHtml).join('');
}
</script>

