// ── Itinerary Analysis ────────────────────────────────────────────────
function analyzeItinerary(text) {
  if (!text) return { mentionedAreas: [], emptyDays: [] };
  const emptyKws = ['???','待定','tbd','空白','未定','不知道','唔知','還沒想','未排','no plan'];
  const found = new Set();
  const emptyDays = [];
  text.split('\n').forEach(line => {
    const lo = line.toLowerCase();
    for (const [key, reg] of Object.entries(REGIONS)) {
      if (reg.keywords.some(kw => lo.includes(kw.toLowerCase()))) found.add(key);
    }
    const dm = line.match(/[Dd](\d+)|第\s*(\d+)\s*[天日]|[Dd]ay\s*(\d+)/);
    if (dm && emptyKws.some(kw => lo.includes(kw.toLowerCase()))) {
      emptyDays.push(LS.emptyDayPre + (dm[1]??dm[2]??dm[3]) + LS.emptyDaySuf);
    }
  });
  return { mentionedAreas: [...found], emptyDays };
}

