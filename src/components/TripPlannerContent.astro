// List item format — used in region sections and interest extras
function listItemHtml({title,url,tag}) {
  return `<a href="${url}" class="alist-item" target="_blank" rel="noopener"><img src="/favicon-16x16.png" class="alist-favicon" alt="" aria-hidden="true"><span class="alist-tag">${tag}</span><span class="alist-title">${title}</span><span class="alist-arrow">→</span></a>`;
}

function regionSection(key) {
  const r = REGIONS[key]; if(!r) return '';
  const desc = LS.regionDescs?.[key] || '';

  // Selected spots for this region — shown at top
  const seenUrls = new Set();
  const selectedSpotItems = (state.allSpots || [])
    .filter(val => SPOT_REGION_MAP[val] === key)
    .map(val => { const s = ALL_SPOTS_DATA[val]; if (!s || seenUrls.has(s.url)) return ''; seenUrls.add(s.url); return listItemHtml(s); })
    .filter(Boolean).join('');
  const spotBlock = selectedSpotItems
    ? `<div class="region-selected-spots"><div class="region-spots-label">${LS.secSpots || '📍 你選擇的景點'}</div><div class="article-list">${selectedSpotItems}</div></div>`
    : '';

  // Regular region articles (skip any URL already shown above)
  const items = [r.guide ? listItemHtml(r.guide) : '', ...r.spots.map(listItemHtml)]
    .filter(html => { if (!html) return false; const m = html.match(/href="([^"]+)"/); return m ? !seenUrls.has(m[1]) : true; })
    .join('');

  return `<div class="results-section region-section"><h3 class="section-title region-title"><span>${r.emoji}</span>${r.name}<span class="region-desc">${desc}</span></h3>${spotBlock}<div class="article-list">${items}</div></div>`;
}

function extraSection(key) {
  const ex = INTEREST_EXTRAS[key]; if(!ex) return '';
  const title = LS.extras?.[key] || key;
  return `<div class="results-section"><h3 class="section-title">${title}</h3><div class="article-list">${ex.articles.map(listItemHtml).join('')}</div></div>`;
}

