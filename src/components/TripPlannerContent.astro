            <button class="chip" data-val="u_tirta">{T.su_tirta}</button>
            <button class="chip" data-val="u_monkey">{T.su_monkey}</button>
            <button class="chip" data-val="u_terraces">{T.su_terraces}</button>
            <button class="chip" data-val="u_skywalk">{T.su_skywalk}</button>
            <button class="chip" data-val="u_coffee">{T.su_coffee}</button>
            <button class="chip" data-val="u_zoo">{T.su_zoo}</button>
            <button class="chip" data-val="u_waterfall">{T.su_waterfall}</button>
            <button class="chip" data-val="u_fairy">{T.su_fairy}</button>
            <button class="chip" data-val="u_junglepool">{T.su_junglepool}</button>
            <button class="chip" data-val="u_jeep">{T.su_jeep}</button>
            <button class="chip" data-val="u_singing">{T.su_singing}</button>
            <button class="chip" data-val="u_swing">{T.su_swing}</button>
            <button class="chip" data-val="u_mario">{T.su_mario}</button>
            <button class="chip" data-val="u_food">{T.su_food}</button>
            <button class="chip" data-val="u_spa">{T.u_spa}</button>
            <button class="chip" data-val="u_penglipuran">{T.u_penglipuran}</button>
            <button class="chip" data-val="rafting">{T.i_rafting}</button>
            <button class="chip" data-val="atv">{T.i_atv}</button>
            <button class="chip" data-val="volcano">{T.i_volcano}</button>
          </div>
        </div>
        <div class="spots-region-group">
          <div class="spots-region-label">{T.spots_kuta}</div>
          <div class="chips multi" id="q-spots-kuta">
            <button class="chip" data-val="k_surf">{T.k_surf}</button>
            <button class="chip" data-val="k_waterbom">{T.k_waterbom}</button>
            <button class="chip" data-val="k_beachwalk">{T.k_beachwalk}</button>
            <button class="chip" data-val="k_turtle">{T.k_turtle}</button>
            <button class="chip" data-val="k_beerbus">{T.k_beerbus}</button>
            <button class="chip" data-val="k_food">{T.k_food}</button>
            <button class="chip" data-val="k_spa">{T.k_spa}</button>
          </div>
        </div>
        <div class="spots-region-group">
          <div class="spots-region-label">{T.spots_seminyak}</div>
          <div class="chips multi" id="q-spots-seminyak">
            <button class="chip" data-val="se_daytour">{T.se_daytour}</button>
            <button class="chip" data-val="se_surf">{T.se_surf}</button>
            <button class="chip" data-val="se_food">{T.se_food}</button>
            <button class="chip" data-val="se_club">{T.se_club}</button>
            <button class="chip" data-val="se_spa">{T.se_spa}</button>
          </div>
        </div>
        <div class="spots-region-group">
          <div class="spots-region-label">{T.spots_canggu}</div>
          <div class="chips multi" id="q-spots-canggu">
            <button class="chip" data-val="cg_tanah">{T.cg_tanah}</button>
            <button class="chip" data-val="cg_labrisa">{T.cg_labrisa}</button>
            <button class="chip" data-val="cg_horse">{T.cg_horse}</button>
            <button class="chip" data-val="cg_nuanu">{T.cg_nuanu}</button>
            <button class="chip" data-val="cg_surf">{T.cg_surf}</button>
            <button class="chip" data-val="cg_spa">{T.cg_spa}</button>
          </div>
        </div>
        <div class="spots-region-group">
          <div class="spots-region-label">{T.spots_jimbaran}</div>
          <div class="chips multi" id="q-spots-jimbaran">
            <button class="chip" data-val="ji_gwk">{T.ji_gwk}</button>
            <button class="chip" data-val="ji_rockbar">{T.ji_rockbar}</button>
            <button class="chip" data-val="ji_seafood">{T.ji_seafood}</button>
            <button class="chip" data-val="ji_shopping">{T.ji_shopping}</button>
            <button class="chip" data-val="ji_annspa">{T.ji_annspa}</button>
            <button class="chip" data-val="ji_spa">{T.ji_spa}</button>
          </div>
        </div>
        <div class="spots-region-group">
          <div class="spots-region-label">{T.spots_uluwatu}</div>
          <div class="chips multi" id="q-spots-uluwatu">
            <button class="chip" data-val="ul_temple">{T.ul_temple}</button>
            <button class="chip" data-val="ul_kecak">{T.ul_kecak}</button>
            <button class="chip" data-val="ul_oneeighty">{T.ul_oneeighty}</button>
            <button class="chip" data-val="ul_highway">{T.ul_highway}</button>
            <button class="chip" data-val="ul_beach">{T.ul_beach}</button>
            <button class="chip" data-val="ul_paraglide">{T.ul_paraglide}</button>
            <button class="chip" data-val="ul_vw">{T.ul_vw}</button>
            <button class="chip" data-val="ul_surf">{T.ul_surf}</button>
            <button class="chip" data-val="ul_spa">{T.ul_spa}</button>
          </div>
        </div>
        <div class="spots-region-group">
          <div class="spots-region-label">{T.spots_nusadua}</div>
          <div class="chips multi" id="q-spots-nusadua">
            <button class="chip" data-val="nd_buffet">{T.nd_buffet}</button>
            <button class="chip" data-val="nd_lobster">{T.nd_lobster}</button>
            <button class="chip" data-val="nd_bali_collection">{T.nd_bali_collection}</button>
            <button class="chip" data-val="nd_watersport">{T.nd_watersport}</button>
            <button class="chip" data-val="nd_devdan">{T.nd_devdan}</button>
            <button class="chip" data-val="nd_turtle_island">{T.nd_turtle_island}</button>
            <button class="chip" data-val="nd_spa">{T.nd_spa}</button>
            <button class="chip" data-val="nd_snorkel">{T.nd_snorkel}</button>
          </div>
        </div>
        <div class="spots-region-group">
          <div class="spots-region-label">{T.spots_sanur}</div>
          <div class="chips multi" id="q-spots-sanur">
            <button class="chip" data-val="sa_icon">{T.sa_icon}</button>
            <button class="chip" data-val="sa_cycling">{T.sa_cycling}</button>
            <button class="chip" data-val="sa_turtle">{T.sa_turtle}</button>
            <button class="chip" data-val="sa_fishing">{T.sa_fishing}</button>
            <button class="chip" data-val="sa_aerox">{T.sa_aerox}</button>
            <button class="chip" data-val="sa_climbing">{T.sa_climbing}</button>
            <button class="chip" data-val="sa_spa">{T.sa_spa}</button>
            <button class="chip" data-val="sa_snorkel">{T.sa_snorkel}</button>
          </div>
        </div>
      </div>

      <div class="q-block">
        <div class="q-label">{T.q4}</div>
        <div class="chips single" id="q-budget">
          <button class="chip" data-val="budget">{T.b_budget}</button>
          <button class="chip" data-val="mid">{T.b_mid}</button>
          <button class="chip" data-val="luxury">{T.b_luxury}</button>
        </div>
      </div>

      <div class="step-actions">
        <button class="btn-next" id="btn-1-next">{T.btnNext1}</button>
      </div>
    </div>

    <!-- Step 2 -->
    <div class="step hidden" id="step-2">
      <h2 class="step-title">{T.s2title}</h2>

      <div class="q-block">
        <div class="q-label">{T.q5} <span class="q-hint">{T.q5hint}</span></div>
        <div class="chips multi" id="q-areas">
          <button class="chip" data-val="kuta">{T.a_kuta}</button>
          <button class="chip" data-val="seminyak">{T.a_seminyak}</button>
          <button class="chip" data-val="canggu">{T.a_canggu}</button>
          <button class="chip" data-val="ubud">{T.a_ubud}</button>
          <button class="chip" data-val="jimbaran">{T.a_jimbaran}</button>
          <button class="chip" data-val="uluwatu">{T.a_uluwatu}</button>
          <button class="chip" data-val="nusadua">{T.a_nusadua}</button>
          <button class="chip" data-val="sanur">{T.a_sanur}</button>
          <button class="chip" data-val="penida">{T.a_penida}</button>
          <button class="chip" data-val="lembongan">{T.a_lembongan}</button>
          <button class="chip" data-val="komodo">{T.a_komodo}</button>
          <button class="chip" data-val="east">{T.a_east}</button>
        </div>
      </div>

      <div class="q-block">
        <div class="q-label">
          {T.q6} <span class="q-hint">{T.q6hint}</span>
        </div>
        <textarea id="q-itinerary" rows="9" placeholder={T.placeholder}></textarea>
      </div>

      <div class="step-actions">
        <button class="btn-back" id="btn-2-back">{T.btnBack}</button>
        <button class="btn-next" id="btn-2-next">{T.btnNext2}</button>
      </div>
    </div>

    <!-- Step 3 -->
    <div class="step hidden" id="step-3">

      <div class="results-header">
        <h2 class="step-title">{T.s3title}</h2>
        <p id="results-summary" class="results-summary"></p>
      </div>

      <div class="empty-alert hidden" id="empty-alert">
        <span>📌</span>
        <span id="empty-alert-text"></span>
      </div>

      <div id="route-tip"></div>
      <div id="spots-section"></div>
      <div id="region-sections"></div>
      <div id="interest-extras"></div>
      <div id="accom-section"></div>

      <!-- Must-Read -->
      <div class="results-section highlight">
