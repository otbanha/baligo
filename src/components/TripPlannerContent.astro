// ── Spot Preview Popover ──────────────────────────────────────────────
(function initSpotPopovers() {
  // Inject ⓘ button into every spot chip that has data
  document.querySelectorAll('[id^="q-spots-"] .chip').forEach(chip => {
    const key = chip.dataset.val;
    if (!ALL_SPOTS_DATA[key]) return;
    const btn = document.createElement('span');
    btn.className = 'chip-info-btn';
    btn.setAttribute('aria-label', '預覽');
    btn.textContent = 'ⓘ';
    btn.dataset.spot = key;
    chip.appendChild(btn);
    btn.addEventListener('click', e => {
      e.stopPropagation();
      togglePopover(btn);
    });
  });

  const pop = document.getElementById('spot-popover');
  const popImg = document.getElementById('spot-pop-img');
  const popTag = document.getElementById('spot-pop-tag');
  const popTitle = document.getElementById('spot-pop-title');
  const popLink = document.getElementById('spot-pop-link');
  let activeBtn = null;

  function positionPopover(btn) {
    const rect = btn.getBoundingClientRect();
    const popW = 220;
    const margin = 8;
    let left = rect.left + rect.width / 2 - popW / 2;
    left = Math.max(margin, Math.min(left, window.innerWidth - popW - margin));
    const hasImg = !pop.classList.contains('no-img');
    const estimatedH = hasImg ? 235 : 115;
    let top = rect.bottom + 8;
    if (top + estimatedH > window.innerHeight - margin) top = rect.top - estimatedH - 8;
    pop.style.left = left + 'px';
    pop.style.top = top + 'px';
  }

  function showPopover(btn) {
    const key = btn.dataset.spot;
    const info = ALL_SPOTS_DATA[key];
    if (!info) return;
    const img = SPOT_IMAGES[key] || '';
    pop.classList.toggle('no-img', !img);
    if (img) { popImg.src = img; popImg.alt = info.title; }
    popTag.textContent = info.tag;
    popTitle.textContent = info.title;
    popLink.href = info.url;
    positionPopover(btn);
    pop.classList.add('visible');
    pop.setAttribute('aria-hidden', 'false');
    activeBtn = btn;
  }

  function hidePopover() {
    pop.classList.remove('visible');
    pop.setAttribute('aria-hidden', 'true');
    activeBtn = null;
  }

  function togglePopover(btn) {
    if (activeBtn === btn) { hidePopover(); return; }
    showPopover(btn);
  }

  document.addEventListener('click', e => {
    if (!activeBtn) return;
    if (pop.contains(e.target)) return;
    hidePopover();
  });

  window.addEventListener('scroll', hidePopover, { passive: true });
  window.addEventListener('resize', () => { if (activeBtn) positionPopover(activeBtn); });
})();


function buildAccomSection(areas) {
  const isFamily = state.companion === 'family' || state.interests.includes('kids');
  const sections = [];

  // 親子住宿 block at top when family companion selected
  if (isFamily && KIDS_ACCOM.length > 0) {
    const kidsTitle = LS.secKidsAccom || '👶 親子住宿推薦';
    sections.push(`<div class="results-section highlight"><h3 class="section-title">${kidsTitle}</h3><div class="article-grid">${KIDS_ACCOM.slice(0, 4).map(cardHtml).join('')}</div></div>`);
  }

  // Per-region accommodation blocks (max 4 each)
  const regionNames = LS.accomRegionNames || {};
  const regionRows = [];
  areas.forEach(key => {
    const list = ACCOM_BY_REGION[key];
    if (!list || list.length === 0) return;
    const region = REGIONS[key];
    const emoji = region ? region.emoji + ' ' : '';
    const name = regionNames[key] || (region ? region.name : key);
    const suffix = lang === 'en' ? ' Stays' : '住宿';
    regionRows.push(`<h4 class="accom-region-title">${emoji}${name}${suffix}</h4><div class="article-grid">${list.slice(0, 4).map(cardHtml).join('')}</div>`);
  });

  if (regionRows.length > 0) {
    const title = LS.secAccom || '🏨 住宿推薦';
    sections.push(`<div class="results-section highlight"><h3 class="section-title">${title}</h3>${regionRows.join('')}</div>`);
  }

  return sections.join('');
}

function buildRouteTip(areas) {
  let ordered = ROUTE_FLOW.filter(a => areas.includes(a));
  if (ordered.length < 2) return '';

  // Preferred last stops in priority order (close to airport)
  const GOOD_LAST = ['jimbaran', 'uluwatu', 'nusadua', 'sanur', 'kuta', 'seminyak'];
  const currentLast = ordered[ordered.length - 1];
  if (!GOOD_LAST.includes(currentLast)) {
    const bestLast = GOOD_LAST.find(a => ordered.includes(a));
    if (bestLast) {
      ordered = [...ordered.filter(a => a !== bestLast), bestLast];
    }
  }

  const lastArea = ordered[ordered.length - 1];
  const showWarning = AIRPORT_FAR_AREAS.has(lastArea);
  // Only show reorder tip when the best we could do is still not ideal (e.g. all areas are far)
  const reorderTip = (!showWarning && !AIRPORT_NEAR_AREAS.has(lastArea) && lastArea !== 'kuta' && lastArea !== 'seminyak')
    ? `<div class="route-tip-note" style="color: var(--gold); font-size: 0.9rem;">💡 ${LS.routeReorderTip || '建議將最後一天改為金巴蘭、烏魯瓦圖、努沙杜瓦或沙努爾，更接近機場。'}</div>`
    : '';
  const steps = ordered.map(a => `<span class="route-step">${REGIONS[a].emoji} ${REGIONS[a].name}</span>`);
  const warningHtml = showWarning && LS.airportWarning
    ? `<div class="route-warning">${LS.airportWarning} <a href="${LS.airportWarningUrl}" target="_blank" rel="noopener">${LS.airportWarningLink}</a></div>`
    : '';
  return `<div class="route-tip-box"><div class="route-tip-label">${LS.routeLabel}</div><div class="route-flow"><span class="route-step route-airport">${LS.airport}</span><span class="route-arrow">→</span>${steps.join('<span class="route-arrow">→</span>')}<span class="route-arrow">→</span><span class="route-step route-airport">${LS.airport}</span></div><div class="route-tip-note">${LS.routeNote}<a href="/blog/2024-03-18-65ba3bfefd89780001650f07/" target="_blank" rel="noopener">${LS.routeLink}</a></div>${warningHtml}${reorderTip}</div>`;
}

// ── Build Results ─────────────────────────────────────────────────────
function buildResults() {
  const { mentionedAreas, emptyDays } = analyzeItinerary(state.itinerary);
  const areas = buildTargetAreas(mentionedAreas);

  // Summary
  const cLabel = LS.companionMap?.[state.companion] || '';
  const dLabel = LS.daysMap?.[state.days] || '';
  const parts = [cLabel, dLabel].filter(Boolean);
  document.getElementById('results-summary').textContent =
    parts.length ? LS.summaryTpl(parts) : LS.summaryFallback;

  // Empty day alert
  const alertEl = document.getElementById('empty-alert');
  if (emptyDays.length) {
    document.getElementById('empty-alert-text').textContent = LS.emptyTpl(emptyDays);
    alertEl.classList.remove('hidden');
  } else {
    alertEl.classList.add('hidden');
  }

  // Sections
  document.getElementById('route-tip').innerHTML = buildRouteTip(areas);
  document.getElementById('spots-section').innerHTML = '';
  document.getElementById('region-sections').innerHTML = areas.map(regionSection).join('');

  // Extras
  const extraKeys = [];
  if (state.interests.includes('surf') || state.areas.includes('kuta') || state.areas.includes('canggu')) extraKeys.push('surf');
  if (state.interests.includes('kids') || state.companion === 'family') extraKeys.push('kids');
  if (state.interests.includes('snorkel') || state.areas.includes('penida')) extraKeys.push('snorkel');
  if (state.interests.includes('nature')) extraKeys.push('nature');
  const hasAtv = state.interests.includes('atv');
  const hasRafting = state.interests.includes('rafting');
  if (hasAtv && hasRafting) {
    extraKeys.push('atv_rafting');
  } else {
    if (hasAtv) extraKeys.push('atv');
    if (hasRafting) extraKeys.push('rafting');
  }
  if (state.interests.includes('beachclub')) extraKeys.push('beachclub');
  if (state.interests.includes('volcano')) extraKeys.push('volcano');
  if (state.interests.includes('performance')) extraKeys.push('performance');
  if (state.companion === 'couple') extraKeys.push('romance');
  if (state.companion === 'elder') extraKeys.push('elder');
  if (state.companion === 'group') extraKeys.push('group');
  const days = parseInt(state.days) || 5;
  if (days <= 4 || state.interests.length === 0) extraKeys.push('klook');
  document.getElementById('interest-extras').innerHTML = [...new Set(extraKeys)].map(extraSection).join('');

  // Accommodation section
  document.getElementById('accom-section').innerHTML = buildAccomSection(areas);

  // Global picks — shuffle and show 10 of 19
  const shuffled = [...GLOBAL_PICKS].sort(() => Math.random() - 0.5);
  document.getElementById('global-picks-grid').innerHTML = shuffled.slice(0, 10).map(cardHtml).join('');
}
</script>

