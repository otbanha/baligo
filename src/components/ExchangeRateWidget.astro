---
// ExchangeRateWidget.astro
---

<div class="exr-widget" id="exr-widget">
  <div class="exr-header">
    <span class="exr-title">💱 每日參考匯率</span>
    <span class="exr-date" id="exr-date"></span>
  </div>
  <div class="exr-row" id="exr-row">
    <span class="exr-loading">載入中…</span>
  </div>
  <p class="exr-disclaimer">參考匯率，實際匯率以各換匯所為準</p>
</div>

<script is:inline>
(function () {
  var CURRENCIES = [
    { code: 'USD', flag: '🇺🇸' },
    { code: 'AUD', flag: '🇦🇺' },
    { code: 'SGD', flag: '🇸🇬' },
    { code: 'HKD', flag: '🇭🇰' },
    { code: 'MYR', flag: '🇲🇾' },
  ];

  function fmt(n) {
    return Number(n).toLocaleString('en-US');
  }

  fetch('/api/exchange-rate')
    .then(function(r) { return r.ok ? r.json() : Promise.reject(); })
    .then(function(data) {
      var row = document.getElementById('exr-row');
      var dateEl = document.getElementById('exr-date');
      if (!row) return;
      if (data.date && dateEl) dateEl.textContent = '最新：' + data.date + '（週末/假日維持前一工作日）';
      if (!data.rates) {
        row.innerHTML = '<span style="color:rgba(255,255,255,0.4);font-size:0.85em">資料暫時無法取得</span>';
        return;
      }
      row.innerHTML = CURRENCIES.map(function(c, i) {
        var val = data.rates[c.code];
        var rp = val != null ? 'Rp ' + fmt(val) : '—';
        return (i > 0 ? '<span class="exr-sep">|</span>' : '') +
          '<div class="exr-item">' +
            '<span class="exr-flag">' + c.flag + '</span>' +
            '<span class="exr-code">1 ' + c.code + '</span>' +
            '<span class="exr-amt">' + rp + '</span>' +
          '</div>';
      }).join('');
    })
    .catch(function() {
      var row = document.getElementById('exr-row');
      if (row) row.innerHTML = '<span style="color:rgba(255,255,255,0.4);font-size:0.85em">資料暫時無法取得</span>';
    });
})();
</script>

<style>
/* widget 外框 — 靜態 HTML，scoped 正常生效 */
.exr-widget {
  background: linear-gradient(135deg, #0a1628 0%, #1a3560 100%);
  border: 1px solid rgba(197,160,89,0.3);
  border-radius: 12px;
  padding: 0.8em 1.2em 0.65em;
  box-shadow: 0 8px 32px rgba(0,0,0,0.25), inset 0 1px 0 rgba(197,160,89,0.3);
  position: relative;
  margin-bottom: 1.2em;
}
.exr-widget::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; height: 2px;
  border-radius: 12px 12px 0 0;
  background: linear-gradient(90deg, transparent, #C5A059, transparent);
}
.exr-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 0.55em;
}
.exr-title {
  font-size: 0.85em;
  font-weight: 700;
  color: #d4b47a;
  letter-spacing: 0.04em;
}
.exr-date {
  font-size: 0.72em;
  color: rgba(197,160,89,0.6);
}
.exr-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  min-height: 2.8em;
}
.exr-loading {
  color: rgba(255,255,255,0.4);
  font-size: 0.85em;
}
.exr-disclaimer {
  margin: 0.5em 0 0;
  font-size: 0.65em;
  color: rgba(255,255,255,0.3);
  text-align: right;
}

/* ── 動態生成的子元素 → 用 :global() 讓 scoped 不阻擋 ── */
:global(.exr-item) {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.18em;
  flex: 1;
  padding: 0.2em 0;
}
:global(.exr-sep) {
  color: rgba(197,160,89,0.35);
  font-size: 1.1em;
  flex-shrink: 0;
  padding: 0 0.1em;
}
:global(.exr-flag) {
  font-size: 1.3em;
  line-height: 1;
}
:global(.exr-code) {
  font-size: 0.75em;
  color: rgba(255,255,255,0.65);
  white-space: nowrap;
}
:global(.exr-amt) {
  font-size: 0.95em;
  font-weight: 800;
  color: #ffffff;
  white-space: nowrap;
  letter-spacing: 0.01em;
}

@media (max-width: 600px) {
  :global(.exr-code) { font-size: 0.68em; }
  :global(.exr-amt)  { font-size: 0.82em; }
  :global(.exr-flag) { font-size: 1.1em; }
}
@media (max-width: 400px) {
  :global(.exr-code) { display: none; }
}
</style>
