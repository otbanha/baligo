---
// ExchangeRateWidget.astro
const { lang = 'zh-tw' } = Astro.props;

const i18n: Record<string, { title: string; datePrefix: string; dateSuffix: string; disclaimer: string }> = {
  'zh-tw': {
    title: '💱 每日參考匯率',
    datePrefix: '最新：',
    dateSuffix: '（週末/假日維持前一工作日）',
    disclaimer: '參考匯率，實際匯率以各換匯所為準',
  },
  'zh-hk': {
    title: '💱 每日參考匯率',
    datePrefix: '最新：',
    dateSuffix: '（週末/假日維持前一工作日）',
    disclaimer: '參考匯率，實際匯率以各換匯所為準',
  },
  'zh-cn': {
    title: '💱 每日参考汇率',
    datePrefix: '最新：',
    dateSuffix: '（周末/节假日维持前一工作日）',
    disclaimer: '参考汇率，实际汇率以各换汇所为准',
  },
  'en': {
    title: '💱 Daily Exchange Rate',
    datePrefix: 'Latest: ',
    dateSuffix: ' (weekends/holidays use prev. business day)',
    disclaimer: 'Reference rate only. Actual rates vary by money changer.',
  },
};

const t = i18n[lang] ?? i18n['zh-tw'];
---

<div class="exr-widget" id="exr-widget">
  <div class="exr-header">
    <span class="exr-title">{t.title}</span>
    <span class="exr-date" id="exr-date"></span>
  </div>
  <div class="exr-row" id="exr-row">
    <span class="exr-loading">{lang === 'en' ? 'Loading…' : '載入中…'}</span>
  </div>
  <p class="exr-disclaimer">{t.disclaimer}</p>
</div>

<script is:inline define:vars={{ datePrefix: t.datePrefix, dateSuffix: t.dateSuffix }}>
(function () {
  var CURRENCIES = [
    { code: 'USD', flag: '🇺🇸' },
    { code: 'AUD', flag: '🇦🇺' },
    { code: 'SGD', flag: '🇸🇬' },
    { code: 'HKD', flag: '🇭🇰' },
    { code: 'MYR', flag: '🇲🇾' },
    { code: 'CNY', flag: '🇨🇳' },
    { code: 'TWD', flag: '🇹🇼', fixed: 350 },
  ];

  function fmt(n) {
    return Number(n).toLocaleString('en-US');
  }

  fetch('/api/exchange-rate')
    .then(function(r) { return r.ok ? r.json() : Promise.reject(); })
    .then(function(data) {
      var row = document.getElementById('exr-row');
      var dateEl = document.getElementById('exr-date');
      if (!row) return;
      if (data.date && dateEl) dateEl.textContent = datePrefix + data.date + dateSuffix;
      if (!data.rates) {
        row.innerHTML = '<span style="color:rgba(255,255,255,0.4);font-size:0.85em">—</span>';
        return;
      }
      row.innerHTML = CURRENCIES.map(function(c, i) {
        var val = c.fixed != null ? c.fixed : data.rates[c.code];
        var rp = val != null ? 'Rp ' + fmt(val) : '—';
        return (i > 0 ? '<span class="exr-sep">|</span>' : '') +
          '<div class="exr-item">' +
            '<span class="exr-flag">' + c.flag + '</span>' +
            '<span class="exr-code">1 ' + c.code + '</span>' +
            '<span class="exr-amt">' + rp + '</span>' +
          '</div>';
      }).join('');
    })
    .catch(function() {
      var row = document.getElementById('exr-row');
      if (row) row.innerHTML = '<span style="color:rgba(255,255,255,0.4);font-size:0.85em">—</span>';
    });
})();
</script>

<style>
.exr-widget {
  background: linear-gradient(135deg, #0a1628 0%, #1a3560 100%);
  border: 1px solid rgba(197,160,89,0.3);
  border-radius: 12px;
  padding: 0.8em 1.2em 0.65em;
  box-shadow: 0 8px 32px rgba(0,0,0,0.25), inset 0 1px 0 rgba(197,160,89,0.3);
  position: relative;
  margin-bottom: 1.2em;
}
.exr-widget::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; height: 2px;
  border-radius: 12px 12px 0 0;
  background: linear-gradient(90deg, transparent, #C5A059, transparent);
}
.exr-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 0.55em;
  gap: 0.5em;
}
.exr-title {
  font-size: 0.85em;
  font-weight: 700;
  color: #d4b47a;
  letter-spacing: 0.04em;
  white-space: nowrap;
}
.exr-date {
  font-size: 0.68em;
  color: rgba(197,160,89,0.6);
  text-align: right;
}
.exr-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  min-height: 2.8em;
}
.exr-loading {
  color: rgba(255,255,255,0.4);
  font-size: 0.85em;
}
.exr-disclaimer {
  margin: 0.5em 0 0;
  font-size: 0.65em;
  color: rgba(255,255,255,0.3);
  text-align: right;
}

:global(.exr-item) {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.18em;
  flex: 1;
  padding: 0.2em 0;
}
:global(.exr-sep) {
  color: rgba(197,160,89,0.35);
  font-size: 1.1em;
  flex-shrink: 0;
  padding: 0 0.1em;
}
:global(.exr-flag) {
  font-size: 1.3em;
  line-height: 1;
}
:global(.exr-code) {
  font-size: 0.75em;
  color: rgba(255,255,255,0.65);
  white-space: nowrap;
}
:global(.exr-amt) {
  font-size: 0.95em;
  font-weight: 800;
  color: #ffffff;
  white-space: nowrap;
  letter-spacing: 0.01em;
}

@media (max-width: 600px) {
  :global(.exr-code) { font-size: 0.68em; }
  :global(.exr-amt)  { font-size: 0.82em; }
  :global(.exr-flag) { font-size: 1.1em; }
  .exr-date { font-size: 0.6em; }
}
@media (max-width: 400px) {
  :global(.exr-code) { display: none; }
}
</style>
