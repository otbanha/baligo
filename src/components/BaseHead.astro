---
import '../styles/global.css';
import { SITE_TITLE, SITE_URL, SITE_LOGO, SITE_OG_IMAGE } from '../consts';

interface Props {
  title: string;
  description: string;
  image?: string;           // absolute URL (R2 heroImage or fallback)
  type?: 'website' | 'article';
  publishedTime?: string;   // ISO 8601
  modifiedTime?: string;    // ISO 8601
  noSuffix?: boolean;       // true = don't append " | Go Bali Go" to title
}

const {
  title: rawTitle,
  description,
  image,
  type = 'website',
  publishedTime,
  modifiedTime,
  noSuffix = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;

// Article pages get "標題 | Go Bali Go" format; index pages already have the brand name
const title = noSuffix ? rawTitle : (rawTitle.includes('Go Bali Go') ? rawTitle : `${rawTitle} | Go Bali Go`);

// Strip emoji from OG/social titles so Facebook/Twitter previews look clean
const stripEmoji = (str: string) => str.replace(/[\p{Emoji_Presentation}\p{Extended_Pictographic}]/gu, '').replace(/\s{2,}/g, ' ').trim();
const ogTitle = stripEmoji(title);

// Use provided heroImage URL, or fall back to default OG image
const ogImage = image && image.startsWith('http') ? image : SITE_OG_IMAGE;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/x-icon" href="/favicon.ico" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="alternate" type="application/rss+xml" title={SITE_TITLE} href={new URL('rss.xml', Astro.site)} />
<meta name="generator" content={Astro.generator} />

<!-- Preconnect to image CDN (R2) to reduce first-image latency -->
<link rel="preconnect" href="https://images.gobaligo.id" />

<!-- Font preloads -->
<link rel="preload" href="/fonts/atkinson-regular.woff" as="font" type="font/woff" crossorigin />
<link rel="preload" href="/fonts/atkinson-bold.woff" as="font" type="font/woff" crossorigin />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="author" content="Go Bali Go" />

<!-- Open Graph -->
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={ogTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
{type === 'article' && publishedTime && <meta property="article:published_time" content={publishedTime} />}
{type === 'article' && modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
{type === 'article' && <meta property="article:author" content={SITE_URL} />}

<!-- Twitter / X -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={ogTitle} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={ogImage} />
