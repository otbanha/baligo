---
import '../styles/global.css';
import { SITE_TITLE, SITE_URL, SITE_LOGO, SITE_OG_IMAGE } from '../consts';

interface Props {
  title: string;
  description: string;
  image?: string;           // absolute URL (R2 heroImage or fallback)
  type?: 'website' | 'article';
  publishedTime?: string;   // ISO 8601
  modifiedTime?: string;    // ISO 8601
  noSuffix?: boolean;       // true = don't append " | Go Bali Go" to title
  hreflangs?: Array<{ hreflang: string; href: string }>;
}

const {
  title: rawTitle,
  description,
  image,
  type = 'website',
  publishedTime,
  modifiedTime,
  noSuffix = false,
  hreflangs,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;

const pathLang = Astro.url.pathname.startsWith('/en/')     ? 'en'    :
                 Astro.url.pathname.startsWith('/zh-cn/')  ? 'zh-cn' :
                 Astro.url.pathname.startsWith('/zh-hk/')  ? 'zh-hk' : 'zh-tw';

const siteName = pathLang === 'en'    ? 'Go Bali Go — Smart Bali Guide' :
                 pathLang === 'zh-cn' ? 'Go Bali Go 巴厘岛旅游攻略' :
                 SITE_TITLE;

const ogLocale = pathLang === 'en'    ? 'en_US'  :
                 pathLang === 'zh-cn' ? 'zh_CN'  :
                 pathLang === 'zh-hk' ? 'zh_HK'  : 'zh_TW';

// Article pages get "標題 | Go Bali Go" format; index pages already have the brand name
const title = noSuffix ? rawTitle : (rawTitle.includes('Go Bali Go') ? rawTitle : `${rawTitle} | Go Bali Go`);

// Strip emoji from OG/social titles so Facebook/Twitter previews look clean
const stripEmoji = (str: string) => str.replace(/[\p{Emoji_Presentation}\p{Extended_Pictographic}]/gu, '').replace(/\s{2,}/g, ' ').trim();
const ogTitle = stripEmoji(title);

// Use provided heroImage URL, or fall back to default OG image
const ogImage = image && image.startsWith('http') ? image : SITE_OG_IMAGE;

// Google Fonts：按語言只載入需要的字型家族（原本 @import 一次載全部 4 家族 ≈ 252KB render-blocking CSS）。
// 300 字重全站無人使用故移除；600/800 維持現狀由瀏覽器就近合成（與原本行為一致）。
const fontsPath = Astro.url.pathname;
const fontsHref = fontsPath.startsWith('/zh-cn/')
  ? 'https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;700&display=swap'
  : (fontsPath.startsWith('/en/') || fontsPath.startsWith('/id/'))
    ? 'https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=Inter:wght@400;500;700&display=swap'
    : 'https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=Noto+Sans+TC:wght@400;500;700&display=swap';
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover,maximum-scale=5" />

<!--
  Facebook / Instagram 內建瀏覽器（in-app WebView）已知問題：
  有時會忽略上面的 viewport width=device-width，導致整頁版面用比實際螢幕
  寬的「排版寬度」計算，畫面右側被裁掉（不是我們 CSS 的 bug，是該 WebView 的通病）。
  偵測到 FB/IG in-app browser 時，透過 JS 重新套用 viewport meta 強制其重算版面寬度。
-->
<script is:inline>
(function () {
  if (!/FBAN|FBAV|FB_IAB|Instagram/i.test(navigator.userAgent || '')) return;
  var vp = document.querySelector('meta[name="viewport"]');
  if (!vp) return;
  var fixed = 'width=device-width,initial-scale=1,viewport-fit=cover,maximum-scale=5';
  function reapply() {
    vp.setAttribute('content', 'width=device-width,initial-scale=1');
    void document.documentElement.offsetHeight;
    vp.setAttribute('content', fixed);
  }
  reapply();
  document.addEventListener('DOMContentLoaded', reapply);
  window.addEventListener('load', reapply);
})();
</script>

<meta name="mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<meta name="theme-color" content="#0f3860" />
<link rel="icon" type="image/x-icon" href="/favicon.ico" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="alternate" type="application/rss+xml" title={siteName} href={new URL('rss.xml', Astro.site)} />
<meta name="generator" content={Astro.generator} />

<!-- Preconnect to image CDN (R2) to reduce first-image latency -->
<link rel="preconnect" href="https://images.gobaligo.id" />

<!-- Font preloads -->
<link rel="preload" href="/fonts/atkinson-regular.woff" as="font" type="font/woff" crossorigin />
<link rel="preload" href="/fonts/atkinson-bold.woff" as="font" type="font/woff" crossorigin />

<!-- Google Fonts：非阻塞載入（media="print" 先不套用，載完切回 all），display=swap 期間先用系統字型 -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="stylesheet" href={fontsHref} media="print" onload="this.media='all'" />
<noscript><link rel="stylesheet" href={fontsHref} /></noscript>

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Hreflang (passed from page for homepage; article hreflangs are in sitemap) -->
{hreflangs && hreflangs.map(({ hreflang, href }) => (
  <link rel="alternate" hreflang={hreflang} href={href} />
))}

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="author" content="Go Bali Go" />

<!-- Open Graph -->
<meta property="fb:app_id" content="1994862997907037" />
<meta property="og:locale" content={ogLocale} />
<meta property="og:site_name" content={siteName} />
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={ogTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={ogTitle} />
<meta property="og:image:type" content="image/jpeg" />
{type === 'article' && publishedTime && <meta property="article:published_time" content={publishedTime} />}
{type === 'article' && modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
{type === 'article' && <meta property="article:author" content={SITE_URL} />}

<!-- Twitter / X -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={ogTitle} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={ogImage} />

<!-- Travelpayout Drive -->
<script nowprocket data-noptimize="1" data-cfasync="false" data-wpfc-render="false" seraph-accel-crit="1" data-no-defer="1">
  (function () {
      var script = document.createElement("script");
      script.async = 1;
      script.src = 'https://mn-tz.com/NTE5OTM3.js?t=519937';
      document.head.appendChild(script);
  })();
</script>

<!-- Travelpayouts White Label Widget -->
<script nowprocket data-noptimize="1" data-cfasync="false" data-wpfc-render="false" seraph-accel-crit="1" data-no-defer="1">
  (function () {
        var script = document.createElement("script");
        script.async = 1;
        script.type = "module";
        script.src = "https://tpwidg.com/wl_web/main.js?wl_id=20057";
        document.head.appendChild(script);
      })();
</script>
