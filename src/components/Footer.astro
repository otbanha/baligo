        <a href="https://www.facebook.com/groups/indonesia.travelguide" target="_blank" rel="noopener" aria-label="FB 社團">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
      </div>
    </div>

  </div>

  <!-- 底部版權+免責聲明 -->
  <div class="footer-bottom">
    <p class="copyright">&copy; {today.getFullYear()} Go Bali Go. All rights reserved.</p>
    <p class="disclaimer">本網站內容僅供參考，旅遊資訊可能隨時變動，出發前請自行確認最新資訊。本站部分連結為聯盟行銷連結。</p>
  </div>
</footer>

<style>
footer {
  background: var(--ocean);
  color: rgba(255,255,255,0.8);
  margin-top: 4em;
  border-top: 2px solid var(--gold);
}

.footer-inner {
  max-width: 1400px;
  margin: 0 auto;
  padding: 3em 2em 2em;
  display: grid;
  grid-template-columns: 1.5fr 1fr 1fr;
  gap: 3em;
}

.footer-brand .footer-logo {
  font-family: 'Playfair Display', serif;
  font-size: 1.3em;
  font-weight: 700;
  color: var(--gold-light);
  margin-bottom: 0.5em;
  display: flex;
  align-items: center;
}

.footer-logo img {
  width: 28px;
  height: 28px;
  border-radius: 4px;
  vertical-align: middle;
  position: relative;
  top: -3px;
  margin-right: 0.3em;
}

.footer-tagline {
  font-size: 0.85em;
  color: rgba(255,255,255,0.6);
  margin: 0;
  line-height: 1.6;
}

.footer-links h4,
.footer-social h4 {
  font-size: 0.85em;
  font-weight: 700;
  color: var(--gold-light);
  letter-spacing: 0.08em;
  margin: 0 0 1em;
  text-transform: uppercase;
}

.footer-links ul {
  list-style: none;
  margin: 0;
  padding: 0;
}

.footer-links li {
  margin-bottom: 0.5em;
}

.footer-links a {
  color: rgba(255,255,255,0.7);
  text-decoration: none;
  font-size: 0.88em;
  transition: color 0.15s;
}

.footer-links a:hover {
  color: var(--gold-light);
}

.social-icons {
  display: flex;
  gap: 0.8em;
  flex-wrap: wrap;
}

.social-icons a {
  width: 36px;
  height: 36px;
  border-radius: 8px;
  background: rgba(255,255,255,0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255,255,255,0.8);
  transition: all 0.2s;
  text-decoration: none;
}

.social-icons a:hover {
  background: var(--gold);
  color: var(--ocean);
}

.social-icons svg {
  width: 18px;
  height: 18px;
}

.footer-bottom {
  border-top: 1px solid rgba(255,255,255,0.1);
  padding: 1.5em 2em;
  max-width: 1400px;
  margin: 0 auto;
  text-align: center;
}

.copyright {
  font-size: 0.85em;
  color: rgba(255,255,255,0.6);
  margin: 0 0 0.5em;
}

.disclaimer {
  font-size: 0.75em;
  color: rgba(255,255,255,0.4);
  margin: 0;
  line-height: 1.6;
}

@media (max-width: 900px) {
  .footer-inner {
    grid-template-columns: 1fr 1fr;
    gap: 2em;
  }
  .footer-brand {
    grid-column: 1 / -1;
  }
}

@media (max-width: 600px) {
  .footer-inner {
    grid-template-columns: 1fr;
    gap: 1.5em;
    padding: 2em 1.5em;
  }
}
</style>