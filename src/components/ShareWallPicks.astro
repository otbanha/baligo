---
const { lang = 'zh-tw' } = Astro.props;

const i18n: Record<string, { title: string; more: string; shuffle: string }> = {
  'zh-tw': { title: '📸 旅人分享', more: '前往分享牆 →', shuffle: '🔀 換一批' },
  'zh-hk': { title: '📸 旅人分享', more: '前往分享牆 →', shuffle: '🔀 換一批' },
  'zh-cn': { title: '📸 旅人分享', more: '前往分享墙 →', shuffle: '🔀 换一批' },
  'en':    { title: '📸 Traveler Shares', more: 'More →', shuffle: '🔀 Shuffle' },
};
const t = i18n[lang] ?? i18n['zh-tw'];
---

<div class="swp-widget">
  <div class="swp-header">
    <span class="swp-title">{t.title}</span>
    <div class="swp-header-actions">
      <button id="swp-shuffle" class="swp-shuffle" type="button" title={t.shuffle}>{t.shuffle}</button>
      <a href="/share/" class="swp-more">{t.more}</a>
    </div>
  </div>
  <div id="swp-list" class="swp-list">
    <div class="swp-loading">載入中⋯</div>
  </div>
</div>

<script>
(async () => {
  const list = document.getElementById('swp-list');
  const shuffleBtn = document.getElementById('swp-shuffle');
  if (!list) return;

  const PLAT_ICON = { youtube: '▶', threads: '◉', instagram: '◈', tiktok: '♪', facebook: 'f' };
  const PLAT_LABEL = {
    youtube: '▶ YouTube', threads: '◉ Threads', instagram: '◈ Instagram',
    facebook: 'f Facebook', tiktok: '♪ TikTok',
  };
  const PLAT_CLS = {
    youtube: 'swp-tag-youtube', threads: 'swp-tag-threads', instagram: 'swp-tag-instagram',
    facebook: 'swp-tag-facebook', tiktok: 'swp-tag-tiktok',
  };

  const META_PLATFORMS = new Set(['threads', 'instagram', 'facebook']);
  const PICK_COUNT = 3;
  let pool = [];

  function sanitize(str) {
    const d = document.createElement('div');
    d.textContent = str ?? '';
    return d.innerHTML;
  }

  /** iframe URL（相容無 embed.iframeUrl 的舊 KV 資料） */
  function getIframeUrl(item) {
    if (item.embed?.iframeUrl) return item.embed.iframeUrl;
    const src = item.sourceUrl || '';
    if (item.platform === 'instagram') {
      const im = src.match(/instagram\.com\/(?:p|reel|tv)\/([\w-]+)/);
      if (im) return `https://www.instagram.com/p/${im[1]}/embed/captioned/`;
    }
    if (item.platform === 'facebook') {
      if (/facebook\.com|fb\.watch/.test(src)) {
        return `https://www.facebook.com/plugins/post.php?href=${encodeURIComponent(src)}&width=500&show_text=true&appId`;
      }
    }
    return null;
  }

  /** 容器比例（相容無 embed.iframeRatio 的舊 KV 資料） */
  function getIframeRatio(item) {
    if (item.embed?.iframeRatio) return item.embed.iframeRatio;
    if (item.platform === 'instagram') return /\/reel\//.test(item.sourceUrl || '') ? '9:16' : '1:1';
    return '4:5'; // facebook / threads
  }

  /** fallback：無法顯示媒體時的品牌色漸層 + icon 佔位 */
  function embedPlaceholderHtml(item) {
    const icon = PLAT_ICON[item.platform] ?? '◉';
    return `<div class="swp-thumb-ph swp-thumb-ph-${item.platform}"><span class="swp-thumb-icon">${icon}</span></div>`;
  }

  /** Meta 系（FB/IG/Threads）卡片的媒體區塊：直接嵌入貼文 iframe，跟 /share 一致 */
  function buildEmbedMediaHtml(item) {
    const ratio = getIframeRatio(item);

    if (item.platform === 'threads') {
      if (item.thumbnail) {
        return `
          <div class="iframe-container" data-ratio="${ratio}" data-platform="threads" style="background:#111">
            <div class="embed-iframe-sk embed-iframe-sk-threads"></div>
            <img src="${sanitize(item.thumbnail)}" alt="" loading="lazy"
              style="width:100%;height:100%;object-fit:cover;object-position:center top;display:block"
              onload="this.previousElementSibling?.remove()"
              onerror="this.parentElement.innerHTML='${embedPlaceholderHtml(item).replace(/'/g, "\\'")}'">
          </div>`;
      }
      return `<div class="iframe-container" data-ratio="${ratio}" data-platform="threads">${embedPlaceholderHtml(item)}</div>`;
    }

    const iframeUrl = getIframeUrl(item);
    if (iframeUrl) {
      return `
        <div class="iframe-container" data-ratio="${ratio}" data-platform="${item.platform}">
          <div class="embed-iframe-sk embed-iframe-sk-${item.platform}"></div>
          <iframe src="${sanitize(iframeUrl)}" loading="lazy" frameborder="0" scrolling="no"
            allowtransparency="true" allow="encrypted-media; picture-in-picture; fullscreen"
            title="${sanitize((item.authorName || item.embedHandle || item.platform) + ' 貼文')}"></iframe>
        </div>`;
    }

    return `<div class="iframe-container" data-ratio="${ratio}" data-platform="${item.platform}">${embedPlaceholderHtml(item)}</div>`;
  }

  /** iframe/img 載入完成後移除 loading skeleton */
  function activateEmbedMedia(root) {
    root.querySelectorAll('.iframe-container').forEach((container) => {
      const sk = container.querySelector('.embed-iframe-sk');
      if (!sk) return;
      const media = container.querySelector('iframe, img');
      if (media) {
        media.addEventListener('load', () => sk.remove());
      } else {
        setTimeout(() => sk.remove(), 15000);
      }
    });
  }

  function shuffle(arr) {
    const a = arr.slice();
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  function displayTitle(item) {
    if (item.title) return item.title;
    if (item.authorName) return `${item.authorName} 的貼文`;
    if (item.embedHandle) return `${item.embedHandle} 的貼文`;
    return `${item.platform} 貼文`;
  }

  function cardHtml(item) {
    const label = PLAT_LABEL[item.platform] ?? item.platform;
    const cls   = PLAT_CLS[item.platform] ?? '';

    // FB/IG/Threads → 直接嵌入貼文 iframe（跟 /share 一致），不再用靜態縮圖
    if (META_PLATFORMS.has(item.platform)) {
      return `
        <div class="swp-card swp-card-embed">
          ${buildEmbedMediaHtml(item)}
          <div class="swp-info">
            <div class="swp-tag ${cls}">${label}</div>
            <div class="swp-card-title">${sanitize(displayTitle(item))}</div>
            <a class="swp-card-link" href="${sanitize(item.sourceUrl || '/share/')}" target="_blank" rel="noopener noreferrer">前往原文 →</a>
          </div>
        </div>`;
    }

    const icon  = PLAT_ICON[item.platform] ?? '◉';
    const phCls = `swp-thumb-ph swp-thumb-ph-${item.platform}`;
    const thumbHtml = item.thumbnail
      ? `<img src="${sanitize(item.thumbnail)}" alt="" loading="lazy"
           style="width:100%;height:100%;object-fit:cover;display:block"
           onerror="this.parentElement.classList.add(...'${phCls}'.split(' '));this.replaceWith(Object.assign(document.createElement('span'),{className:'swp-thumb-icon',textContent:'${icon}'}))">`
      : `<span class="swp-thumb-icon">${icon}</span>`;
    const thumbCls = item.thumbnail ? 'swp-thumb' : `swp-thumb ${phCls}`;

    return `
      <a class="swp-card" href="${sanitize(item.sourceUrl || '/share/')}" target="_blank" rel="noopener noreferrer">
        <div class="${thumbCls}">${thumbHtml}</div>
        <div class="swp-info">
          <div class="swp-tag ${cls}">${label}</div>
          <div class="swp-card-title">${sanitize(displayTitle(item))}</div>
        </div>
      </a>`;
  }

  function render() {
    const picks = shuffle(pool).slice(0, PICK_COUNT);
    if (picks.length === 0) {
      list.innerHTML = '';
      shuffleBtn?.style.setProperty('display', 'none');
      return;
    }
    list.innerHTML = picks.map(cardHtml).join('');
    activateEmbedMedia(list);
  }

  try {
    const res = await fetch('/api/recent-unfurls?limit=30');
    const data = await res.json();
    pool = (data.items || []).filter((it) => it.sourceUrl);
    if (pool.length === 0) {
      list.innerHTML = '';
      shuffleBtn?.style.setProperty('display', 'none');
      return;
    }
    render();
    shuffleBtn?.addEventListener('click', render);
  } catch {
    list.innerHTML = '';
    shuffleBtn?.style.setProperty('display', 'none');
  }
})();
</script>

<style is:global>
.swp-widget {
  background: #fafafa;
  border: 1px solid #e5e5e5;
  border-radius: 12px;
  padding: .9rem 1.1rem;
  margin-bottom: 1.2rem;
}
.swp-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: .6rem;
  gap: .5rem;
}
.swp-title {
  font-size: .85rem;
  font-weight: 700;
  color: #444;
  letter-spacing: .01em;
  white-space: nowrap;
}
.swp-header-actions {
  display: flex;
  align-items: center;
  gap: .6rem;
}
.swp-shuffle {
  font-size: .72rem;
  color: #666;
  background: #fff;
  border: 1px solid #ddd;
  border-radius: 20px;
  padding: .15em .7em;
  cursor: pointer;
  white-space: nowrap;
}
.swp-shuffle:hover { background: #f0f0f0; }
.swp-more {
  font-size: .75rem;
  color: #777;
  text-decoration: none;
  white-space: nowrap;
}
.swp-more:hover { text-decoration: underline; }

.swp-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: .5rem;
}
.swp-loading {
  font-size: .82rem;
  color: #999;
  padding: .3rem 0;
  grid-column: 1 / -1;
}

.swp-card {
  display: block;
  text-decoration: none;
  color: inherit;
  border-radius: 8px;
  overflow: hidden;
  background: #fff;
  border: 1px solid #eee;
}
.swp-card-embed { display: block; }
.swp-card-link {
  display: block;
  font-size: .7rem;
  color: #1a6fad;
  font-weight: 600;
  text-decoration: none;
  margin-top: .25rem;
}
.swp-card-link:hover { text-decoration: underline; }

/* Meta 系（FB/IG/Threads）貼文 iframe 容器 */
.iframe-container {
  position: relative;
  overflow: hidden;
  background: #f0f0f0;
}
.iframe-container[data-ratio="9:16"] { aspect-ratio: 9 / 16; }
.iframe-container[data-ratio="4:5"]  { aspect-ratio: 4 / 5; }
.iframe-container[data-ratio="16:9"] { aspect-ratio: 16 / 9; }
.iframe-container[data-ratio="1:1"]  { aspect-ratio: 1 / 1; }
.iframe-container iframe, .iframe-container img {
  width: 100%; height: 100%; border: 0; display: block;
}
/* IG /embed/captioned/ 沒有 embed.js 時頂部會露出大頭貼列，往上裁掉讓視覺更一致 */
.iframe-container[data-platform="instagram"] iframe {
  height: calc(100% + 60px);
  margin-top: -60px;
}
/* iframe / 縮圖載入中的骨架動畫 */
@keyframes swp-shimmer {
  0%   { background-position: -300px 0; }
  100% { background-position: 300px 0; }
}
.embed-iframe-sk {
  position: absolute; inset: 0; z-index: 1;
  background-size: 600px 100%;
  animation: swp-shimmer 1.4s infinite linear;
}
.embed-iframe-sk-threads   { background: linear-gradient(90deg,#111 25%,#222 50%,#111 75%); }
.embed-iframe-sk-instagram { background: linear-gradient(90deg,#b24592 25%,#e15c8a 50%,#b24592 75%); opacity:.4; }
.embed-iframe-sk-facebook  { background: linear-gradient(90deg,#1565c0 25%,#1e88e5 50%,#1565c0 75%); opacity:.4; }
.swp-thumb {
  width: 100%;
  aspect-ratio: 1 / 1;
  overflow: hidden;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.6rem;
  color: #bbb;
}
.swp-thumb-icon { filter: drop-shadow(0 2px 4px rgba(0,0,0,.25)); }
/* 無縮圖的平台（FB/IG 無法抓取真實縮圖）→ 用品牌色漸層佔位，取代灰色空白 */
.swp-thumb-ph {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 1.8rem;
}
.swp-thumb-ph-facebook  { background: linear-gradient(160deg, #1877f2 0%, #42a5f5 100%); }
.swp-thumb-ph-instagram { background: linear-gradient(160deg, #833ab4 0%, #fd1d1d 55%, #fcb045 100%); }
.swp-thumb-ph-threads   { background: linear-gradient(160deg, #111 0%, #2a2a2a 100%); }
.swp-thumb-ph-tiktok    { background: linear-gradient(160deg, #010101 0%, #25f4ee 130%); }
.swp-thumb-ph-youtube   { background: linear-gradient(160deg, #c00 0%, #ff5252 100%); }
.swp-info { padding: .4rem .5rem; }
.swp-tag {
  font-size: .62rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .04em;
  margin-bottom: .2rem;
}
.swp-tag-youtube   { color: #c00; }
.swp-tag-threads   { color: #111; }
.swp-tag-instagram { color: #c13584; }
.swp-tag-facebook  { color: #1877f2; }
.swp-tag-tiktok    { color: #010101; }
.swp-card-title {
  font-size: .74rem;
  color: #444;
  line-height: 1.35;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

@media (max-width: 480px) {
  .swp-list { grid-template-columns: repeat(2, 1fr); }
}
</style>
