---
// forumId: scope the widget to a single phpBB board (e.g. per blog-category
// discussion board) instead of the site-wide "latest posts" feed.
const { lang = 'zh-tw', forumId, title, cta } = Astro.props;

const i18n: Record<string, { title: string; more: string; loading: string }> = {
  'zh-tw': { title: '峇里島討論區', more: '前往討論區 →', loading: '載入中⋯' },
  'zh-hk': { title: '峇里島討論區', more: '前往討論區 →', loading: '載入中⋯' },
  'zh-cn': { title: '峇里岛讨论区', more: '前往讨论区 →', loading: '载入中⋯' },
  'en':    { title: 'Community Forum', more: 'Visit forum →', loading: 'Loading⋯' },
  'id':    { title: 'Forum Komunitas', more: 'Kunjungi forum →', loading: 'Memuat⋯' },
};
const t = i18n[lang] ?? i18n['zh-tw'];
const widgetTitle = title || t.title;
const ctaLabel = cta || t.more;
const forumUrl = forumId
  ? `https://community.gobaligo.id/viewforum.php?f=${forumId}`
  : 'https://community.gobaligo.id/';
const apiUrl = forumId ? `/api/forum-latest?f=${forumId}` : '/api/forum-latest';
---

<div class="flt-widget">
  <div class="flt-header">
    <span class="flt-title">{widgetTitle}</span>
    <a href={forumUrl} class="flt-more" target="_blank" rel="noopener">{ctaLabel}</a>
  </div>
  <ul id="flt-list" class="flt-list">
    <li class="flt-loading">{t.loading}</li>
  </ul>
</div>

<script define:vars={{ apiUrl }}>
(async () => {
  const list = document.getElementById('flt-list');
  if (!list) return;

  try {
    const res = await fetch(apiUrl);
    const data = await res.json();
    const topics = data.topics || [];

    if (topics.length === 0) { list.innerHTML = ''; return; }

    function sanitize(str) {
      const d = document.createElement('div');
      d.textContent = str ?? '';
      return d.innerHTML;
    }

    list.innerHTML = topics.map((topic) => `
      <li class="flt-item">
        <a href="${sanitize(topic.url)}" class="flt-link" target="_blank" rel="noopener">
          <img src="/favicon-16x16.png" class="flt-icon" alt="" aria-hidden="true" />
          <span class="flt-post-title">${sanitize(topic.title)}</span>
        </a>
      </li>`).join('');

  } catch {
    list.innerHTML = '';
  }
})();
</script>

<style is:global>
.flt-widget {
  background: #f5f8fc;
  border: 1px solid #c9d6e8;
  border-radius: 12px;
  padding: .9rem 1.1rem;
  margin-bottom: 1.2rem;
  min-width: 0;
}
.flt-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: .6rem;
}
.flt-title {
  font-size: .85rem;
  font-weight: 700;
  color: #1A365D;
  letter-spacing: .01em;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  min-width: 0;
  flex: 1 1 auto;
}
.flt-more {
  font-size: .75rem;
  color: #9c7a3f;
  text-decoration: none;
  white-space: nowrap;
  flex-shrink: 0;
}
.flt-more:hover { text-decoration: underline; }

.flt-list {
  list-style: none;
  margin: 0;
  padding: 0;
}
.flt-loading {
  font-size: .82rem;
  color: #5b7194;
  padding: .3rem 0;
}

.flt-item {
  border-bottom: 1px solid #c9d6e8;
}
.flt-item:last-child { border-bottom: none; }

.flt-link {
  display: flex;
  align-items: center;
  gap: .45rem;
  padding: .45rem 0;
  text-decoration: none;
  color: inherit;
}
.flt-link:hover .flt-post-title { color: #1A365D; text-decoration: underline; }

.flt-icon {
  width: 14px;
  height: 14px;
  flex-shrink: 0;
  border-radius: 3px;
}

.flt-post-title {
  font-size: .82rem;
  font-weight: 500;
  color: #2c4a6e;
  line-height: 1.4;
  white-space: normal;
  overflow-wrap: break-word;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  flex: 1;
  min-width: 0;
}

</style>
