---
import { getMapBlogLink, getAnchorText } from '../data/mapBlogMapping';

interface Props {
  mapSlug: string;
  position: 'hero' | 'inline' | 'footer';
  variant?: 'card' | 'inline' | 'list';
}

const { mapSlug, position, variant = position === 'hero' ? 'card' : position === 'inline' ? 'inline' : 'list' } = Astro.props;

const entry = getMapBlogLink(mapSlug);
if (!entry) return;

const anchorText = getAnchorText(mapSlug, position);
if (!anchorText) return;
---

{variant === 'card' && (
  <div class="related-guide-card">
    <div class="related-guide-card__icon">📖</div>
    <div class="related-guide-card__body">
      <p class="related-guide-card__title">{entry.blogTitle}</p>
      <p class="related-guide-card__teaser">{entry.teaser}</p>
    </div>
    <a href={entry.blogUrl} rel="related" class="related-guide-card__cta">
      {anchorText} →
    </a>
  </div>
)}

{variant === 'inline' && (
  <a href={entry.blogUrl} rel="related" class="related-guide-inline">
    {anchorText}
  </a>
)}

{variant === 'list' && (
  <li class="related-guide-list-item">
    <a href={entry.blogUrl} rel="related">{anchorText}</a>
  </li>
)}

<style>
  .related-guide-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: #fffbf0;
    border: 1px solid #f0c050;
    border-radius: 12px;
    padding: 1rem 1.25rem;
    margin: 1.5rem 0;
  }
  .related-guide-card__icon {
    font-size: 1.75rem;
    flex-shrink: 0;
  }
  .related-guide-card__body {
    flex: 1;
    min-width: 0;
  }
  .related-guide-card__title {
    font-weight: 700;
    margin: 0 0 0.25rem;
    font-size: 0.95rem;
    color: #1a1a1a;
  }
  .related-guide-card__teaser {
    margin: 0;
    font-size: 0.85rem;
    color: #555;
    line-height: 1.4;
  }
  .related-guide-card__cta {
    display: inline-block;
    white-space: nowrap;
    background: #f5a623;
    color: #fff;
    font-weight: 700;
    font-size: 0.85rem;
    padding: 0.5rem 1rem;
    border-radius: 8px;
    text-decoration: none;
    flex-shrink: 0;
  }
  .related-guide-card__cta:hover {
    background: #d4891a;
  }
  .related-guide-inline {
    color: #d4891a;
    text-decoration: underline;
    font-weight: 500;
  }
  .related-guide-list-item {
    list-style: disc;
  }
  .related-guide-list-item a {
    color: #d4891a;
    text-decoration: none;
  }
  .related-guide-list-item a:hover {
    text-decoration: underline;
  }
  @media (max-width: 480px) {
    .related-guide-card {
      flex-wrap: wrap;
    }
    .related-guide-card__cta {
      width: 100%;
      text-align: center;
    }
  }
</style>
