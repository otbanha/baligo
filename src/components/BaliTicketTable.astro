<section id="ticket-table-section" class="tt-section">
  <div class="tt-header">
    <div class="tt-title-row">
      <h2 class="tt-title">🎟️ 峇里島景點門票總表</h2>
      <div class="tt-sort">
        <span class="tt-sort-label">排序：</span>
        <button class="tt-sort-btn active" data-sort="default">預設</button>
        <button class="tt-sort-btn" data-sort="asc">票價低→高</button>
        <button class="tt-sort-btn" data-sort="desc">票價高→低</button>
      </div>
    </div>
    <div class="tt-filters" id="tt-filters">
      <button class="tt-filter active" data-cat="all">全部</button>
      <button class="tt-filter" data-cat="temple">🛕 寺廟</button>
      <button class="tt-filter" data-cat="nature">🌿 自然景觀</button>
      <button class="tt-filter" data-cat="island">🏝️ Nusa Penida</button>
      <button class="tt-filter" data-cat="park">🏛️ 文化園區</button>
      <button class="tt-filter" data-cat="activity">🎡 主題樂園</button>
      <button class="tt-filter" data-cat="adventure">⚡ 冒險活動</button>
    </div>
  </div>

  <div class="tt-grid" id="tt-grid"></div>

  <p class="tt-disclaimer">
    票價資訊更新至 2026 年，現場價格可能調整，建議出發前確認。Klook / Agoda 為聯盟連結。
  </p>
</section>

<script is:inline>
(function () {
  var AGODA_URL = 'https://www.agoda.com/zh-tw/bali-activities/?cid=1961347';

  var CAT_LABEL = {
    temple:    '寺廟',
    nature:    '自然景觀',
    island:    'Nusa Penida',
    park:      '文化園區',
    activity:  '主題樂園',
    adventure: '冒險活動',
  };

  var data = [
    // 寺廟
    { name:'Uluwatu Temple', cat:'temple', idr:150000, note:'含 Kecak Fire Dance。僅參觀神廟 IDR 50,000。現場付現/QRIS。', klook:'https://www.klook.com/zh-TW/activity/2679-uluwatu-temple-kecak-fire-dance-bali/?aid=116349', agoda:false, warn:null },
    { name:'Tanah Lot', cat:'temple', idr:75000, note:'不接受刷卡，現場付現。', klook:'https://www.klook.com/zh-TW/activity/2688-tanah-lot-temple-bali/?aid=116349', agoda:false, warn:null },
    { name:'Tirta Empul', cat:'temple', idr:50000, note:'含沙龍。可自費參加 Melukat 淨化浴儀式。', klook:'https://www.klook.com/zh-TW/search/?query=tirta+empul+bali&aid=116349', agoda:false, warn:null },
    { name:'Goa Gajah', cat:'temple', idr:50000, note:'含沙龍。可與 Tirta Empul 同日遊覽。', klook:null, agoda:false, warn:null },
    { name:'Lempuyang Temple', cat:'temple', idr:100000, note:'含沙龍。天堂之門拍照需接駁車 IDR 50,000。', klook:'https://www.klook.com/zh-TW/search/?query=lempuyang+temple+bali&aid=116349', agoda:false, warn:'⚠ 排隊可達 2–4 小時' },
    { name:'Besakih Temple', cat:'temple', idr:150000, note:'峇里島最神聖母廟，阿貢火山山腰。必須著沙龍。', klook:'https://www.klook.com/zh-TW/search/?query=besakih+temple+bali&aid=116349', agoda:false, warn:null },
    { name:'Ulun Danu Bratan', cat:'temple', idr:75000, note:'湖中水廟，含沙龍租借。', klook:'https://www.klook.com/zh-TW/search/?query=ulun+danu+bratan&aid=116349', agoda:false, warn:null },
    { name:'Gunung Kawi', cat:'temple', idr:50000, note:'含沙龍。需步行下坡約 300 階。', klook:null, agoda:false, warn:null },
    // 自然景觀
    { name:'Ubud Monkey Forest', cat:'nature', idr:80000, note:'僅接受電子支付，不收現金。', klook:'https://www.klook.com/zh-TW/activity/2695-ubud-monkey-forest-bali/?aid=116349', agoda:false, warn:'⚠ 不收現金' },
    { name:'Tegalalang Rice Terrace', cat:'nature', idr:50000, note:'各觀景台分別收費 IDR 15,000–25,000，入口管理費約 IDR 50,000。', klook:null, agoda:false, warn:null },
    { name:'Jatiluwih Rice Terrace', cat:'nature', idr:50000, note:'UNESCO 世界文化遺產。停車另計 IDR 5,000。', klook:'https://www.klook.com/zh-TW/search/?query=jatiluwih+rice+terrace&aid=116349', agoda:false, warn:null },
    { name:'Tegenungan Waterfall', cat:'nature', idr:25000, note:'含步道。玻璃橋另收 IDR 50,000。現場付現。', klook:'https://www.klook.com/zh-TW/search/?query=tegenungan+waterfall&aid=116349', agoda:false, warn:null },
    { name:'Kintamani Volcano View', cat:'nature', idr:50000, note:'俯瞰 Mount Batur 與火山湖。登山健行另需嚮導費。', klook:'https://www.klook.com/zh-TW/search/?query=kintamani+bali&aid=116349', agoda:false, warn:null },
    { name:'Tirta Gangga', cat:'nature', idr:50000, note:'東峇里王室水宮，含蓮花池步道。', klook:null, agoda:false, warn:null },
    { name:'Taman Ayun Temple', cat:'nature', idr:20000, note:'皇家花園廟宇，UNESCO 遺產之一。', klook:null, agoda:false, warn:null },
    { name:'Kanto Lampo Waterfall', cat:'nature', idr:20000, note:'拍照熱點，需走小徑下溪床，建議穿防滑鞋。現場付現。', klook:null, agoda:false, warn:null },
    // 努沙佩尼達
    { name:'Nusa Penida Retribution Fee', cat:'island', idr:25000, note:'2026年2月起改為線上預購，須持電子憑證上船。', klook:'https://www.klook.com/zh-TW/search/?query=nusa+penida+day+trip&aid=116349', agoda:false, warn:'⚠ 須線上預購' },
    { name:'Nusa Penida Marine Conservation Fee', cat:'island', idr:100000, note:'進入海洋保護區（浮潛/潛水）另收。通常含在套裝行程內。', klook:'https://www.klook.com/zh-TW/search/?query=nusa+penida+snorkeling&aid=116349', agoda:false, warn:null },
    { name:'Fast Boat（Sanur ↔ Nusa Penida）', cat:'island', idr:250000, note:'單程約 IDR 150,000–250,000，依船公司而異。建議線上預購對號入座。', klook:'https://www.klook.com/zh-TW/search/?query=fast+boat+nusa+penida&aid=116349', agoda:false, warn:null },
    { name:'Nusa Penida Full Day Tour', cat:'island', idr:450000, note:'含接送、導遊、午餐。西線（Kelingking/Angel\'s Billabong）或東線（Atuh Beach）可選。', klook:'https://www.klook.com/zh-TW/search/?query=nusa+penida+full+day+tour&aid=116349', agoda:true, warn:null },
    // 文化園區
    { name:'GWK Cultural Park', cat:'park', idr:150000, note:'含文化表演區。線上購票可省 IDR 25,000。', klook:'https://www.klook.com/zh-TW/search/?query=GWK+cultural+park+bali&aid=116349', agoda:false, warn:null },
    { name:'Ubud Palace Night Dance', cat:'park', idr:100000, note:'白天免費參觀。夜間傳統舞蹈約 IDR 100,000，每晚節目不同。', klook:'https://www.klook.com/zh-TW/search/?query=ubud+palace+dance&aid=116349', agoda:false, warn:null },
    { name:'Bali Museum', cat:'park', idr:50000, note:'登巴薩市區，展示峇里島傳統文物與歷史。', klook:null, agoda:false, warn:null },
    // 主題樂園
    { name:'Waterbom Bali', cat:'activity', idr:600000, note:'票價依旺淡季浮動（IDR 550,000–700,000）。線上購票通常較便宜。', klook:'https://www.klook.com/zh-TW/search/?query=waterbom+bali&aid=116349', agoda:true, warn:null },
    { name:'Bali Zoo', cat:'activity', idr:350000, note:'含園區入場及動物秀。與紅毛猩猩共進早餐為熱門加購項目。', klook:'https://www.klook.com/zh-TW/search/?query=bali+zoo&aid=116349', agoda:false, warn:null },
    { name:'Bali Safari & Marine Park', cat:'activity', idr:500000, note:'Jungle Hopper 基本票含 Safari 車程。含 Bali Agung Show 的 Legend 票另計。', klook:'https://www.klook.com/zh-TW/search/?query=bali+safari+marine+park&aid=116349', agoda:false, warn:null },
    { name:'Trans Studio Bali', cat:'activity', idr:250000, note:'室內主題樂園，適合親子。含多項機械遊樂設施。', klook:'https://www.klook.com/zh-TW/search/?query=trans+studio+bali&aid=116349', agoda:false, warn:null },
    // 冒險活動
    { name:'Bali Swing Ubud', cat:'adventure', idr:500000, note:'含午餐、開放式飲料吧。多種鞦韆高度可選（最高 78m）。含接送（Ubud 區）。', klook:'https://www.klook.com/zh-TW/search/?query=bali+swing+ubud&aid=116349', agoda:false, warn:null },
    { name:'Ayung River Rafting', cat:'adventure', idr:350000, note:'約 2 小時，Class II–III 急流。含午餐、保險、裝備。', klook:'https://www.klook.com/zh-TW/search/?query=ayung+river+rafting+bali&aid=116349', agoda:false, warn:null },
    { name:'ATV Ride Ubud', cat:'adventure', idr:550000, note:'約 1.5 小時，穿越稻田、叢林與村莊。含午餐、裝備。', klook:'https://www.klook.com/zh-TW/search/?query=atv+ride+ubud+bali&aid=116349', agoda:false, warn:null },
    { name:'Mount Batur Sunrise Trek', cat:'adventure', idr:450000, note:'凌晨出發，約 2 小時登頂。含嚮導、早餐。建議線上預購。', klook:'https://www.klook.com/zh-TW/search/?query=mount+batur+sunrise+trek&aid=116349', agoda:false, warn:null },
    { name:'Nusa Penida Snorkeling', cat:'adventure', idr:400000, note:'含 3 個浮潛點、裝備、午餐。通常含 Marine Conservation Fee。', klook:'https://www.klook.com/zh-TW/search/?query=nusa+penida+snorkeling+tour&aid=116349', agoda:false, warn:null },
    { name:'Surfing Lesson Canggu', cat:'adventure', idr:350000, note:'約 2 小時，含教練、板子、蠟。適合初學者。', klook:'https://www.klook.com/zh-TW/search/?query=surfing+lesson+canggu&aid=116349', agoda:false, warn:null },
    { name:'Surfing Lesson Kuta', cat:'adventure', idr:300000, note:'Kuta Beach 沙灘浪適合初學，約 2 小時含教練與板子。', klook:'https://www.klook.com/zh-TW/search/?query=surfing+lesson+kuta+bali&aid=116349', agoda:false, warn:null },
    { name:'Ubud Cooking Class', cat:'adventure', idr:400000, note:'含市場採購、3–5 道菜烹飪、食譜帶回。約 4–5 小時。', klook:'https://www.klook.com/zh-TW/search/?query=ubud+cooking+class&aid=116349', agoda:false, warn:null },
    { name:'Uluwatu Paragliding', cat:'adventure', idr:1500000, note:'雙人滑翔傘，俯瞰印度洋，約 15–20 分鐘飛行。含接送。', klook:'https://www.klook.com/zh-TW/search/?query=paragliding+uluwatu+bali&aid=116349', agoda:false, warn:null },
    { name:'River Tubing', cat:'adventure', idr:350000, note:'坐橡皮圈漂流峇里島叢林河道，約 2 小時。含裝備、午餐。', klook:'https://www.klook.com/zh-TW/search/?query=river+tubing+bali&aid=116349', agoda:false, warn:null },
  ];

  function fmtIdr(n) {
    return 'IDR ' + n.toLocaleString('en-US');
  }

  function catClass(cat) {
    var map = { temple:'cat-temple', nature:'cat-nature', island:'cat-island', park:'cat-park', activity:'cat-activity', adventure:'cat-adventure' };
    return map[cat] || '';
  }

  function buildCard(item) {
    var card = document.createElement('div');
    card.className = 'tt-card';
    card.dataset.cat = item.cat;
    card.dataset.idr = item.idr;

    var top = '<div class="tt-card-top">';
    top += '<div class="tt-name-row">';
    top += '<span class="tt-name">' + item.name + '</span>';
    top += '<span class="tt-cat-badge ' + catClass(item.cat) + '">' + CAT_LABEL[item.cat] + '</span>';
    top += '</div>';
    if (item.warn) {
      top += '<span class="tt-warn">' + item.warn + '</span>';
    }
    top += '</div>';

    var price = '<div class="tt-price">' + fmtIdr(item.idr) + '</div>';
    var note = '<p class="tt-note">' + item.note + '</p>';

    var btns = '<div class="tt-btns">';
    if (item.klook) {
      btns += '<a class="tt-btn tt-btn-klook" href="' + item.klook + '" target="_blank" rel="noopener">Klook 訂票</a>';
    }
    if (item.agoda) {
      btns += '<a class="tt-btn tt-btn-agoda" href="' + AGODA_URL + '" target="_blank" rel="noopener">Agoda 查價</a>';
    }
    btns += '</div>';

    card.innerHTML = top + price + note + btns;
    return card;
  }

  var originalData = data.slice();
  var currentCat = 'all';
  var currentSort = 'default';

  function getFiltered() {
    var list = currentCat === 'all' ? originalData.slice() : originalData.filter(function(d){ return d.cat === currentCat; });
    if (currentSort === 'asc') list.sort(function(a,b){ return a.idr - b.idr; });
    else if (currentSort === 'desc') list.sort(function(a,b){ return b.idr - a.idr; });
    return list;
  }

  function render() {
    var grid = document.getElementById('tt-grid');
    if (!grid) return;
    grid.innerHTML = '';
    var list = getFiltered();
    list.forEach(function(item){ grid.appendChild(buildCard(item)); });
  }

  function init() {
    render();

    document.getElementById('tt-filters').addEventListener('click', function(e) {
      var btn = e.target.closest('.tt-filter');
      if (!btn) return;
      document.querySelectorAll('.tt-filter').forEach(function(b){ b.classList.remove('active'); });
      btn.classList.add('active');
      currentCat = btn.dataset.cat;
      render();
    });

    document.querySelectorAll('.tt-sort-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.tt-sort-btn').forEach(function(b){ b.classList.remove('active'); });
        btn.classList.add('active');
        currentSort = btn.dataset.sort;
        render();
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>

<style>
.tt-section {
  margin: 2em 0 1.5em;
  background: var(--white);
  border-radius: 14px;
  border: 1px solid rgba(197,160,89,0.2);
  padding: 1.5em;
  box-shadow: 0 2px 12px rgba(10,22,40,0.06);
}

.tt-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 0.6em;
  margin-bottom: 0.8em;
}

.tt-title {
  font-size: 1.05em;
  font-weight: 700;
  color: var(--ocean);
  margin: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.tt-sort {
  display: flex;
  align-items: center;
  gap: 0.4em;
  flex-wrap: wrap;
}

.tt-sort-label {
  font-size: 0.78em;
  color: var(--text-light);
}

.tt-sort-btn {
  font-size: 0.75em;
  padding: 0.25em 0.7em;
  border-radius: 20px;
  border: 1px solid rgba(197,160,89,0.35);
  background: transparent;
  color: var(--text-light);
  cursor: pointer;
  font-family: inherit;
  transition: all 0.15s;
}

.tt-sort-btn.active,
.tt-sort-btn:hover {
  background: var(--ocean);
  color: var(--gold-light);
  border-color: var(--ocean);
}

.tt-filters {
  display: flex;
  flex-wrap: wrap;
  gap: 0.45em;
  margin-bottom: 1.2em;
  padding-bottom: 1em;
  border-bottom: 1px solid rgba(197,160,89,0.15);
}

.tt-filter {
  font-size: 0.82em;
  font-weight: 600;
  padding: 0.3em 0.85em;
  border-radius: 20px;
  border: 1px solid rgba(197,160,89,0.35);
  background: transparent;
  color: var(--text);
  cursor: pointer;
  font-family: inherit;
  transition: all 0.15s;
  white-space: nowrap;
}

.tt-filter:hover { border-color: var(--gold); color: var(--ocean); }
.tt-filter.active { background: var(--ocean); color: var(--gold-light); border-color: var(--ocean); }

/* Grid */
.tt-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 0.9em;
}

@media (min-width: 600px) {
  .tt-grid { grid-template-columns: repeat(2, 1fr); }
}

@media (min-width: 1024px) {
  .tt-grid { grid-template-columns: repeat(3, 1fr); }
}

/* Card */
.tt-card {
  border: 1px solid rgba(197,160,89,0.2);
  border-radius: 10px;
  padding: 1em 1.1em;
  background: #fafaf8;
  display: flex;
  flex-direction: column;
  gap: 0.45em;
  transition: box-shadow 0.15s, transform 0.15s;
}

.tt-card:hover {
  box-shadow: 0 4px 16px rgba(26,54,93,0.1);
  transform: translateY(-2px);
}

.tt-card-top {
  display: flex;
  flex-direction: column;
  gap: 0.3em;
}

.tt-name-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 0.5em;
}

.tt-name {
  font-size: 0.92em;
  font-weight: 700;
  color: var(--ocean);
  line-height: 1.35;
  flex: 1;
}

.tt-cat-badge {
  font-size: 0.68em;
  font-weight: 700;
  padding: 0.2em 0.55em;
  border-radius: 10px;
  white-space: nowrap;
  flex-shrink: 0;
  margin-top: 1px;
}

.cat-temple   { background: #ede9fe; color: #6d28d9; }
.cat-nature   { background: #dcfce7; color: #166534; }
.cat-island   { background: #cffafe; color: #0e7490; }
.cat-park     { background: #ffedd5; color: #9a3412; }
.cat-activity { background: #dbeafe; color: #1e40af; }
.cat-adventure{ background: #fee2e2; color: #991b1b; }

.tt-warn {
  display: inline-block;
  font-size: 0.72em;
  font-weight: 600;
  color: #c2410c;
  background: #fff7ed;
  border: 1px solid #fed7aa;
  padding: 0.15em 0.55em;
  border-radius: 20px;
  align-self: flex-start;
}

.tt-price {
  font-size: 1em;
  font-weight: 800;
  color: var(--ocean);
  letter-spacing: 0.01em;
}

.tt-note {
  font-size: 0.78em;
  color: var(--text-light);
  line-height: 1.55;
  margin: 0;
  flex: 1;
}

.tt-btns {
  display: flex;
  gap: 0.5em;
  flex-wrap: wrap;
  margin-top: 0.3em;
}

.tt-btn {
  font-size: 0.75em;
  font-weight: 700;
  padding: 0.3em 0.85em;
  border-radius: 7px;
  text-decoration: none;
  transition: all 0.15s;
  display: inline-block;
}

.tt-btn-klook {
  border: 1.5px solid #ff6602;
  color: #e05500;
  background: transparent;
}
.tt-btn-klook:hover { background: #ff6602; color: #fff; }

.tt-btn-agoda {
  border: 1.5px solid #1a6ee1;
  color: #1a6ee1;
  background: transparent;
}
.tt-btn-agoda:hover { background: #1a6ee1; color: #fff; }

.tt-disclaimer {
  font-size: 0.72em;
  color: #999;
  margin: 1.2em 0 0;
  padding-top: 0.8em;
  border-top: 1px solid rgba(197,160,89,0.12);
  line-height: 1.5;
}

@media (max-width: 600px) {
  .tt-section { padding: 1em; }
  .tt-title { font-size: 0.95em; }
  .tt-title-row { flex-direction: column; align-items: flex-start; }
}
</style>
