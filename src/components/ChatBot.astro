---
// 峇里島旅遊 AI 問答機器人（頁面內嵌版）
// 需要在 Cloudflare Pages 後台設定 Workers AI binding（名稱：AI）
---

<section class="chatbot-section">
  <div class="chatbot-inner">
    <div class="chatbot-header">
      <span class="chatbot-icon">🌴</span>
      <div>
        <h2 class="chatbot-title">最精準的峇里島知識庫AI</h2>
        <p class="chatbot-subtitle">有任何峇里島旅遊問題都可以問我！</p>
      </div>
    </div>

    <div class="chat-messages" id="chat-messages">
      <div class="msg bot">
        <span class="msg-avatar">🌴</span>
        <div class="msg-bubble">
          你好！我是峇里島知識庫AI 👋<br>
          簽證、交通、住宿、行程⋯⋯隨時為您解答！
        </div>
      </div>
    </div>

    <form class="chat-input-area" id="chat-form">
      <input
        type="text"
        id="chat-input"
        placeholder="輸入問題，例如：峇里島最佳旅遊季節？"
        maxlength="200"
        autocomplete="off"
      />
      <button type="submit" id="chat-send">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
        <span>送出</span>
      </button>
    </form>
  </div>
</section>

<script>
  const API_URL = '/api/chat';
  const form = document.getElementById('chat-form');
  const input = document.getElementById('chat-input') as HTMLInputElement;
  const messages = document.getElementById('chat-messages');

  function escapeHtml(str: string) {
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  function renderReply(text: string) {
    // Parse markdown links [title](url) → <a>, escape everything else
    const parts = text.split(/(\[[^\]]+\]\([^)]+\))/g);
    return parts.map(part => {
      const match = part.match(/^\[([^\]]+)\]\(([^)]+)\)$/);
      if (match) {
        return `<a href="${escapeHtml(match[2])}" class="chat-link" target="_blank" rel="noopener">${escapeHtml(match[1])}</a>`;
      }
      return escapeHtml(part).replace(/\n/g, '<br>');
    }).join('');
  }

  function addMessage(text: string, role: 'user' | 'error') {
    const div = document.createElement('div');
    div.className = `msg ${role}`;
    if (role === 'error') {
      div.innerHTML = `<div class="msg-bubble error">${escapeHtml(text)}</div>`;
    } else {
      div.innerHTML = `<div class="msg-bubble">${escapeHtml(text)}</div>`;
    }
    messages!.appendChild(div);
    messages!.scrollTop = messages!.scrollHeight;
  }

  function addBotResponse(data: { reply: string; articles?: {title: string; url: string}[]; affiliate?: string | null; affiliateLink?: string | null }) {
    const div = document.createElement('div');
    div.className = 'msg bot';

    let articlesHtml = '';
    if (data.articles && data.articles.length > 0) {
      articlesHtml = `<div class="related-articles">
        <div class="related-label">📖 相關文章</div>
        ${data.articles.map(a => `<a href="${a.url}" class="related-card" target="_blank" rel="noopener">${escapeHtml(a.title)}</a>`).join('')}
      </div>`;
    }

    let affiliateHtml = '';
    if (data.affiliate === 'agoda' && data.affiliateLink) {
      affiliateHtml = `<a href="${data.affiliateLink}" class="affiliate-btn agoda-btn" target="_blank" rel="noopener sponsored">
        🏨 Agoda 搜尋峇里島住宿
      </a>`;
    } else if (data.affiliate === 'klook' && data.affiliateLink) {
      affiliateHtml = `<a href="${data.affiliateLink}" class="affiliate-btn klook-btn" target="_blank" rel="noopener sponsored">
        🎟️ Klook 峇里島活動 & 行程
      </a>`;
    }

    div.innerHTML = `<span class="msg-avatar">🌴</span>
      <div class="msg-content">
        <div class="msg-bubble">${renderReply(data.reply)}</div>
        ${articlesHtml}
        ${affiliateHtml}
      </div>`;

    messages!.appendChild(div);
    messages!.scrollTop = messages!.scrollHeight;
  }

  function addTyping() {
    const div = document.createElement('div');
    div.className = 'msg bot typing';
    div.id = 'typing-indicator';
    div.innerHTML = '<span class="msg-avatar">🌴</span><div class="msg-bubble"><span class="dot"></span><span class="dot"></span><span class="dot"></span></div>';
    messages!.appendChild(div);
    messages!.scrollTop = messages!.scrollHeight;
  }

  function removeTyping() {
    document.getElementById('typing-indicator')?.remove();
  }

  form!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const text = input.value.trim();
    if (!text) return;

    input.value = '';
    const sendBtn = document.getElementById('chat-send') as HTMLButtonElement;
    sendBtn.disabled = true;
    input.disabled = true;

    addMessage(text, 'user');
    addTyping();

    try {
      const res = await fetch(API_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: text }),
      });
      const data = await res.json();
      removeTyping();
      if (data.reply) {
        addBotResponse(data);
      } else {
        addMessage(data.error || '抱歉，暫時無法回答，請稍後再試。', 'error');
      }
    } catch {
      removeTyping();
      addMessage('網路錯誤，請稍後再試。', 'error');
    } finally {
      sendBtn.disabled = false;
      input.disabled = false;
      input.focus();
    }
  });
</script>

<style>
.chatbot-section {
  background: linear-gradient(135deg, #f5efe6 0%, #ede4d3 100%);
  border-top: 2px solid var(--gold);
  padding: 2em 1.5em;
}

.chatbot-inner {
  max-width: 760px;
  margin: 0 auto;
}

.chatbot-header {
  display: flex;
  align-items: center;
  gap: 0.8em;
  margin-bottom: 1.2em;
}

.chatbot-icon {
  font-size: 2em;
  line-height: 1;
}

.chatbot-title {
  font-size: 1.1em;
  color: var(--ocean);
  margin: 0 0 0.2em;
  font-family: inherit;
}

.chatbot-subtitle {
  font-size: 0.82em;
  color: var(--text-light);
  margin: 0;
}

.chat-messages {
  background: rgba(255, 255, 255, 0.7);
  border: 1px solid rgba(197, 160, 89, 0.3);
  border-radius: 12px;
  padding: 1em;
  min-height: 120px;
  max-height: 420px;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 0.8em;
  scroll-behavior: smooth;
  margin-bottom: 0.8em;
}
.chat-messages::-webkit-scrollbar { width: 4px; }
.chat-messages::-webkit-scrollbar-thumb { background: rgba(197,160,89,0.3); border-radius: 2px; }

.msg {
  display: flex;
  align-items: flex-start;
  gap: 0.5em;
}
.msg.user { flex-direction: row-reverse; }
.msg-avatar { font-size: 1.1em; flex-shrink: 0; margin-top: 4px; }

.msg-content {
  display: flex;
  flex-direction: column;
  gap: 0.5em;
  max-width: 85%;
}

.msg-bubble {
  padding: 0.65em 1em;
  border-radius: 14px;
  font-size: 0.88em;
  line-height: 1.6;
}
.msg.bot .msg-bubble {
  background: #f0ece4;
  color: var(--text);
  border-top-left-radius: 4px;
}
.msg.user .msg-bubble {
  background: var(--gold);
  color: var(--ocean);
  font-weight: 600;
  border-top-right-radius: 4px;
  max-width: 80%;
}
.msg-bubble.error {
  background: rgba(229, 62, 62, 0.15);
  color: #c53030;
  border: 1px solid rgba(229, 62, 62, 0.3);
}

/* 回答內嵌連結 */
.chat-link {
  color: var(--ocean);
  text-decoration: underline;
  text-underline-offset: 2px;
  font-weight: 600;
}
.chat-link:hover { opacity: 0.75; }

/* 相關文章卡片 */
.related-articles {
  display: flex;
  flex-direction: column;
  gap: 0.4em;
}
.related-label {
  font-size: 0.78em;
  color: var(--text-light);
  font-weight: 600;
}
.related-card {
  display: block;
  background: white;
  border: 1px solid rgba(197, 160, 89, 0.4);
  border-radius: 8px;
  padding: 0.5em 0.8em;
  font-size: 0.82em;
  color: var(--ocean);
  text-decoration: none;
  line-height: 1.4;
  transition: background 0.15s, border-color 0.15s;
}
.related-card:hover {
  background: #fdf6ec;
  border-color: var(--gold);
}

/* 聯盟行銷按鈕 */
.affiliate-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.4em;
  padding: 0.55em 1em;
  border-radius: 8px;
  font-size: 0.82em;
  font-weight: 700;
  text-decoration: none;
  width: fit-content;
  transition: opacity 0.15s;
}
.affiliate-btn:hover { opacity: 0.85; }
.agoda-btn {
  background: #e74c3c;
  color: white;
}
.klook-btn {
  background: #ff6b35;
  color: white;
}

/* 打字動畫 */
.typing .msg-bubble {
  padding: 0.8em 1em;
  display: flex;
  gap: 5px;
  align-items: center;
}
.dot {
  width: 7px; height: 7px;
  background: var(--gold);
  border-radius: 50%;
  animation: bounce 1.2s infinite;
}
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes bounce {
  0%, 60%, 100% { transform: translateY(0); }
  30% { transform: translateY(-6px); }
}

.chat-input-area {
  display: flex;
  gap: 0.6em;
}

#chat-input {
  flex: 1;
  background: white;
  border: 1px solid rgba(197, 160, 89, 0.5);
  border-radius: 10px;
  padding: 0.65em 1em;
  font-size: 0.9em;
  font-family: inherit;
  color: var(--text);
  outline: none;
  min-width: 0;
}
#chat-input::placeholder { color: #aaa; }
#chat-input:focus { border-color: var(--gold); }

#chat-send {
  background: var(--gold);
  border: none;
  border-radius: 10px;
  padding: 0.65em 1.2em;
  color: var(--ocean);
  font-weight: 700;
  font-size: 0.88em;
  font-family: inherit;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 0.4em;
  white-space: nowrap;
  transition: background 0.15s;
  flex-shrink: 0;
}
#chat-send:hover { background: var(--gold-light); }
#chat-send:disabled { opacity: 0.5; cursor: not-allowed; }
#chat-send svg { width: 15px; height: 15px; }

@media (max-width: 600px) {
  .chatbot-section { padding: 1.5em 1em; }
  #chat-send span { display: none; }
  #chat-send { padding: 0.65em 0.9em; }
}
</style>
