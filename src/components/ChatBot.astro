---
// 峇里島旅遊 AI 問答機器人
interface Props {
  lang?: string;
}
const { lang } = Astro.props;

const i18n = {
  bubbleLabel:  lang === 'en'    ? 'Bali Travel AI'
              : lang === 'zh-cn' ? '峇里岛旅游AI'
              :                    '峇里島旅遊AI',
  title:        lang === 'en'    ? 'The Most Accurate Bali AI'
              : lang === 'zh-cn' ? '最精准的峇里岛知识库AI'
              :                    '最精準的峇里島知識庫AI',
  subtitle:     lang === 'en'    ? 'Ask me anything about Bali travel!'
              : lang === 'zh-cn' ? '有任何峇里岛旅游问题都可以问我！'
              :                    '有任何峇里島旅遊問題都可以問我！',
  closeLabel:   lang === 'en'    ? 'Close' : '關閉',
  greeting:     lang === 'en'    ? 'Hi! I\'m the Bali Travel AI 👋<br>Visas, transport, hotels, itineraries… ask me anything!'
              : lang === 'zh-cn' ? '你好！我是峇里岛知识库AI 👋<br>签证、交通、住宿、行程⋯⋯随时为您解答！'
              :                    '你好！我是峇里島知識庫AI 👋<br>簽證、交通、住宿、行程⋯⋯隨時為您解答！',
  placeholder:  lang === 'en'    ? 'Ask a question, e.g. Best time to visit Bali?'
              : lang === 'zh-cn' ? '输入问题，例如：峇里岛最佳旅游季节？'
              :                    '輸入問題，例如：峇里島最佳旅遊季節？',
  send:         lang === 'en'    ? 'Send' : lang === 'zh-cn' ? '发送' : '送出',
  errNetwork:   lang === 'en'    ? 'Network error, please try again.'
              : lang === 'zh-cn' ? '网络错误，请稍后再试。'
              :                    '網路錯誤，請稍後再試。',
  errFallback:  lang === 'en'    ? 'Sorry, unable to answer right now. Please try again later.'
              : lang === 'zh-cn' ? '抱歉，暂时无法回答，请稍后再试。'
              :                    '抱歉，暫時無法回答，請稍後再試。',
};

const htmlLang = lang === 'en' ? 'en' : lang === 'zh-cn' ? 'zh-CN' : 'zh-TW';
---

<!-- 浮動 Bubble 按鈕（桌機 + 手機） -->
<button class="chat-bubble-btn" id="chat-bubble-btn" aria-label={i18n.bubbleLabel}>
  <span class="bubble-ping"></span>
  <img src="/favicon-32x32.png" alt="" class="bubble-icon" />
  <span class="bubble-label">{i18n.bubbleLabel}</span>
</button>

<!-- 聊天視窗 -->
<div class="chatbot-panel" id="chatbot-panel" aria-hidden="true">
  <div class="chatbot-inner">
    <div class="chatbot-header">
      <img src="/favicon-32x32.png" alt="" class="chatbot-icon" />
      <div>
        <h2 class="chatbot-title">{i18n.title}</h2>
        <p class="chatbot-subtitle">{i18n.subtitle}</p>
      </div>
      <button class="chatbot-close" id="chatbot-close" aria-label={i18n.closeLabel}>✕</button>
    </div>

    <div class="chat-messages" id="chat-messages">
      <div class="msg bot">
        <img src="/favicon-32x32.png" alt="" class="msg-avatar" />
        <div class="msg-bubble" set:html={i18n.greeting} />
      </div>
    </div>

    <form class="chat-input-area" id="chat-form">
      <input
        type="text"
        id="chat-input"
        placeholder={i18n.placeholder}
        maxlength="200"
        autocomplete="off"
      />
      <button type="submit" id="chat-send">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
        <span>{i18n.send}</span>
      </button>
    </form>
  </div>
</div>

<script define:vars={{ htmlLang, errNetwork: i18n.errNetwork, errFallback: i18n.errFallback }}>
  const API_URL = '/api/chat';
  const form = document.getElementById('chat-form');
  const input = document.getElementById('chat-input');
  const messages = document.getElementById('chat-messages');
  const panel = document.getElementById('chatbot-panel');
  const bubbleBtn = document.getElementById('chat-bubble-btn');
  const closeBtn = document.getElementById('chatbot-close');

  function openPanel() {
    bubbleBtn?.classList.add('exploding');
    setTimeout(() => {
      bubbleBtn?.classList.add('hidden');
      bubbleBtn?.classList.remove('exploding');
      panel?.classList.add('open');
      panel?.setAttribute('aria-hidden', 'false');
      adjustPanelHeight();
      setTimeout(() => input?.focus(), 300);
    }, 180);
  }

  function closePanel() {
    panel?.classList.remove('open');
    panel?.setAttribute('aria-hidden', 'true');
    bubbleBtn?.classList.remove('hidden');
  }

  function adjustPanelHeight() {
    if (window.innerWidth > 768) return;
    const vvh = window.visualViewport?.height ?? window.innerHeight;
    panel.style.maxHeight = vvh + 'px';
  }

  window.visualViewport?.addEventListener('resize', () => {
    if (panel?.classList.contains('open')) adjustPanelHeight();
  });

  bubbleBtn?.addEventListener('click', openPanel);
  closeBtn?.addEventListener('click', closePanel);

  function escapeHtml(str) {
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  function renderReply(text) {
    const parts = text.split(/(\[[^\]]+\]\([^)]+\))/g);
    return parts.map(part => {
      const match = part.match(/^\[([^\]]+)\]\(([^)]+)\)$/);
      if (match) {
        return `<a href="${escapeHtml(match[2])}" class="chat-link" target="_blank" rel="noopener">${escapeHtml(match[1])}</a>`;
      }
      return escapeHtml(part).replace(/\n/g, '<br>');
    }).join('');
  }

  function addMessage(text, role) {
    const div = document.createElement('div');
    div.className = `msg ${role}`;
    div.innerHTML = `<div class="msg-bubble${role === 'error' ? ' error' : ''}">${escapeHtml(text)}</div>`;
    messages.appendChild(div);
    messages.scrollTop = messages.scrollHeight;
  }

  function addBotMessage(reply) {
    const div = document.createElement('div');
    div.className = 'msg bot';
    div.innerHTML = `<img src="/favicon-32x32.png" alt="" class="msg-avatar" /><div class="msg-bubble">${renderReply(reply)}</div>`;
    messages.appendChild(div);
    messages.scrollTop = messages.scrollHeight;
  }

  function addTyping() {
    const div = document.createElement('div');
    div.className = 'msg bot typing';
    div.id = 'typing-indicator';
    div.innerHTML = '<img src="/favicon-32x32.png" alt="" class="msg-avatar" /><div class="msg-bubble"><span class="dot"></span><span class="dot"></span><span class="dot"></span></div>';
    messages.appendChild(div);
    messages.scrollTop = messages.scrollHeight;
  }

  function removeTyping() {
    document.getElementById('typing-indicator')?.remove();
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const text = input.value.trim();
    if (!text) return;

    input.value = '';
    const sendBtn = document.getElementById('chat-send');
    sendBtn.disabled = true;
    input.disabled = true;

    addMessage(text, 'user');

    // 建立 bot 訊息泡泡，逐字填入
    const botDiv = document.createElement('div');
    botDiv.className = 'msg bot';
    botDiv.innerHTML = '<img src="/favicon-32x32.png" alt="" class="msg-avatar spinning" /><div class="msg-bubble"><span class="dot"></span><span class="dot"></span><span class="dot"></span></div>';
    messages.appendChild(botDiv);
    messages.scrollTop = messages.scrollHeight;
    const bubble = botDiv.querySelector('.msg-bubble');
    const avatar = botDiv.querySelector('.msg-avatar');

    try {
      const res = await fetch(API_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: text, lang: htmlLang }),
      });

      if (!res.ok) {
        const data = await res.json().catch(() => ({}));
        bubble.innerHTML = `<span class="error">${data.error || errFallback}</span>`;
        return;
      }

      const ct = res.headers.get('content-type') || '';

      if (ct.includes('text/event-stream')) {
        // Streaming: 逐 token 顯示
        const reader = res.body.getReader();
        const dec = new TextDecoder();
        let fullText = '';
        let buf = '';
        let firstToken = true;
        bubble.innerHTML = '';

        while (true) {
          const { done, value } = await reader.read();
          if (done) break;
          buf += dec.decode(value, { stream: true });
          const lines = buf.split('\n');
          buf = lines.pop();
          for (const line of lines) {
            if (!line.startsWith('data: ') || line === 'data: [DONE]') continue;
            try {
              const token = JSON.parse(line.slice(6))?.choices?.[0]?.delta?.content || '';
              if (token) {
                if (firstToken) { avatar.classList.remove('spinning'); firstToken = false; }
                fullText += token;
                bubble.innerHTML = renderReply(fullText);
                messages.scrollTop = messages.scrollHeight;
              }
            } catch {}
          }
        }
        avatar.classList.remove('spinning');
        if (!fullText) bubble.innerHTML = `<span class="error">${errFallback}</span>`;
      } else {
        // Fallback: cached JSON response
        const data = await res.json();
        avatar.classList.remove('spinning');
        bubble.innerHTML = data.reply ? renderReply(data.reply) : `<span class="error">${data.error || errFallback}</span>`;
        messages.scrollTop = messages.scrollHeight;
      }
    } catch {
      avatar?.classList.remove('spinning');
      bubble.innerHTML = `<span class="error">${errNetwork}</span>`;
    } finally {
      sendBtn.disabled = false;
      input.disabled = false;
      input.focus();
    }
  });
</script>

<style>
/* ── Floating Bubble ─────────────────────────────────────────── */
.chat-bubble-btn {
  position: fixed;
  bottom: 1.8em;
  right: 1.5em;
  height: 52px;
  padding: 0 1.2em 0 0.9em;
  border-radius: 26px;
  background: var(--ocean, #1A365D);
  border: none;
  cursor: pointer;
  box-shadow: 0 4px 20px rgba(10,22,40,0.4);
  z-index: 9999;
  display: flex;
  align-items: center;
  gap: 0.5em;
  animation: bubble-float 3s ease-in-out infinite;
  transition: transform 0.15s, box-shadow 0.15s;
}
.chat-bubble-btn:hover {
  transform: scale(1.06) translateY(-2px);
  box-shadow: 0 8px 28px rgba(10,22,40,0.45);
  animation-play-state: paused;
}
.chat-bubble-btn.hidden { display: none !important; }

@keyframes bubble-float {
  0%, 100% { transform: translateY(0); }
  50%       { transform: translateY(-6px); }
}

/* 呼吸光暈 */
.bubble-ping {
  position: absolute;
  top: -4px;
  right: -4px;
  width: 14px;
  height: 14px;
  border-radius: 50%;
  background: #f97316;
  animation: ping 2s cubic-bezier(0, 0, 0.2, 1) infinite;
}
@keyframes ping {
  0%        { transform: scale(1); opacity: 1; }
  75%, 100% { transform: scale(2.2); opacity: 0; }
}

.bubble-icon  { width: 28px; height: 28px; border-radius: 5px; flex-shrink: 0; }
.bubble-label { color: #fff; font-size: 0.9em; font-weight: 700; white-space: nowrap; letter-spacing: 0.02em; }

/* ── Chat Panel ──────────────────────────────────────────────── */
.chatbot-panel {
  position: fixed;
  bottom: 5.5em;
  right: 1.5em;
  width: 380px;
  max-width: calc(100vw - 2em);
  background: linear-gradient(135deg, #f5efe6 0%, #ede4d3 100%);
  border: 1.5px solid rgba(197,160,89,0.4);
  border-radius: 18px;
  box-shadow: 0 8px 40px rgba(10,22,40,0.25);
  z-index: 9999;
  overflow: hidden;
  transform: scale(0.85) translateY(20px);
  transform-origin: bottom right;
  opacity: 0;
  pointer-events: none;
  transition: transform 0.22s cubic-bezier(0.34,1.56,0.64,1), opacity 0.18s ease;
}
.chatbot-panel.open {
  transform: scale(1) translateY(0);
  opacity: 1;
  pointer-events: auto;
}

.chatbot-inner { padding: 1.2em 1.2em 1em; }

.chatbot-header {
  display: flex;
  align-items: center;
  gap: 0.7em;
  margin-bottom: 1em;
}
.chatbot-icon { width: 34px; height: 34px; border-radius: 6px; flex-shrink: 0; }

.chatbot-title {
  font-size: 1em;
  color: var(--ocean, #1A365D);
  margin: 0 0 0.15em;
  font-family: inherit;
  font-weight: 700;
}
.chatbot-subtitle {
  font-size: 0.78em;
  color: #888;
  margin: 0;
}

.chatbot-close {
  margin-left: auto;
  background: none;
  border: none;
  font-size: 1em;
  color: #aaa;
  cursor: pointer;
  padding: 0.3em 0.4em;
  border-radius: 6px;
  flex-shrink: 0;
  transition: background 0.12s, color 0.12s;
}
.chatbot-close:hover { background: rgba(0,0,0,0.07); color: #555; }

.chat-messages {
  background: rgba(255,255,255,0.7);
  border: 1px solid rgba(197,160,89,0.3);
  border-radius: 12px;
  padding: 0.8em;
  min-height: 100px;
  max-height: 280px;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 0.75em;
  scroll-behavior: smooth;
  margin-bottom: 0.8em;
}
.chat-messages::-webkit-scrollbar { width: 4px; }
.chat-messages::-webkit-scrollbar-thumb { background: rgba(197,160,89,0.3); border-radius: 2px; }

.msg { display: flex; align-items: flex-start; gap: 0.5em; }
.msg.user { flex-direction: row-reverse; }
.msg-avatar { width: 22px; height: 22px; border-radius: 4px; flex-shrink: 0; margin-top: 4px; transition: transform 0.3s; }
@keyframes spin { to { transform: rotate(360deg); } }
.msg-avatar.spinning { animation: spin 1s linear infinite; }

.msg-bubble {
  max-width: 85%;
  padding: 0.6em 0.9em;
  border-radius: 14px;
  font-size: 0.86em;
  line-height: 1.6;
}
.msg.bot .msg-bubble  { background: #f0ece4; color: var(--text, #222); border-top-left-radius: 4px; }
.msg.user .msg-bubble { background: var(--gold, #C5A059); color: var(--ocean, #1A365D); font-weight: 600; border-top-right-radius: 4px; }
.msg-bubble.error     { background: rgba(229,62,62,0.12); color: #c53030; border: 1px solid rgba(229,62,62,0.3); }

.chat-link { color: var(--ocean, #1A365D); text-decoration: underline; text-underline-offset: 2px; font-weight: 600; }
.chat-link:hover { opacity: 0.75; }

/* 打字動畫 */
.typing .msg-bubble { padding: 0.7em 0.9em; display: flex; gap: 5px; align-items: center; }
.dot { width: 6px; height: 6px; background: var(--gold, #C5A059); border-radius: 50%; animation: bounce 1.2s infinite; }
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes bounce {
  0%, 60%, 100% { transform: translateY(0); }
  30%           { transform: translateY(-6px); }
}

.chat-input-area { display: flex; gap: 0.5em; }
#chat-input {
  flex: 1;
  background: white;
  border: 1px solid rgba(197,160,89,0.5);
  border-radius: 10px;
  padding: 0.6em 0.9em;
  font-size: 0.87em;
  font-family: inherit;
  color: var(--text, #222);
  outline: none;
  min-width: 0;
}
#chat-input::placeholder { color: #aaa; }
#chat-input:focus { border-color: var(--gold, #C5A059); }

#chat-send {
  background: var(--gold, #C5A059);
  border: none;
  border-radius: 10px;
  padding: 0.6em 1em;
  color: var(--ocean, #1A365D);
  font-weight: 700;
  font-size: 0.85em;
  font-family: inherit;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 0.35em;
  white-space: nowrap;
  flex-shrink: 0;
  transition: background 0.15s;
}
#chat-send:hover   { background: var(--gold-light, #d4b06a); }
#chat-send:disabled { opacity: 0.5; cursor: not-allowed; }
#chat-send svg { width: 14px; height: 14px; }

/* 手機：聊天視窗從頂部滑入（避免 Android 鍵盤遮擋） */
@media (max-width: 768px) {
  .chatbot-panel {
    top: 0;
    bottom: auto;
    right: 0;
    left: 0;
    width: 100%;
    max-width: 100%;
    max-height: 100dvh;
    border-radius: 0 0 18px 18px;
    transform: translateY(-100%);
    transform-origin: top center;
    overflow-y: auto;
    transition: transform 0.28s cubic-bezier(0.34,1.3,0.64,1), opacity 0.2s ease;
  }
  .chatbot-panel.open {
    transform: translateY(0);
    opacity: 1;
  }
  .chat-bubble-btn {
    bottom: 180px;
    right: 1em;
    transition: transform 0.18s ease, opacity 0.18s ease;
  }
  .chat-bubble-btn.exploding {
    transform: scale(1.25) translateY(-8px);
    opacity: 0;
  }
  #chat-send span { display: none; }
  #chat-send { padding: 0.6em 0.85em; }
  .chat-messages { max-height: 40vh; }
}
</style>
