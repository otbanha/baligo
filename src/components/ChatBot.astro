---
// 峇里島旅遊 AI 問答機器人
---

<!-- 桌機版：inline section -->
<section class="chatbot-section" id="chatbot-section">
  <button class="chatbot-close" id="chatbot-close" aria-label="關閉">✕</button>
  <div class="chatbot-inner">
    <div class="chatbot-header">
      <span class="chatbot-icon">🌴</span>
      <div>
        <h2 class="chatbot-title">最精準的峇里島知識庫AI</h2>
        <p class="chatbot-subtitle">有任何峇里島旅遊問題都可以問我！</p>
      </div>
    </div>

    <div class="chat-messages" id="chat-messages">
      <div class="msg bot">
        <span class="msg-avatar">🌴</span>
        <div class="msg-bubble">
          你好！我是峇里島知識庫AI 👋<br>
          簽證、交通、住宿、行程⋯⋯隨時為您解答！
        </div>
      </div>
    </div>

    <form class="chat-input-area" id="chat-form">
      <input
        type="text"
        id="chat-input"
        placeholder="輸入問題，例如：峇里島最佳旅遊季節？"
        maxlength="200"
        autocomplete="off"
      />
      <button type="submit" id="chat-send">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
        <span>送出</span>
      </button>
    </form>
  </div>
</section>

<!-- Mobile 浮動按鈕 -->
<button class="chat-bubble-btn" id="chat-bubble-btn" aria-label="開啟AI問答">
  <img src="/favicon-32x32.png" alt="" class="bubble-icon" />
  <span class="bubble-label">峇里島旅遊AI</span>
</button>

<script>
  const API_URL = '/api/chat';
  const form = document.getElementById('chat-form');
  const input = document.getElementById('chat-input') as HTMLInputElement;
  const messages = document.getElementById('chat-messages');
  const section = document.getElementById('chatbot-section');
  const bubbleBtn = document.getElementById('chat-bubble-btn');
  const closeBtn = document.getElementById('chatbot-close');

  // Mobile bubble toggle
  bubbleBtn?.addEventListener('click', () => {
    section?.classList.add('mobile-open');
    bubbleBtn?.classList.add('hidden');
    input?.focus();
  });
  closeBtn?.addEventListener('click', () => {
    section?.classList.remove('mobile-open');
    bubbleBtn?.classList.remove('hidden');
  });

  function escapeHtml(str: string) {
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  function renderReply(text: string) {
    const parts = text.split(/(\[[^\]]+\]\([^)]+\))/g);
    return parts.map(part => {
      const match = part.match(/^\[([^\]]+)\]\(([^)]+)\)$/);
      if (match) {
        return `<a href="${escapeHtml(match[2])}" class="chat-link" target="_blank" rel="noopener">${escapeHtml(match[1])}</a>`;
      }
      return escapeHtml(part).replace(/\n/g, '<br>');
    }).join('');
  }

  function addMessage(text: string, role: 'user' | 'error') {
    const div = document.createElement('div');
    div.className = `msg ${role}`;
    div.innerHTML = `<div class="msg-bubble${role === 'error' ? ' error' : ''}">${escapeHtml(text)}</div>`;
    messages!.appendChild(div);
    messages!.scrollTop = messages!.scrollHeight;
  }

  function addBotMessage(reply: string) {
    const div = document.createElement('div');
    div.className = 'msg bot';
    div.innerHTML = `<span class="msg-avatar">🌴</span><div class="msg-bubble">${renderReply(reply)}</div>`;
    messages!.appendChild(div);
    messages!.scrollTop = messages!.scrollHeight;
  }

  function addTyping() {
    const div = document.createElement('div');
    div.className = 'msg bot typing';
    div.id = 'typing-indicator';
    div.innerHTML = '<span class="msg-avatar">🌴</span><div class="msg-bubble"><span class="dot"></span><span class="dot"></span><span class="dot"></span></div>';
    messages!.appendChild(div);
    messages!.scrollTop = messages!.scrollHeight;
  }

  function removeTyping() {
    document.getElementById('typing-indicator')?.remove();
  }

  form!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const text = input.value.trim();
    if (!text) return;

    input.value = '';
    const sendBtn = document.getElementById('chat-send') as HTMLButtonElement;
    sendBtn.disabled = true;
    input.disabled = true;

    addMessage(text, 'user');
    addTyping();

    try {
      const res = await fetch(API_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: text }),
      });
      const data = await res.json();
      removeTyping();
      if (data.reply) {
        addBotMessage(data.reply);
      } else {
        addMessage(data.error || '抱歉，暫時無法回答，請稍後再試。', 'error');
      }
    } catch {
      removeTyping();
      addMessage('網路錯誤，請稍後再試。', 'error');
    } finally {
      sendBtn.disabled = false;
      input.disabled = false;
      input.focus();
    }
  });
</script>

<style>
.chatbot-section {
  background: linear-gradient(135deg, #f5efe6 0%, #ede4d3 100%);
  border-top: 2px solid var(--gold);
  padding: 2em 1.5em;
  position: relative;
}

.chatbot-close {
  display: none;
}

.chatbot-inner {
  max-width: 760px;
  margin: 0 auto;
}

.chatbot-header {
  display: flex;
  align-items: center;
  gap: 0.8em;
  margin-bottom: 1.2em;
}

.chatbot-icon { font-size: 2em; line-height: 1; }

.chatbot-title {
  font-size: 1.1em;
  color: var(--ocean);
  margin: 0 0 0.2em;
  font-family: inherit;
}

.chatbot-subtitle {
  font-size: 0.82em;
  color: var(--text-light);
  margin: 0;
}

.chat-messages {
  background: rgba(255, 255, 255, 0.7);
  border: 1px solid rgba(197, 160, 89, 0.3);
  border-radius: 12px;
  padding: 1em;
  min-height: 120px;
  max-height: 320px;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 0.8em;
  scroll-behavior: smooth;
  margin-bottom: 0.8em;
}
.chat-messages::-webkit-scrollbar { width: 4px; }
.chat-messages::-webkit-scrollbar-thumb { background: rgba(197,160,89,0.3); border-radius: 2px; }

.msg { display: flex; align-items: flex-start; gap: 0.5em; }
.msg.user { flex-direction: row-reverse; }
.msg-avatar { font-size: 1.1em; flex-shrink: 0; margin-top: 4px; }

.msg-bubble {
  max-width: 85%;
  padding: 0.65em 1em;
  border-radius: 14px;
  font-size: 0.88em;
  line-height: 1.6;
}
.msg.bot .msg-bubble { background: #f0ece4; color: var(--text); border-top-left-radius: 4px; }
.msg.user .msg-bubble { background: var(--gold); color: var(--ocean); font-weight: 600; border-top-right-radius: 4px; }
.msg-bubble.error { background: rgba(229,62,62,0.15); color: #c53030; border: 1px solid rgba(229,62,62,0.3); }

.chat-link { color: var(--ocean); text-decoration: underline; text-underline-offset: 2px; font-weight: 600; }
.chat-link:hover { opacity: 0.75; }

/* 打字動畫 */
.typing .msg-bubble { padding: 0.8em 1em; display: flex; gap: 5px; align-items: center; }
.dot { width: 7px; height: 7px; background: var(--gold); border-radius: 50%; animation: bounce 1.2s infinite; }
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes bounce {
  0%, 60%, 100% { transform: translateY(0); }
  30% { transform: translateY(-6px); }
}

.chat-input-area { display: flex; gap: 0.6em; }

#chat-input {
  flex: 1;
  background: white;
  border: 1px solid rgba(197, 160, 89, 0.5);
  border-radius: 10px;
  padding: 0.65em 1em;
  font-size: 0.9em;
  font-family: inherit;
  color: var(--text);
  outline: none;
  min-width: 0;
}
#chat-input::placeholder { color: #aaa; }
#chat-input:focus { border-color: var(--gold); }

#chat-send {
  background: var(--gold);
  border: none;
  border-radius: 10px;
  padding: 0.65em 1.2em;
  color: var(--ocean);
  font-weight: 700;
  font-size: 0.88em;
  font-family: inherit;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 0.4em;
  white-space: nowrap;
  transition: background 0.15s;
  flex-shrink: 0;
}
#chat-send:hover { background: var(--gold-light); }
#chat-send:disabled { opacity: 0.5; cursor: not-allowed; }
#chat-send svg { width: 15px; height: 15px; }

/* 浮動按鈕（手機專用） */
.chat-bubble-btn {
  display: none;
  position: fixed;
  bottom: 1.5em;
  right: 1em;
  height: 48px;
  padding: 0 1.1em 0 0.8em;
  border-radius: 24px;
  background: var(--ocean);
  border: none;
  cursor: pointer;
  box-shadow: 0 4px 16px rgba(10,22,40,0.35);
  z-index: 999;
  transition: transform 0.15s, box-shadow 0.15s;
  align-items: center;
  gap: 0.5em;
}
.chat-bubble-btn:hover { transform: scale(1.05); box-shadow: 0 6px 20px rgba(10,22,40,0.4); }
.chat-bubble-btn.hidden { display: none !important; }
.bubble-icon { width: 26px; height: 26px; border-radius: 4px; flex-shrink: 0; }
.bubble-label { color: #fff; font-size: 0.88em; font-weight: 700; white-space: nowrap; letter-spacing: 0.02em; }

@media (max-width: 768px) {
  /* 桌機版 inline section 隱藏 */
  .chatbot-section {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    border-radius: 16px 16px 0 0;
    padding: 1.2em 1em 1.5em;
    max-height: 85vh;
    overflow-y: auto;
    box-shadow: 0 -4px 24px rgba(10,22,40,0.2);
  }
  .chatbot-section.mobile-open {
    display: block;
  }
  .chatbot-close {
    display: block;
    position: absolute;
    top: 0.8em;
    right: 1em;
    background: none;
    border: none;
    font-size: 1.1em;
    color: var(--text-light);
    cursor: pointer;
    padding: 0.3em;
  }
  .chat-bubble-btn {
    display: flex !important;
    align-items: center;
    position: fixed !important;
    bottom: 1.2em !important;
    right: 1em !important;
    left: auto !important;
  }
  #chat-send span { display: none; }
  #chat-send { padding: 0.65em 0.9em; }
  .chat-messages { max-height: 45vh; }
}
</style>
