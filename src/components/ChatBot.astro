---
// 峇里島旅遊 AI 問答機器人（頁面內嵌版）
// 需要在 Cloudflare Pages 後台設定 Workers AI binding（名稱：AI）
---

<section class="chatbot-section">
  <div class="chatbot-inner">
    <div class="chatbot-header">
      <span class="chatbot-icon">🌴</span>
      <div>
        <h2 class="chatbot-title">峇里島旅遊小助手</h2>
        <p class="chatbot-subtitle">有任何峇里島旅遊問題都可以問我！</p>
      </div>
    </div>

    <div class="chat-messages" id="chat-messages">
      <div class="msg bot">
        <span class="msg-avatar">🌴</span>
        <div class="msg-bubble">
          你好！我是峇里島小助手 👋<br>
          簽證、交通、住宿、行程⋯⋯隨時為您解答！
        </div>
      </div>
    </div>

    <form class="chat-input-area" id="chat-form">
      <input
        type="text"
        id="chat-input"
        placeholder="輸入問題，例如：峇里島最佳旅遊季節？"
        maxlength="200"
        autocomplete="off"
      />
      <button type="submit" id="chat-send">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
        <span>送出</span>
      </button>
    </form>
  </div>
</section>

<script>
  const API_URL = '/api/chat';
  const form = document.getElementById('chat-form');
  const input = document.getElementById('chat-input') as HTMLInputElement;
  const messages = document.getElementById('chat-messages');

  function addMessage(text: string, role: 'user' | 'bot' | 'error') {
    const div = document.createElement('div');
    div.className = `msg ${role}`;
    if (role === 'bot') {
      div.innerHTML = `<span class="msg-avatar">🌴</span><div class="msg-bubble">${text.replace(/\n/g, '<br>')}</div>`;
    } else if (role === 'error') {
      div.innerHTML = `<div class="msg-bubble error">${text}</div>`;
    } else {
      div.innerHTML = `<div class="msg-bubble">${text}</div>`;
    }
    messages.appendChild(div);
    messages.scrollTop = messages.scrollHeight;
  }

  function addTyping() {
    const div = document.createElement('div');
    div.className = 'msg bot typing';
    div.id = 'typing-indicator';
    div.innerHTML = '<span class="msg-avatar">🌴</span><div class="msg-bubble"><span class="dot"></span><span class="dot"></span><span class="dot"></span></div>';
    messages.appendChild(div);
    messages.scrollTop = messages.scrollHeight;
  }

  function removeTyping() {
    document.getElementById('typing-indicator')?.remove();
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const text = input.value.trim();
    if (!text) return;

    input.value = '';
    const sendBtn = document.getElementById('chat-send') as HTMLButtonElement;
    sendBtn.disabled = true;
    input.disabled = true;

    addMessage(text, 'user');
    addTyping();

    try {
      const res = await fetch(API_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: text }),
      });
      const data = await res.json();
      removeTyping();
      addMessage(data.reply || data.error || '抱歉，暫時無法回答，請稍後再試。', data.reply ? 'bot' : 'error');
    } catch {
      removeTyping();
      addMessage('網路錯誤，請稍後再試。', 'error');
    } finally {
      sendBtn.disabled = false;
      input.disabled = false;
      input.focus();
    }
  });
</script>

<style>
.chatbot-section {
  background: linear-gradient(135deg, #f5efe6 0%, #ede4d3 100%);
  border-top: 2px solid var(--gold);
  padding: 2em 1.5em;
}

.chatbot-inner {
  max-width: 760px;
  margin: 0 auto;
}

.chatbot-header {
  display: flex;
  align-items: center;
  gap: 0.8em;
  margin-bottom: 1.2em;
}

.chatbot-icon {
  font-size: 2em;
  line-height: 1;
}

.chatbot-title {
  font-size: 1.1em;
  color: var(--ocean);
  margin: 0 0 0.2em;
  font-family: inherit;
}

.chatbot-subtitle {
  font-size: 0.82em;
  color: var(--text-light);
  margin: 0;
}

.chat-messages {
  background: rgba(255, 255, 255, 0.7);
  border: 1px solid rgba(197, 160, 89, 0.3);
  border-radius: 12px;
  padding: 1em;
  min-height: 120px;
  max-height: 320px;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 0.8em;
  scroll-behavior: smooth;
  margin-bottom: 0.8em;
}
.chat-messages::-webkit-scrollbar { width: 4px; }
.chat-messages::-webkit-scrollbar-thumb { background: rgba(197,160,89,0.3); border-radius: 2px; }

.msg {
  display: flex;
  align-items: flex-end;
  gap: 0.5em;
}
.msg.user { flex-direction: row-reverse; }
.msg-avatar { font-size: 1.1em; flex-shrink: 0; margin-bottom: 2px; }

.msg-bubble {
  max-width: 80%;
  padding: 0.65em 1em;
  border-radius: 14px;
  font-size: 0.88em;
  line-height: 1.6;
}
.msg.bot .msg-bubble {
  background: #f0ece4;
  color: var(--text);
  border-bottom-left-radius: 4px;
}
.msg.user .msg-bubble {
  background: var(--gold);
  color: var(--ocean);
  font-weight: 600;
  border-bottom-right-radius: 4px;
}
.msg-bubble.error {
  background: rgba(229, 62, 62, 0.15);
  color: #fc8181;
  border: 1px solid rgba(229, 62, 62, 0.3);
}

/* 打字動畫 */
.typing .msg-bubble {
  padding: 0.8em 1em;
  display: flex;
  gap: 5px;
  align-items: center;
}
.dot {
  width: 7px; height: 7px;
  background: var(--gold);
  border-radius: 50%;
  animation: bounce 1.2s infinite;
}
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes bounce {
  0%, 60%, 100% { transform: translateY(0); }
  30% { transform: translateY(-6px); }
}

.chat-input-area {
  display: flex;
  gap: 0.6em;
}

#chat-input {
  flex: 1;
  background: white;
  border: 1px solid rgba(197, 160, 89, 0.5);
  border-radius: 10px;
  padding: 0.65em 1em;
  font-size: 0.9em;
  font-family: inherit;
  color: var(--text);
  outline: none;
  min-width: 0;
}
#chat-input::placeholder { color: #aaa; }
#chat-input:focus { border-color: var(--gold); }

#chat-send {
  background: var(--gold);
  border: none;
  border-radius: 10px;
  padding: 0.65em 1.2em;
  color: var(--ocean);
  font-weight: 700;
  font-size: 0.88em;
  font-family: inherit;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 0.4em;
  white-space: nowrap;
  transition: background 0.15s;
  flex-shrink: 0;
}
#chat-send:hover { background: var(--gold-light); }
#chat-send:disabled { opacity: 0.5; cursor: not-allowed; }
#chat-send svg { width: 15px; height: 15px; }

@media (max-width: 600px) {
  .chatbot-section { padding: 1.5em 1em; }
  #chat-send span { display: none; }
  #chat-send { padding: 0.65em 0.9em; }
}
</style>
