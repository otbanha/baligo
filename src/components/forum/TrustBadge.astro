---
import type { TrustLevel } from '../../types/forum';
import { TRUST_LABELS } from '../../types/forum';
interface Props { level: TrustLevel; }
const { level } = Astro.props;
---
<span class={`trust-badge trust-badge--${level}`}>{TRUST_LABELS[level]}</span>

<style>
.trust-badge {
  display: inline-block;
  font-size: 0.68em;
  font-weight: 700;
  padding: 0.15em 0.6em;
  border-radius: 10px;
  vertical-align: middle;
}
.trust-badge--new     { background: #f1f5f9; color: #64748b; }
.trust-badge--trial   { background: #e0f2fe; color: #0369a1; }
.trust-badge--trusted { background: #dcfce7; color: #166534; }
.trust-badge--gold    { background: rgba(201,168,76,.2); color: var(--ocean); }
</style>
