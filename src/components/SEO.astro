---
/**
 * SEO.astro — Category-Aware SEO Engine
 *
 * Generates JSON-LD Schema.org markup based on article category:
 *   住宿推薦      → Article + ItemList[Hotel + AggregateRating]
 *   峇里島分區攻略 → Article + TouristDestination
 *   簽證通關      → Article + HowTo (steps from H2 headings)
 *   新手指南
 *   旅行技巧      → Article + FAQPage (Q from H2 headings)
 *   美食景點活動   → Article + LocalBusiness
 *   家庭親子 / 叫車包車 / 遊記分享 / 新聞存檔 → Article only
 *
 * Also generates BreadcrumbList for all articles.
 *
 * Hotel data is read from src/data/hotel-cache.json (generated by
 * scripts/fetch-hotel-data.mjs). Missing cache → hotel schema skipped.
 */

import { readFileSync, existsSync } from 'fs';
import { enhancedTitle, enhancedDescription, applyHkSubs } from '../utils/seo-keywords';
import { getMapSlugByBlogUrl } from '../data/mapBlogMapping';

interface Props {
  title: string;
  description?: string;
  category?: string | string[];
  body?: string;
  headings?: { depth: number; slug: string; text: string }[];
  lang?: string;
  slug?: string;
  pubDate?: Date | string;
  updatedDate?: Date | string;
  heroImage?: string;
}

const {
  title,
  description = '',
  category,
  body = '',
  headings = [],
  lang,
  slug,
  pubDate,
  updatedDate,
  heroImage,
} = Astro.props;

// ── Helpers ──────────────────────────────────────────────────────────────────

const cats = Array.isArray(category) ? category : (category ? [category] : []);

// Build URL prefix for this language
const langPath = (lang && lang !== 'zh-tw' && lang !== 'blog') ? `${lang}/` : '';
const articleUrl = `https://gobaligo.id/${langPath}blog/${slug}/`;
const blogUrl    = `https://gobaligo.id/${langPath}blog/`;

// Keyword-enhanced title & description for JSON-LD
const seoTitle = enhancedTitle(title, cats, lang ?? 'zh-tw');
const seoDesc  = enhancedDescription(description, cats, lang ?? 'zh-tw');

const ogImage = (typeof heroImage === 'string' && heroImage.startsWith('http'))
  ? heroImage
  : 'https://gobaligo.id/og-default.jpg';

const pubIso  = pubDate     ? new Date(pubDate).toISOString()     : undefined;
const modIso  = updatedDate ? new Date(updatedDate).toISOString() : pubIso;

// H2 headings for step-based schemas
const h2s = headings.filter(h => h.depth === 2);

// ── Markdown answer extraction (for FAQPage) ─────────────────────────────────
// 擷取每個 H2 底下的第一個內容區塊（段落或清單）作為 FAQ 的真實答案，
// 避免產生「詳見：URL」這種空答案佔位字（Google 會判定為無效 FAQ）。
const stripInline = (s: string): string =>
  s
    .replace(/!\[[^\]]*\]\([^)]*\)/g, '')       // 圖片
    .replace(/\[([^\]]+)\]\([^)]*\)/g, '$1')    // 連結 → 純文字
    .replace(/\{\{[^}]*\}\}/g, '')              // remark {{block}} 指令
    .replace(/[*_~`#>]+/g, '')                  // 強調/程式碼/標題/引用符號
    .replace(/<[^>]+>/g, '')                    // 內嵌 HTML
    .replace(/\s+/g, ' ')
    .trim();

const isHeading   = (l: string): boolean => /^#{1,6}\s/.test(l);
const isListItem  = (l: string): boolean => /^\s*([-*+]|\d+\.)\s+/.test(l);
const isBareUrl   = (l: string): boolean => /^https?:\/\/\S+$/.test(l.trim());
const isImageOnly = (l: string): boolean => /^!\[[^\]]*\]\([^)]*\)\s*$/.test(l.trim());

// 從 H2 之後、下一個標題之前的行中，取出第一個有意義的段落或清單
function firstAnswerBlock(lines: string[]): string {
  let i = 0;
  while (i < lines.length) {
    const t = lines[i].trim();
    if (!t || isImageOnly(t) || isBareUrl(t)) { i++; continue; }
    break;
  }
  if (i >= lines.length) return '';

  const parts: string[] = [];
  const startIsList = isListItem(lines[i]);
  for (; i < lines.length; i++) {
    const raw = lines[i];
    const t = raw.trim();
    if (!t) break;                              // 空行 → 區塊結束
    if (isHeading(t)) break;                     // 下個標題 → 結束
    if (startIsList && !isListItem(raw)) break;  // 清單結束
    const cleaned = stripInline(raw.replace(/^\s*([-*+]|\d+\.)\s+/, ''));
    if (cleaned) parts.push(cleaned);
  }
  let text = parts.join(startIsList ? '；' : ' ').replace(/\s+/g, ' ').trim();

  const LIMIT = 300;
  if (text.length > LIMIT) {
    const cut = text.slice(0, LIMIT);
    const stop = Math.max(
      cut.lastIndexOf('。'), cut.lastIndexOf('！'),
      cut.lastIndexOf('？'), cut.lastIndexOf('.'),
    );
    text = stop > 120 ? cut.slice(0, stop + 1) : cut.trim() + '…';
  }
  return text;
}

// 掃描原始 markdown，建立「H2 標題文字 → 首段答案」對照表
function buildAnswerMap(md: string): Map<string, string> {
  const map = new Map<string, string>();
  const lines = md.split(/\r?\n/);
  for (let i = 0; i < lines.length; i++) {
    const m = /^##\s+(.+?)\s*$/.exec(lines[i]);  // 只吃 H2（### 不符 ^##\s）
    if (!m) continue;
    const key = stripInline(m[1]);
    const buf: string[] = [];
    for (let j = i + 1; j < lines.length && !isHeading(lines[j]); j++) buf.push(lines[j]);
    const answer = firstAnswerBlock(buf);
    if (key && answer.length >= 12 && !map.has(key)) map.set(key, answer);
  }
  return map;
}

// ── Hotel cache (build-time file read) ───────────────────────────────────────
const CACHE_FILE = './src/data/hotel-cache.json';
type HotelEntry = {
  id: string; name: string; stars?: number | null;
  rating?: number | null; reviews?: number | null;
  city?: string; lowestRate?: number | null; currency?: string;
};
let hotelMap: Record<string, HotelEntry> = {};
if (existsSync(CACHE_FILE)) {
  try {
    const raw = JSON.parse(readFileSync(CACHE_FILE, 'utf-8'));
    hotelMap = raw.hotels ?? {};
  } catch { /* silently skip */ }
}

// Extract Agoda hotel IDs from article body (only for 住宿推薦)
const hotelIds: string[] = [];
if (cats.includes('住宿推薦')) {
  const re = /agoda\.com[^)'"\s]*[?&]hid=(\d+)/g;
  let m: RegExpExecArray | null;
  while ((m = re.exec(body)) !== null) {
    if (!hotelIds.includes(m[1])) hotelIds.push(m[1]);
  }
}

// ── Base schemas (every article) ─────────────────────────────────────────────

const schemaArticle = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": seoTitle,
  "description": seoDesc,
  "image": ogImage,
  "datePublished": pubIso,
  "dateModified": modIso,
  "inLanguage": lang === 'en' ? 'en' : lang === 'zh-cn' ? 'zh-CN' : lang === 'zh-hk' ? 'zh-HK' : 'zh-TW',
  "author": { "@type": "Organization", "name": "Go Bali Go", "url": "https://gobaligo.id" },
  "publisher": {
    "@type": "Organization",
    "name": "Go Bali Go 峇里島旅遊攻略",
    "url": "https://gobaligo.id",
    "logo": { "@type": "ImageObject", "url": "https://gobaligo.id/favicon-32x32.png" }
  },
  "mainEntityOfPage": { "@type": "WebPage", "@id": articleUrl },
  ...(cats.length > 0 ? { "articleSection": cats[0] } : {}),
  // E.2 relatedLink：blog 頁指向對應的互動地圖
  ...((() => {
    const canonicalZhTw = `https://gobaligo.id/blog/${slug}/`;
    const mapSlug = getMapSlugByBlogUrl(canonicalZhTw);
    return mapSlug ? { "relatedLink": `https://gobaligo.id/map/${mapSlug}/` } : {};
  })()),
};

const schemaBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Go Bali Go", "item": "https://gobaligo.id" },
    { "@type": "ListItem", "position": 2, "name": lang === 'en' ? "Bali Travel Blog" : "峇里島旅遊攻略", "item": blogUrl },
    { "@type": "ListItem", "position": 3, "name": title, "item": articleUrl },
  ],
};

// ── Category-specific schemas ─────────────────────────────────────────────────

const extraSchemas: object[] = [];

// ── [住宿推薦] Hotel + ItemList + AggregateRating ─────────────────────────────
if (cats.includes('住宿推薦')) {
  const hotels = hotelIds.map(hid => hotelMap[hid]).filter(Boolean) as HotelEntry[];

  if (hotels.length > 0) {
    extraSchemas.push({
      "@context": "https://schema.org",
      "@type": "ItemList",
      "name": title,
      "description": description,
      "url": articleUrl,
      "numberOfItems": hotels.length,
      "itemListElement": hotels.map((h, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "item": {
          "@type": "Hotel",
          "name": h.name,
          "url": `https://gobaligo.id/${langPath}blog/${slug}/#hotel-${h.id}`,
          "address": {
            "@type": "PostalAddress",
            "addressLocality": h.city ?? "Bali",
            "addressCountry": "ID",
          },
          ...(h.stars != null ? {
            "starRating": { "@type": "Rating", "ratingValue": h.stars },
          } : {}),
          ...(h.rating != null && h.reviews != null ? {
            "aggregateRating": {
              "@type": "AggregateRating",
              "ratingValue": h.rating,
              "reviewCount": h.reviews,
              "bestRating": 10,
              "worstRating": 1,
            },
          } : {}),
          ...(h.lowestRate != null ? {
            "offers": {
              "@type": "Offer",
              "price": h.lowestRate,
              "priceCurrency": h.currency ?? "USD",
              "availability": "https://schema.org/InStock",
            },
          } : {}),
        },
      })),
    });
  }
}

// ── [峇里島分區攻略] TouristDestination + Guide ───────────────────────────────
if (cats.includes('峇里島分區攻略') || cats.includes('峇里岛分区攻略')) {
  extraSchemas.push({
    "@context": "https://schema.org",
    "@type": "TouristDestination",
    "name": seoTitle,
    "description": seoDesc,
    "image": ogImage,
    "url": articleUrl,
    "touristType": {
      "@type": "Audience",
      "audienceType": lang === 'en' ? "Tourists" : "旅遊者",
    },
    "geo": {
      "@type": "GeoCoordinates",
      "addressCountry": "ID",
      "addressRegion": "Bali",
    },
    "includesAttraction": h2s.slice(0, 8).map(h => ({
      "@type": "TouristAttraction",
      "name": h.text,
      "url": `${articleUrl}#${h.slug}`,
    })),
  });
  // Guide schema signals topical authority for area guides
  if (h2s.length >= 2) {
    extraSchemas.push({
      "@context": "https://schema.org",
      "@type": "Article",
      "@id": `${articleUrl}#guide`,
      "additionalType": "https://schema.org/TravelAction",
      "name": seoTitle,
      "description": seoDesc,
      "about": {
        "@type": "Place",
        "name": "Bali",
        "address": { "@type": "PostalAddress", "addressCountry": "ID", "addressRegion": "Bali" },
      },
      "hasPart": h2s.slice(0, 6).map(h => ({
        "@type": "WebPageElement",
        "name": h.text,
        "url": `${articleUrl}#${h.slug}`,
      })),
    });
  }
}

// ── [簽證通關] HowTo ──────────────────────────────────────────────────────────
if ((cats.includes('簽證通關') || cats.includes('签证通关')) && h2s.length > 0) {
  extraSchemas.push({
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": seoTitle,
    "description": seoDesc,
    "image": ogImage,
    "totalTime": "PT30M",
    "estimatedCost": { "@type": "MonetaryAmount", "currency": "USD", "value": "0" },
    "supply": [
      { "@type": "HowToSupply", "name": lang === 'en' ? "Valid passport (≥6 months)" : "有效護照（剩餘效期≥6個月）" },
      { "@type": "HowToSupply", "name": lang === 'en' ? "Return flight ticket" : "來回機票" },
      { "@type": "HowToSupply", "name": lang === 'en' ? "Hotel reservation" : "住宿訂單" },
    ],
    "step": h2s.filter(h => h.text?.trim()).map((h, i) => ({
      "@type": "HowToStep",
      "position": i + 1,
      "name": h.text.trim(),
      "url": `${articleUrl}#${h.slug}`,
      "image": ogImage,
    })),
  });
}

// ── [新手指南] & [旅行技巧] FAQPage ──────────────────────────────────────────
// 只在 H2 底下能擷取到真實答案時才產出 FAQ，避免空答案佔位字。
if (cats.includes('新手指南') || cats.includes('旅行技巧')) {
  const answerMap = buildAnswerMap(body);
  const faqItems = h2s
    .filter(h => h.text?.trim())
    .slice(0, 10)
    .map(h => ({ h, answer: answerMap.get(stripInline(h.text)) }))
    .filter((x): x is { h: typeof h2s[number]; answer: string } => !!x.answer);

  if (faqItems.length > 0) {
    extraSchemas.push({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqItems.map(({ h, answer }) => ({
        "@type": "Question",
        "name": h.text.trim(),
        "acceptedAnswer": {
          "@type": "Answer",
          "text": answer,
          "url": `${articleUrl}#${h.slug}`,
        },
      })),
    });
  }
}

// ── [美食景點活動] LocalBusiness ─────────────────────────────────────────────
if (cats.includes('美食景點活動') || cats.includes('美食景点活动')) {
  extraSchemas.push({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": seoTitle,
    "description": seoDesc,
    "image": ogImage,
    "url": articleUrl,
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Bali",
      "addressCountry": "ID",
    },
    "areaServed": {
      "@type": "AdministrativeArea",
      "name": "Bali",
    },
    "sameAs": ["https://gobaligo.id"],
  });
}

const allSchemas = [schemaArticle, schemaBreadcrumb, ...extraSchemas];
---

{allSchemas.map(schema => (
  <script type="application/ld+json" set:html={JSON.stringify(schema).replace(/<\//g, '<\\/')} />
))}
