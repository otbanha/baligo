---
/**
 * SEO.astro — Category-Aware SEO Engine
 *
 * Generates JSON-LD Schema.org markup based on article category:
 *   住宿推薦      → Article + ItemList[Hotel + AggregateRating]
 *   峇里島分區攻略 → Article + TouristDestination
 *   簽證通關      → Article + HowTo (steps from H2 headings)
 *   新手指南
 *   旅行技巧      → Article + FAQPage (Q from H2 headings)
 *   美食景點活動   → Article + LocalBusiness
 *   家庭親子 / 叫車包車 / 遊記分享 / 新聞存檔 → Article only
 *
 * Also generates BreadcrumbList for all articles.
 *
 * Hotel data is read from src/data/hotel-cache.json (generated by
 * scripts/fetch-hotel-data.mjs). Missing cache → hotel schema skipped.
 */

import { readFileSync, existsSync } from 'fs';

interface Props {
  title: string;
  description?: string;
  category?: string | string[];
  body?: string;
  headings?: { depth: number; slug: string; text: string }[];
  lang?: string;
  slug?: string;
  pubDate?: Date | string;
  updatedDate?: Date | string;
  heroImage?: string;
}

const {
  title,
  description = '',
  category,
  body = '',
  headings = [],
  lang,
  slug,
  pubDate,
  updatedDate,
  heroImage,
} = Astro.props;

// ── Helpers ──────────────────────────────────────────────────────────────────

const cats = Array.isArray(category) ? category : (category ? [category] : []);

// Build URL prefix for this language
const langPath = (lang && lang !== 'zh-tw') ? `${lang}/` : '';
const articleUrl = `https://gobaligo.id/${langPath}blog/${slug}/`;
const blogUrl    = `https://gobaligo.id/${langPath}blog/`;

const ogImage = (typeof heroImage === 'string' && heroImage.startsWith('http'))
  ? heroImage
  : 'https://gobaligo.id/og-default.jpg';

const pubIso  = pubDate     ? new Date(pubDate).toISOString()     : undefined;
const modIso  = updatedDate ? new Date(updatedDate).toISOString() : pubIso;

// H2 headings for step-based schemas
const h2s = headings.filter(h => h.depth === 2);

// ── Hotel cache (build-time file read) ───────────────────────────────────────
const CACHE_FILE = './src/data/hotel-cache.json';
type HotelEntry = {
  id: string; name: string; stars?: number | null;
  rating?: number | null; reviews?: number | null;
  city?: string; lowestRate?: number | null; currency?: string;
};
let hotelMap: Record<string, HotelEntry> = {};
if (existsSync(CACHE_FILE)) {
  try {
    const raw = JSON.parse(readFileSync(CACHE_FILE, 'utf-8'));
    hotelMap = raw.hotels ?? {};
  } catch { /* silently skip */ }
}

// Extract Agoda hotel IDs from article body (only for 住宿推薦)
const hotelIds: string[] = [];
if (cats.includes('住宿推薦')) {
  const re = /agoda\.com[^)'"\\s]*[?&]hid=(\d+)/g;
  let m: RegExpExecArray | null;
  while ((m = re.exec(body)) !== null) {
    if (!hotelIds.includes(m[1])) hotelIds.push(m[1]);
  }
}

// ── Base schemas (every article) ─────────────────────────────────────────────

const schemaArticle = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "image": ogImage,
  "datePublished": pubIso,
  "dateModified": modIso,
  "inLanguage": lang === 'en' ? 'en' : lang === 'zh-cn' ? 'zh-CN' : lang === 'zh-hk' ? 'zh-HK' : 'zh-TW',
  "author": { "@type": "Organization", "name": "Go Bali Go", "url": "https://gobaligo.id" },
  "publisher": {
    "@type": "Organization",
    "name": "Go Bali Go 峇里島旅遊攻略",
    "url": "https://gobaligo.id",
    "logo": { "@type": "ImageObject", "url": "https://gobaligo.id/favicon-32x32.png" }
  },
  "mainEntityOfPage": { "@type": "WebPage", "@id": articleUrl },
  ...(cats.length > 0 ? { "articleSection": cats[0] } : {}),
};

const schemaBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Go Bali Go", "item": "https://gobaligo.id" },
    { "@type": "ListItem", "position": 2, "name": lang === 'en' ? "Bali Travel Blog" : "峇里島旅遊攻略", "item": blogUrl },
    { "@type": "ListItem", "position": 3, "name": title, "item": articleUrl },
  ],
};

// ── Category-specific schemas ─────────────────────────────────────────────────

const extraSchemas: object[] = [];

// ── [住宿推薦] Hotel + ItemList + AggregateRating ─────────────────────────────
if (cats.includes('住宿推薦')) {
  const hotels = hotelIds.map(hid => hotelMap[hid]).filter(Boolean) as HotelEntry[];

  if (hotels.length > 0) {
    extraSchemas.push({
      "@context": "https://schema.org",
      "@type": "ItemList",
      "name": title,
      "description": description,
      "url": articleUrl,
      "numberOfItems": hotels.length,
      "itemListElement": hotels.map((h, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "item": {
          "@type": "Hotel",
          "name": h.name,
          "url": `https://gobaligo.id/${langPath}blog/${slug}/#hotel-${h.id}`,
          "address": {
            "@type": "PostalAddress",
            "addressLocality": h.city ?? "Bali",
            "addressCountry": "ID",
          },
          ...(h.stars != null ? {
            "starRating": { "@type": "Rating", "ratingValue": h.stars },
          } : {}),
          ...(h.rating != null && h.reviews != null ? {
            "aggregateRating": {
              "@type": "AggregateRating",
              "ratingValue": h.rating,
              "reviewCount": h.reviews,
              "bestRating": 10,
              "worstRating": 1,
            },
          } : {}),
          ...(h.lowestRate != null ? {
            "offers": {
              "@type": "Offer",
              "price": h.lowestRate,
              "priceCurrency": h.currency ?? "USD",
              "availability": "https://schema.org/InStock",
            },
          } : {}),
        },
      })),
    });
  }
}

// ── [峇里島分區攻略] TouristDestination ──────────────────────────────────────
if (cats.includes('峇里島分區攻略') || cats.includes('峇里岛分区攻略')) {
  extraSchemas.push({
    "@context": "https://schema.org",
    "@type": "TouristDestination",
    "name": title,
    "description": description,
    "image": ogImage,
    "url": articleUrl,
    "touristType": {
      "@type": "Audience",
      "audienceType": lang === 'en' ? "Tourists" : "旅遊者",
    },
    "geo": {
      "@type": "GeoCoordinates",
      "addressCountry": "ID",
      "addressRegion": "Bali",
    },
    "includesAttraction": h2s.slice(0, 8).map(h => ({
      "@type": "TouristAttraction",
      "name": h.text,
      "url": `${articleUrl}#${h.slug}`,
    })),
  });
}

// ── [簽證通關] HowTo ──────────────────────────────────────────────────────────
if ((cats.includes('簽證通關') || cats.includes('签证通关')) && h2s.length > 0) {
  extraSchemas.push({
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": title,
    "description": description,
    "image": ogImage,
    "totalTime": "PT30M",
    "estimatedCost": { "@type": "MonetaryAmount", "currency": "USD", "value": "0" },
    "supply": [
      { "@type": "HowToSupply", "name": lang === 'en' ? "Valid passport (≥6 months)" : "有效護照（剩餘效期≥6個月）" },
      { "@type": "HowToSupply", "name": lang === 'en' ? "Return flight ticket" : "來回機票" },
      { "@type": "HowToSupply", "name": lang === 'en' ? "Hotel reservation" : "住宿訂單" },
    ],
    "step": h2s.map((h, i) => ({
      "@type": "HowToStep",
      "position": i + 1,
      "name": h.text,
      "url": `${articleUrl}#${h.slug}`,
      "image": ogImage,
    })),
  });
}

// ── [新手指南] & [旅行技巧] FAQPage ──────────────────────────────────────────
if (
  (cats.includes('新手指南') || cats.includes('旅行技巧')) &&
  h2s.length > 0
) {
  extraSchemas.push({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": h2s.slice(0, 10).map(h => ({
      "@type": "Question",
      "name": h.text,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": description || `詳見：${articleUrl}#${h.slug}`,
        "url": `${articleUrl}#${h.slug}`,
      },
    })),
  });
}

// ── [美食景點活動] LocalBusiness ─────────────────────────────────────────────
if (cats.includes('美食景點活動') || cats.includes('美食景点活动')) {
  extraSchemas.push({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": title,
    "description": description,
    "image": ogImage,
    "url": articleUrl,
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Bali",
      "addressCountry": "ID",
    },
    "areaServed": {
      "@type": "AdministrativeArea",
      "name": "Bali",
    },
    "sameAs": ["https://gobaligo.id"],
  });
}

const allSchemas = [schemaArticle, schemaBreadcrumb, ...extraSchemas];
---

{allSchemas.map(schema => (
  <script type="application/ld+json" set:text={JSON.stringify(schema)} />
))}
