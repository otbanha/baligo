---
export const prerender = true;
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import ChatBot from '../../../components/ChatBot.astro';

function extractFirstImage(body: string): string {
  const m = body?.match(/!\[.*?\]\((https?:\/\/[^)\s]+)\)/);
  return m ? m[1] : '';
}

const getCategories = (cat: any): string[] => {
  if (!cat) return [];
  if (Array.isArray(cat)) return cat;
  if (typeof cat === 'string') return [cat];
  return [];
};

const allPosts = (await getCollection('zh-cn'))
  .filter(p => p.data.pubDate)
  .map(p => ({
    ...p,
    heroImage: p.data.heroImage || extractFirstImage(p.body ?? ''),
  }))
  .sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf());

const categoryOrder = [
  '新手指南','住宿推荐','峇里岛分区攻略','签证通关',
  '叫车包车','家庭亲子','游记分享','美食景点活动','新闻存档',
  // fallback to zh-tw names if not translated
  '住宿推薦','峇里島分區攻略','簽證通關','叫車包車','家庭親子','遊記分享','美食景點活動','新聞存檔',
];

const allCategories = [...new Set(allPosts.flatMap(p => getCategories(p.data.category)).filter(Boolean))];
const categories = [
  ...categoryOrder.filter(c => allCategories.includes(c)),
  ...allCategories.filter(c => !categoryOrder.includes(c)),
];
const categoryCounts = categories.reduce((acc, cat) => {
  acc[cat] = allPosts.filter(p => getCategories(p.data.category).includes(cat)).length;
  return acc;
}, {} as Record<string, number>);

const allPostsData = allPosts.map(p => ({
  id: p.id,
  title: p.data.title,
  description: p.data.description || '',
  heroImage: p.heroImage,
  category: getCategories(p.data.category),
}));
---

<!doctype html>
<html lang="zh-CN">
<head>
  <BaseHead title="巴厘岛旅游攻略 | gobaligo" description="您的巴厘岛终极旅游指南：签证、交通、住宿、行程一网打尽。" />
</head>
<body>
  <Header lang="zh-cn" />

  <div class="layout">
    <aside class="sidebar" id="sidebar">
      <button class="sidebar-toggle" id="sidebar-toggle" aria-expanded="false">
        📂 文章分类 <span class="toggle-arrow">▼</span>
      </button>
      <div class="sidebar-inner" id="sidebar-inner">
        <div class="sidebar-section">
          <div class="listing-banner">
            🌐 目前为简体中文翻译版本。
            <a href="/blog/" onclick="document.cookie='gobaligo_lang=zh-tw; path=/; max-age=31536000; SameSite=Lax'">查看繁体中文版 →</a>
          </div>
        </div>
        <div class="sidebar-section">
          <h3 class="sidebar-title">📂 文章分类</h3>
          <ul class="category-list">
            <li>
              <button class="category-item active" data-category="all">
                <span class="cat-name">全部文章</span>
                <span class="cat-count">{allPosts.length}</span>
              </button>
            </li>
            {categories.map(cat => (
              <li>
                <button class="category-item" data-category={cat}>
                  <span class="cat-name">{cat}</span>
                  <span class="cat-count">{categoryCounts[cat]}</span>
                </button>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </aside>

    <main>
      <div class="grid" id="posts-grid">
        {allPosts.map(post => (
          <a href={`/zh-cn/blog/${post.id}/`} class="card" data-category={JSON.stringify(getCategories(post.data.category))}>
            <div class="card-image">
              {post.heroImage
                ? <img src={post.heroImage} alt={post.data.title} loading="lazy" />
                : <div class="card-image-placeholder">🌴</div>
              }
              {post.data.category && (
                <span class="category-badge">
                  {Array.isArray(post.data.category) ? post.data.category[0] : post.data.category}
                </span>
              )}
            </div>
            <div class="card-body">
              <h2 class="card-title">{post.data.title}</h2>
              <p class="card-desc">{post.data.description}</p>
            </div>
          </a>
        ))}
      </div>
      <div id="pagination" class="pagination"></div>
    </main>
  </div>

  <ChatBot />
  <Footer />
</body>

<script is:inline define:vars={{ allPostsData }}>
  window.addEventListener('DOMContentLoaded', () => {
    // Sidebar toggle (mobile)
    const sidebarToggle = document.getElementById('sidebar-toggle');
    const sidebarInner = document.getElementById('sidebar-inner');
    if (sidebarToggle && sidebarInner) {
      sidebarToggle.addEventListener('click', () => {
        const isOpen = sidebarInner.classList.toggle('open');
        sidebarToggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      });
    }

    const POSTS_PER_PAGE = 18;
    let currentPage = 1;
    let currentCat = 'all';
    let filteredCards = [];
    const buttons = document.querySelectorAll('.category-item');
    const cards = document.querySelectorAll('.card');

    function buildUrl(cat, page) {
      const params = new URLSearchParams();
      if (cat !== 'all') params.set('cat', cat);
      if (page > 1) params.set('page', String(page));
      return '/zh-cn/blog' + (params.toString() ? '?' + params.toString() : '');
    }

    function renderCards() {
      const start = (currentPage - 1) * POSTS_PER_PAGE;
      const end = start + POSTS_PER_PAGE;
      filteredCards.forEach((card, i) => {
        card.style.display = (i >= start && i < end) ? 'flex' : 'none';
      });
      updatePagination();
    }

    function updatePagination() {
      const totalPages = Math.ceil(filteredCards.length / POSTS_PER_PAGE);
      const pagination = document.getElementById('pagination');
      pagination.innerHTML = '';
      if (totalPages <= 1) return;

      const prev = document.createElement('button');
      prev.textContent = '← 上一页';
      prev.className = 'page-btn';
      prev.disabled = currentPage === 1;
      prev.onclick = () => { currentPage--; window.history.pushState({}, '', buildUrl(currentCat, currentPage)); renderCards(); window.scrollTo(0, 0); };
      pagination.appendChild(prev);

      const info = document.createElement('span');
      info.className = 'page-info';
      info.textContent = `第 ${currentPage} / ${totalPages} 页`;
      pagination.appendChild(info);

      const next = document.createElement('button');
      next.textContent = '下一页 →';
      next.className = 'page-btn';
      next.disabled = currentPage === totalPages;
      next.onclick = () => { currentPage++; window.history.pushState({}, '', buildUrl(currentCat, currentPage)); renderCards(); window.scrollTo(0, 0); };
      pagination.appendChild(next);
    }

    function applyState(cat, page) {
      currentCat = cat;
      currentPage = page;
      buttons.forEach(b => b.classList.remove('active'));
      const activeBtn = document.querySelector(`[data-category="${cat}"]`);
      if (activeBtn) activeBtn.classList.add('active');

      filteredCards = [...cards].filter(card => {
        try {
          const cats = JSON.parse(card.dataset.category || '[]');
          if (cat === 'all') return true;
          return cats.includes(cat);
        } catch {
          return cat === 'all' || card.dataset.category === cat;
        }
      });
      cards.forEach(card => card.style.display = 'none');
      renderCards();
    }

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const cat = btn.dataset.category;
        window.history.pushState({ cat, page: 1 }, '', buildUrl(cat, 1));
        applyState(cat, 1);
      });
    });

    window.addEventListener('popstate', (e) => {
      applyState(e.state?.cat || 'all', e.state?.page || 1);
    });

    const urlParams = new URLSearchParams(window.location.search);
    const catParam = urlParams.get('cat') || 'all';
    const pageParam = Math.max(1, parseInt(urlParams.get('page') || '1', 10));
    window.history.replaceState({ cat: catParam, page: pageParam }, '', window.location.href);
    applyState(catParam, pageParam);
  });
</script>

<style>
.layout {
  display: grid;
  grid-template-columns: 260px 1fr;
  max-width: 1400px;
  margin: 0 auto;
  min-height: calc(100vh - 64px);
  align-items: start;
}
.sidebar {
  position: sticky;
  top: 64px;
  height: calc(100vh - 64px);
  overflow-y: auto;
  background: var(--white);
  border-right: 1px solid rgba(197,160,89,0.2);
  padding: 1.5em 1em;
}
.sidebar::-webkit-scrollbar { width: 4px; }
.sidebar::-webkit-scrollbar-thumb { background: rgba(197,160,89,0.3); border-radius: 2px; }
.sidebar-section { margin-bottom: 1.8em; }
.sidebar-title {
  font-size: 0.85em; font-weight: 700; color: var(--ocean);
  letter-spacing: 0.05em; margin: 0 0 0.8em;
  padding-bottom: 0.5em; border-bottom: 1px solid rgba(197,160,89,0.2);
}
.listing-banner {
  background: rgba(197,160,89,0.1);
  border: 1px solid rgba(197,160,89,0.25);
  border-radius: 8px;
  padding: 0.6em 0.8em;
  font-size: 0.78em;
  color: var(--ocean);
  line-height: 1.5;
}
.listing-banner a { color: var(--gold); font-weight: 600; display: block; margin-top: 0.2em; }
.category-list { list-style: none; margin: 0; padding: 0; }
.category-item {
  display: flex; justify-content: space-between; align-items: center;
  width: 100%; min-height: 44px; padding: 0.45em 0.7em;
  border-radius: 8px; border: none; background: none; cursor: pointer;
  color: var(--text); font-size: 0.88em; font-family: inherit;
  text-align: left; transition: all 0.15s; margin-bottom: 0.2em;
}
.category-item:hover { background: rgba(197,160,89,0.1); color: var(--ocean); }
.category-item.active { background: var(--ocean); color: var(--gold-light); }
.cat-name { flex: 1; }
.cat-count {
  font-size: 0.78em; background: rgba(197,160,89,0.15);
  color: var(--gold); padding: 0.1em 0.5em; border-radius: 10px; font-weight: 600;
}
.category-item.active .cat-count { background: rgba(255,255,255,0.15); color: var(--gold-light); }
.sidebar-toggle { display: none; }
main { width: 100%; max-width: 100%; margin: 0; padding: 2em 2em 4em; }
.grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5em; }
.card {
  background: var(--white); border-radius: 16px; overflow: hidden;
  text-decoration: none; color: inherit;
  box-shadow: 0 2px 12px rgba(10,22,40,0.08);
  transition: transform 0.25s ease, box-shadow 0.25s ease;
  display: flex; flex-direction: column; min-width: 0;
}
.card:hover { transform: translateY(-5px); box-shadow: 0 8px 32px rgba(10,22,40,0.15); }
.card-image { position: relative; aspect-ratio: 16/10; overflow: hidden; background: var(--ocean-mid); }
.card-image img { width: 100%; height: 100%; object-fit: cover; border-radius: 0; transition: transform 0.4s ease; }
.card:hover .card-image img { transform: scale(1.05); }
.card-image-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 3em; background: linear-gradient(135deg, var(--ocean) 0%, var(--ocean-light) 100%); }
.category-badge { position: absolute; bottom: 0.7em; left: 0.7em; background: var(--gold); color: var(--ocean); font-size: 0.72em; font-weight: 700; padding: 0.2em 0.7em; border-radius: 20px; }
.card-body { padding: 1.2em 1.4em 1.4em; flex: 1; display: flex; flex-direction: column; }
.card-title { font-size: 1em; font-weight: 700; color: var(--ocean); margin: 0 0 0.5em; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.card-desc { font-size: 0.82em; color: var(--text-light); line-height: 1.5; margin: 0; flex: 1; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.pagination { display: flex; align-items: center; justify-content: center; gap: 1em; margin-top: 2.5em; padding-top: 1.5em; border-top: 1px solid rgba(197,160,89,0.2); }
.page-btn { background: var(--ocean); color: var(--white); border: none; padding: 0.5em 1.2em; border-radius: 8px; cursor: pointer; font-size: 0.9em; font-family: inherit; transition: background 0.2s; }
.page-btn:hover:not(:disabled) { background: var(--ocean-light); }
.page-btn:disabled { opacity: 0.4; cursor: not-allowed; }
.page-info { font-size: 0.88em; color: var(--text-light); }

@media (max-width: 1100px) { .grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 900px) {
  .layout { grid-template-columns: 1fr; }
  .sidebar { position: static; height: auto; border-right: none; border-bottom: 1px solid rgba(197,160,89,0.2); padding: 0; }
  .sidebar-toggle {
    display: flex; align-items: center; justify-content: space-between;
    width: 100%; padding: 0.9em 1.2em; border: none; background: var(--white);
    color: var(--ocean); font-size: 0.95em; font-weight: 700; font-family: inherit; cursor: pointer;
  }
  .sidebar-inner { display: none; padding: 1em 1.2em; }
  .sidebar-inner.open { display: block; }
  main { padding: 1.5em 1em 3em; }
}
@media (max-width: 600px) { .grid { grid-template-columns: 1fr; } }
</style>
</html>
