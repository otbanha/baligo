<script define:vars={{ promosJson }}>
window.addEventListener('load', () => {
  const promos = JSON.parse(promosJson);
  if (promos.length === 0) return;
  const promo = promos[Math.floor(Math.random() * promos.length)];
  const block = document.getElementById('promo-block-index');
  if (!block) return;
  block.innerHTML = `
    <a href="${promo.url}" target="_blank" rel="noopener" class="promo-card">
      <div class="promo-body">
        <p class="promo-title">${promo.title}</p>
        <span class="promo-cta">查看优惠 →</span>
      </div>
      ${promo.coverImage ? `<div class="promo-image"><img src="${promo.coverImage}" alt="${promo.title}" loading="lazy" /></div>` : ''}
    </a>
  `;
});
</script>
