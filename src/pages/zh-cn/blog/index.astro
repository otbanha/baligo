---
export const prerender = true;
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import ChatBot from '../../../components/ChatBot.astro';
import { getCollection, render } from 'astro:content';
import featuredData from '../../../featured.json';
import top5Data from '../../../top5.json';

const blogBase = '/zh-cn/blog';

const allPromos = await getCollection('promotions');
const now = new Date();
const activePromos = allPromos.filter(p => !p.data.expiresAt || p.data.expiresAt > now);
const promosJson = JSON.stringify(activePromos.map(p => ({
  title: p.data.title_zh_cn || p.data.title,
  url: p.data.url.startsWith('/blog/') ? `/zh-cn${p.data.url}` : p.data.url,
  coverImage: p.data.coverImage || null,
})));

function extractFirstImage(body: string): string {
  const m = body?.match(/!\[.*?\]\((https?:\/\/[^)\s]+)\)/);
  return m ? m[1] : '';
}

const langPosts = await getCollection('zh-cn');
const langMap = new Map(langPosts.map(p => [p.id, p]));

function getPublishTime(p: any): Date {
  const d = new Date(p.data.pubDate);
  if (p.data.pubHour != null) {
    d.setTime(d.getTime() + (p.data.pubHour - 8) * 3600 * 1000);
  }
  return d;
}
const isPublished = (p: any) => p.data.pubDate && !p.data.private && getPublishTime(p) <= now;

const allPosts = (await getCollection('blog'))
  .filter(isPublished)
  .map(p => {
    const t = langMap.get(p.id);
    return {
      ...p,
      data: {
        ...p.data,
        title: t?.data.title ?? p.data.title,
        description: t?.data.description ?? p.data.description,
        pubDate: new Date(p.data.pubDate),
        heroImage: p.data.heroImage || extractFirstImage(p.body),
      }
    };
  })
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const getCategories = (cat: any): string[] => {
  if (!cat) return [];
  if (Array.isArray(cat)) return cat;
  if (typeof cat === 'string') return [cat];
  return [];
};

const CAT_ZH_CN: Record<string, string> = {
  '新手指南': '新手指南',
  '住宿推薦': '住宿推荐', '住宿推荐': '住宿推荐',
  '峇里島分區攻略': '峇里岛分区攻略', '峇里岛分区攻略': '峇里岛分区攻略',
  '簽證通關': '签证通关', '签证通关': '签证通关',
  '叫車包車': '叫车包车', '叫车包车': '叫车包车',
  '家庭親子': '家庭亲子', '家庭亲子': '家庭亲子',
  '遊記分享': '游记分享', '游记分享': '游记分享',
  '美食景點活動': '美食景点活动', '美食景点活动': '美食景点活动',
  '新聞存檔': '新闻存档', '新闻存档': '新闻存档',
};

const categoryOrder = [
  '新手指南','住宿推薦','峇里島分區攻略','簽證通關',
  '叫車包車','家庭親子','遊記分享','美食景點活動','新聞存檔',
];

const allCategories = [...new Set(allPosts.flatMap(p => getCategories(p.data.category)).filter(Boolean))];
const categories = [
  ...categoryOrder.filter(c => allCategories.includes(c)),
  ...allCategories.filter(c => !categoryOrder.includes(c)),
];
const categoryCounts = categories.reduce((acc, cat) => {
  acc[cat] = allPosts.filter(p => getCategories(p.data.category).includes(cat)).length;
  return acc;
}, {} as Record<string, number>);

const allPostsData = allPosts
  .filter(p => true /* include 新聞存檔 */)
  .map(p => ({
    id: p.id,
    slug: p.data.slug || p.id,
    title: p.data.title,
    heroImage: p.data.heroImage || '',
    category: getCategories(p.data.category),
  }));

const accommodations = allPosts
  .filter(p => getCategories(p.data.category).includes('住宿推薦'))
  .slice(0, 5)
  .map(p => ({ id: p.id, title: p.data.title, heroImage: p.data.heroImage || '' }));

const allBlogRaw = await getCollection('blog');
const baliNewsRaw = allBlogRaw
  .filter(p => getCategories(p.data.category).includes('新聞存檔') && isPublished(p))
  .sort((a, b) => getPublishTime(b).valueOf() - getPublishTime(a).valueOf())
  .at(0);

const baliNewsToRender = (baliNewsRaw && langMap.get(baliNewsRaw.id)) ?? baliNewsRaw;
const { Content: BaliNewsContent } = baliNewsToRender
  ? await render(baliNewsToRender)
  : { Content: null };

const top5Posts = top5Data.articles
  .map(id => allPosts.find(p => p.id === id))
  .filter(Boolean)
  .map(p => ({ id: p!.id, title: p!.data.title }));

const qaCollection = await getCollection('qa');
const qaData = qaCollection.map(q => ({ title: (q.data as any).title_zh_cn ?? q.data.title }));

const youtubeVideos = [
  '0fqEvAzAy9A','GivvqCXp11A','H5N5_UuK7TI','EotdDxXHFwE','7JIqxDIyDF0','ePutHL_Ob1Q'
];

const socialLinks = [
  { label: 'FB 粉丝团', url: 'https://www.facebook.com/bali.guide.blog', type: 'facebook' },
  { label: '峇里岛/印尼旅游', url: 'https://www.facebook.com/groups/indonesia.travelguide', type: 'facebook' },
  { label: '峇里岛旅游', url: 'https://www.facebook.com/groups/baligo', type: 'facebook' },
  { label: 'Instagram', url: 'https://www.instagram.com/go.bali.go/', type: 'instagram' },
  { label: 'YouTube', url: 'https://www.youtube.com/@j_indonesia', type: 'youtube' },
  { label: 'Threads', url: 'https://www.threads.com/@go.bali.go', type: 'threads' },
];
---

<!doctype html>
<html lang="zh-CN">
<head>
  <BaseHead title="峇里岛旅游攻略 | Go Bali Go" description="峇里岛旅游最完整的中文攻略网站。签证、交通、住宿、美食、景点、行程规划，600+ 篇深度文章。" noSuffix={true} />
  <link rel="alternate" hreflang="x-default" href="https://gobaligo.id/blog/" />
  <link rel="alternate" hreflang="zh-TW"     href="https://gobaligo.id/blog/" />
  <link rel="alternate" hreflang="zh-HK"     href="https://gobaligo.id/zh-hk/blog/" />
  <link rel="alternate" hreflang="zh-CN"     href="https://gobaligo.id/zh-cn/blog/" />
  <link rel="alternate" hreflang="en"        href="https://gobaligo.id/en/blog/" />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Go Bali Go 峇里岛旅游攻略",
    "url": "https://gobaligo.id",
    "description": "峇里岛旅游最完整的中文攻略网站，600+ 篇深度文章。",
    "inLanguage": ["zh-TW", "zh-HK", "zh-CN", "en"],
    "potentialAction": {
      "@type": "SearchAction",
      "target": { "@type": "EntryPoint", "urlTemplate": "https://www.google.com/search?sitesearch=gobaligo.id/zh-cn/blog&q={search_term_string}" },
      "query-input": "required name=search_term_string"
    }
  })} />
</head>
<body>
  <Header lang="zh-cn" />

  <div class="layout">
    <aside class="sidebar" id="sidebar">
      <button class="sidebar-toggle" id="sidebar-toggle" aria-expanded="false">
        📂 文章分类 <span class="toggle-arrow">▼</span>
      </button>
      <div class="sidebar-inner" id="sidebar-inner">
        <div class="sidebar-section">
          <h3 class="sidebar-title">📂 文章分类</h3>
          <ul class="category-list">
            <li>
              <button class="category-item active" data-category="all">
                <span class="cat-name">首页</span>
                <span class="cat-count">{allPosts.length}</span>
              </button>
            </li>
            {categories.map(cat => (
              <li>
                <button class="category-item" data-category={cat}>
                  <span class="cat-name">{CAT_ZH_CN[cat] ?? cat}</span>
                  <span class="cat-count">{categoryCounts[cat]}</span>
                </button>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </aside>

    <main>
      <div id="homepage-blocks">

        <!-- 田字格 2×2 快速入口 -->
        <div class="quick-grid">
          <a href="/zh-cn/trip-planner/" class="qg-btn qg-blue">
            <span class="qg-icon">🗺️</span>
            <span class="qg-title">行程规划工具</span>
            <span class="qg-desc">个性化分区攻略与景点推荐</span>
          </a>
          <a href="/zh-cn/bali-budget-calculator/" class="qg-btn qg-green">
            <span class="qg-icon">💰</span>
            <span class="qg-title">预算计算器</span>
            <span class="qg-desc">立即估算每人巴厘岛旅费</span>
          </a>
          <a href="https://gobaligo.id/blog/bali-transport-quiz/" class="qg-btn qg-orange">
            <span class="qg-icon">🚗</span>
            <span class="qg-title">包车？叫车？</span>
            <span class="qg-desc">一分钟测验选出最省钱移动方式</span>
          </a>
          <a href="https://gobaligo.id/map/" class="qg-btn qg-teal">
            <span class="qg-icon">📍</span>
            <span class="qg-title">攻略地图</span>
            <span class="qg-desc">景点、住宿、餐厅互动地图</span>
          </a>
        </div>

        <div class="top-widgets" id="top-widgets">
          <div class="widget-box">
            <h2 class="widget-title fade-in">🏨 Accommodations</h2>
            {accommodations.length > 0 ? (
              <a href="#" id="accom-link" class="accom-card">
                <div class="accom-image">
                  <img id="accom-img" src={accommodations[0].heroImage} alt="" loading="lazy" />
                </div>
                <div class="accom-body">
                  <p id="accom-title">{accommodations[0].title}</p>
                </div>
              </a>
            ) : (
              <div class="widget-empty">即将推出</div>
            )}
          </div>

          <div class="widget-box">
            <h2 class="widget-title fade-in">📰 Bali News</h2>
            {baliNewsRaw ? (
              <div class="news-scroll">
                <a href={`${blogBase}/${baliNewsRaw.id}/`} class="news-post-date">
                  {new Date(baliNewsRaw.data.pubDate).toISOString().split('T')[0]}
                </a>
                <div class="news-body">
                  <BaliNewsContent />
                </div>
              </div>
            ) : (
              <div class="widget-empty">即将推出</div>
            )}
          </div>
        </div>

        {top5Posts.length > 0 && (
          <div class="top5-section" id="top5-section">
            <h2 class="section-title fade-in">🔥 本周热门文章</h2>
            <ul class="top5-list" id="top5-list">
              {top5Posts.map((post, i) => (
                <li class="top5-item" data-index={i}>
                  <a href={`${blogBase}/${post.id}/`}>
                    <span class="top5-num">{i + 1}</span>
                    <span class="top5-title">{post.title}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- YouTube + 求救箱 两栏 -->
        <div class="yt-qa-row">
          <div class="youtube-section">
            <div class="youtube-player">
              <iframe id="yt-iframe" width="100%" height="100%" src=""
                title="峇里岛旅游影片" frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen></iframe>
            </div>
          </div>
          <div class="qa-widget" id="qa-widget">
            <div class="qa-widget-header">
              <h2 class="qa-widget-title">🆘 峇里岛求救箱</h2>
              <a href="/ask/" class="qa-widget-more">查看全部 →</a>
            </div>
            <p class="qa-widget-desc">其他人也在问这些问题</p>
            <ul class="qa-widget-list" id="qa-widget-list"></ul>
            <a href="/ask/" class="qa-widget-cta">✉️ 我也有问题想问</a>
          </div>
        </div>

        <div class="social-section">
          {socialLinks.map(s => (
            <a href={s.url} target="_blank" rel="noopener" class={`social-btn ${s.type}`}>
              {s.type === 'facebook' && <svg viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>}
              {s.type === 'instagram' && <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>}
              {s.type === 'youtube' && <svg viewBox="0 0 24 24" fill="currentColor"><path d="M23.495 6.205a3.007 3.007 0 00-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 00.527 6.205a31.247 31.247 0 00-.522 5.805 31.247 31.247 0 00.522 5.783 3.007 3.007 0 002.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 002.088-2.088 31.247 31.247 0 00.5-5.783 31.247 31.247 0 00-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/></svg>}
              {s.type === 'threads' && <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.27 8.27 0 004.84 1.56V6.79a4.85 4.85 0 01-1.07-.1z"/></svg>}
              <span>{s.label}</span>
            </a>
          ))}
        </div>

      </div>

      <div id="cat-heading" style="display:none">
        <h1 id="cat-heading-text" class="cat-heading-title"></h1>
      </div>

      <div id="featured-section" style="display:none">
        <h2 class="section-title fade-in">⭐ 编辑精选</h2>
        <div class="featured-grid">
          {[0,1,2].map(i => (
            <a href="#" class="featured-card" data-index={i}>
              <div class="featured-image"><img src="" alt="" loading="lazy" /></div>
              <div class="featured-body">
                <span class="featured-badge">精选</span>
                <h3></h3>
              </div>
            </a>
          ))}
        </div>
      </div>

      <div class="grid" id="posts-grid">
        {allPosts.map(post => (
          <a href={`${blogBase}/${post.id}/`} class="card fade-in" data-category={JSON.stringify(getCategories(post.data.category))}>
            <div class="card-image">
              {post.data.heroImage
                ? <img src={post.data.heroImage} alt={post.data.title} loading="lazy" />
                : <div class="card-image-placeholder"><img src="/apple-touch-icon.png" alt="Go Bali Go" /></div>
              }
              {post.data.category && (
                <span class="category-badge">
                  {CAT_ZH_CN[Array.isArray(post.data.category) ? post.data.category[0] : post.data.category] ?? (Array.isArray(post.data.category) ? post.data.category[0] : post.data.category)}
                </span>
              )}
            </div>
            <div class="card-body">
              <h2 class="card-title">{post.data.title}</h2>
              <p class="card-desc">{post.data.description}</p>
            </div>
          </a>
        ))}
      </div>

      <div id="pagination" class="pagination"></div>

      {activePromos.length > 0 && (
        <div id="promo-block-main">
          <div id="promo-block-index"></div>
        </div>
      )}
    </main>
  </div>

  <ChatBot lang="zh-cn" />
  <Footer lang="zh-cn" />
</body>

<script is:inline define:vars={{ featuredData, allPostsData, youtubeVideos, accommodations, top5Posts, blogBase, qaData }}>
  window.addEventListener('DOMContentLoaded', () => {
    const sidebarToggle = document.getElementById('sidebar-toggle');
    const sidebarInner = document.getElementById('sidebar-inner');
    if (sidebarToggle && sidebarInner) {
      sidebarToggle.addEventListener('click', () => {
        const isOpen = sidebarInner.classList.toggle('open');
        sidebarToggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      });
    }

    let activeVideos = youtubeVideos;
    fetch('/api/videos').then(r => r.ok ? r.json() : null).then(data => {
      if (Array.isArray(data) && data.length > 0) activeVideos = data;
    }).catch(() => {}).finally(() => {
      const randomVideo = activeVideos[Math.floor(Math.random() * activeVideos.length)];
      document.getElementById('yt-iframe').src = `https://www.youtube.com/embed/${randomVideo}?rel=0`;
    });

    if (accommodations.length > 0) {
      const random = accommodations[Math.floor(Math.random() * accommodations.length)];
      const link = document.getElementById('accom-link');
      const img = document.getElementById('accom-img');
      const title = document.getElementById('accom-title');
      if (link) link.href = `${blogBase}/${random.id}/`;
      if (img) { img.src = random.heroImage; img.alt = random.title; }
      if (title) title.textContent = random.title;
    }

    fetch('/api/hot-articles').then(r => r.json()).then(data => {
      if (!Array.isArray(data) || data.length === 0) return;
      const section = document.getElementById('top5-section');
      const list = document.getElementById('top5-list');
      if (!section || !list) return;
      const shuffled = data.slice().sort(() => Math.random() - 0.5).slice(0, 6);
      list.innerHTML = shuffled.map((item) => {
        const postData = allPostsData.find(p => p.id === item.id);
        const localTitle = postData?.title || item.title;
        const slug = postData?.slug || item.id;
        return `<li class="top5-item"><a href="${blogBase}/${slug}/"><span style="display:inline-block;width:20px;height:20px;flex-shrink:0;background-image:url('/favicon-32x32.png');background-size:cover;background-repeat:no-repeat;border-radius:4px"></span><span class="top5-title">${localTitle}</span></a></li>`;
      }).join('');
      section.style.display = '';
    }).catch(() => {});

    let dynamicFeatured = null;
    fetch('/api/featured').then(r => r.json()).then(data => {
      if (data && typeof data === 'object' && Object.keys(data).length > 0) {
        dynamicFeatured = data;
        if (currentCat && currentCat !== 'all') updateFeatured(currentCat);
      }
    }).catch(() => {});

    const POSTS_PER_PAGE = 18;
    let currentPage = 1;
    let currentCat = 'all';
    let currentQ = '';
    let filteredCards = [];
    const buttons = document.querySelectorAll('.category-item');
    const cards = document.querySelectorAll('.card');

    function updateFeatured(cat) {
      const section = document.getElementById('featured-section');
      const catHeading = document.getElementById('cat-heading');
      const catHeadingText = document.getElementById('cat-heading-text');
      if (catHeading && catHeadingText) {
        if (cat === 'all') { catHeading.style.display = 'none'; }
        else { catHeadingText.textContent = cat; catHeading.style.display = 'block'; }
      }
      const source = dynamicFeatured || featuredData;
      const ids = source[cat] || [];
      if (cat === 'all' || ids.length === 0) { section.style.display = 'none'; return; }
      const matchedPosts = ids.map(id => allPostsData.find(p => p.id === id)).filter(Boolean);
      if (matchedPosts.length === 0) { section.style.display = 'none'; return; }
      const shuffled = matchedPosts.sort(() => Math.random() - 0.5).slice(0, 3);
      const featuredCardEls = document.querySelectorAll('.featured-card');
      featuredCardEls.forEach((card, i) => {
        if (shuffled[i]) {
          card.href = `${blogBase}/${shuffled[i].id}/`;
          card.querySelector('h3').textContent = shuffled[i].title;
          const img = card.querySelector('img');
          if (img) { img.src = shuffled[i].heroImage; img.alt = shuffled[i].title; }
          card.style.display = 'flex';
        } else { card.style.display = 'none'; }
      });
      section.style.display = 'block';
    }

    function buildUrl(cat, page, q = '') {
      const params = new URLSearchParams();
      if (cat !== 'all') params.set('cat', cat);
      if (q) params.set('q', q);
      if (page > 1) params.set('page', String(page));
      return blogBase + (params.toString() ? '?' + params.toString() : '');
    }

    function renderCards() {
      const start = (currentPage - 1) * POSTS_PER_PAGE;
      const end = start + POSTS_PER_PAGE;
      let si = 0;
      filteredCards.forEach((card, i) => {
        if (i >= start && i < end) {
          card.classList.remove('visible');
          card.style.transitionDelay = '';
          card.style.display = 'flex';
          const delay = si++ * 0.1;
          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              card.style.transitionDelay = `${delay}s`;
              card.classList.add('visible');
            });
          });
        } else {
          card.style.display = 'none';
          card.classList.remove('visible');
          card.style.transitionDelay = '';
        }
      });
      updatePagination();
    }

    function updatePagination() {
      const totalPages = Math.ceil(filteredCards.length / POSTS_PER_PAGE);
      const pagination = document.getElementById('pagination');
      pagination.innerHTML = '';
      if (totalPages <= 1) return;
      const prev = document.createElement('button');
      prev.textContent = '← 上一页';
      prev.className = 'page-btn';
      prev.disabled = currentPage === 1;
      prev.onclick = () => { currentPage--; window.history.pushState({ cat: currentCat, page: currentPage, q: currentQ }, '', buildUrl(currentCat, currentPage, currentQ)); renderCards(); window.scrollTo(0, 0); };
      pagination.appendChild(prev);
      const info = document.createElement('span');
      info.className = 'page-info';
      info.textContent = `第 ${currentPage} / ${totalPages} 页`;
      pagination.appendChild(info);
      const next = document.createElement('button');
      next.textContent = '下一页 →';
      next.className = 'page-btn';
      next.disabled = currentPage === totalPages;
      next.onclick = () => { currentPage++; window.history.pushState({ cat: currentCat, page: currentPage, q: currentQ }, '', buildUrl(currentCat, currentPage, currentQ)); renderCards(); window.scrollTo(0, 0); };
      pagination.appendChild(next);
    }

    function applyState(cat, page, q = '') {
      currentCat = cat;
      currentPage = page;
      currentQ = q;
      buttons.forEach(b => b.classList.remove('active'));
      const activeBtn = document.querySelector(`[data-category="${cat}"]`);
      if (activeBtn) activeBtn.classList.add('active');
      const homepageBlocks = document.getElementById('homepage-blocks');
      if (homepageBlocks) homepageBlocks.style.display = (cat === 'all' && !q) ? 'block' : 'none';
      const qLower = q ? q.toLowerCase() : '';
      filteredCards = [...cards].filter(card => {
        try {
          const cats = JSON.parse(card.dataset.category || '[]');
          const catList = Array.isArray(cats) ? cats : [cats];
          if (catList.includes('新聞存檔') && cat !== '新聞存檔') return false;
          if (cat !== 'all' && !catList.includes(cat)) return false;
        } catch {
          if (card.dataset.category === '新聞存檔' && cat !== '新聞存檔') return false;
          if (cat !== 'all' && card.dataset.category !== cat) return false;
        }
        if (qLower) {
          const title = (card.querySelector('.card-title')?.textContent || '').toLowerCase();
          return title.includes(qLower);
        }
        return true;
      });
      cards.forEach(card => card.style.display = 'none');
      updateFeatured(cat);
      renderCards();
    }

    function filterCategory(cat) {
      window.history.pushState({ cat, page: 1, q: '' }, '', buildUrl(cat, 1));
      applyState(cat, 1, '');
      const newVideo = activeVideos[Math.floor(Math.random() * activeVideos.length)];
      const iframe = document.getElementById('yt-iframe');
      if (iframe) iframe.src = `https://www.youtube.com/embed/${newVideo}?rel=0`;
    }

    buttons.forEach(btn => btn.addEventListener('click', () => filterCategory(btn.dataset.category)));
    window.addEventListener('popstate', (e) => { applyState(e.state?.cat || 'all', e.state?.page || 1, e.state?.q || ''); });

    const urlParams = new URLSearchParams(window.location.search);
    const catParam = urlParams.get('cat') || 'all';
    const qParam = urlParams.get('q') || '';
    const pageParam = Math.max(1, parseInt(urlParams.get('page') || '1', 10));
    window.history.replaceState({ cat: catParam, page: pageParam, q: qParam }, '', window.location.href);
    if (catParam !== 'all' || qParam) {
      setTimeout(() => applyState(catParam, pageParam, qParam), 100);
    } else {
      applyState('all', pageParam, '');
    }
  });

  // 求救箱随机问题
  (function() {
    const list = document.getElementById('qa-widget-list');
    if (!list || !qaData || !qaData.length) return;
    const shuffled = [...qaData].sort(() => Math.random() - 0.5).slice(0, 4);
    shuffled.forEach(q => {
      const li = document.createElement('li');
      const a = document.createElement('a');
      a.href = '/ask/';
      a.textContent = q.title;
      li.appendChild(a);
      list.appendChild(li);
    });
  })();
</script>

