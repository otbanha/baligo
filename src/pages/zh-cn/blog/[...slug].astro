---
import { getCollection, render } from 'astro:content';
import BlogPost from '../../../layouts/BlogPost.astro';
import { readFileSync, readdirSync } from 'fs';
import { join } from 'path';
import matter from 'gray-matter';

export async function getStaticPaths() {
  const blogPosts = await getCollection('blog');
  const langPosts = await getCollection('zh-cn');
  const langMap = new Map(langPosts.map(p => [p.id, p]));

  // 讀取實際檔案名，為舊檔案名生成路由
  const blogDir = join(process.cwd(), 'src/content/blog');
  const langDir = join(process.cwd(), 'src/content/zh-cn');
  const fileNameMap = new Map<string, string>(); // slug -> 檔案名（不含副檔名）

  for (const dir of [blogDir, langDir]) {
    const files = readdirSync(dir).filter(f => f.endsWith('.md') || f.endsWith('.mdx'));
    for (const file of files) {
      try {
        const content = readFileSync(join(dir, file), 'utf-8');
        const { data } = matter(content);
        const slug = data.slug || file.replace(/\.(md|mdx)$/, '');
        const fileId = file.replace(/\.(md|mdx)$/, '');
        fileNameMap.set(slug, fileId);
      } catch (e) {}
    }
  }

  // Create maps by slug for matching
  const langMapBySlug = new Map(langPosts.map(p => [(p.data.slug || p.id), p]));

  const usedSlugs = new Set<string>();
  const paths: any[] = [];

  // 只生成乾淨 slug 路由；舊日期碼網址交由 _redirects 的 301 處理，
  // 避免產生 self-canonical 的重複頁（SEO duplicate）。
  for (const blogPost of blogPosts) {
    const slug = blogPost.data.slug || blogPost.id;
    usedSlugs.add(slug);
    const post = langMapBySlug.get(slug) ?? blogPost;
    paths.push({ params: { slug }, props: { post } });
  }

  // Add entries from zh-cn collection that don't have a blog version (by slug)
  for (const langPost of langPosts) {
    const slug = langPost.data.slug || langPost.id;
    if (!usedSlugs.has(slug)) {
      paths.push({ params: { slug }, props: { post: langPost } });
    }
  }

  console.log(`✅ 簡體中文版本: ${paths.length} 路由`);

  return paths;
}

const { post } = Astro.props;
const { Content, headings } = await render(post as any);

const blogDir = join(process.cwd(), 'src/content/blog');
let rawEmbeds: any[] = [];
let firstImage: string = post.data.heroImage || '';
try {
  const files = readdirSync(blogDir);
  const matchFile = files.find(f => f.replace(/\.mdx?$/, '') === post.id);
  if (matchFile) {
    const raw = readFileSync(join(blogDir, matchFile), 'utf-8');
    const { data, content } = matter(raw);
    rawEmbeds = data.embeds || [];
    if (!firstImage) {
      const imgMatch = content.match(/!\[.*?\]\((https?:\/\/[^)]+)\)/);
      if (imgMatch) firstImage = imgMatch[1];
    }
  }
} catch (e) {}

const embedMap: Record<string, {platform: string, url: string}> = {};
rawEmbeds.forEach((e: any) => {
  embedMap[e.position] = { platform: e.platform, url: e.url };
});
---

<BlogPost {...post.data} heroImage={firstImage} embedMap={embedMap} body={post.body} headings={headings} lang="zh-cn" slug={post.id}>
  <Content />
</BlogPost>
