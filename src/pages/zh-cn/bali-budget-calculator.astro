const CS_OFF = 'padding:10px 12px;border-radius:8px;border:1px solid #e0ddd6;background:#fafaf8;cursor:pointer;box-sizing:border-box;';
const CS_ON  = 'padding:10px 12px;border-radius:8px;border:2px solid #1a6fa8;background:#eef5fb;cursor:pointer;box-sizing:border-box;';

function bbcSelT(el, val) {
  document.querySelectorAll('#bbc-t-opts > div').forEach(d => {
    d.style.cssText = CS_OFF;
    d.querySelectorAll('div')[1].style.color = '#999';
  });
  el.style.cssText = CS_ON;
  el.querySelectorAll('div')[1].style.color = '#1a6fa8';
  document.getElementById('bbc-vd-row').style.display = (val==='van5'||val==='van10'||val==='unsure') ? 'flex' : 'none';
  bbcCalc();
}

function bbcSelM(el, val) {
  document.querySelectorAll('#bbc-meal-opts > div').forEach(d => {
    d.style.cssText = CS_OFF;
    d.querySelectorAll('div')[1].style.color = '#999';
  });
  el.style.cssText = CS_ON;
  el.querySelectorAll('div')[1].style.color = '#1a6fa8';
  bbcCalc();
}

function bbcGetT() {
  const el = document.querySelector('#bbc-t-opts > div[style*="2px solid"]');
  return el ? el.dataset.v : 'van5';
}
function bbcGetM() {
  const el = document.querySelector('#bbc-meal-opts > div[style*="2px solid"]');
  return el ? el.dataset.v : 'balanced';
}

function bbcAttrPrice(item) {
  if (item.usdMin !== undefined) return item.usdMin===item.usdMax ? '$'+item.usdMin : '$'+item.usdMin+'～$'+item.usdMax;
  if (item.iMin === 0) return '免费';
  const a = +(item.iMin/BBC_IDR).toFixed(2), b = +(item.iMax/BBC_IDR).toFixed(2);
  return a===b ? '$'+a : '$'+a+'～$'+b;
}

function bbcActPrice(item) {
  if (item.type==='d150') return '$150 ÷ 人数';
  if (item.type==='d100') return '$100 ÷ 人数';
  if (item.type==='kintamani'||item.type==='tubing') return '按人数计算';
  return item.mn===item.mx ? '$'+item.mn : '$'+item.mn+'～$'+item.mx;
}

const CHIP_OFF = 'display:flex;align-items:flex-start;gap:8px;padding:10px 12px;border-radius:8px;border:1px solid #e0ddd6;background:#fafaf8;cursor:pointer;box-sizing:border-box;';
const CHIP_ON  = 'display:flex;align-items:flex-start;gap:8px;padding:10px 12px;border-radius:8px;border:2px solid #1a6fa8;background:#eef5fb;cursor:pointer;box-sizing:border-box;';

function bbcBuildList(items, cid, priceFn) {
  const c = document.getElementById(cid);
  c.innerHTML = '';
  items.forEach(item => {
    const noteStr = item.note ? item.note + '・' : '';
    const wrap = document.createElement('div');
    wrap.style.cssText = CHIP_OFF;
    wrap.innerHTML = `
      <input type="checkbox" id="${item.id}" style="width:15px;height:15px;flex-shrink:0;margin-top:2px;accent-color:#1a6fa8;cursor:pointer;" />
      <div style="flex:1;min-width:0;">
        <div style="font-size:13px;font-weight:500;color:#1a1a1a;line-height:1.4;">${item.name}</div>
        <div class="bbc-sub-price" style="font-size:11px;color:#999;margin-top:3px;">${noteStr}${priceFn(item)}</div>
      </div>`;
    wrap.onclick = function(e) {
      if (e.target.tagName !== 'INPUT') {
        const cb = wrap.querySelector('input'); cb.checked = !cb.checked;
      }
      const on = wrap.querySelector('input').checked;
      wrap.style.cssText = on ? CHIP_ON : CHIP_OFF;
      wrap.querySelector('.bbc-sub-price').style.color = on ? '#1a6fa8' : '#999';
      bbcCalc();
    };
    c.appendChild(wrap);
  });
}

function bbcFmt(mn, mx) { mn=Math.round(mn); mx=Math.round(mx); return mn===mx ? '$'+mn : '$'+mn+'～$'+mx; }

let bbcLastRecs = [];

function bbcCalc() {
  const days  = +document.getElementById('bbc-days').value;
  const ppl   = +document.getElementById('bbc-people').value;
  const vdays = +document.getElementById('bbc-van-days').value;
  const transport = bbcGetT(), meal = bbcGetM();
  const spaN = +document.getElementById('bbc-spa-n').value || 0;
  const bcN  = +document.getElementById('bbc-bc-n').value  || 0;
  document.getElementById('bbc-tips-p').textContent = '$' + (20*days);

  let rows=[], totMin=0, totMax=0;
  function add(lbl,mn,mx,formula){rows.push({lbl,mn,mx,formula});totMin+=mn;totMax+=mx;}

  if(transport==='van5'||transport==='unsure'){const v=(40*vdays)/ppl;add('包车（5人座）',v,v,`$40 × ${vdays} 天 ÷ ${ppl} 人 = $${Math.round(v)}`);}
  else if(transport==='van10'){const v=(90*vdays)/ppl;add('包车（10人座）',v,v,`$90 × ${vdays} 天 ÷ ${ppl} 人 = $${Math.round(v)}`);}
  else if(transport==='scooter'){const v=ppl===1?6*days:(6*days)/2;add('租摩托车',v,v,ppl===1?`$6 × ${days} 天 = $${Math.round(v)}`:`$6 × ${days} 天 ÷ 2（合乘）= $${Math.round(v)}`);}
  else if(transport==='grab'){const v=(15*days)/ppl;add('网约车（Gojek/Grab）',v,v,`$15 × ${days} 天 ÷ ${ppl} 人 = $${Math.round(v)}`);}

  let aMin=0,aMax=0,aCnt=0,aParts=[];
  BBC_ATTRS.forEach(item=>{
    const cb=document.getElementById(item.id);if(!cb||!cb.checked)return;
    let mn,mx;
    if(item.usdMin!==undefined){mn=item.usdMin;mx=item.usdMax;}else{mn=item.iMin/BBC_IDR;mx=item.iMax/BBC_IDR;}
    aMin+=mn;aMax+=mx;aCnt++;
    const p=(item.iMin===0&&item.usdMin===undefined)?'免费':(mn===mx?`$${+(mn).toFixed(2)}`:`$${+(mn).toFixed(2)}～$${+(mx).toFixed(2)}`);
    aParts.push(`${item.name} ${p}`);
  });
  if(aCnt>0) add(`景点门票（${aCnt} 个）`,aMin,aMax,aParts.join('　'));

  let acMin=0,acMax=0,acCnt=0,acParts=[];
  BBC_ACTS.forEach(item=>{
    const cb=document.getElementById(item.id);if(!cb||!cb.checked)return;
    let mn=0,mx=0,f='';
    if(item.type==='d150'){mn=mx=150/ppl;f=`${item.name}：$150 ÷ ${ppl} 人 = $${Math.round(mn)}`;}
    else if(item.type==='d100'){mn=mx=100/ppl;f=`${item.name}：$100 ÷ ${ppl} 人 = $${Math.round(mn)}`;}
    else if(item.type==='kintamani'){mn=mx=ppl===1?100:50;f=`${item.name}：${ppl===1?'独游 $100':'2~4人每人 $50'}`;}
    else if(item.type==='tubing'){const v=ppl===1?50:ppl===2?32:ppl<=4?25:21;mn=mx=v;f=`${item.name}：${ppl} 人 → 每人 $${v}`;}
    else{mn=item.mn;mx=item.mx;f=mn===mx?`${item.name}：$${mn}`:`${item.name}：$${mn}～$${mx}`;}
    acMin+=mn;acMax+=mx;acCnt++;acParts.push(f);
  });
  if(spaN>0){acMin+=spaN*30;acMax+=spaN*100;acCnt++;acParts.push(`Spa ${spaN} 次：$${spaN*30}～$${spaN*100}`);}
  if(bcN>0){acMin+=bcN*20;acMax+=bcN*40;acCnt++;acParts.push(`俱乐部 ${bcN} 次：$${bcN*20}～$${bcN*40}`);}
  if(acCnt>0) add(`活动体验（${acCnt} 项）`,acMin,acMax,acParts.join('　'));

  const md=days-1;
  if(meal==='luxury') add('餐饮（享受型）',100*md,200*md,`$100～$200 × ${md} 天 = $${100*md}～$${200*md}`);
  else if(meal==='balanced') add('餐饮（均衡型）',30*md,60*md,`$30～$60 × ${md} 天 = $${30*md}～$${60*md}`);
  else add('餐饮（省钱型）',10*md,20*md,`$10～$20 × ${md} 天 = $${10*md}～$${20*md}`);
  add('小费 / 购物',20*days,20*days,`$20 × ${days} 天 = $${20*days}`);

  const ts=bbcFmt(totMin,totMax);
  document.getElementById('bbc-total-disp').textContent=ts;
  document.getElementById('bbc-total2').textContent=ts;
  document.getElementById('bbc-breakdown').innerHTML=rows.map(r=>
    `<div style="padding:8px 0;border-bottom:1px solid #f0ede6;">
      <div style="display:flex;justify-content:space-between;align-items:baseline;">
        <span style="font-size:14px;color:#555;">${r.lbl}</span>
        <span style="font-size:14px;font-weight:600;color:#1a1a1a;white-space:nowrap;margin-left:12px;">${bbcFmt(r.mn,r.mx)}</span>
      </div>
      ${r.formula?`<div style="font-size:11px;color:#bbb;margin-top:3px;line-height:1.5;">${r.formula}</div>`:''}
    </div>`
  ).join('');

  const seen=new Set(),dynItems=[];
  BBC_ATTRS.forEach(item=>{const cb=document.getElementById(item.id);
    if(cb&&cb.checked&&item.lk&&BBC_LINKS[item.lk]&&!seen.has(item.lk)){seen.add(item.lk);dynItems.push({name:item.name,url:BBC_LINKS[item.lk]});}
  });
  BBC_ACTS.forEach(item=>{const cb=document.getElementById(item.id);
    if(cb&&cb.checked&&item.lk&&BBC_LINKS[item.lk]&&!seen.has(item.lk)){seen.add(item.lk);dynItems.push({name:item.name,url:BBC_LINKS[item.lk]});}
  });
  if(spaN>0&&!seen.has('Spa')){seen.add('Spa');dynItems.push({name:'高档Spa / 按摩攻略',url:BBC_LINKS['Spa']});}
  bbcLastRecs=[BBC_FIXED_TOP,...dynItems,BBC_FIXED_BTM];
  document.getElementById('bbc-rec-links').innerHTML=bbcLastRecs.map(r=>
    `<a href="${r.url}" target="_blank" style="display:flex;align-items:center;justify-content:space-between;padding:9px 13px;border-radius:8px;border:1px solid #e0ddd6;text-decoration:none;background:#fafaf8;margin-bottom:0;">
      <span style="font-size:13px;color:#1a1a1a;">${r.name}</span>
      <span style="font-size:13px;color:#bbb;margin-left:8px;">→</span>
    </a>`
  ).join('');
}

