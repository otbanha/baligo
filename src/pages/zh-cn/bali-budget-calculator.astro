---
export const prerender = true;
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const title = '巴厘岛旅费预算计算器 2026';
const description = '免费巴厘岛旅费预算计算器，输入天数、人数、景点与活动，立即估算每人花费。';
const lang = 'zh-cn';
const basePath = 'bali-budget-calculator';
---

<html lang="zh-CN">
<head>
  <BaseHead title={title} description={description} />
</head>

<body>
  <Header lang={lang} basePath={basePath} />

  <!-- Mobile 导航 pills（只在 ≤900px 显示，桌机隐藏） -->
  <nav class="bbc-pills-nav" aria-label="导航">
    <ul class="bbc-pills-list">
      <li><a href="/zh-cn/blog/" class="bbc-pill">首页</a></li>
    </ul>
  </nav>

  <main style="max-width:780px;margin:0 auto;padding:32px 16px 80px;box-sizing:border-box;">

    <div style="text-align:center;margin-bottom:28px;">
      <h1 style="font-size:22px;font-weight:600;margin:0;padding:0;color:#1a1a1a;">巴厘岛旅费预算计算器</h1>
      <p style="font-size:14px;color:#888;margin:6px 0 0;">选择你的旅游方式，立即估算每人花费</p>
    </div>

    <div style="max-width:680px;margin:0 auto;" id="bbc-root">

      <!-- Step 1 -->
      <div style="background:#fff;border:1px solid #e0ddd6;border-radius:12px;padding:20px;margin-bottom:14px;box-sizing:border-box;">
        <h2 style="font-size:15px;font-weight:600;margin:0 0 16px;padding:0;display:flex;align-items:center;gap:8px;color:#1a1a1a;border:none;">
          <span style="display:inline-flex;align-items:center;justify-content:center;width:22px;height:22px;border-radius:50%;background:#f0ede6;border:1px solid #ddd;font-size:11px;font-weight:600;color:#666;flex-shrink:0;">1</span>
          基本设定
        </h2>
        <div style="display:flex;gap:12px;align-items:center;margin-bottom:10px;">
          <label style="font-size:14px;color:#666;min-width:80px;margin:0;">旅游天数</label>
          <select id="bbc-days" onchange="bbcCalc()" style="flex:1;height:38px;border-radius:8px;border:1px solid #ddd;background:#fafaf8;color:#1a1a1a;font-size:14px;padding:0 10px;">
            <option value="3">3 天</option><option value="4">4 天</option><option value="5" selected>5 天</option>
            <option value="6">6 天</option><option value="7">7 天</option><option value="8">8 天</option>
            <option value="10">10 天</option><option value="14">14 天</option>
          </select>
        </div>
        <div style="display:flex;gap:12px;align-items:center;">
          <label style="font-size:14px;color:#666;min-width:80px;margin:0;">旅游人数</label>
          <select id="bbc-people" onchange="bbcCalc()" style="flex:1;height:38px;border-radius:8px;border:1px solid #ddd;background:#fafaf8;color:#1a1a1a;font-size:14px;padding:0 10px;">
            <option value="1">1 人（独游）</option><option value="2" selected>2 人</option>
            <option value="3">3 人</option><option value="4">4 人</option><option value="5">5 人</option>
            <option value="6">6 人</option><option value="8">8 人</option><option value="10">10 人</option>
          </select>
        </div>
      </div>

      <!-- Step 2 -->
      <div style="background:#fff;border:1px solid #e0ddd6;border-radius:12px;padding:20px;margin-bottom:14px;box-sizing:border-box;">
        <h2 style="font-size:15px;font-weight:600;margin:0 0 16px;padding:0;display:flex;align-items:center;gap:8px;color:#1a1a1a;border:none;">
          <span style="display:inline-flex;align-items:center;justify-content:center;width:22px;height:22px;border-radius:50%;background:#f0ede6;border:1px solid #ddd;font-size:11px;font-weight:600;color:#666;flex-shrink:0;">2</span>
          交通方式
        </h2>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;" id="bbc-t-opts">
          <div onclick="bbcSelT(this,'van5')" data-v="van5" style="padding:10px 12px;border-radius:8px;border:2px solid #1a6fa8;background:#eef5fb;cursor:pointer;box-sizing:border-box;">
            <div style="font-size:13px;font-weight:500;color:#1a1a1a;">包车 5人座</div>
            <div style="font-size:11px;color:#1a6fa8;margin-top:3px;">$40 / 天</div>
          </div>
          <div onclick="bbcSelT(this,'van10')" data-v="van10" style="padding:10px 12px;border-radius:8px;border:1px solid #e0ddd6;background:#fafaf8;cursor:pointer;box-sizing:border-box;">
            <div style="font-size:13px;font-weight:500;color:#1a1a1a;">包车 10人座</div>
            <div style="font-size:11px;color:#999;margin-top:3px;">$90 / 天</div>
          </div>
          <div onclick="bbcSelT(this,'scooter')" data-v="scooter" style="padding:10px 12px;border-radius:8px;border:1px solid #e0ddd6;background:#fafaf8;cursor:pointer;box-sizing:border-box;">
            <div style="font-size:13px;font-weight:500;color:#1a1a1a;">租摩托车</div>
            <div style="font-size:11px;color:#999;margin-top:3px;">$6 / 天（2人共乘）</div>
          </div>
          <div onclick="bbcSelT(this,'grab')" data-v="grab" style="padding:10px 12px;border-radius:8px;border:1px solid #e0ddd6;background:#fafaf8;cursor:pointer;box-sizing:border-box;">
            <div style="font-size:13px;font-weight:500;color:#1a1a1a;">网约车（Gojek/Grab）</div>
            <div style="font-size:11px;color:#999;margin-top:3px;">$15 / 天</div>
          </div>
          <div onclick="bbcSelT(this,'unsure')" data-v="unsure" style="padding:10px 12px;border-radius:8px;border:1px solid #e0ddd6;background:#fafaf8;cursor:pointer;box-sizing:border-box;">
            <div style="font-size:13px;font-weight:500;color:#1a1a1a;">不确定</div>
            <div style="font-size:11px;color:#999;margin-top:3px;">以包车5人座估算</div>
          </div>
        </div>
        <div id="bbc-vd-row" style="display:flex;gap:12px;align-items:center;margin-top:12px;">
          <label style="font-size:14px;color:#666;min-width:80px;margin:0;">包车天数</label>
          <select id="bbc-van-days" onchange="bbcCalc()" style="flex:1;height:38px;border-radius:8px;border:1px solid #ddd;background:#fafaf8;color:#1a1a1a;font-size:14px;padding:0 10px;">
            <option value="1">1 天</option><option value="2">2 天</option><option value="3" selected>3 天</option>
            <option value="4">4 天</option><option value="5">5 天</option><option value="6">6 天</option><option value="7">7 天</option>
          </select>
        </div>
