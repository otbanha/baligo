          <div onclick="bbcSelM(this,'local')" data-v="local" style="padding:10px 12px;border-radius:8px;border:1px solid #e0ddd6;background:#fafaf8;cursor:pointer;box-sizing:border-box;">
            <div style="font-size:13px;font-weight:500;color:#1a1a1a;">省钱型</div>
            <div style="font-size:11px;color:#999;margin-top:3px;">$10～$20 / 天</div>
          </div>
        </div>
      </div>

      <!-- Step 6 -->
      <div style="background:#fff;border:1px solid #e0ddd6;border-radius:12px;padding:20px;margin-bottom:14px;box-sizing:border-box;">
        <h2 style="font-size:15px;font-weight:600;margin:0 0 12px;padding:0;display:flex;align-items:center;gap:8px;color:#1a1a1a;border:none;">
          <span style="display:inline-flex;align-items:center;justify-content:center;width:22px;height:22px;border-radius:50%;background:#f0ede6;border:1px solid #ddd;font-size:11px;font-weight:600;color:#666;flex-shrink:0;">6</span>
          小费 / 购物
