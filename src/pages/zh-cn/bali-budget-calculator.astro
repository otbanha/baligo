        <div id="bbc-breakdown" style="border-top:1px solid #eee;padding-top:12px;"></div>
        <div style="display:flex;justify-content:space-between;align-items:baseline;padding:12px 0 0;font-size:15px;font-weight:700;margin-top:4px;border-top:1px solid #ccc;">
          <span>合计</span><span id="bbc-total2">$0</span>
