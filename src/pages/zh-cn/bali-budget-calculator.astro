      <!-- Result -->
      <div style="background:#fff;border:1px solid #e0ddd6;border-radius:12px;padding:20px;margin-bottom:14px;box-sizing:border-box;">
        <div style="font-size:13px;color:#888;">以下为一个人预估的总旅费</div>
        <div id="bbc-total-disp" style="font-size:36px;font-weight:700;color:#1a1a1a;margin:6px 0 2px;line-height:1.2;">$0</div>
