        <div style="margin-top:18px;border-top:1px solid #eee;padding-top:14px;">
          <div style="font-size:12px;font-weight:600;color:#999;margin-bottom:10px;letter-spacing:0.04em;text-transform:uppercase;">推荐以下攻略文章</div>
          <div id="bbc-rec-links" style="display:flex;flex-direction:column;gap:6px;"></div>
        </div>
        <div style="display:flex;gap:8px;margin-top:16px;flex-wrap:wrap;">
          <button onclick="bbcReset()" style="display:inline-flex;align-items:center;gap:6px;padding:9px 18px;border-radius:8px;border:1px solid #ddd;font-size:13px;color:#1a1a1a;background:#fafaf8;cursor:pointer;font-family:inherit;">↺ 重新计算</button>
