</style>

<script is:inline>
let BBC_IDR = 17000; // 默认值，会被实时汇率覆盖

// GMT+8 当天日期字符串，用作 localStorage key
function bbcTodayKey() {
  const now = new Date(Date.now() + 8 * 60 * 60 * 1000);
  if (now.getUTCHours() < 16) now.setUTCDate(now.getUTCDate() - 1);
  return 'bbc_idr_' + now.toISOString().slice(0, 10);
}

// 更新页面上的汇率说明文字
function bbcUpdateRateHint(rate) {
  const el = document.getElementById('bbc-rate-hint');
  if (el) el.textContent = `IDR 费用以 1 USD = ${rate.toLocaleString()} 换算`;
}

// 抓取汇率：先查 localStorage，没有才调用 API
async function bbcFetchRate() {
  const key = bbcTodayKey();
  const cached = localStorage.getItem(key);
  if (cached) {
    BBC_IDR = parseInt(cached, 10);
    bbcUpdateRateHint(BBC_IDR);
    bbcBuildList(BBC_ATTRS, 'bbc-attr-list', bbcAttrPrice);
    bbcCalc();
    return;
  }
  try {
    const res = await fetch('https://api.frankfurter.app/latest?from=USD&to=IDR');
    const data = await res.json();
    const raw = Math.round(data.rates.IDR);
    BBC_IDR = raw - 400;
    localStorage.setItem(key, BBC_IDR);
    Object.keys(localStorage).forEach(k => { if (k.startsWith('bbc_idr_') && k !== key) localStorage.removeItem(k); });
    bbcUpdateRateHint(BBC_IDR);
    bbcBuildList(BBC_ATTRS, 'bbc-attr-list', bbcAttrPrice);
    bbcCalc();
  } catch(e) {
    console.warn('汇率获取失败，使用默认值', e);
  }
}

