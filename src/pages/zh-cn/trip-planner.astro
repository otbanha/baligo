---
export const prerender = true;
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import TopStrip from '../../components/TopStrip.astro';
import Footer from '../../components/Footer.astro';
import TripPlannerContent from '../../components/TripPlannerContent.astro';

const hreflangs = [
  { hreflang: 'zh-TW', href: 'https://gobaligo.id/trip-planner/' },
  { hreflang: 'zh-CN', href: 'https://gobaligo.id/zh-cn/trip-planner/' },
  { hreflang: 'zh-HK', href: 'https://gobaligo.id/zh-hk/trip-planner/' },
  { hreflang: 'en',    href: 'https://gobaligo.id/en/trip-planner/' },
  { hreflang: 'x-default', href: 'https://gobaligo.id/trip-planner/' },
];
---

<!doctype html>
<html lang="zh-CN">
<head>
  <BaseHead
    title="巴厘岛行程规划工具｜免费个性化攻略景点推荐 2026"
    description="免费巴厘岛行程规划工具，输入旅行风格立即获得个性化景点攻略。分区景点、美食、活动整理清楚，适合第一次去巴厘岛的旅行者。"
    hreflangs={hreflangs}
  />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "WebApplication",
        "name": "巴厘岛行程规划工具",
        "description": "免费在线巴厘岛行程规划工具。依照旅行风格、天数与偏好，即时产生个性化景点攻略、分区住宿建议与推荐文章。",
        "url": "https://gobaligo.id/zh-cn/trip-planner/",
        "applicationCategory": "TravelApplication",
        "operatingSystem": "Web",
        "inLanguage": "zh-CN",
        "offers": { "@type": "Offer", "price": "0", "priceCurrency": "CNY" },
        "featureList": [
          "旅行风格选择（亲子、蜜月、朋友、独旅、长辈）",
          "行程草稿分析与空缺补充",
          "分区景点攻略推荐",
          "个性化住宿区域建议",
          "存成PDF分享旅伴"
        ],
        "provider": {
          "@type": "Organization",
          "name": "Go Bali Go",
          "url": "https://gobaligo.id"
        }
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "首页", "item": "https://gobaligo.id/zh-cn/" },
          { "@type": "ListItem", "position": 2, "name": "巴厘岛行程规划工具", "item": "https://gobaligo.id/zh-cn/trip-planner/" }
        ]
      },
      {
        "@type": "HowTo",
        "name": "3步骤使用巴厘岛行程规划工具",
        "description": "使用免费巴厘岛行程规划工具，依照旅行风格获得个性化攻略推荐",
        "step": [
          { "@type": "HowToStep", "position": 1, "name": "选择旅行风格", "text": "选择同行对象、天数、想做的活动与预算范围，全程点击操作。" },
          { "@type": "HowToStep", "position": 2, "name": "粘贴行程草稿", "text": "选填：粘贴你已有的行程草稿，系统自动分析空缺并补充推荐。" },
          { "@type": "HowToStep", "position": 3, "name": "获取个性化推荐", "text": "获得专属的景点攻略、住宿区域推荐与必读文章，可存成PDF共享。" }
        ]
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "巴厘岛自由行要几天才够？",
            "acceptedAnswer": { "@type": "Answer", "text": "大多数旅客选择5天4晚到7天6晚。如果是第一次去，建议至少安排6天，才能同时涵盖南部海滩（库塔、水明漾、乌鲁瓦图）与中部文化区（乌布）两大核心。天数少于5天容易走马观花，超过8天则可以考虑加入努沙佩尼达、科莫多等离岛行程，丰富度倍增。" }
          },
          {
            "@type": "Question",
            "name": "第一次去巴厘岛应该安排哪些区域？",
            "acceptedAnswer": { "@type": "Answer", "text": "新手首推「乌布＋南部沿海」的组合。乌布是巴厘岛的文化中心，梯田、猴子森林、圣泉寺是必访；南部可依喜好选择：喜欢冲浪就住库塔，喜欢精品餐厅就选水明漾，喜欢安静就去乌鲁瓦图或沙努尔。建议同一地区至少住2晚，避免每天搬行李。" }
          },
          {
            "@type": "Question",
            "name": "巴厘岛亲子家庭适合住哪一区？",
            "acceptedAnswer": { "@type": "Answer", "text": "带孩子旅游首选沙努尔或努沙杜瓦。沙努尔有平静的海滩、海龟保育中心、AeroXSpace室内游乐场，很适合带幼儿；努沙杜瓦酒店集中、治安好、有Waterbom水上乐园，是最多亲子团的选择。乌布的野生动物园和泛舟也非常受孩子欢迎，适合安排1–2天游玩。" }
          },
          {
            "@type": "Question",
            "name": "巴厘岛蜜月情侣推荐怎么玩？",
            "acceptedAnswer": { "@type": "Answer", "text": "蜜月行程首选乌鲁瓦图的悬崖私人泳池别墅，搭配火舞表演和夕阳海鲜大餐；水明漾适合浪漫晚餐与精品SPA；乌布有丛林泳池与Kecak文化表演。建议避开库塔（较嘈杂），预算充足的话，可以在努沙佩尼达安排一日游，天使之眼蓝泻湖是极佳的蜜月打卡点。" }
          },
          {
            "@type": "Question",
            "name": "巴厘岛行程规划工具怎么使用？",
            "acceptedAnswer": { "@type": "Answer", "text": "整个流程只需1–2分钟。先在步骤一选择你的同行对象、天数、想做的活动，接着步骤二可选填你已有的行程草稿（直接粘贴文字即可），最后点「查看推荐攻略」，系统就会根据你的条件整理出个性化景点文章、住宿区域和注意事项清单。" }
          },
          {
            "@type": "Question",
            "name": "规划结果可以存档或分享给旅伴吗？",
            "acceptedAnswer": { "@type": "Answer", "text": "可以！推荐结果页面下方有「存成PDF」按钮，点击后会打开浏览器打印功能，选择「另存PDF」即可。PDF里包含你选择的景点、推荐文章链接和gobaligo.id的网址，方便旅伴一起参考。也可以直接把页面网址复制分享给朋友。" }
          },
          {
            "@type": "Question",
            "name": "巴厘岛淡旺季差别大吗？什么时候去最好？",
            "acceptedAnswer": { "@type": "Answer", "text": "巴厘岛全年温暖，主要分旱季（5–9月）和雨季（11–3月）。旱季是旺季，天气稳定、适合离岛、户外活动丰富，但机票和住宿较贵；雨季通常下午短暂阵雨，其余时间依旧晴朗，物价较低、游客较少，SPA和室内行程不受影响。建议第一次去选6–8月，有预算弹性的旅客可考虑4月或10月（性价比最高）。" }
          }
        ]
      }
    ]
  })} />
</head>
<body>
  <Header lang="zh-cn" basePath="trip-planner" />
  <TopStrip lang={'zh-cn'} />
  <TripPlannerContent lang="zh-cn" />
  <Footer lang="zh-cn" />
</body>
</html>
