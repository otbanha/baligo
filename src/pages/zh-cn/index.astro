---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import TopStrip from '../../components/TopStrip.astro';
import Footer from '../../components/Footer.astro';

const SITE_URL = 'https://gobaligo.id';

const hreflangs = [
  { hreflang: 'zh-TW',     href: `${SITE_URL}/` },
  { hreflang: 'zh-CN',     href: `${SITE_URL}/zh-cn/` },
  { hreflang: 'zh-HK',     href: `${SITE_URL}/zh-hk/` },
  { hreflang: 'en',        href: `${SITE_URL}/en/` },
  { hreflang: 'x-default', href: `${SITE_URL}/` },
];

const schemaWebsite = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Gobaligo 峇里島旅遊指南",
  "alternateName": "Go Bali Go",
  "url": `${SITE_URL}/`,
  "inLanguage": ["zh-TW", "zh-CN", "zh-HK", "en"],
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": `${SITE_URL}/?q={search_term_string}`
    },
    "query-input": "required name=search_term_string"
  }
};

const schemaOrganization = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Gobaligo",
  "url": `${SITE_URL}/`,
  "logo": `${SITE_URL}/images/logo.png`,
  "sameAs": [
    "https://www.youtube.com/@j_indonesia",
    "https://www.facebook.com/bali.guide.blog"
  ],
  "description": "巴厘岛旅游中文攻略网站，提供每日汇率、最新资讯、行程规划工具、住宿推荐"
};

const schemaItemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "巴厘岛旅游工具",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "行程规划工具", "url": `${SITE_URL}/zh-cn/trip-planner/` },
    { "@type": "ListItem", "position": 2, "name": "预算计算器",   "url": `${SITE_URL}/zh-cn/bali-budget-calculator/` },
    { "@type": "ListItem", "position": 3, "name": "景点门票费用", "url": `${SITE_URL}/zh-cn/tickets/` },
    { "@type": "ListItem", "position": 4, "name": "攻略地图",     "url": `${SITE_URL}/map/` },
  ]
};
---

<html lang="zh-Hans">
  <head>
    <BaseHead
      title="巴厘岛旅游攻略2026｜每日汇率・巴厘岛新闻・行程规划・住宿推荐 - Gobaligo"
      description="巴厘岛旅游最完整中文攻略。每日更新印尼盾汇率、巴厘岛最新旅游资讯，提供免费行程规划工具、预算计算器、景点门票查询、住宿推荐及包车攻略。"
      noSuffix={true}
      hreflangs={hreflangs}
      image="https://gobaligo.id/images/og-home.jpg"
    />
    <script type="application/ld+json" set:html={JSON.stringify(schemaWebsite)} />
    <script type="application/ld+json" set:html={JSON.stringify(schemaOrganization)} />
    <script type="application/ld+json" set:html={JSON.stringify(schemaItemList)} />
  </head>
  <body>
    <Header lang="zh-cn" />
  <TopStrip lang={'zh-cn'} />
    <main style="min-height:60vh;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:1rem;padding:2rem;text-align:center">
      <h1 style="font-size:1.5rem;margin:0">巴厘岛旅游攻略2026</h1>
      <p style="color:#666;margin:0">正在加载最新旅游资讯...</p>
    </main>
    <Footer lang="zh-cn" />
    <script>window.location.replace('/zh-cn/blog');</script>
  </body>
</html>
