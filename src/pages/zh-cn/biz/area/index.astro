---
import BizLayout from '../../../../layouts/BizLayout.astro';
import { getBizListings } from '../../../../lib/getBizListings';

const all = await getBizListings();
const areaCounts: Record<string, number> = {};
for (const b of all) {
  if (b.area) areaCounts[b.area] = (areaCounts[b.area] ?? 0) + 1;
}
const areas = Object.entries(areaCounts).sort((a, b) => b[1] - a[1]);
---

<BizLayout
  title="巴厘岛各分区中文商家 | Go Bali Go"
  description="按巴厘岛分区浏览中文商家，包含库塔、水明漾、乌布等热门区域。"
>
  <div class="biz-hero">
    <h1>按分区浏览</h1>
    <p>选择你所在或计划前往的巴厘岛分区，找到附近的中文商家</p>
  </div>

  {areas.length > 0 ? (
    <div class="cat-grid">
      {areas.map(([area, count]) => (
        <a href={`/zh-cn/biz/area/${encodeURIComponent(area)}/`} class="cat-card">
          <span class="cat-card__icon">📍</span>
          <span class="cat-card__label">{area}</span>
          <span class="area-count">{count} 家</span>
        </a>
      ))}
    </div>
  ) : (
    <p style="text-align:center;color:#8a9880;padding:3rem 0">目前此类别暂无商家资料，敬请期待。</p>
  )}

  <div class="biz-register-cta">
    <p>你的商家也想出现在这里吗？</p>
    <a href="/biz-register.html" class="btn btn--gold">免费登录你的商家</a>
  </div>
</BizLayout>

<style>
  .area-count {
    font-size: 0.75rem;
    color: #8a9880;
    margin-top: 2px;
  }
</style>
