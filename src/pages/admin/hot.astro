---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>本週熱門文章 — gobaligo 後台</title>
  <meta name="robots" content="noindex, nofollow" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
           background: #f5f5f5; color: #222; padding: 1.5rem 1rem; }
    .container { max-width: 780px; margin: 0 auto; }
    h1 { font-size: 1.25rem; font-weight: 700; margin-bottom: 1.5rem; }

    /* Auth */
    #auth-wall { background: #fff; border-radius: 10px; padding: 2rem;
                 box-shadow: 0 1px 6px rgba(0,0,0,.1); max-width: 360px; }
    #auth-wall h2 { font-size: 1rem; margin-bottom: 1rem; }
    .auth-row { display: flex; gap: .5rem; }
    .auth-row input { flex: 1; padding: .5rem .8rem; border: 1px solid #ccc;
                      border-radius: 6px; font-size: .95rem; }
    .auth-err { color: #c53030; font-size: .82rem; margin-top: .5rem; display: none; }

    #main-ui { display: none; }

    .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
    @media (max-width: 600px) { .two-col { grid-template-columns: 1fr; } }

    .panel { background: #fff; border-radius: 10px; padding: 1.2rem 1.4rem;
             box-shadow: 0 1px 6px rgba(0,0,0,.1); }
    .panel h2 { font-size: .95rem; font-weight: 700; color: #555; margin-bottom: 1rem; }

    /* Search */
    #search-input { width: 100%; padding: .5rem .75rem; border: 1px solid #ccc;
                    border-radius: 7px; font-size: .9rem; font-family: inherit;
                    margin-bottom: .7rem; outline: none; }
    #search-input:focus { border-color: #f97316; }
    #search-results { max-height: 400px; overflow-y: auto; display: flex;
                      flex-direction: column; gap: .3rem; }
    .search-item { padding: .5rem .7rem; border-radius: 6px; cursor: pointer;
                   font-size: .85rem; line-height: 1.4; transition: background .1s;
                   border: 1px solid #eee; }
    .search-item:hover { background: #fff8ee; border-color: #f97316; }
    .search-item.in-list { opacity: .4; cursor: not-allowed; }
    .search-item-cat { font-size: .72rem; color: #aaa; margin-top: .15rem; }

    /* Hot list */
    #hot-list { display: flex; flex-direction: column; gap: .4rem;
                min-height: 60px; margin-bottom: 1rem; }
    .hot-item { display: flex; align-items: center; gap: .5rem; padding: .55rem .7rem;
                background: #f9f6f0; border: 1px solid #e5d9c5; border-radius: 7px; }
    .hot-num { font-size: .85rem; font-weight: 700; color: #f97316; width: 20px;
               text-align: center; flex-shrink: 0; }
    .hot-title { flex: 1; font-size: .85rem; line-height: 1.4; }
    .hot-actions { display: flex; gap: .25rem; flex-shrink: 0; }
    .btn-icon { background: none; border: 1px solid #ddd; border-radius: 5px;
                padding: .2rem .45rem; font-size: .8rem; cursor: pointer;
                color: #666; transition: background .1s, border-color .1s; }
    .btn-icon:hover { background: #f0f0f0; border-color: #bbb; }
    .btn-icon.del:hover { background: #fff0f0; border-color: #fca5a5; color: #c53030; }
    .btn-icon:disabled { opacity: .3; cursor: not-allowed; }

    .empty-hint { font-size: .85rem; color: #aaa; padding: .8rem 0; }

    .save-row { display: flex; align-items: center; gap: .8rem; }
    #save-btn { padding: .55rem 1.5rem; background: #1A365D; color: #fff;
                border: none; border-radius: 8px; font-size: .95rem; font-weight: 700;
                cursor: pointer; font-family: inherit; transition: background .15s; }
    #save-btn:hover { background: #254d85; }
    #save-btn:disabled { opacity: .45; cursor: not-allowed; }
    #save-status { font-size: .85rem; }

    /* Buttons */
    .btn { padding: .4rem .9rem; border: none; border-radius: 6px; cursor: pointer;
           font-size: .85rem; font-weight: 600; font-family: inherit; }
    .btn-ocean { background: #1A365D; color: #fff; }
  </style>
</head>
<body>
<div class="container">
  <h1>🔥 本週熱門文章</h1>

  <div id="auth-wall">
    <h2>請輸入管理密碼</h2>
    <div class="auth-row">
      <input type="password" id="token-input" placeholder="Admin token" />
      <button class="btn btn-ocean" id="token-submit">進入</button>
    </div>
    <div class="auth-err" id="auth-err">密碼錯誤，請再試一次</div>
  </div>

  <div id="main-ui">
    <div class="two-col">

      <!-- Left: current list -->
      <div class="panel">
        <h2>📋 目前清單（最多 10 篇）</h2>
        <div id="hot-list"></div>
        <div class="save-row">
          <button id="save-btn">儲存</button>
          <span id="save-status"></span>
        </div>
      </div>

      <!-- Right: search & add -->
      <div class="panel">
        <h2>🔍 搜尋文章加入</h2>
        <input type="text" id="search-input" placeholder="輸入關鍵字搜尋…" autocomplete="off" />
        <div id="search-results"></div>
      </div>

    </div>
  </div>
</div>

<script is:inline>
  var token = '';
  var hotList = [];      // [{id, title}]
  var allArticles = [];  // from article-index.json

  // ── Auth ──────────────────────────────────────────────────────────────────
  var saved = sessionStorage.getItem('sl-token');
  if (saved) { token = saved; unlock(); }

  document.getElementById('token-input').addEventListener('keydown', function(e) {
    if (e.key === 'Enter') document.getElementById('token-submit').click();
  });
  document.getElementById('token-submit').addEventListener('click', async function() {
    var t = document.getElementById('token-input').value.trim();
    if (!t) return;
    var res = await fetch('/api/shortlinks?id=__verify__', {
      method: 'DELETE', headers: { 'X-Admin-Token': t }
    });
    if (res.status === 401) { document.getElementById('auth-err').style.display = 'block'; return; }
    token = t;
    sessionStorage.setItem('sl-token', t);
    document.getElementById('auth-err').style.display = 'none';
    unlock();
  });

  async function unlock() {
    document.getElementById('auth-wall').style.display = 'none';
    document.getElementById('main-ui').style.display = 'block';
    await Promise.all([loadHotList(), loadArticles()]);
    renderHotList();
    renderSearch('');
  }

  // ── Load hot list ─────────────────────────────────────────────────────────
  async function loadHotList() {
    try {
      var res = await fetch('/api/hot-articles');
      hotList = res.ok ? await res.json() : [];
    } catch (e) { hotList = []; }
  }

  // ── Load article index ────────────────────────────────────────────────────
  async function loadArticles() {
    try {
      var res = await fetch('/article-index.json');
      var data = res.ok ? await res.json() : [];
      // Filter out test/non-real articles
      allArticles = data.filter(function(a) {
        return a.id && a.id.match(/^\d{4}-\d{2}-\d{2}-/) && a.title;
      });
    } catch (e) { allArticles = []; }
  }

  // ── Render hot list ───────────────────────────────────────────────────────
  function renderHotList() {
    var el = document.getElementById('hot-list');
    if (hotList.length === 0) {
      el.innerHTML = '<div class="empty-hint">尚無文章，從右側搜尋加入</div>';
      return;
    }
    el.innerHTML = hotList.map(function(item, i) {
      return '<div class="hot-item" data-i="' + i + '">' +
        '<span class="hot-num">' + (i + 1) + '</span>' +
        '<span class="hot-title">' + esc(item.title) + '</span>' +
        '<div class="hot-actions">' +
          '<button class="btn-icon" onclick="moveUp(' + i + ')" ' + (i === 0 ? 'disabled' : '') + '>↑</button>' +
          '<button class="btn-icon" onclick="moveDown(' + i + ')" ' + (i === hotList.length - 1 ? 'disabled' : '') + '>↓</button>' +
          '<button class="btn-icon del" onclick="removeItem(' + i + ')">✕</button>' +
        '</div>' +
      '</div>';
    }).join('');
  }

  function moveUp(i) {
    if (i === 0) return;
    var tmp = hotList[i - 1]; hotList[i - 1] = hotList[i]; hotList[i] = tmp;
    renderHotList(); renderSearch(document.getElementById('search-input').value);
  }
  function moveDown(i) {
    if (i >= hotList.length - 1) return;
    var tmp = hotList[i + 1]; hotList[i + 1] = hotList[i]; hotList[i] = tmp;
    renderHotList(); renderSearch(document.getElementById('search-input').value);
  }
  function removeItem(i) {
    hotList.splice(i, 1);
    renderHotList(); renderSearch(document.getElementById('search-input').value);
  }

  // ── Search ────────────────────────────────────────────────────────────────
  document.getElementById('search-input').addEventListener('input', function() {
    renderSearch(this.value);
  });

  function renderSearch(q) {
    var container = document.getElementById('search-results');
    q = q.trim().toLowerCase();
    var inListIds = hotList.map(function(a) { return a.id; });

    var filtered = q
      ? allArticles.filter(function(a) {
          return a.title.toLowerCase().includes(q) ||
                 (a.description || '').toLowerCase().includes(q) ||
                 (Array.isArray(a.category) ? a.category.join(' ') : (a.category || '')).toLowerCase().includes(q);
        })
      : allArticles.slice(0, 30);

    if (filtered.length === 0) {
      container.innerHTML = '<div class="empty-hint">找不到文章</div>';
      return;
    }

    container.innerHTML = filtered.slice(0, 50).map(function(a) {
      var inList = inListIds.includes(a.id);
      var cats = Array.isArray(a.category) ? a.category.join(', ') : (a.category || '');
      return '<div class="search-item' + (inList ? ' in-list' : '') + '" ' +
        (inList ? '' : 'onclick="addItem(\'' + a.id.replace(/'/g, "\\'") + '\', \'' + a.title.replace(/'/g, "\\'") + '\')"') + '>' +
        '<div>' + esc(a.title) + (inList ? ' ✓' : '') + '</div>' +
        (cats ? '<div class="search-item-cat">' + esc(cats) + '</div>' : '') +
      '</div>';
    }).join('');
  }

  function addItem(id, title) {
    if (hotList.length >= 10) { alert('最多 10 篇'); return; }
    if (hotList.find(function(a) { return a.id === id; })) return;
    hotList.push({ id: id, title: title });
    renderHotList(); renderSearch(document.getElementById('search-input').value);
  }

  // ── Save ──────────────────────────────────────────────────────────────────
  document.getElementById('save-btn').addEventListener('click', async function() {
    var btn = document.getElementById('save-btn');
    var status = document.getElementById('save-status');
    btn.disabled = true;
    status.textContent = '儲存中…'; status.style.color = '#888';
    try {
      var res = await fetch('/api/hot-articles', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-Admin-Token': token },
        body: JSON.stringify(hotList),
      });
      var data = await res.json();
      if (data.ok) {
        status.textContent = '✓ 已儲存！首頁即時生效'; status.style.color = '#38a169';
      } else {
        status.textContent = '❌ ' + (data.error || '失敗'); status.style.color = '#c53030';
      }
    } catch (e) {
      status.textContent = '❌ 網路錯誤'; status.style.color = '#c53030';
    }
    btn.disabled = false;
    setTimeout(function() { status.textContent = ''; }, 4000);
  });

  function esc(s) {
    return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }
</script>
</body>
</html>
