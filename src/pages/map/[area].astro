---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import TopStrip from '../../components/TopStrip.astro';
import MapView from '../../components/MapView.astro';
import RecommendForm from '../../components/RecommendForm.astro';
import { maps, getMapBySlug } from '../../data/maps';

export function getStaticPaths() {
  return maps.map(area => ({
    params: { area: area.slug },
  }));
}

const { area: areaSlug } = Astro.params;
const area = getMapBySlug(areaSlug!);

if (!area) return Astro.redirect('/map/');

const title = `${area.name} 攻略地圖｜峇里島景點推薦`;
const description = area.description;
---

<html lang="zh-TW">
<head>
  <BaseHead title={title} description={description} />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Noto Sans TC', sans-serif;
      overflow: hidden;
      height: 100dvh;
    }

    .map-topbar {
      height: 52px;
      background: #fff;
      border-bottom: 1px solid #efefef;
      display: flex;
      align-items: center;
      padding: 0 16px;
      gap: 12px;
      position: relative;
      z-index: 10;
    }

    .back-btn {
      display: flex;
      align-items: center;
      gap: 4px;
      color: #2d8653;
      font-size: 15px;
      font-weight: 600;
      text-decoration: none;
      -webkit-tap-highlight-color: transparent;
      flex-shrink: 0;
    }

    .topbar-info {
      flex: 1;
      overflow: hidden;
    }

    .topbar-title {
      font-size: 16px;
      font-weight: 700;
      color: #1a1a1a;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .topbar-desc {
      font-size: 11px;
      color: #999;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .topbar-emoji {
      font-size: 22px;
      flex-shrink: 0;
    }

    #dark-btn {
      background: none;
      border: none;
      font-size: 20px;
      cursor: pointer;
      padding: 4px;
      flex-shrink: 0;
      -webkit-tap-highlight-color: transparent;
      line-height: 1;
    }

    #itin-topbar-btn {
      display: none;
      align-items: center;
      gap: 4px;
      background: #2d8653;
      color: #fff;
      border-radius: 20px;
      padding: 5px 10px;
      font-size: 12px;
      font-weight: 700;
      text-decoration: none;
      flex-shrink: 0;
      -webkit-tap-highlight-color: transparent;
    }
    [data-dark] #itin-topbar-btn { background: #1a5c3a; }

    /* Dark mode topbar */
    [data-dark] body {
      background: #121212;
    }

    [data-dark] .map-topbar {
      background: #1e1e1e;
      border-bottom-color: #2a2a2a;
    }

    [data-dark] .back-btn {
      color: #4caf8a;
    }

    [data-dark] .topbar-title {
      color: #f0f0f0;
    }

    [data-dark] .topbar-desc {
      color: #777;
    }

    @keyframes pulse-attention {
      0%, 100% { box-shadow: 0 2px 8px rgba(0,0,0,0.2), 0 0 0 0 rgba(45,134,83,0.45); }
      50%       { box-shadow: 0 2px 8px rgba(0,0,0,0.1), 0 0 0 14px rgba(45,134,83,0); }
    }
    @keyframes spin-gps {
      to { transform: rotate(360deg); }
    }

    #gps-btn {
      position: fixed;
      top: 166px; left: 16px;
      height: 44px;
      padding: 0 14px 0 10px;
      background: #fff;
      border: none;
      border-radius: 22px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.2);
      display: flex;
      align-items: center;
      gap: 8px;
      cursor: pointer;
      z-index: 900;
      -webkit-tap-highlight-color: transparent;
      transition: background 0.2s, color 0.2s;
      font-family: -apple-system, BlinkMacSystemFont, 'Noto Sans TC', sans-serif;
      font-size: 13px;
      font-weight: 600;
      color: #333;
      white-space: nowrap;
    }
    #gps-btn .gps-icon { display: block; flex-shrink: 0; }
    #gps-btn[data-state="loading"] .gps-icon { animation: spin-gps 1s linear infinite; }
    #gps-btn[data-state="success"] { background: #e8f5ee; color: #1a5c3a; }
    #gps-btn[data-state="error"]   { background: #fff0f0; color: #c33; }
    #gps-btn.first-visit { animation: pulse-attention 1.5s ease-in-out 4; }

    [data-dark] #gps-btn { background: #1e1e1e; color: #ccc; box-shadow: 0 2px 8px rgba(0,0,0,0.5); }
    [data-dark] #gps-btn[data-state="success"] { background: #1a3a2a; color: #4caf8a; }
    [data-dark] #gps-btn[data-state="error"]   { background: #2a1212; color: #f87171; }

    @media (max-width: 767px) {
      #gps-btn { width: 44px; padding: 0; border-radius: 50%; justify-content: center; }
      #gps-btn .gps-label { display: none; }
    }

  </style>
</head>

<body>
  <Header lang="zh-tw" slug="map" hideLangSwitcher={true} />
  <TopStrip lang="zh-tw" />

  <div class="map-topbar">
    <a href="/map/" class="back-btn">‹ 返回</a>
    <div class="topbar-info">
      <div class="topbar-title">{area.name} {area.isThematic ? '' : '攻略地圖'}</div>
      <div class="topbar-desc">{area.description}</div>
    </div>
    <a href="/map/itinerary/" id="itin-topbar-btn" aria-label="行程規劃">
      📋 <span id="itin-topbar-count">0</span>
    </a>
    <button id="dark-btn" aria-label="深色模式">🌙</button>
    <span class="topbar-emoji">{area.emoji}</span>
  </div>

  <MapView area={area} />
  <button id="gps-btn" aria-label="定位到我的位置" onclick="window._gpsClick(this)" data-state="idle">
    <svg class="gps-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="10"/>
      <circle cx="12" cy="12" r="3"/>
      <line x1="12" y1="2" x2="12" y2="4"/>
      <line x1="12" y1="20" x2="12" y2="22"/>
      <line x1="2" y1="12" x2="4" y2="12"/>
      <line x1="20" y1="12" x2="22" y2="12"/>
    </svg>
    <span class="gps-label">我的位置</span>
  </button>
  <RecommendForm areaName={area.name} areaSlug={area.slug} />

  <script>
    (function() {
      const btn = document.getElementById('dark-btn');
      const html = document.documentElement;

      function applyDark(dark) {
        if (dark) {
          html.setAttribute('data-dark', '');
          btn.textContent = '☀️';
        } else {
          html.removeAttribute('data-dark');
          btn.textContent = '🌙';
        }
      }

      applyDark(localStorage.getItem('map_dark') === '1');

      btn?.addEventListener('click', () => {
        const nowDark = !html.hasAttribute('data-dark');
        applyDark(nowDark);
        localStorage.setItem('map_dark', nowDark ? '1' : '0');
      });
    })();

    // Itinerary badge
    (function() {
      const itinBtn = document.getElementById('itin-topbar-btn');
      const itinCount = document.getElementById('itin-topbar-count');

      function updateItinBadge() {
        try {
          const count = JSON.parse(localStorage.getItem('map_itinerary') || '[]').length;
          if (count > 0) {
            itinBtn.style.display = 'flex';
            itinCount.textContent = count;
          } else {
            itinBtn.style.display = 'none';
          }
        } catch {}
      }

      updateItinBadge();
      window.updateItinBadge = updateItinBadge;
    })();
  </script>

  <script is:inline>
    var _gpsWatchId = null;
    var _GPS_HINT_KEY = 'gobaligo_map_locate_hint_seen';

    function _resetGpsBtn() {
      var btn = document.getElementById('gps-btn');
      if (!btn) return;
      btn.dataset.state = 'idle';
      var label = btn.querySelector('.gps-label');
      if (label) label.textContent = '我的位置';
    }

    function _showGpsToast(msg) {
      var old = document.getElementById('_gps_toast');
      if (old) old.remove();
      var t = document.createElement('div');
      t.id = '_gps_toast';
      t.style.cssText = 'position:fixed;bottom:80px;left:50%;transform:translateX(-50%);background:rgba(0,0,0,0.78);color:#fff;padding:10px 18px;border-radius:12px;font-size:13px;font-weight:600;z-index:9999;white-space:nowrap;pointer-events:none;transition:opacity 0.3s';
      t.textContent = msg;
      document.body.appendChild(t);
      setTimeout(function() {
        t.style.opacity = '0';
        setTimeout(function() { if (t.parentNode) t.remove(); }, 300);
      }, 3000);
    }

    window._gpsClick = function(btn) {
      if (btn.dataset.state === 'loading') return;
      var label = btn.querySelector('.gps-label');

      if (!navigator.geolocation) {
        btn.dataset.state = 'error';
        if (label) label.textContent = '不支援定位';
        setTimeout(_resetGpsBtn, 2500);
        return;
      }

      btn.dataset.state = 'loading';
      if (label) label.textContent = '定位中…';

      var done = false;
      var tid = setTimeout(function() {
        if (done) return;
        done = true;
        btn.dataset.state = 'error';
        if (label) label.textContent = '逾時';
        setTimeout(_resetGpsBtn, 2000);
      }, 10000);

      navigator.geolocation.getCurrentPosition(
        function(pos) {
          if (done) return;
          done = true;
          clearTimeout(tid);
          var lat = pos.coords.latitude, lng = pos.coords.longitude;
          var api = window._mapApi;
          if (api) { api.flyTo(lat, lng, 15); api.setUserLocation(lat, lng); api.enableNearby(); }
          btn.dataset.state = 'success';
          if (label) label.textContent = '已定位';
          setTimeout(_resetGpsBtn, 2000);
          if (_gpsWatchId === null) {
            _gpsWatchId = navigator.geolocation.watchPosition(
              function(p) { window._mapApi && window._mapApi.setUserLocation(p.coords.latitude, p.coords.longitude); },
              null, { enableHighAccuracy: true }
            );
          }
        },
        function(err) {
          if (done) return;
          done = true;
          clearTimeout(tid);
          btn.dataset.state = 'error';
          if (err.code === 1) {
            if (label) label.textContent = '無權限';
            _showGpsToast('請在瀏覽器設定中開啟定位權限');
          } else {
            if (label) label.textContent = '定位失敗';
          }
          setTimeout(_resetGpsBtn, 2500);
        },
        { enableHighAccuracy: true, timeout: 10000, maximumAge: 30000 }
      );
    };

    // First-visit pulse
    (function() {
      var btn = document.getElementById('gps-btn');
      if (!btn) return;
      var seen = false;
      try { seen = localStorage.getItem(_GPS_HINT_KEY) === '1'; } catch {}
      if (seen) return;
      btn.classList.add('first-visit');
      function markSeen() {
        btn.classList.remove('first-visit');
        try { localStorage.setItem(_GPS_HINT_KEY, '1'); } catch {}
      }
      btn.addEventListener('animationend', markSeen, { once: true });
      setTimeout(markSeen, 7000); // fallback
    })();
  </script>
</body>
</html>
