function bbcAttrPrice(item) {
  if (item.usdMin !== undefined) return item.usdMin===item.usdMax ? '$'+item.usdMin : '$'+item.usdMin+'～$'+item.usdMax;
  if (item.iMin === 0) return '免費';
  const a = +(item.iMin/BBC_IDR).toFixed(2), b = +(item.iMax/BBC_IDR).toFixed(2);
  return a===b ? '$'+a : '$'+a+'～$'+b;
}

function bbcActPrice(item) {
  if (item.type === 'd150') return '$150 ÷ 人數';
  if (item.type === 'd100') return '$100 ÷ 人數';
  if (item.type === 'kintamani') return '依人數計算';
  if (item.type === 'tubing') return '依人數計算';
  return item.mn === item.mx ? '$'+item.mn : '$'+item.mn+'～$'+item.mx;
}

function bbcBuildList(items, cid, priceFn) {
  const c = document.getElementById(cid);
  c.innerHTML = '';
  items.forEach(item => {
    const d = document.createElement('div');
    d.className = 'bbc-check-chip';
    const noteStr = item.note ? item.note + '・' : '';
    d.innerHTML = `<input type="checkbox" id="${item.id}" /><div><div class="bbc-cn">${item.name}</div><div class="bbc-cp">${noteStr}${priceFn(item)}</div></div>`;
    d.onclick = function(e) {
      if (e.target.tagName !== 'INPUT') {
        const cb = d.querySelector('input'); cb.checked = !cb.checked;
      }
      d.classList.toggle('bbc-on', d.querySelector('input').checked);
      bbcCalc();
    };
    c.appendChild(d);
  });
}

function bbcSelT(el) {
  document.querySelectorAll('#bbc-t-opts .bbc-chip').forEach(x => x.classList.remove('bbc-on'));
  el.classList.add('bbc-on');
  const v = el.dataset.v;
  document.getElementById('bbc-vd-row').style.display = (v==='van5'||v==='van10'||v==='unsure') ? 'flex' : 'none';
  bbcCalc();
}
function bbcSelM(el) {
  document.querySelectorAll('#bbc-meal-opts .bbc-chip').forEach(x => x.classList.remove('bbc-on'));
  el.classList.add('bbc-on'); bbcCalc();
}
function bbcGetT() { return (document.querySelector('#bbc-t-opts .bbc-chip.bbc-on') || {dataset:{v:'van5'}}).dataset.v; }
function bbcGetM() { return (document.querySelector('#bbc-meal-opts .bbc-chip.bbc-on') || {dataset:{v:'balanced'}}).dataset.v; }
function bbcFmt(mn, mx) { mn = Math.round(mn); mx = Math.round(mx); return mn===mx ? '$'+mn : '$'+mn+'～$'+mx; }

let bbcLastRecs = [];

function bbcCalc() {
  const days  = +document.getElementById('bbc-days').value;
  const ppl   = +document.getElementById('bbc-people').value;
  const vdays = +document.getElementById('bbc-van-days').value;
  const transport = bbcGetT(), meal = bbcGetM();
  const spaN = +document.getElementById('bbc-spa-n').value || 0;
  const bcN  = +document.getElementById('bbc-bc-n').value  || 0;
  document.getElementById('bbc-tips-p').textContent = '$' + (20 * days);

  let rows = [], totMin = 0, totMax = 0;
  function add(lbl, mn, mx, formula) { rows.push({lbl, mn, mx, formula}); totMin += mn; totMax += mx; }

  if (transport==='van5'||transport==='unsure') {
    const v=(40*vdays)/ppl; add('包車（5人座）',v,v,`$40 × ${vdays} 天 ÷ ${ppl} 人 = $${Math.round(v)}`);
  } else if (transport==='van10') {
    const v=(90*vdays)/ppl; add('包車（10人座）',v,v,`$90 × ${vdays} 天 ÷ ${ppl} 人 = $${Math.round(v)}`);
  } else if (transport==='scooter') {
    const v=ppl===1?6*days:(6*days)/2;
    add('租機車',v,v,ppl===1?`$6 × ${days} 天 = $${Math.round(v)}`:`$6 × ${days} 天 ÷ 2（共乘）= $${Math.round(v)}`);
  } else if (transport==='grab') {
    const v=(15*days)/ppl; add('網約車（Gojek/Grab）',v,v,`$15 × ${days} 天 ÷ ${ppl} 人 = $${Math.round(v)}`);
  }

  let aMin=0,aMax=0,aCnt=0,aParts=[];
  BBC_ATTRS.forEach(item => {
    const cb=document.getElementById(item.id); if(!cb||!cb.checked) return;
    let mn,mx;
    if(item.usdMin!==undefined){mn=item.usdMin;mx=item.usdMax;}
    else{mn=item.iMin/BBC_IDR;mx=item.iMax/BBC_IDR;}
    aMin+=mn;aMax+=mx;aCnt++;
    const p=item.iMin===0&&item.usdMin===undefined?'免費':(mn===mx?`$${+(mn).toFixed(2)}`:`$${+(mn).toFixed(2)}～$${+(mx).toFixed(2)}`);
    aParts.push(`${item.name} ${p}`);
  });
  if(aCnt>0) add(`景點門票（${aCnt} 個）`,aMin,aMax,aParts.join('　'));

  let acMin=0,acMax=0,acCnt=0,acParts=[];
  BBC_ACTS.forEach(item => {
    const cb=document.getElementById(item.id); if(!cb||!cb.checked) return;
    let mn=0,mx=0,f='';
    if(item.type==='d150'){mn=mx=150/ppl;f=`${item.name}：$150 ÷ ${ppl} 人 = $${Math.round(mn)}`;}
    else if(item.type==='d100'){mn=mx=100/ppl;f=`${item.name}：$100 ÷ ${ppl} 人 = $${Math.round(mn)}`;}
    else if(item.type==='kintamani'){mn=mx=ppl===1?100:50;f=`${item.name}：${ppl===1?'獨旅 $100':'2~4人每人 $50'}`;}
    else if(item.type==='tubing'){const v=ppl===1?50:ppl===2?32:ppl<=4?25:21;mn=mx=v;f=`${item.name}：${ppl} 人 → 每人 $${v}`;}
    else{mn=item.mn;mx=item.mx;f=mn===mx?`${item.name}：$${mn}`:`${item.name}：$${mn}～$${mx}`;}
    acMin+=mn;acMax+=mx;acCnt++;acParts.push(f);
  });
  if(spaN>0){acMin+=spaN*30;acMax+=spaN*100;acCnt++;acParts.push(`Spa ${spaN} 次：$${spaN*30}～$${spaN*100}`);}
  if(bcN>0){acMin+=bcN*20;acMax+=bcN*40;acCnt++;acParts.push(`俱樂部 ${bcN} 次：$${bcN*20}～$${bcN*40}`);}
  if(acCnt>0) add(`活動體驗（${acCnt} 項）`,acMin,acMax,acParts.join('　'));

  const md=days-1;
  if(meal==='luxury') add('餐飲（享受型）',100*md,200*md,`$100～$200 × ${md} 天 = $${100*md}～$${200*md}`);
  else if(meal==='balanced') add('餐飲（均衡型）',30*md,60*md,`$30～$60 × ${md} 天 = $${30*md}～$${60*md}`);
  else add('餐飲（精省型）',10*md,20*md,`$10～$20 × ${md} 天 = $${10*md}～$${20*md}`);
  add('小費 / 購物',20*days,20*days,`$20 × ${days} 天 = $${20*days}`);

  const ts=bbcFmt(totMin,totMax);
  document.getElementById('bbc-total-disp').textContent=ts;
  document.getElementById('bbc-total2').textContent=ts;
  document.getElementById('bbc-breakdown').innerHTML=rows.map(r=>
    `<div class="bbc-bd-row"><div class="bbc-bd-main"><span class="bbc-bd-lbl">${r.lbl}</span><span class="bbc-bd-val">${bbcFmt(r.mn,r.mx)}</span></div>${r.formula?`<div class="bbc-bd-formula">${r.formula}</div>`:''}</div>`
  ).join('');

  const seen=new Set(),dynItems=[];
  BBC_ATTRS.forEach(item=>{const cb=document.getElementById(item.id);
    if(cb&&cb.checked&&item.lk&&BBC_LINKS[item.lk]&&!seen.has(item.lk)){seen.add(item.lk);dynItems.push({name:item.name,url:BBC_LINKS[item.lk]});}
  });
  BBC_ACTS.forEach(item=>{const cb=document.getElementById(item.id);
    if(cb&&cb.checked&&item.lk&&BBC_LINKS[item.lk]&&!seen.has(item.lk)){seen.add(item.lk);dynItems.push({name:item.name,url:BBC_LINKS[item.lk]});}
  });
  if(spaN>0&&!seen.has('Spa')){seen.add('Spa');dynItems.push({name:'Spa / 按摩攻略',url:BBC_LINKS['Spa']});}
  bbcLastRecs=[BBC_FIXED_TOP,...dynItems,BBC_FIXED_BTM];
  document.getElementById('bbc-rec-links').innerHTML=bbcLastRecs.map(r=>
    `<a class="bbc-rec-link" href="${r.url}" target="_blank"><span class="bbc-rec-link-name">${r.name}</span><span class="bbc-rec-link-arr">→</span></a>`
  ).join('');
}

function bbcReset() {
  document.getElementById('bbc-days').value='5';
  document.getElementById('bbc-people').value='2';
  document.getElementById('bbc-van-days').value='3';
  document.getElementById('bbc-spa-n').value='0';
  document.getElementById('bbc-bc-n').value='0';
  document.getElementById('bbc-vd-row').style.display='flex';
  document.querySelectorAll('#bbc-t-opts .bbc-chip').forEach(x=>x.classList.remove('bbc-on'));
  document.querySelector('#bbc-t-opts .bbc-chip[data-v="van5"]').classList.add('bbc-on');
  document.querySelectorAll('#bbc-meal-opts .bbc-chip').forEach(x=>x.classList.remove('bbc-on'));
  document.querySelector('#bbc-meal-opts .bbc-chip[data-v="balanced"]').classList.add('bbc-on');
  document.querySelectorAll('#bbc-attr-list input,#bbc-act-list input').forEach(cb=>{cb.checked=false;cb.closest('.bbc-check-chip').classList.remove('bbc-on');});
  bbcCalc();
}

function bbcPDF() {
  const days=document.getElementById('bbc-days').value;
  const ppl=document.getElementById('bbc-people').value;
  const total=document.getElementById('bbc-total-disp').textContent;
  const rows=[...document.querySelectorAll('#bbc-breakdown .bbc-bd-row')].map(r=>({
    lbl:r.querySelector('.bbc-bd-lbl').textContent,
    val:r.querySelector('.bbc-bd-val').textContent,
    formula:r.querySelector('.bbc-bd-formula')?r.querySelector('.bbc-bd-formula').textContent:''
  }));
  const recHTML=bbcLastRecs.map(r=>`<div style="margin:5px 0;"><a href="${r.url}" style="color:#1a6fa8;font-size:13px;text-decoration:none;">${r.name}</a></div>`).join('');
  const rowsHTML=rows.map(r=>`<tr><td style="padding:7px 0;color:#555;font-size:13px;vertical-align:top;border-bottom:1px solid #eee;">${r.lbl}${r.formula?`<div style="font-size:11px;color:#aaa;margin-top:2px;">${r.formula}</div>`:''}</td><td style="padding:7px 0;font-weight:600;font-size:13px;text-align:right;vertical-align:top;border-bottom:1px solid #eee;">${r.val}</td></tr>`).join('');
  const html=`<!DOCTYPE html><html><head><meta charset="utf-8"><title>峇里島旅費預算</title></head><body style="font-family:sans-serif;max-width:580px;margin:40px auto;padding:0 24px;color:#222;"><div style="font-size:11px;color:#aaa;margin-bottom:6px;">Go Bali Go · gobaligo.id</div><h1 style="font-size:20px;font-weight:600;margin:0 0 4px;">峇里島旅費預算估算</h1><div style="font-size:12px;color:#888;margin-bottom:20px;">${days} 天・${ppl} 人・每人預估</div><div style="font-size:36px;font-weight:700;margin-bottom:20px;">${total} USD</div><div style="font-size:11px;font-weight:600;color:#888;letter-spacing:.05em;margin-bottom:8px;">費用明細</div><table style="width:100%;border-collapse:collapse;margin-bottom:20px;">${rowsHTML}</table><div style="display:flex;justify-content:space-between;font-size:15px;font-weight:600;padding-top:12px;border-top:1px solid #ccc;margin-bottom:28px;"><span>合計</span><span>${total} USD</span></div><div style="font-size:11px;font-weight:600;color:#888;letter-spacing:.05em;margin-bottom:8px;">推薦攻略文章</div>${recHTML}<div style="font-size:11px;color:#bbb;margin-top:32px;line-height:1.6;">本預算為粗估參考，實際費用依個人消費習慣而異。<br>© Go Bali Go · gobaligo.id</div></body></html>`;
  const blob=new Blob([html],{type:'text/html'});
  const url=URL.createObjectURL(blob);
  const w=window.open(url,'_blank');
  if(w) setTimeout(()=>w.print(),600);
}

bbcBuildList(BBC_ATTRS,'bbc-attr-list',bbcAttrPrice);
bbcBuildList(BBC_ACTS,'bbc-act-list',bbcActPrice);
bbcCalc();
</script>
