---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = '峇里島旅費預算計算器 2026';
const description = '免費峇里島旅費預算計算器，輸入天數、人數、景點與活動，立即估算每人花費。';
const lang = 'zh-tw';
const slug = 'bali-budget-calculator';
---

<html lang="zh-TW">
<head>
  <BaseHead title={title} description={description} />
</head>

<body>
  <Header lang={lang} slug={slug} />

  <main class="bbc-page">
    <div class="bbc-page-header">
      <h1>峇里島旅費預算計算器</h1>
      <p>選擇你的旅遊方式，立即估算每人花費</p>
    </div>

    <div class="bbc-wrap">

      <div class="bbc-card">
        <h2><span class="bbc-badge">1</span> 基本設定</h2>
        <div class="bbc-row">
          <label>旅遊天數</label>
          <select id="bbc-days" onchange="bbcCalc()">
            <option value="3">3 天</option><option value="4">4 天</option><option value="5" selected>5 天</option>
            <option value="6">6 天</option><option value="7">7 天</option><option value="8">8 天</option>
            <option value="10">10 天</option><option value="14">14 天</option>
          </select>
        </div>
        <div class="bbc-row">
          <label>旅遊人數</label>
          <select id="bbc-people" onchange="bbcCalc()">
            <option value="1">1 人（獨旅）</option><option value="2" selected>2 人</option>
            <option value="3">3 人</option><option value="4">4 人</option><option value="5">5 人</option>
            <option value="6">6 人</option><option value="8">8 人</option><option value="10">10 人</option>
          </select>
        </div>
      </div>

      <div class="bbc-card">
        <h2><span class="bbc-badge">2</span> 交通方式</h2>
        <div class="bbc-grid2" id="bbc-t-opts">
          <div class="bbc-chip bbc-on" data-v="van5" onclick="bbcSelT(this)">
            <div class="bbc-cn">包車 5人座</div><div class="bbc-cp">$40 / 天</div>
          </div>
          <div class="bbc-chip" data-v="van10" onclick="bbcSelT(this)">
            <div class="bbc-cn">包車 10人座</div><div class="bbc-cp">$90 / 天</div>
          </div>
          <div class="bbc-chip" data-v="scooter" onclick="bbcSelT(this)">
            <div class="bbc-cn">租機車</div><div class="bbc-cp">$6 / 天（2人共乘）</div>
          </div>
          <div class="bbc-chip" data-v="grab" onclick="bbcSelT(this)">
            <div class="bbc-cn">網約車（Gojek/Grab）</div><div class="bbc-cp">$15 / 天</div>
          </div>
          <div class="bbc-chip" data-v="unsure" onclick="bbcSelT(this)">
            <div class="bbc-cn">不確定</div><div class="bbc-cp">以包車 5人座估算</div>
          </div>
        </div>
        <div class="bbc-van-row" id="bbc-vd-row">
          <label>包車天數</label>
          <select id="bbc-van-days" onchange="bbcCalc()">
            <option value="1">1 天</option><option value="2">2 天</option><option value="3" selected>3 天</option>
            <option value="4">4 天</option><option value="5">5 天</option><option value="6">6 天</option><option value="7">7 天</option>
          </select>
        </div>
        <p class="bbc-note">網約車備註：以五人座市區短途移動粗估，實際依搭乘次數而異</p>
      </div>

      <div class="bbc-card">
        <h2><span class="bbc-badge">3</span> 景點 / 門票</h2>
        <p class="bbc-hint">勾選計畫前往的景點（IDR 費用以 1 USD = 17,000 換算，實際費用以現場公告為準）</p>
        <div class="bbc-grid2" id="bbc-attr-list"></div>
      </div>

      <div class="bbc-card">
        <h2><span class="bbc-badge">4</span> 活動體驗</h2>
        <div class="bbc-grid2" id="bbc-act-list"></div>
        <div class="bbc-sep"></div>
        <div class="bbc-sublabel">中高階 Spa / 按摩（每人每小時 $30～$100）</div>
        <div class="bbc-spa-row">次數 <input type="number" class="bbc-num" id="bbc-spa-n" min="0" max="20" value="0" oninput="bbcCalc()"> 次</div>
        <div class="bbc-sublabel">海灘 / 森林俱樂部（每人 $20～$40）</div>
        <div class="bbc-spa-row">次數 <input type="number" class="bbc-num" id="bbc-bc-n" min="0" max="20" value="0" oninput="bbcCalc()"> 次</div>
      </div>

      <div class="bbc-card">
        <h2><span class="bbc-badge">5</span> 餐飲預算</h2>
        <div class="bbc-grid2" id="bbc-meal-opts">
          <div class="bbc-chip" data-v="luxury" onclick="bbcSelM(this)">
            <div class="bbc-cn">享受型</div><div class="bbc-cp">$100～$200 / 天</div>
          </div>
          <div class="bbc-chip bbc-on" data-v="balanced" onclick="bbcSelM(this)">
            <div class="bbc-cn">均衡型</div><div class="bbc-cp">$30～$60 / 天</div>
          </div>
          <div class="bbc-chip" data-v="local" onclick="bbcSelM(this)">
            <div class="bbc-cn">精省型</div><div class="bbc-cp">$10～$20 / 天</div>
          </div>
        </div>
      </div>

      <div class="bbc-card">
        <h2><span class="bbc-badge">6</span> 小費 / 購物</h2>
        <div class="bbc-tips-row">
          <span>粗估 $20 × 旅遊天數</span>
          <span id="bbc-tips-p">$100</span>
        </div>
      </div>

      <div class="bbc-result">
        <div class="bbc-eyebrow">以下為一個人預估的總旅費</div>
        <div class="bbc-total" id="bbc-total-disp">$0</div>
        <div class="bbc-total-sub">費用明細（美金 USD）</div>
        <div class="bbc-bd" id="bbc-breakdown"></div>
        <div class="bbc-grand"><span>合計</span><span id="bbc-total2">$0</span></div>
        <div class="bbc-recs" id="bbc-recs-wrap">
          <div class="bbc-recs-title">推薦以下攻略文章</div>
          <div class="bbc-rec-links" id="bbc-rec-links"></div>
        </div>
        <div class="bbc-btn-row">
          <button class="bbc-btn" onclick="bbcReset()">↺ 重新計算</button>
          <button class="bbc-btn" onclick="bbcPDF()">儲存 PDF 分享給旅伴</button>
        </div>
      </div>

    </div>
  </main>

  <Footer />
</body>
</html>

<style>
  /* ── 全部用 bbc- 前綴，避免與網站全域樣式衝突 ── */
  .bbc-page { max-width: 780px; margin: 0 auto; padding: 32px 16px 80px; }
  .bbc-page-header { text-align: center; margin-bottom: 28px; }
  .bbc-page-header h1 { font-size: 22px; font-weight: 600; margin: 0; }
  .bbc-page-header p { font-size: 14px; color: #888; margin: 6px 0 0; }
  .bbc-wrap { max-width: 680px; margin: 0 auto; }

  /* Card */
  .bbc-card {
    background: #ffffff !important;
    border: 1px solid #e0ddd6 !important;
    border-radius: 12px !important;
    padding: 20px !important;
    margin-bottom: 14px !important;
    box-shadow: none !important;
  }
  .bbc-card h2 {
    font-size: 15px !important;
    font-weight: 600 !important;
    margin: 0 0 16px !important;
    padding: 0 !important;
    display: flex !important;
    align-items: center !important;
    gap: 8px !important;
    border: none !important;
    color: #1a1a1a !important;
  }
  .bbc-badge {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    width: 22px !important;
    height: 22px !important;
    border-radius: 50% !important;
    background: #f0ede6 !important;
    border: 1px solid #ddd !important;
    font-size: 11px !important;
    font-weight: 600 !important;
    color: #666 !important;
    flex-shrink: 0 !important;
    line-height: 1 !important;
  }

  /* Row selects */
  .bbc-row {
    display: flex !important;
    gap: 12px !important;
    align-items: center !important;
    margin-bottom: 10px !important;
  }
  .bbc-row label {
    font-size: 14px !important;
    color: #666 !important;
    min-width: 80px !important;
    margin: 0 !important;
  }
  .bbc-row select {
    flex: 1 !important;
    height: 38px !important;
    border-radius: 8px !important;
    border: 1px solid #ddd !important;
    background: #fafaf8 !important;
    color: #1a1a1a !important;
    font-size: 14px !important;
    padding: 0 10px !important;
  }

  /* Grid */
  .bbc-grid2 {
    display: grid !important;
    grid-template-columns: 1fr 1fr !important;
    gap: 6px !important;
  }

  /* Chip — 核心修正：強制 block，不用 flex，避免被全域覆蓋 */
  .bbc-chip {
    display: block !important;
    padding: 10px 12px !important;
    border-radius: 8px !important;
    border: 1px solid #e0ddd6 !important;
    cursor: pointer !important;
    background: #fafaf8 !important;
    transition: border-color 0.15s, background 0.15s !important;
    user-select: none !important;
    box-sizing: border-box !important;
  }
  .bbc-chip:hover { border-color: #aaa !important; }
  .bbc-chip.bbc-on { border-color: #1a6fa8 !important; background: #eef5fb !important; }
  .bbc-cn {
    font-size: 13px !important;
    color: #1a1a1a !important;
    font-weight: 500 !important;
    line-height: 1.4 !important;
    display: block !important;
    margin: 0 !important;
  }
  .bbc-cp {
    font-size: 11px !important;
    color: #999 !important;
    margin: 3px 0 0 !important;
    display: block !important;
  }
  .bbc-chip.bbc-on .bbc-cp { color: #1a6fa8 !important; }

  /* Checkbox chips (景點/活動) */
  .bbc-check-chip {
    display: flex !important;
    align-items: flex-start !important;
    gap: 8px !important;
    padding: 10px 12px !important;
    border-radius: 8px !important;
    border: 1px solid #e0ddd6 !important;
    cursor: pointer !important;
    background: #fafaf8 !important;
    transition: border-color 0.15s, background 0.15s !important;
    user-select: none !important;
    box-sizing: border-box !important;
  }
  .bbc-check-chip:hover { border-color: #aaa !important; }
  .bbc-check-chip.bbc-on { border-color: #1a6fa8 !important; background: #eef5fb !important; }
  .bbc-check-chip input[type="checkbox"] {
    width: 15px !important;
    height: 15px !important;
    flex-shrink: 0 !important;
    margin: 2px 0 0 !important;
    accent-color: #1a6fa8 !important;
    cursor: pointer !important;
  }
  .bbc-check-chip .bbc-cn { font-size: 13px !important; color: #1a1a1a !important; font-weight: 500 !important; line-height: 1.4 !important; display: block !important; margin: 0 !important; }
  .bbc-check-chip .bbc-cp { font-size: 11px !important; color: #999 !important; margin: 3px 0 0 !important; display: block !important; }
  .bbc-check-chip.bbc-on .bbc-cp { color: #1a6fa8 !important; }

  .bbc-hint { font-size: 12px !important; color: #aaa !important; margin: 0 0 12px !important; line-height: 1.6 !important; }
  .bbc-note { font-size: 12px !important; color: #aaa !important; padding: 8px 10px !important; border-radius: 8px !important; background: #fafaf8 !important; margin: 10px 0 0 !important; line-height: 1.6 !important; }
  .bbc-sep { height: 1px !important; background: #eee !important; margin: 14px 0 !important; }
  .bbc-sublabel { font-size: 13px !important; color: #555 !important; margin: 0 0 6px !important; }
  .bbc-spa-row { display: flex !important; gap: 8px !important; align-items: center !important; font-size: 13px !important; color: #666 !important; margin-bottom: 10px !important; }
  .bbc-num { width: 64px !important; height: 32px !important; border-radius: 8px !important; border: 1px solid #ddd !important; background: #fafaf8 !important; color: #1a1a1a !important; font-size: 13px !important; padding: 0 8px !important; text-align: center !important; }
  .bbc-van-row { display: flex !important; gap: 12px !important; align-items: center !important; margin-top: 12px !important; }
  .bbc-van-row label { font-size: 14px !important; color: #666 !important; min-width: 80px !important; margin: 0 !important; }
  .bbc-van-row select { flex: 1 !important; height: 38px !important; border-radius: 8px !important; border: 1px solid #ddd !important; background: #fafaf8 !important; color: #1a1a1a !important; font-size: 14px !important; padding: 0 10px !important; }
  .bbc-tips-row { display: flex !important; justify-content: space-between !important; align-items: center !important; font-size: 14px !important; color: #666 !important; }
  #bbc-tips-p { font-weight: 600 !important; color: #1a1a1a !important; }

  /* Result card */
  .bbc-result {
    background: #ffffff !important;
    border: 1px solid #e0ddd6 !important;
    border-radius: 12px !important;
    padding: 20px !important;
    margin-bottom: 14px !important;
  }
  .bbc-eyebrow { font-size: 13px !important; color: #888 !important; margin: 0 !important; }
  .bbc-total { font-size: 36px !important; font-weight: 700 !important; color: #1a1a1a !important; margin: 6px 0 2px !important; line-height: 1.2 !important; }
  .bbc-total-sub { font-size: 12px !important; color: #aaa !important; margin: 0 0 16px !important; }

  /* Breakdown */
  .bbc-bd { border-top: 1px solid #eee !important; padding-top: 12px !important; }
  .bbc-bd-row { padding: 8px 0 !important; border-bottom: 1px solid #f0ede6 !important; }
  .bbc-bd-row:last-child { border-bottom: none !important; }
  .bbc-bd-main { display: flex !important; justify-content: space-between !important; align-items: baseline !important; }
  .bbc-bd-lbl { font-size: 14px !important; color: #555 !important; }
  .bbc-bd-val { font-size: 14px !important; font-weight: 600 !important; color: #1a1a1a !important; }
  .bbc-bd-formula { font-size: 11px !important; color: #bbb !important; margin: 3px 0 0 !important; line-height: 1.5 !important; }
  .bbc-grand { display: flex !important; justify-content: space-between !important; align-items: baseline !important; padding: 12px 0 0 !important; font-size: 15px !important; font-weight: 700 !important; margin-top: 4px !important; border-top: 1px solid #ccc !important; }

  /* Recs */
  .bbc-recs { margin-top: 18px !important; border-top: 1px solid #eee !important; padding-top: 14px !important; }
  .bbc-recs-title { font-size: 12px !important; font-weight: 600 !important; color: #999 !important; margin: 0 0 10px !important; letter-spacing: 0.04em !important; text-transform: uppercase !important; }
  .bbc-rec-links { display: flex !important; flex-direction: column !important; gap: 6px !important; }
  .bbc-rec-link {
    display: flex !important;
    align-items: center !important;
    justify-content: space-between !important;
    padding: 9px 13px !important;
    border-radius: 8px !important;
    border: 1px solid #e0ddd6 !important;
    text-decoration: none !important;
    background: #fafaf8 !important;
    transition: border-color 0.15s !important;
  }
  .bbc-rec-link:hover { border-color: #aaa !important; text-decoration: none !important; }
  .bbc-rec-link-name { font-size: 13px !important; color: #1a1a1a !important; }
  .bbc-rec-link-arr { font-size: 13px !important; color: #bbb !important; }

  /* Buttons */
  .bbc-btn-row { display: flex !important; gap: 8px !important; margin-top: 16px !important; flex-wrap: wrap !important; }
  .bbc-btn {
    display: inline-flex !important;
    align-items: center !important;
    gap: 6px !important;
    padding: 9px 18px !important;
    border-radius: 8px !important;
    border: 1px solid #ddd !important;
    font-size: 13px !important;
    color: #1a1a1a !important;
    background: #fafaf8 !important;
    cursor: pointer !important;
    font-family: inherit !important;
    transition: background 0.15s !important;
  }
  .bbc-btn:hover { background: #f0ede6 !important; }

  @media (max-width: 480px) {
    .bbc-grid2 { grid-template-columns: 1fr !important; }
    .bbc-total { font-size: 28px !important; }
    .bbc-page { padding: 20px 12px 60px !important; }
  }
</style>

<script>
const BBC_IDR = 17000;
const BBC_FIXED_TOP = { name:'峇里島包車攻略', url:'https://gobaligo.id/go/bali-car-charter-guide' };
