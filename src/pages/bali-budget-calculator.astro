---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = '峇里島旅費預算計算器 2026';
const description = '免費峇里島旅費預算計算器，輸入天數、人數、景點與活動，立即估算每人花費。';
const lang = 'zh-tw';
---

<html lang="zh-TW">
<head>
  <BaseHead title={title} description={description} />
</head>

<body>
  <Header lang={lang} />

  <main class="calc-page">
    <div class="calc-page-header">
      <h1>峇里島旅費預算計算器</h1>
      <p>選擇你的旅遊方式，立即估算每人花費</p>
    </div>

    <div class="calc-wrap">

      <div class="card">
        <h2><span class="step-badge">1</span> 基本設定</h2>
        <div class="row"><label>旅遊天數</label>
          <select id="days" onchange="calc()">
            <option value="3">3 天</option><option value="4">4 天</option><option value="5" selected>5 天</option>
            <option value="6">6 天</option><option value="7">7 天</option><option value="8">8 天</option>
            <option value="10">10 天</option><option value="14">14 天</option>
          </select>
        </div>
        <div class="row"><label>旅遊人數</label>
          <select id="people" onchange="calc()">
            <option value="1">1 人（獨旅）</option><option value="2" selected>2 人</option>
            <option value="3">3 人</option><option value="4">4 人</option><option value="5">5 人</option>
            <option value="6">6 人</option><option value="8">8 人</option><option value="10">10 人</option>
          </select>
        </div>
      </div>

      <div class="card">
        <h2><span class="step-badge">2</span> 交通方式</h2>
        <div class="grid2" id="t-opts">
          <div class="chip on" data-v="van5" onclick="selT(this)"><div><div class="cn">包車 5人座</div><div class="cp">$40 / 天</div></div></div>
          <div class="chip" data-v="van10" onclick="selT(this)"><div><div class="cn">包車 10人座</div><div class="cp">$90 / 天</div></div></div>
          <div class="chip" data-v="scooter" onclick="selT(this)"><div><div class="cn">租機車</div><div class="cp">$6 / 天（2人共乘）</div></div></div>
          <div class="chip" data-v="grab" onclick="selT(this)"><div><div class="cn">網約車（Gojek/Grab）</div><div class="cp">$15 / 天</div></div></div>
          <div class="chip" data-v="unsure" onclick="selT(this)"><div><div class="cn">不確定</div><div class="cp">以包車 5人座估算</div></div></div>
        </div>
        <div class="van-days-row" id="vd-row">
          <label>包車天數</label>
          <select id="van-days" onchange="calc()">
            <option value="1">1 天</option><option value="2">2 天</option><option value="3" selected>3 天</option>
            <option value="4">4 天</option><option value="5">5 天</option><option value="6">6 天</option><option value="7">7 天</option>
          </select>
        </div>
        <p class="note">網約車備註：以五人座市區短途移動粗估，實際依搭乘次數而異</p>
      </div>

      <div class="card">
        <h2><span class="step-badge">3</span> 景點 / 門票</h2>
        <p class="hint">勾選計畫前往的景點（IDR 費用以 1 USD = 17,000 換算，實際費用以現場公告為準）</p>
        <div class="grid2" id="attr-list"></div>
      </div>

      <div class="card">
        <h2><span class="step-badge">4</span> 活動體驗</h2>
        <div class="grid2" id="act-list"></div>
        <div class="sep"></div>
        <div class="sub-label">中高階 Spa / 按摩（每人每小時 $30～$100）</div>
        <div class="spa-row">次數 <input type="number" class="mini-inp" id="spa-n" min="0" max="20" value="0" oninput="calc()"> 次</div>
        <div class="sub-label">海灘 / 森林俱樂部（每人 $20～$40）</div>
        <div class="spa-row">次數 <input type="number" class="mini-inp" id="bc-n" min="0" max="20" value="0" oninput="calc()"> 次</div>
      </div>

      <div class="card">
        <h2><span class="step-badge">5</span> 餐飲預算</h2>
        <div class="grid2" id="meal-opts">
          <div class="chip" data-v="luxury" onclick="selM(this)"><div><div class="cn">享受型</div><div class="cp">$100～$200 / 天</div></div></div>
          <div class="chip on" data-v="balanced" onclick="selM(this)"><div><div class="cn">均衡型</div><div class="cp">$30～$60 / 天</div></div></div>
          <div class="chip" data-v="local" onclick="selM(this)"><div><div class="cn">精省型</div><div class="cp">$10～$20 / 天</div></div></div>
        </div>
      </div>

      <div class="card">
        <h2><span class="step-badge">6</span> 小費 / 購物</h2>
        <div class="row" style="margin-bottom:0">
          <span style="flex:1;font-size:14px;color:#666;">粗估 $20 × 旅遊天數</span>
          <span id="tips-p" style="font-size:14px;font-weight:500;">$100</span>
        </div>
      </div>

      <div class="result-card">
        <div class="result-eyebrow">以下為一個人預估的總旅費</div>
        <div class="total-num" id="total-disp">$0</div>
        <div class="total-sub">費用明細（美金 USD）</div>
        <div class="bd" id="breakdown"></div>
        <div class="bd-total"><span>合計</span><span id="total2">$0</span></div>
        <div class="recs" id="recs-wrap">
          <div class="recs-title">推薦以下攻略文章</div>
          <div class="rec-links" id="rec-links"></div>
        </div>
        <div class="btn-row">
          <button class="btn" onclick="resetAll()">↺ 重新計算</button>
          <button class="btn" onclick="savePDF()">儲存 PDF 分享給旅伴</button>
        </div>
      </div>

    </div>
  </main>

  <Footer />
</body>
</html>

<style>
  .calc-page { max-width: 780px; margin: 0 auto; padding: 32px 16px 80px; }
  .calc-page-header { text-align: center; margin-bottom: 28px; }
  .calc-page-header h1 { font-size: 22px; font-weight: 500; }
  .calc-page-header p { font-size: 14px; color: #888; margin-top: 6px; }
  .calc-wrap { max-width: 680px; margin: 0 auto; }

  .card { background: #fff; border: 1px solid #e8e6e0; border-radius: 12px; padding: 20px; margin-bottom: 14px; }
  .card h2 { font-size: 15px; font-weight: 500; margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }
  .step-badge { display: inline-flex; align-items: center; justify-content: center; width: 22px; height: 22px; border-radius: 50%; background: #f0ede6; border: 1px solid #ddd; font-size: 11px; font-weight: 500; color: #666; flex-shrink: 0; }

  .row { display: flex; gap: 12px; align-items: center; margin-bottom: 10px; }
  .row label { font-size: 14px; color: #666; min-width: 80px; }
  .row select { flex: 1; height: 38px; border-radius: 8px; border: 1px solid #ddd; background: #fafaf8; font-size: 14px; padding: 0 10px; }

  .grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; }
  .chip { display: flex; align-items: flex-start; gap: 8px; padding: 9px 11px; border-radius: 8px; border: 1px solid #e4e2dc; cursor: pointer; transition: border-color 0.15s, background 0.15s; user-select: none; background: #fafaf8; }
  .chip:hover { border-color: #bbb; }
  .chip.on { border-color: #1a6fa8; background: #eef5fb; }
  .chip input[type=checkbox] { margin-top: 2px; flex-shrink: 0; accent-color: #1a6fa8; }
  .chip .cn { font-size: 13px; line-height: 1.4; }
  .chip .cp { font-size: 11px; color: #999; margin-top: 2px; }
  .chip.on .cp { color: #1a6fa8; }

  .hint { font-size: 12px; color: #aaa; margin-bottom: 12px; line-height: 1.6; }
  .note { font-size: 12px; color: #aaa; padding: 8px 10px; border-radius: 8px; background: #fafaf8; margin-top: 10px; line-height: 1.6; }
  .sep { height: 1px; background: #eee; margin: 14px 0; }
  .mini-inp { width: 64px; height: 32px; border-radius: 8px; border: 1px solid #ddd; background: #fafaf8; font-size: 13px; padding: 0 8px; }
  .spa-row { display: flex; gap: 8px; align-items: center; font-size: 13px; color: #666; margin-bottom: 6px; }
  .sub-label { font-size: 13px; color: #666; margin-bottom: 6px; margin-top: 12px; }
  .van-days-row { display: flex; gap: 12px; align-items: center; margin-top: 12px; }
  .van-days-row label { font-size: 14px; color: #666; min-width: 80px; }
  .van-days-row select { flex: 1; height: 38px; border-radius: 8px; border: 1px solid #ddd; background: #fafaf8; font-size: 14px; padding: 0 10px; }

  .result-card { background: #fff; border: 1px solid #e8e6e0; border-radius: 12px; padding: 20px; margin-bottom: 14px; }
  .result-eyebrow { font-size: 13px; color: #888; }
  .total-num { font-size: 36px; font-weight: 500; margin: 6px 0 2px; }
  .total-sub { font-size: 12px; color: #aaa; margin-bottom: 16px; }
  .bd { border-top: 1px solid #eee; padding-top: 12px; }
  .bd-row { padding: 7px 0; border-bottom: 1px solid #f0ede6; }
  .bd-row:last-child { border-bottom: none; }
  .bd-main { display: flex; justify-content: space-between; align-items: baseline; }
  .bd-lbl { font-size: 14px; color: #666; }
  .bd-val { font-size: 14px; font-weight: 500; }
  .bd-formula { font-size: 11px; color: #bbb; margin-top: 3px; line-height: 1.5; }
  .bd-total { display: flex; justify-content: space-between; align-items: baseline; padding: 12px 0 0; font-size: 15px; font-weight: 500; margin-top: 4px; border-top: 1px solid #ccc; }

  .recs { margin-top: 18px; border-top: 1px solid #eee; padding-top: 14px; }
  .recs-title { font-size: 12px; font-weight: 500; color: #999; margin-bottom: 10px; letter-spacing: 0.04em; }
  .rec-links { display: flex; flex-direction: column; gap: 6px; }
  .rec-link { display: flex; align-items: center; justify-content: space-between; padding: 9px 13px; border-radius: 8px; border: 1px solid #e4e2dc; text-decoration: none; background: #fafaf8; transition: border-color 0.15s; }
  .rec-link:hover { border-color: #bbb; }
  .rec-link-name { font-size: 13px; color: #1a1a1a; }
  .rec-link-arr { font-size: 13px; color: #bbb; }

  .btn-row { display: flex; gap: 8px; margin-top: 16px; flex-wrap: wrap; }
  .btn { display: inline-flex; align-items: center; gap: 6px; padding: 9px 18px; border-radius: 8px; border: 1px solid #ddd; font-size: 13px; background: #fafaf8; cursor: pointer; transition: background 0.15s; font-family: inherit; }
  .btn:hover { background: #f0ede6; }

  @media (max-width: 480px) {
    .grid2 { grid-template-columns: 1fr; }
    .total-num { font-size: 28px; }
  }
</style>

