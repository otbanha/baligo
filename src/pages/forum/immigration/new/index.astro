---
import BaseHead from '../../../../components/BaseHead.astro';
import Header from '../../../../components/Header.astro';
import TopStrip from '../../../../components/TopStrip.astro';
import Footer from '../../../../components/Footer.astro';

const supabaseUrl  = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseAnon = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
---

<html lang="zh-TW">
<head>
  <BaseHead
    title="發布入境通報 — Go Bali Go"
    description="分享你的峇里島入境體驗，幫助其他旅客了解最新海關、簽證、排隊情況。"
    noSuffix
  />
  <meta name="robots" content="noindex, nofollow" />
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
</head>
<body>
  <Header lang="blog" />
  <TopStrip lang="zh-tw" />

  <main class="new-report-page">
    <div class="nr-container">
      <div class="nr-header">
        <a href="/forum/immigration/" class="nr-back">← 返回列表</a>
        <h1 class="nr-title">發布入境通報</h1>
        <p class="nr-subtitle">分享你的真實入境體驗，幫助其他旅客做好準備</p>
      </div>

      <div id="auth-gate" style="display:none" class="nr-auth-gate">
        <p>請先登入才能發布通報</p>
        <a href="/forum/login/?next=/forum/immigration/new/" class="btn-login">使用 Google 登入</a>
      </div>

      <form id="report-form" style="display:none" class="nr-form" novalidate>
        <div id="form-error" class="form-error" style="display:none"></div>
        <div id="form-success" class="form-success" style="display:none">
          <span class="success-icon">✓</span>
          <div>
            <strong>通報已成功提交！</strong>
            <p>審核通過後將公開顯示。感謝你的貢獻。</p>
            <a href="/forum/immigration/" class="btn-back-list">返回通報列表</a>
          </div>
        </div>

        <!-- 入境資訊 -->
        <fieldset class="nr-fieldset">
          <legend>入境基本資訊</legend>

          <div class="nr-field">
            <label for="entry-date">入境日期 <span class="required">*</span></label>
            <input type="date" id="entry-date" name="entry_date" required class="nr-input" />
          </div>

          <div class="nr-field">
            <label for="airport">機場 <span class="required">*</span></label>
            <select id="airport" name="airport" required class="nr-select">
              <option value="">請選擇</option>
              <option value="DPS">峇里島 (DPS)</option>
              <option value="CGK">雅加達 (CGK)</option>
              <option value="SUB">泗水 (SUB)</option>
              <option value="LOP">龍目島 (LOP)</option>
            </select>
          </div>

          <div class="nr-field">
            <label for="entry-time-slot">入境時段 <span class="required">*</span></label>
            <select id="entry-time-slot" name="entry_time_slot" required class="nr-select">
              <option value="">請選擇</option>
              <option value="early_morning">清晨 (00:00–06:00)</option>
              <option value="morning">上午 (06:00–12:00)</option>
              <option value="afternoon">下午 (12:00–18:00)</option>
              <option value="evening">傍晚/夜間 (18:00–24:00)</option>
            </select>
          </div>

          <div class="nr-field">
            <label for="visa-type">簽證類型 <span class="required">*</span></label>
            <select id="visa-type" name="visa_type" required class="nr-select">
              <option value="">請選擇</option>
              <option value="voa">落地簽 (VOA)</option>
              <option value="evoa">電子落地簽 (e-VOA)</option>
              <option value="visa-free">免簽</option>
              <option value="kitas">KITAS / 居留簽</option>
            </select>
          </div>

          <div class="nr-field" id="voa-payment-field" style="display:none">
            <label for="voa-payment">VOA 付款方式</label>
            <select id="voa-payment" name="voa_payment_method" class="nr-select">
              <option value="">請選擇</option>
              <option value="cash_usd">現金 USD</option>
              <option value="cash_idr">現金 IDR</option>
              <option value="card">刷卡</option>
            </select>
          </div>

          <div class="nr-field">
            <label for="queue-minutes">排隊等候時間（分鐘）</label>
            <input type="number" id="queue-minutes" name="queue_minutes" min="0" max="300" placeholder="如不確定可留空" class="nr-input nr-input--short" />
          </div>
        </fieldset>

        <!-- 海關 -->
        <fieldset class="nr-fieldset">
          <legend>海關情況</legend>

          <div class="nr-field nr-field--inline">
            <label class="nr-toggle">
              <input type="checkbox" id="customs-checked" name="customs_checked" class="toggle-input" />
              <span class="toggle-track"></span>
              <span class="toggle-label">有被海關抽查</span>
            </label>
          </div>

          <div class="nr-field" id="customs-issue-field" style="display:none">
            <label for="customs-issue">海關檢查詳情</label>
            <textarea id="customs-issue" name="customs_issue" rows="3" maxlength="1000" placeholder="請描述檢查的物品或情況" class="nr-textarea"></textarea>
            <span class="nr-char-count"><span id="customs-issue-count">0</span>/1000</span>
          </div>
        </fieldset>

        <!-- 索賄 -->
        <fieldset class="nr-fieldset">
          <legend>索賄情況</legend>

          <div class="nr-field nr-field--inline">
            <label class="nr-toggle">
              <input type="checkbox" id="bribe-attempted" name="bribe_attempted" class="toggle-input" />
              <span class="toggle-track"></span>
              <span class="toggle-label">有被索賄</span>
            </label>
          </div>

          <div id="bribe-details-field" style="display:none">
            <div class="nr-field">
              <label for="bribe-amount">索賄金額（IDR）</label>
              <input type="number" id="bribe-amount" name="bribe_amount_idr" min="0" placeholder="如金額不明可留空" class="nr-input nr-input--short" />
            </div>
            <div class="nr-field">
              <label for="bribe-context">索賄經過</label>
              <textarea id="bribe-context" name="bribe_context" rows="3" maxlength="1000" placeholder="請描述索賄的情況" class="nr-textarea"></textarea>
              <span class="nr-char-count"><span id="bribe-context-count">0</span>/1000</span>
            </div>
          </div>
        </fieldset>

        <!-- 完整記錄 -->
        <fieldset class="nr-fieldset">
          <legend>入境完整記錄</legend>
          <div class="nr-field">
            <label for="general-notes">詳細描述 <span class="required">*</span></label>
            <textarea id="general-notes" name="general_notes" rows="6" maxlength="3000" required
              placeholder="請詳細描述你的入境過程：海關流程、等候情況、有無特殊狀況等。資訊越詳細越能幫助其他旅客。"
              class="nr-textarea"></textarea>
            <span class="nr-char-count"><span id="general-notes-count">0</span>/3000</span>
          </div>
        </fieldset>

        <!-- 圖片上傳 -->
        <fieldset class="nr-fieldset">
          <legend>佐證照片（選填，最多 3 張）</legend>
          <div class="nr-field">
            <div class="upload-zone" id="upload-zone">
              <input type="file" id="image-input" accept="image/jpeg,image/png,image/webp" multiple class="upload-input" />
              <div class="upload-placeholder">
                <span class="upload-icon">📷</span>
                <p>點擊或拖曳上傳照片</p>
                <p class="upload-hint">JPG / PNG / WebP，每張最大 5MB，自動壓縮至 500KB</p>
              </div>
            </div>
            <div id="image-previews" class="image-previews"></div>
            <div id="upload-progress" class="upload-progress" style="display:none">
              <div class="progress-bar"><div id="progress-fill" class="progress-fill"></div></div>
              <span id="progress-text" class="progress-text">上傳中⋯</span>
            </div>
          </div>
        </fieldset>

        <!-- Turnstile -->
        <div class="nr-turnstile">
          <div class="cf-turnstile" id="turnstile-widget" data-sitekey={turnstileSiteKey} data-theme="light"></div>
        </div>

        <div class="nr-submit-row">
          <button type="submit" id="submit-btn" class="btn-submit">提交通報</button>
          <p class="nr-disclaimer">通報將在審核通過後公開，個人資料受隱私政策保護</p>
        </div>
      </form>
    </div>
  </main>

  <Footer />
</body>
</html>

<script define:vars={{ supabaseUrl, supabaseAnon }}>
import('https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/+esm').then(({ createClient }) => {
  const supabase = createClient(supabaseUrl, supabaseAnon, {
    auth: { flowType: 'pkce', persistSession: true },
  });

  // --- Auth gate ---
  supabase.auth.getSession().then(({ data: { session } }) => {
    const form = document.getElementById('report-form');
    const gate = document.getElementById('auth-gate');
    if (session) {
      form.style.display = 'block';
    } else {
      gate.style.display = 'flex';
    }
  });

  supabase.auth.onAuthStateChange((_event, session) => {
    const form = document.getElementById('report-form');
    const gate = document.getElementById('auth-gate');
    if (session) {
      form.style.display = 'block';
      gate.style.display = 'none';
    } else {
      form.style.display = 'none';
      gate.style.display = 'flex';
    }
  });

  // --- Conditional fields ---
  document.getElementById('visa-type').addEventListener('change', (e) => {
    const show = e.target.value === 'voa';
    document.getElementById('voa-payment-field').style.display = show ? 'block' : 'none';
  });

  document.getElementById('customs-checked').addEventListener('change', (e) => {
    document.getElementById('customs-issue-field').style.display = e.target.checked ? 'block' : 'none';
  });

  document.getElementById('bribe-attempted').addEventListener('change', (e) => {
    document.getElementById('bribe-details-field').style.display = e.target.checked ? 'block' : 'none';
  });

  // --- Char counters ---
  function bindCharCount(textareaId, countId) {
    const ta = document.getElementById(textareaId);
    const cnt = document.getElementById(countId);
    if (!ta || !cnt) return;
    ta.addEventListener('input', () => { cnt.textContent = ta.value.length; });
  }
  bindCharCount('general-notes', 'general-notes-count');
  bindCharCount('customs-issue', 'customs-issue-count');
  bindCharCount('bribe-context', 'bribe-context-count');

  // --- Image upload handling ---
  const MAX_IMAGES = 3;
  const MAX_BYTES = 500 * 1024; // 500KB after compression
  let imageFiles = []; // { file: File, previewUrl: string }

  const uploadZone = document.getElementById('upload-zone');
  const imageInput = document.getElementById('image-input');
  const imagePreviewsEl = document.getElementById('image-previews');

  imageInput.addEventListener('change', (e) => handleFiles(Array.from(e.target.files)));

  uploadZone.addEventListener('dragover', (e) => { e.preventDefault(); uploadZone.classList.add('drag-over'); });
  uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('drag-over'));
  uploadZone.addEventListener('drop', (e) => {
    e.preventDefault();
    uploadZone.classList.remove('drag-over');
    handleFiles(Array.from(e.dataTransfer.files));
  });

  async function handleFiles(files) {
    const remaining = MAX_IMAGES - imageFiles.length;
    const toProcess = files.filter(f => f.type.startsWith('image/')).slice(0, remaining);
    for (const file of toProcess) {
      const compressed = await compressImage(file);
      const previewUrl = URL.createObjectURL(compressed);
      imageFiles.push({ file: compressed, previewUrl });
    }
    renderPreviews();
  }

  async function compressImage(file) {
    return new Promise((resolve) => {
      const img = new Image();
      const url = URL.createObjectURL(file);
      img.onload = () => {
        URL.revokeObjectURL(url);
        const MAX_DIM = 1920;
        let { width, height } = img;
        if (width > MAX_DIM || height > MAX_DIM) {
          const ratio = Math.min(MAX_DIM / width, MAX_DIM / height);
          width = Math.round(width * ratio);
          height = Math.round(height * ratio);
        }
        const canvas = document.createElement('canvas');
        canvas.width = width;
        canvas.height = height;
        const ctx = canvas.getContext('2d');
        ctx.drawImage(img, 0, 0, width, height);

        // Try quality steps until under MAX_BYTES
        let quality = 0.85;
        const attempt = (q) => {
          canvas.toBlob((blob) => {
            if (blob.size <= MAX_BYTES || q <= 0.3) {
              resolve(new File([blob], file.name.replace(/\.\w+$/, '.webp'), { type: 'image/webp' }));
            } else {
              attempt(q - 0.1);
            }
          }, 'image/webp', q);
        };
        attempt(quality);
      };
      img.src = url;
    });
  }

  function renderPreviews() {
    imagePreviewsEl.innerHTML = '';
    imageFiles.forEach((item, i) => {
      const wrap = document.createElement('div');
      wrap.className = 'preview-item';
      const img = document.createElement('img');
      img.src = item.previewUrl;
      img.alt = `預覽 ${i + 1}`;
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'preview-remove';
      btn.textContent = '✕';
      btn.setAttribute('aria-label', '移除此照片');
      btn.addEventListener('click', () => {
        URL.revokeObjectURL(item.previewUrl);
        imageFiles.splice(i, 1);
        renderPreviews();
      });
      wrap.append(img, btn);
      imagePreviewsEl.appendChild(wrap);
    });
    // Reset input so same file can be re-added after removal
    imageInput.value = '';
  }

  async function uploadImages(userId) {
    const urls = [];
    const progressFill = document.getElementById('progress-fill');
    const progressText = document.getElementById('progress-text');
    const progressWrap = document.getElementById('upload-progress');

    if (imageFiles.length === 0) return urls;
    progressWrap.style.display = 'block';

    for (let i = 0; i < imageFiles.length; i++) {
      const { file } = imageFiles[i];
      const timestamp = Date.now();
      const path = `${userId}/${timestamp}-${i}.webp`;
      progressText.textContent = `上傳照片 ${i + 1}/${imageFiles.length}⋯`;
      progressFill.style.width = `${Math.round((i / imageFiles.length) * 100)}%`;

      const { data, error } = await supabase.storage
        .from('report-images')
        .upload(path, file, { contentType: 'image/webp', upsert: false });

      if (error) throw new Error(`圖片上傳失敗：${error.message}`);

      const { data: { publicUrl } } = supabase.storage.from('report-images').getPublicUrl(path);
      urls.push(publicUrl);
    }
    progressFill.style.width = '100%';
    progressText.textContent = '上傳完成';
    return urls;
  }

  // --- Form submission ---
  const form = document.getElementById('report-form');
  const submitBtn = document.getElementById('submit-btn');
  const formError = document.getElementById('form-error');
  const formSuccess = document.getElementById('form-success');

  function showError(msg) {
    formError.textContent = msg;
    formError.style.display = 'block';
    formError.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }
  function hideError() { formError.style.display = 'none'; }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    hideError();

    // Validate Turnstile
    const turnstileToken = document.querySelector('[name="cf-turnstile-response"]')?.value;
    if (!turnstileToken) {
      showError('請完成人機驗證後再提交');
      return;
    }

    // Validate required fields
    const entryDate = document.getElementById('entry-date').value;
    const airport = document.getElementById('airport').value;
    const entryTimeSlot = document.getElementById('entry-time-slot').value;
    const visaType = document.getElementById('visa-type').value;
    const generalNotes = document.getElementById('general-notes').value.trim();

    if (!entryDate || !airport || !entryTimeSlot || !visaType || !generalNotes) {
      showError('請填寫所有必填欄位（標有 * 號）');
      return;
    }

    // Validate date not in the future
    if (new Date(entryDate) > new Date()) {
      showError('入境日期不能是未來日期');
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = '提交中⋯';

    try {
      const { data: { session } } = await supabase.auth.getSession();
      if (!session) {
        window.location.href = '/forum/login/?next=/forum/immigration/new/';
        return;
      }
      const userId = session.user.id;

      // Upload images first
      const proofImageUrls = await uploadImages(userId);

      // Build payload
      const customs_checked = document.getElementById('customs-checked').checked;
      const bribe_attempted = document.getElementById('bribe-attempted').checked;
      const queueVal = document.getElementById('queue-minutes').value;
      const bribeAmountVal = document.getElementById('bribe-amount').value;

      const payload = {
        user_id: userId,
        entry_date: entryDate,
        airport,
        entry_time_slot: entryTimeSlot,
        visa_type: visaType,
        voa_payment_method: visaType === 'voa' ? (document.getElementById('voa-payment').value || null) : null,
        queue_minutes: queueVal !== '' ? parseInt(queueVal, 10) : null,
        customs_checked,
        customs_issue: customs_checked ? (document.getElementById('customs-issue').value.trim() || null) : null,
        bribe_attempted,
        bribe_amount_idr: bribe_attempted && bribeAmountVal !== '' ? parseInt(bribeAmountVal, 10) : null,
        bribe_context: bribe_attempted ? (document.getElementById('bribe-context').value.trim() || null) : null,
        general_notes: generalNotes,
        proof_image_urls: proofImageUrls,
        status: 'pending',
      };

      const { error } = await supabase.from('reports').insert(payload);
      if (error) throw new Error(error.message);

      // Show success
      form.querySelectorAll('fieldset, .nr-turnstile, .nr-submit-row').forEach(el => {
        el.style.display = 'none';
      });
      formSuccess.style.display = 'flex';
      formSuccess.scrollIntoView({ behavior: 'smooth' });

    } catch (err) {
      showError(`提交失敗：${err.message}`);
      submitBtn.disabled = false;
      submitBtn.textContent = '提交通報';
    }
  });
});
</script>

<style>
.new-report-page { padding: 2rem 1rem 4rem; }
.nr-container { max-width: 680px; margin: 0 auto; }

.nr-header { margin-bottom: 2rem; }
.nr-back { font-size: .9rem; color: var(--ocean); text-decoration: none; display: inline-block; margin-bottom: .8rem; }
.nr-back:hover { color: var(--gold); }
.nr-title { font-size: 1.6rem; font-weight: 800; color: var(--ocean); margin: 0 0 .4rem; }
.nr-subtitle { font-size: .9rem; color: var(--text-light); margin: 0; }

/* Auth gate */
.nr-auth-gate {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1rem;
  padding: 3rem 2rem;
  background: #fafaf8;
  border: 1px solid rgba(201,168,76,.2);
  border-radius: 12px;
  text-align: center;
}
.btn-login {
  display: inline-block;
  background: var(--ocean);
  color: #fff;
  padding: .65rem 1.5rem;
  border-radius: 8px;
  text-decoration: none;
  font-weight: 600;
  font-size: .95rem;
}
.btn-login:hover { background: #1a3a6a; }

/* Form */
.nr-form { display: flex; flex-direction: column; gap: 1.5rem; }

.form-error {
  background: #fff5f5;
  border: 1px solid #fca5a5;
  color: #c53030;
  padding: .75rem 1rem;
  border-radius: 8px;
  font-size: .9rem;
}
.form-success {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
  background: #f0fdf4;
  border: 1px solid #86efac;
  color: #166534;
  padding: 1.2rem;
  border-radius: 12px;
}
.success-icon { font-size: 1.8rem; }
.form-success strong { display: block; margin-bottom: .25rem; }
.form-success p { margin: 0 0 .8rem; font-size: .88rem; }
.btn-back-list {
  display: inline-block;
  color: var(--ocean);
  text-decoration: none;
  font-weight: 600;
  font-size: .9rem;
}

/* Fieldset */
.nr-fieldset {
  border: 1px solid rgba(201,168,76,.2);
  border-radius: 12px;
  padding: 1.2rem 1.3rem;
  margin: 0;
}
.nr-fieldset legend {
  font-size: .85rem;
  font-weight: 700;
  color: var(--ocean);
  padding: 0 .4rem;
  text-transform: uppercase;
  letter-spacing: .04em;
}

/* Fields */
.nr-field { display: flex; flex-direction: column; gap: .3rem; margin-bottom: 1rem; }
.nr-field:last-child { margin-bottom: 0; }
.nr-field--inline { flex-direction: row; align-items: center; }

.nr-field label { font-size: .88rem; font-weight: 600; color: var(--text); }
.required { color: #c53030; }

.nr-input, .nr-select, .nr-textarea {
  border: 1px solid #d1c9b5;
  border-radius: 8px;
  padding: .55rem .8rem;
  font-size: .95rem;
  font-family: inherit;
  color: var(--text);
  background: #fff;
  transition: border-color .15s;
  width: 100%;
  box-sizing: border-box;
}
.nr-input:focus, .nr-select:focus, .nr-textarea:focus {
  outline: none;
  border-color: var(--ocean);
  box-shadow: 0 0 0 3px rgba(26,58,93,.1);
}
.nr-input--short { max-width: 200px; }
.nr-textarea { resize: vertical; min-height: 80px; }
.nr-char-count { font-size: .75rem; color: var(--text-light); text-align: right; margin-top: .15rem; }

/* Toggle */
.nr-toggle { display: flex; align-items: center; gap: .7rem; cursor: pointer; user-select: none; }
.toggle-input { position: absolute; opacity: 0; width: 0; height: 0; }
.toggle-track {
  width: 42px; height: 24px;
  background: #d1d5db;
  border-radius: 12px;
  position: relative;
  transition: background .2s;
  flex-shrink: 0;
}
.toggle-track::after {
  content: '';
  position: absolute;
  top: 3px; left: 3px;
  width: 18px; height: 18px;
  background: #fff;
  border-radius: 50%;
  transition: transform .2s;
  box-shadow: 0 1px 3px rgba(0,0,0,.2);
}
.toggle-input:checked + .toggle-track { background: var(--ocean); }
.toggle-input:checked + .toggle-track::after { transform: translateX(18px); }
.toggle-label { font-size: .9rem; color: var(--text); }

/* Upload */
.upload-zone {
  border: 2px dashed #d1c9b5;
  border-radius: 12px;
  padding: 2rem 1rem;
  text-align: center;
  cursor: pointer;
  transition: border-color .15s, background .15s;
  position: relative;
}
.upload-zone:hover, .upload-zone.drag-over { border-color: var(--ocean); background: rgba(26,58,93,.03); }
.upload-input {
  position: absolute; inset: 0;
  opacity: 0; cursor: pointer;
  width: 100%; height: 100%;
}
