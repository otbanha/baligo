---
import BaseHead from '../../../../components/BaseHead.astro';
import Header from '../../../../components/Header.astro';
import TopStrip from '../../../../components/TopStrip.astro';
import Footer from '../../../../components/Footer.astro';

const supabaseUrl  = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseAnon = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
---

<html lang="zh-TW">
<head>
  <BaseHead
    title="發起討論 — 簽證/入境討論區 | Go Bali Go"
    description="在峇里島簽證入境討論區發起新討論，分享你的問題或經驗。"
    noSuffix
  />
  <meta name="robots" content="noindex, nofollow" />
</head>
<body>
  <Header lang="blog" />
  <TopStrip lang="zh-tw" />

  <main class="new-post-page">
    <div class="np-container">
      <div class="np-header">
        <a href="/forum/immigration/" class="np-back">← 返回討論區</a>
        <h1 class="np-title">發起新討論</h1>
        <p class="np-subtitle">選擇主題分類，填寫標題與內容，送出後等待審核即可公開顯示</p>
      </div>

      <div id="auth-gate" style="display:none" class="np-auth-gate">
        <div class="gate-icon">💬</div>
        <p>請先登入才能發起討論</p>
        <a href="/forum/login/?next=/forum/immigration/new/" class="btn-login">使用 Google 登入</a>
      </div>

      <form id="post-form" style="display:none" class="np-form" novalidate>
        <div id="form-error" class="form-error" style="display:none"></div>
        <div id="form-success" class="form-success" style="display:none">
          <span class="success-icon">✓</span>
          <div>
            <strong>討論已成功提交！</strong>
            <p>審核通過後將公開顯示，通常在 24 小時內完成。</p>
            <a href="/forum/immigration/" class="btn-back-list">返回討論區</a>
          </div>
        </div>

        <div class="np-field">
          <label for="topic">討論主題分類 <span class="required">*</span></label>
          <select id="topic" name="topic" required class="np-select">
            <option value="">請選擇主題</option>
            <option value="evisa">電子簽證問題</option>
            <option value="voa">落地簽問題</option>
            <option value="aiac">AIAC 入境卡問題</option>
            <option value="tourism-tax">旅遊稅問題</option>
            <option value="other">其他入境問題</option>
          </select>
        </div>

        <div class="np-field">
          <label for="title">標題 <span class="required">*</span></label>
          <input
            type="text"
            id="title"
            name="title"
            maxlength="100"
            required
            placeholder="簡短描述你的問題或想分享的內容"
            class="np-input"
          />
          <span class="np-char-count"><span id="title-count">0</span>/100</span>
        </div>

        <div class="np-field">
          <label for="content">內容 <span class="required">*</span></label>
          <textarea
            id="content"
            name="content"
            rows="8"
            maxlength="3000"
            required
            placeholder="詳細說明你的問題、經歷或建議。資訊越具體，越能幫助其他旅客。"
            class="np-textarea"
          ></textarea>
          <span class="np-char-count"><span id="content-count">0</span>/3000</span>
        </div>

        <div class="np-submit-row">
          <button type="submit" id="submit-btn" class="btn-submit">送出討論</button>
          <p class="np-disclaimer">送出後將進入審核佇列，通過後即可公開顯示。個人資料受隱私政策保護。</p>
        </div>
      </form>
    </div>
  </main>

  <Footer />
</body>
</html>

<script define:vars={{ supabaseUrl, supabaseAnon }}>
import('https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/+esm').then(({ createClient }) => {
  const supabase = createClient(supabaseUrl, supabaseAnon, {
    auth: { flowType: 'pkce', persistSession: true },
  });

  // --- Auth gate ---
  supabase.auth.getSession().then(({ data: { session } }) => {
    if (session) {
      document.getElementById('post-form').style.display = 'flex';
    } else {
      document.getElementById('auth-gate').style.display = 'flex';
    }
  });

  supabase.auth.onAuthStateChange((_event, session) => {
    if (session) {
      document.getElementById('post-form').style.display = 'flex';
      document.getElementById('auth-gate').style.display = 'none';
    } else {
      document.getElementById('post-form').style.display = 'none';
      document.getElementById('auth-gate').style.display = 'flex';
    }
  });

  // --- Char counters ---
  const titleInput   = document.getElementById('title');
  const contentInput = document.getElementById('content');
  titleInput.addEventListener('input',   () => { document.getElementById('title-count').textContent   = titleInput.value.length; });
  contentInput.addEventListener('input', () => { document.getElementById('content-count').textContent = contentInput.value.length; });

  // --- Form submission ---
  const formError   = document.getElementById('form-error');
  const formSuccess = document.getElementById('form-success');
  const submitBtn   = document.getElementById('submit-btn');

  function showError(msg) {
    formError.textContent = msg;
    formError.style.display = 'block';
    formError.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }
  function hideError() { formError.style.display = 'none'; }

  document.getElementById('post-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    hideError();

    const topic   = document.getElementById('topic').value;
    const title   = titleInput.value.trim();
    const content = contentInput.value.trim();

    if (!topic)   { showError('請選擇討論主題分類'); return; }
    if (!title)   { showError('請填寫標題'); return; }
    if (title.length < 5) { showError('標題至少需要 5 個字元'); return; }
    if (!content) { showError('請填寫內容'); return; }
    if (content.length < 10) { showError('內容至少需要 10 個字元'); return; }

    submitBtn.disabled = true;
    submitBtn.textContent = '送出中⋯';

    try {
      const { data: { session } } = await supabase.auth.getSession();
      if (!session) {
        window.location.href = '/forum/login/?next=/forum/immigration/new/';
        return;
      }

      const { error } = await supabase.from('posts').insert({
        user_id: session.user.id,
        topic,
        title,
        content,
        moderation_status: 'pending',
      });
      if (error) throw new Error(error.message);

      // Show success — hide form fields
      document.querySelectorAll('.np-field, .np-submit-row').forEach(el => el.style.display = 'none');
      formSuccess.style.display = 'flex';
      formSuccess.scrollIntoView({ behavior: 'smooth' });

    } catch (err) {
      showError(`提交失敗：${err.message}`);
      submitBtn.disabled = false;
      submitBtn.textContent = '送出討論';
    }
  });
});
</script>

<style>
.new-post-page { padding: 2rem 1rem 4rem; }
.np-container  { max-width: 640px; margin: 0 auto; }

.np-header { margin-bottom: 2rem; }
.np-back { font-size: .9rem; color: var(--ocean); text-decoration: none; display: inline-block; margin-bottom: .8rem; }
.np-back:hover { color: var(--gold); }
.np-title    { font-size: 1.6rem; font-weight: 800; color: var(--ocean); margin: 0 0 .4rem; }
.np-subtitle { font-size: .9rem;  color: var(--text-light); margin: 0; }

/* Auth gate */
.np-auth-gate {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1rem;
  padding: 3rem 2rem;
  background: #fafaf8;
  border: 1px solid rgba(201,168,76,.2);
  border-radius: 12px;
  text-align: center;
}
.gate-icon { font-size: 2.5rem; }
.btn-login {
  display: inline-block;
  background: var(--ocean);
  color: #fff;
  padding: .65rem 1.5rem;
  border-radius: 8px;
  text-decoration: none;
  font-weight: 600;
  font-size: .95rem;
}
.btn-login:hover { background: #1a3a6a; }

/* Form */
.np-form { display: flex; flex-direction: column; gap: 1.3rem; }

.form-error {
  background: #fff5f5;
  border: 1px solid #fca5a5;
  color: #c53030;
  padding: .75rem 1rem;
  border-radius: 8px;
  font-size: .9rem;
}
.form-success {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
  background: #f0fdf4;
  border: 1px solid #86efac;
  color: #166534;
  padding: 1.2rem;
  border-radius: 12px;
}
.success-icon { font-size: 1.8rem; }
.form-success strong { display: block; margin-bottom: .25rem; }
.form-success p { margin: 0 0 .8rem; font-size: .88rem; }
.btn-back-list {
  display: inline-block;
  color: var(--ocean);
  text-decoration: none;
  font-weight: 600;
  font-size: .9rem;
}

/* Fields */
.np-field { display: flex; flex-direction: column; gap: .35rem; }

.np-field label { font-size: .9rem; font-weight: 600; color: var(--text); }
.required { color: #c53030; }

.np-input, .np-select, .np-textarea {
  border: 1px solid #d1c9b5;
  border-radius: 8px;
  padding: .6rem .85rem;
  font-size: .95rem;
  font-family: inherit;
  color: var(--text);
  background: #fff;
  transition: border-color .15s;
  width: 100%;
  box-sizing: border-box;
}
.np-input:focus, .np-select:focus, .np-textarea:focus {
  outline: none;
  border-color: var(--ocean);
  box-shadow: 0 0 0 3px rgba(26,58,93,.1);
}
.np-textarea { resize: vertical; min-height: 160px; line-height: 1.6; }
.np-char-count { font-size: .75rem; color: var(--text-light); text-align: right; }

/* Submit */
.np-submit-row { display: flex; flex-direction: column; align-items: flex-start; gap: .7rem; padding-top: .3rem; }
.btn-submit {
  background: var(--ocean);
  color: #fff;
  border: none;
  border-radius: 8px;
  padding: .75rem 2rem;
  font-size: 1rem;
  font-weight: 700;
  cursor: pointer;
  transition: background .15s, opacity .15s;
}
.btn-submit:hover:not(:disabled) { background: #1a3a6a; }
.btn-submit:disabled { opacity: .55; cursor: not-allowed; }
.np-disclaimer { font-size: .78rem; color: var(--text-light); margin: 0; line-height: 1.5; }
</style>
