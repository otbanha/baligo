---
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import TopStrip from '../../../components/TopStrip.astro';
import Footer from '../../../components/Footer.astro';

const supabaseUrl  = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseAnon = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
---

<html lang="zh-TW">
<head>
  <BaseHead
    title="峇里島入境通報 — 海關、簽證、排隊即時情報 | Go Bali Go"
    description="由旅客真實分享的峇里島入境體驗：海關檢查、VOA 排隊時間、簽證流程，出發前必看。"
    noSuffix
  />
  <meta name="robots" content="noindex, follow" />
</head>
<body>
  <Header lang="blog" />
  <TopStrip lang="zh-tw" />

  <!-- List View -->
  <main id="view-list" class="forum-main">
    <div class="forum-hero">
      <h1 class="forum-title">峇里島入境通報</h1>
      <p class="forum-subtitle">旅客真實分享的入境體驗 — 海關、簽證、排隊時間即時情報</p>
      <a href="/forum/immigration/new/" class="btn-new-report">+ 發布我的通報</a>
    </div>

    <!-- Filter bar -->
    <div class="filter-bar">
      <select id="filter-visa" class="filter-select">
        <option value="">所有簽證類型</option>
        <option value="voa">落地簽 (VOA)</option>
        <option value="evoa">電子落地簽 (e-VOA)</option>
        <option value="visa-free">免簽</option>
        <option value="kitas">KITAS</option>
      </select>
      <select id="filter-sort" class="filter-select">
        <option value="newest">最新</option>
        <option value="oldest">最舊</option>
      </select>
    </div>

    <div id="reports-list" class="reports-grid">
      <div class="loading-skeleton">載入中⋯</div>
    </div>

    <div id="load-more-wrap" style="text-align:center;margin-top:1.5rem;display:none">
      <button id="load-more-btn" class="btn-load-more">載入更多</button>
    </div>

    <div id="reports-empty" class="reports-empty" style="display:none">
      <p>目前還沒有通報，<a href="/forum/immigration/new/">來第一個分享</a>！</p>
    </div>
  </main>

  <!-- Detail View (hidden by default, shown when URL has #id) -->
  <main id="view-detail" class="forum-main" style="display:none" aria-live="polite">
    <div id="detail-loading" class="loading-skeleton">載入中⋯</div>
    <div id="detail-content"></div>
  </main>

  <Footer lang="zh-tw" />

  <script define:vars={{ supabaseUrl, supabaseAnon }}>
  (async () => {
    const { createClient } = await import('https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/+esm');
    const sb = createClient(supabaseUrl, supabaseAnon);

    // ── Helpers ──────────────────────────────────────────────────────
    const VISA_LABELS = { voa:'落地簽(VOA)', evoa:'電子落地簽(e-VOA)', 'visa-free':'免簽', kitas:'KITAS', other:'其他' };
    const TIME_LABELS = { 'early-morning':'凌晨', morning:'早上', afternoon:'下午', evening:'傍晚', 'late-night':'深夜' };
    const TRUST_LABELS = { new:'新成員', trial:'試用中', trusted:'可信賴', gold:'金牌' };

    function getTrust(approvedCount, lastFlagAt) {
      if (approvedCount >= 10) return 'gold';
      const recentFlag = lastFlagAt && new Date(lastFlagAt) > new Date(Date.now() - 30*86400000);
      if (approvedCount >= 3 && !recentFlag) return 'trusted';
      if (approvedCount >= 1) return 'trial';
      return 'new';
    }

    function daysSince(dateStr) {
      return Math.floor((Date.now() - new Date(dateStr).getTime()) / 86400000);
    }

    function sanitize(str) {
      const d = document.createElement('div');
      d.textContent = str ?? '';
      return d.innerHTML;
    }

    // ── Card template ─────────────────────────────────────────────────
    function renderCard(r) {
      const p = r.user_profiles || {};
      const trust = getTrust(p.approved_count || 0, p.last_flag_at);
      const stale = daysSince(r.entry_date) >= 14;
      const notes = sanitize(r.general_notes.slice(0, 120)) + (r.general_notes.length > 120 ? '⋯' : '');
      const thumb = r.proof_image_urls?.[0]
        ? `<div class="rc-thumb"><img src="${sanitize(r.proof_image_urls[0])}" alt="通報照片" loading="lazy"/></div>` : '';

      return `<article class="report-card${stale ? ' report-card--stale' : ''}">
        <a href="/forum/immigration/#${r.id}" class="report-card-link" data-report-id="${r.id}">
          <header class="rc-header">
            <div class="rc-meta">
              <span class="rc-date">${sanitize(r.entry_date)}</span>
              <span class="rc-dot">·</span>
              <span>${TIME_LABELS[r.entry_time_slot] || r.entry_time_slot}</span>
              ${stale ? '<span class="rc-stale-badge">可能過期</span>' : ''}
            </div>
            <span class="rc-visa">${VISA_LABELS[r.visa_type] || r.visa_type}</span>
          </header>
          <p class="rc-notes">${notes}</p>
          <footer class="rc-footer">
            <div class="rc-flags">
              ${r.customs_checked ? '<span class="rc-flag rc-flag--customs">🔍 海關</span>' : ''}
              ${r.bribe_attempted  ? '<span class="rc-flag rc-flag--bribe">⚠️ 索賄</span>' : ''}
              ${r.queue_minutes != null ? `<span class="rc-flag">⏱ ${r.queue_minutes}分</span>` : ''}
            </div>
            <div class="rc-author">
              ${p.avatar_url ? `<img src="${sanitize(p.avatar_url)}" class="rc-avatar" alt="" loading="lazy"/>` : '<span class="rc-avatar-placeholder">👤</span>'}
              <span class="rc-display-name">${sanitize(p.display_name || '匿名')}</span>
              <span class="trust-badge trust-badge--${trust}">${TRUST_LABELS[trust]}</span>
            </div>
          </footer>
          ${thumb}
        </a>
      </article>`;
    }

    // ── Detail template ───────────────────────────────────────────────
    function renderDetail(r) {
      const p = r.user_profiles || {};
      const trust = getTrust(p.approved_count || 0, p.last_flag_at);
      const stale = daysSince(r.entry_date);
      const expiryHtml = stale >= 30
        ? '<div class="expiry-notice expiry-notice--archived">⚠️ 此通報已超過 30 天，資訊可能已過時。</div>'
        : stale >= 14
        ? '<div class="expiry-notice expiry-notice--warning">⏰ 此通報已超過 14 天，建議參考最新通報。</div>'
        : '';

      const images = (r.proof_image_urls || []).map(u =>
        `<img src="${sanitize(u)}" alt="佐證照片" class="rd-image" loading="lazy"/>`
      ).join('');

      const customsSection = (r.customs_checked && r.customs_issue)
        ? `<section class="rd-section"><h2 class="rd-section-title">海關檢查詳情</h2><pre class="rd-text">${sanitize(r.customs_issue)}</pre></section>` : '';

      const bribeSection = r.bribe_attempted
        ? `<section class="rd-section rd-section--warn"><h2 class="rd-section-title">索賄詳情</h2>
           ${r.bribe_amount_idr ? `<p class="rd-bribe-amount">索賄金額：IDR ${r.bribe_amount_idr.toLocaleString()}</p>` : ''}
           ${r.bribe_context ? `<pre class="rd-text">${sanitize(r.bribe_context)}</pre>` : ''}
           </section>` : '';

      return `<article class="report-detail">
        ${expiryHtml}
        <header class="rd-header">
          <h1 class="rd-title">${sanitize(r.entry_date)} 入境通報 <span class="rd-airport">(${r.airport})</span></h1>
          <div class="rd-meta-row">
            <span>${TIME_LABELS[r.entry_time_slot] || r.entry_time_slot}</span>
            <span class="rd-dot">·</span>
            <span class="rd-visa">${VISA_LABELS[r.visa_type] || r.visa_type}</span>
          </div>
        </header>
        <section class="rd-section">
          <h2 class="rd-section-title">通報摘要</h2>
          <div class="rd-grid">
            ${r.queue_minutes != null ? `<div class="rd-stat"><span class="rd-stat-label">排隊時間</span><span class="rd-stat-value">${r.queue_minutes} 分鐘</span></div>` : ''}
            <div class="rd-stat"><span class="rd-stat-label">海關抽查</span><span class="rd-stat-value">${r.customs_checked ? '有' : '無'}</span></div>
            <div class="rd-stat"><span class="rd-stat-label">遭索賄</span><span class="rd-stat-value${r.bribe_attempted ? ' rd-warn' : ''}">${r.bribe_attempted ? '有' : '無'}</span></div>
          </div>
        </section>
        ${customsSection}
        ${bribeSection}
        <section class="rd-section">
          <h2 class="rd-section-title">入境完整記錄</h2>
          <pre class="rd-text">${sanitize(r.general_notes)}</pre>
        </section>
        ${images ? `<section class="rd-section"><h2 class="rd-section-title">照片佐證</h2><div class="rd-images">${images}</div></section>` : ''}
        <footer class="rd-author">
          <div class="rd-author-info">
            ${p.avatar_url ? `<img src="${sanitize(p.avatar_url)}" class="rd-avatar" alt="" loading="lazy"/>` : '<span>👤</span>'}
            <span class="rd-author-name">${sanitize(p.display_name || '匿名')}</span>
            <span class="trust-badge trust-badge--${trust}">${TRUST_LABELS[trust]}</span>
          </div>
          <span class="rd-posted">發布於 ${new Date(r.created_at).toLocaleDateString('zh-TW')}</span>
        </footer>
        <a href="/forum/immigration/" class="rd-back" id="back-to-list">← 返回列表</a>
      </article>`;
    }

    // ── State ─────────────────────────────────────────────────────────
    let page = 0;
    const PAGE_SIZE = 12;
    let currentVisa = '';
    let currentSort = 'newest';

    // ── List loading ──────────────────────────────────────────────────
    async function loadReports(reset = false) {
      if (reset) { page = 0; document.getElementById('reports-list').innerHTML = ''; }

      let q = sb.from('reports')
        .select('*, user_profiles(display_name, avatar_url, approved_count)')
        .eq('moderation_status', 'approved')
        .order('entry_date', { ascending: currentSort === 'oldest' })
        .range(page * PAGE_SIZE, (page + 1) * PAGE_SIZE - 1);

      if (currentVisa) q = q.eq('visa_type', currentVisa);

      const { data, error } = await q;
      if (error) { console.error(error); return; }

      const list = document.getElementById('reports-list');
      const empty = document.getElementById('reports-empty');
      const loadMoreWrap = document.getElementById('load-more-wrap');

      if (reset && (!data || data.length === 0)) {
        list.innerHTML = '';
        empty.style.display = 'block';
        loadMoreWrap.style.display = 'none';
        return;
      }

      empty.style.display = 'none';
      list.innerHTML += data.map(renderCard).join('');
      page++;
      loadMoreWrap.style.display = data.length === PAGE_SIZE ? 'block' : 'none';
    }

    // ── Detail loading ────────────────────────────────────────────────
    async function loadDetail(id) {
      const loading = document.getElementById('detail-loading');
      const content = document.getElementById('detail-content');
      loading.style.display = 'block';
      content.innerHTML = '';

      const { data, error } = await sb
        .from('reports')
        .select('*, user_profiles(display_name, avatar_url, approved_count, last_flag_at)')
        .eq('id', id)
        .eq('moderation_status', 'approved')
        .single();

      loading.style.display = 'none';

      if (error || !data) {
        content.innerHTML = '<p style="color:#c53030;text-align:center;padding:2rem">找不到此通報，可能已下架。<br><a href="/forum/immigration/">← 返回列表</a></p>';
        return;
      }

      // Hide if archived (30+ days)
      if (daysSince(data.entry_date) >= 30) {
        content.innerHTML = '<p style="color:#c53030;text-align:center;padding:2rem">此通報已超過 30 天自動歸檔。<br><a href="/forum/immigration/">← 返回列表</a></p>';
        return;
      }

      content.innerHTML = renderDetail(data);
    }

    // ── View switching ────────────────────────────────────────────────
    function getHash() { return location.hash.slice(1); }

    function updateView() {
      const id = getHash();
      const listView   = document.getElementById('view-list');
      const detailView = document.getElementById('view-detail');

      if (id) {
        listView.style.display   = 'none';
        detailView.style.display = 'block';
        loadDetail(id);
        document.title = '入境通報詳情 | Go Bali Go';
      } else {
        listView.style.display   = 'block';
        detailView.style.display = 'none';
        document.title = '峇里島入境通報 | Go Bali Go';
      }
    }

    // ── Events ────────────────────────────────────────────────────────
    window.addEventListener('hashchange', updateView);

    document.addEventListener('click', e => {
      const link = e.target.closest('[data-report-id]');
      if (link) {
        e.preventDefault();
        const id = link.dataset.reportId;
        history.pushState(null, '', `/forum/immigration/#${id}`);
        updateView();
        window.scrollTo(0, 0);
      }
      if (e.target.id === 'back-to-list') {
        e.preventDefault();
        history.pushState(null, '', '/forum/immigration/');
        updateView();
        window.scrollTo(0, 0);
      }
    });

    document.getElementById('filter-visa').addEventListener('change', e => {
      currentVisa = e.target.value;
      loadReports(true);
    });
    document.getElementById('filter-sort').addEventListener('change', e => {
      currentSort = e.target.value;
      loadReports(true);
    });
    document.getElementById('load-more-btn').addEventListener('click', () => loadReports(false));

    // ── Init ─────────────────────────────────────────────────────────
    updateView();
    if (!getHash()) loadReports(true);
  })();
  </script>

  <style is:global>
  .forum-main { max-width: 900px; margin: 0 auto; padding: 1.5rem 1rem 3rem; }

  .forum-hero { text-align: center; padding: 2rem 0 1.5rem; }
  .forum-title { font-size: 1.7rem; color: var(--ocean); margin: 0 0 .5rem; font-weight: 700; }
  .forum-subtitle { color: var(--text-light); font-size: .95rem; margin-bottom: 1.2rem; }

  .btn-new-report {
    display: inline-block;
    background: var(--gold);
    color: var(--ocean);
    font-weight: 700;
    font-size: .95rem;
    padding: .65rem 1.6rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background .15s;
  }
  .btn-new-report:hover { background: var(--gold-light); }

  .filter-bar { display: flex; gap: .8rem; margin-bottom: 1.2rem; flex-wrap: wrap; }
  .filter-select {
    border: 1px solid rgba(201,168,76,.3);
    border-radius: 8px;
    padding: .45rem .8rem;
    font-size: .88rem;
    font-family: inherit;
    color: var(--text);
    background: #fff;
    cursor: pointer;
  }

  .reports-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem; }
  .reports-empty { text-align: center; padding: 3rem 0; color: var(--text-light); }
  .loading-skeleton { color: var(--text-light); font-size: .9rem; padding: 2rem 0; text-align: center; }

  .btn-load-more {
    background: #fff;
    border: 1.5px solid rgba(201,168,76,.4);
    color: var(--ocean);
    font-size: .9rem;
    font-weight: 600;
    padding: .6rem 1.8rem;
    border-radius: 8px;
    cursor: pointer;
    font-family: inherit;
    transition: background .15s;
  }
  .btn-load-more:hover { background: rgba(201,168,76,.08); }

  /* Report card styles (duplicated from component for client-rendered cards) */
  .report-card { background:#fff; border:1px solid rgba(201,168,76,.2); border-radius:12px; overflow:hidden; transition:transform .15s,box-shadow .15s; }
  .report-card:hover { transform:translateY(-2px); box-shadow:0 4px 16px rgba(26,54,93,.1); }
  .report-card--stale { border-color:#fcd34d; }
  .report-card-link { display:block; text-decoration:none; color:inherit; padding:1rem; }
  .rc-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:.6rem; flex-wrap:wrap; gap:.4rem; }
  .rc-meta { display:flex; align-items:center; gap:.4rem; font-size:.82rem; color:var(--text-light); }
  .rc-dot { color:#d4c9b5; }
  .rc-stale-badge { background:#fffbeb; color:#92400e; font-size:.68rem; font-weight:700; padding:.1em .5em; border-radius:8px; border:1px solid #fcd34d; }
  .rc-visa { font-size:.78rem; font-weight:700; color:var(--ocean); background:rgba(201,168,76,.12); padding:.15em .6em; border-radius:8px; }
  .rc-notes { font-size:.88rem; line-height:1.65; color:var(--text); margin:0 0 .8rem; }
  .rc-footer { display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:.5rem; }
  .rc-flags { display:flex; flex-wrap:wrap; gap:.4rem; }
  .rc-flag { font-size:.75rem; background:#f8f9fa; border-radius:6px; padding:.15em .55em; color:var(--text-light); }
  .rc-flag--customs { background:#eff6ff; color:#1d4ed8; }
  .rc-flag--bribe   { background:#fff5f5; color:#c53030; }
  .rc-author { display:flex; align-items:center; gap:.4rem; }
  .rc-avatar { width:22px; height:22px; border-radius:50%; object-fit:cover; }
  .rc-avatar-placeholder { font-size:1rem; }
  .rc-display-name { font-size:.8rem; color:var(--text-light); }
  .rc-thumb { margin:.8rem -1rem -1rem; }
  .rc-thumb img { width:100%; height:160px; object-fit:cover; display:block; }

  /* Trust badge */
  .trust-badge { display:inline-block; font-size:.68em; font-weight:700; padding:.15em .6em; border-radius:10px; vertical-align:middle; }
  .trust-badge--new     { background:#f1f5f9; color:#64748b; }
  .trust-badge--trial   { background:#e0f2fe; color:#0369a1; }
  .trust-badge--trusted { background:#dcfce7; color:#166534; }
  .trust-badge--gold    { background:rgba(201,168,76,.2); color:var(--ocean); }

  /* Detail view styles */
  .report-detail { max-width:720px; margin:0 auto; }
  .rd-header { margin-bottom:1.5rem; }
  .rd-title { font-size:1.4rem; color:var(--ocean); margin:0 0 .5rem; font-weight:700; }
  .rd-airport { font-size:.9rem; font-weight:400; color:var(--text-light); }
  .rd-meta-row { display:flex; align-items:center; flex-wrap:wrap; gap:.4rem; font-size:.85rem; color:var(--text-light); }
  .rd-dot { color:#d4c9b5; }
  .rd-visa { font-weight:700; color:var(--ocean); }
  .rd-section { background:#fafaf8; border:1px solid rgba(201,168,76,.15); border-radius:10px; padding:1.1rem 1.2rem; margin-bottom:1rem; }
  .rd-section--warn { background:#fff5f5; border-color:#fca5a5; }
  .rd-section-title { font-size:.88rem; font-weight:700; color:var(--ocean); margin:0 0 .7rem; text-transform:uppercase; letter-spacing:.04em; }
  .rd-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(140px,1fr)); gap:.6rem; }
  .rd-stat { display:flex; flex-direction:column; gap:.15rem; }
  .rd-stat-label { font-size:.75rem; color:var(--text-light); }
  .rd-stat-value { font-size:.95rem; font-weight:600; color:var(--text); }
  .rd-warn { color:#c53030; }
  .rd-bribe-amount { font-size:.9rem; font-weight:700; color:#c53030; margin:0 0 .5rem; }
  .rd-text { white-space:pre-wrap; font-family:inherit; font-size:.9rem; line-height:1.7; color:var(--text); margin:0; }
  .rd-images { display:flex; flex-wrap:wrap; gap:.8rem; }
  .rd-image { max-width:100%; width:280px; border-radius:8px; cursor:zoom-in; }
  .rd-author { display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:.5rem; margin-top:1.5rem; padding-top:1rem; border-top:1px solid rgba(201,168,76,.2); }
  .rd-author-info { display:flex; align-items:center; gap:.6rem; }
  .rd-avatar { width:28px; height:28px; border-radius:50%; object-fit:cover; }
  .rd-author-name { font-size:.88rem; font-weight:600; color:var(--ocean); margin-right:.4rem; }
  .rd-posted { font-size:.8rem; color:var(--text-light); }
  .rd-back { display:inline-block; margin-top:1.2rem; font-size:.9rem; color:var(--ocean); text-decoration:none; }
  .rd-back:hover { color:var(--gold); }

  /* Expiry notice */
  .expiry-notice { display:flex; align-items:flex-start; gap:.5rem; font-size:.84rem; line-height:1.5; border-radius:8px; padding:.65rem .9rem; margin-bottom:1rem; }
  .expiry-notice--warning  { background:#fffbeb; color:#92400e; border:1px solid #fcd34d; }
  .expiry-notice--archived { background:#fef2f2; color:#991b1b; border:1px solid #fca5a5; }
  </style>
</body>
</html>
