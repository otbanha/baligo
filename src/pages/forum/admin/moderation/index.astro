---
import BaseHead from '../../../../components/BaseHead.astro';
import Header from '../../../../components/Header.astro';
import Footer from '../../../../components/Footer.astro';

const supabaseUrl  = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseAnon = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
---

<html lang="zh-TW">
<head>
  <BaseHead title="通報審核後台 — Go Bali Go" description="" noSuffix />
  <meta name="robots" content="noindex, nofollow" />
</head>
<body>
  <Header lang="blog" />

  <main class="mod-page">
    <div class="mod-container">

      <div id="access-denied" style="display:none" class="mod-access-denied">
        <h1>無存取權限</h1>
        <p>此頁面僅限管理員使用。</p>
        <a href="/" class="btn-home">返回首頁</a>
      </div>

      <div id="mod-content" style="display:none">
        <div class="mod-header">
          <h1 class="mod-title">入境通報審核</h1>
          <div class="mod-tab-bar">
            <button class="mod-tab mod-tab--active" data-status="pending">待審核 <span id="pending-count" class="tab-count">0</span></button>
            <button class="mod-tab" data-status="approved">已核准</button>
            <button class="mod-tab" data-status="rejected">已拒絕</button>
          </div>
        </div>

        <div id="mod-list" class="mod-list">
          <div class="mod-loading">載入中⋯</div>
        </div>

        <div id="mod-empty" class="mod-empty" style="display:none">
          <p>此分類目前沒有通報</p>
        </div>
      </div>

      <!-- Report detail panel -->
      <aside id="detail-panel" class="detail-panel" style="display:none">
        <button id="panel-close" class="panel-close" aria-label="關閉">✕</button>
        <div id="panel-content" class="panel-content"></div>
        <div class="panel-actions">
          <button id="btn-approve" class="action-btn action-btn--approve">✓ 核准</button>
          <button id="btn-reject"  class="action-btn action-btn--reject">✕ 拒絕</button>
          <button id="btn-ban"     class="action-btn action-btn--ban">🚫 封禁用戶</button>
        </div>
        <div id="panel-error" class="panel-error" style="display:none"></div>
      </aside>

      <div id="panel-overlay" class="panel-overlay" style="display:none"></div>
    </div>
  </main>

  <Footer />
</body>
</html>

<script define:vars={{ supabaseUrl, supabaseAnon }}>
import('https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/+esm').then(({ createClient }) => {
  const supabase = createClient(supabaseUrl, supabaseAnon, {
    auth: { flowType: 'pkce', persistSession: true },
  });

  let currentStatus = 'pending';
  let currentReportId = null;

  // --- Auth & role check ---
  async function init() {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) {
      window.location.href = '/forum/login/?next=/forum/admin/moderation/';
      return;
    }
    const { data: profile } = await supabase
      .from('user_profiles')
      .select('role')
      .eq('id', session.user.id)
      .single();

    if (!profile || profile.role !== 'admin') {
      document.getElementById('access-denied').style.display = 'block';
      return;
    }
    document.getElementById('mod-content').style.display = 'block';
    loadReports('pending');
    loadPendingCount();
  }

  async function loadPendingCount() {
    const { count } = await supabase
      .from('reports')
      .select('*', { count: 'exact', head: true })
      .eq('moderation_status', 'pending');
    document.getElementById('pending-count').textContent = count ?? 0;
  }

  // --- Load reports ---
  async function loadReports(status) {
    const list = document.getElementById('mod-list');
    const empty = document.getElementById('mod-empty');
    list.innerHTML = '<div class="mod-loading">載入中⋯</div>';
    empty.style.display = 'none';

    const { data: reports, error } = await supabase
      .from('reports')
      .select(`
        id, entry_date, airport, entry_time_slot, visa_type,
        queue_minutes, customs_checked, bribe_attempted,
        general_notes, status, created_at, user_id,
        user_profiles (display_name, avatar_url, approved_count, is_banned)
      `)
      .eq('moderation_status', status)
      .order('created_at', { ascending: false })
      .limit(50);

    if (error) {
      list.innerHTML = `<div class="mod-error">載入失敗：${sanitize(error.message)}</div>`;
      return;
    }
    if (!reports || reports.length === 0) {
      list.innerHTML = '';
      empty.style.display = 'block';
      return;
    }
    list.innerHTML = reports.map(r => renderRow(r)).join('');

    list.querySelectorAll('.mod-row').forEach(row => {
      row.addEventListener('click', () => openPanel(row.dataset.id, reports));
    });
  }

  const TIME_SLOT = { early_morning: '清晨', morning: '上午', afternoon: '下午', evening: '夜間' };
  const VISA = { voa: 'VOA', evoa: 'e-VOA', 'visa-free': '免簽', kitas: 'KITAS' };

  function renderRow(r) {
    const profile = r.user_profiles;
    const banned = profile?.is_banned ? ' <span class="badge-banned">已封禁</span>' : '';
    const bribeWarn = r.bribe_attempted ? ' <span class="badge-bribe">⚠️ 索賄</span>' : '';
    return `
      <div class="mod-row" data-id="${sanitize(r.id)}">
        <div class="row-date">${sanitize(r.entry_date)}<span class="row-airport">${sanitize(r.airport)}</span></div>
        <div class="row-meta">
          <span class="row-slot">${sanitize(TIME_SLOT[r.entry_time_slot] ?? r.entry_time_slot)}</span>
          <span class="row-visa">${sanitize(VISA[r.visa_type] ?? r.visa_type)}</span>
          ${bribeWarn}
        </div>
        <div class="row-notes">${sanitize(r.general_notes.slice(0, 100))}${r.general_notes.length > 100 ? '⋯' : ''}</div>
        <div class="row-author">
          ${sanitize(profile?.display_name ?? '匿名')}${banned}
          <span class="row-approved-count">${profile?.approved_count ?? 0} 篇通過</span>
        </div>
        <div class="row-time">${new Date(r.created_at).toLocaleString('zh-TW')}</div>
      </div>
    `;
  }

  function sanitize(str) {
    if (str == null) return '';
    const div = document.createElement('div');
    div.textContent = String(str);
    return div.innerHTML;
  }

  // --- Detail panel ---
  function openPanel(id, reports) {
    const report = reports.find(r => r.id === id);
    if (!report) return;
    currentReportId = id;

    const profile = report.user_profiles;
    const panel = document.getElementById('detail-panel');
    const overlay = document.getElementById('panel-overlay');
    const content = document.getElementById('panel-content');
    const error = document.getElementById('panel-error');
    error.style.display = 'none';

    content.innerHTML = `
      <h2 class="panel-report-title">${sanitize(report.entry_date)} 入境通報</h2>
      <div class="panel-meta">
        <span>${sanitize(report.airport)}</span> ·
        <span>${sanitize(TIME_SLOT[report.entry_time_slot] ?? report.entry_time_slot)}</span> ·
        <span>${sanitize(VISA[report.visa_type] ?? report.visa_type)}</span>
        ${report.queue_minutes != null ? `· <span>排隊 ${sanitize(String(report.queue_minutes))} 分</span>` : ''}
      </div>
      ${report.customs_checked ? `<div class="panel-flag panel-flag--customs">🔍 有被海關檢查${report.customs_issue ? `<pre class="panel-pre">${sanitize(report.customs_issue)}</pre>` : ''}</div>` : ''}
      ${report.bribe_attempted ? `<div class="panel-flag panel-flag--bribe">⚠️ 有被索賄${report.bribe_amount_idr ? ` IDR ${sanitize(report.bribe_amount_idr.toLocaleString())}` : ''}${report.bribe_context ? `<pre class="panel-pre">${sanitize(report.bribe_context)}</pre>` : ''}</div>` : ''}
      <div class="panel-section">
        <div class="panel-section-title">完整記錄</div>
        <pre class="panel-pre">${sanitize(report.general_notes)}</pre>
      </div>
      ${report.proof_image_urls?.length ? `
        <div class="panel-section">
          <div class="panel-section-title">佐證照片</div>
          <div class="panel-images">
            ${report.proof_image_urls.map(url => `<img src="${sanitize(url)}" class="panel-img" loading="lazy" />`).join('')}
          </div>
        </div>
      ` : ''}
      <div class="panel-author">
        作者：<strong>${sanitize(profile?.display_name ?? '匿名')}</strong>
        ${profile?.is_banned ? '<span class="badge-banned">已封禁</span>' : ''}
        · 已核准通報：${profile?.approved_count ?? 0} 篇
        <br><small>User ID：${sanitize(report.user_id)}</small>
        <br><small>提交時間：${new Date(report.created_at).toLocaleString('zh-TW')}</small>
      </div>
    `;

    // Show/hide action buttons based on status
    document.getElementById('btn-approve').style.display = currentStatus === 'pending' || currentStatus === 'rejected' ? 'inline-flex' : 'none';
    document.getElementById('btn-reject').style.display = currentStatus === 'pending' || currentStatus === 'approved' ? 'inline-flex' : 'none';
    document.getElementById('btn-ban').style.display = !profile?.is_banned ? 'inline-flex' : 'none';

    panel.style.display = 'flex';
    overlay.style.display = 'block';
  }

  function closePanel() {
    document.getElementById('detail-panel').style.display = 'none';
    document.getElementById('panel-overlay').style.display = 'none';
    currentReportId = null;
  }

  document.getElementById('panel-close').addEventListener('click', closePanel);
  document.getElementById('panel-overlay').addEventListener('click', closePanel);

  // --- Moderation actions ---
  async function setReportStatus(id, status) {
    const { error } = await supabase
      .from('reports')
      .update({ moderation_status: status })
      .eq('id', id);
    return error;
  }

  document.getElementById('btn-approve').addEventListener('click', async () => {
    if (!currentReportId) return;
    const err = await setReportStatus(currentReportId, 'approved');
    if (err) { showPanelError(err.message); return; }
    closePanel();
    loadReports(currentStatus);
    loadPendingCount();
  });

  document.getElementById('btn-reject').addEventListener('click', async () => {
    if (!currentReportId) return;
    const err = await setReportStatus(currentReportId, 'rejected');
    if (err) { showPanelError(err.message); return; }
    closePanel();
    loadReports(currentStatus);
    loadPendingCount();
  });

  document.getElementById('btn-ban').addEventListener('click', async () => {
    if (!currentReportId) return;
    if (!confirm('確定要封禁此用戶？此操作將禁止其發布新通報。')) return;

    // Get user_id from current report
    const { data: report } = await supabase
      .from('reports')
      .select('user_id')
      .eq('id', currentReportId)
      .single();

    if (!report) { showPanelError('找不到通報'); return; }

    const { error } = await supabase
      .from('user_profiles')
      .update({ is_banned: true })
      .eq('id', report.user_id);

    if (error) { showPanelError(error.message); return; }
    closePanel();
    loadReports(currentStatus);
  });

  function showPanelError(msg) {
    const el = document.getElementById('panel-error');
    el.textContent = `操作失敗：${msg}`;
    el.style.display = 'block';
  }

  // --- Tab switching ---
  document.querySelectorAll('.mod-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.mod-tab').forEach(t => t.classList.remove('mod-tab--active'));
      tab.classList.add('mod-tab--active');
      currentStatus = tab.dataset.status;
      loadReports(currentStatus);
    });
  });

  init();
});
</script>

<style>
.mod-page { padding: 2rem 1rem 4rem; min-height: 60vh; }
.mod-container { max-width: 1000px; margin: 0 auto; }

.mod-access-denied { text-align: center; padding: 4rem 2rem; }
.btn-home { color: var(--ocean); text-decoration: none; }

/* Header */
.mod-header { margin-bottom: 1.5rem; }
.mod-title { font-size: 1.4rem; font-weight: 800; color: var(--ocean); margin: 0 0 1rem; }
.mod-tab-bar { display: flex; gap: .5rem; flex-wrap: wrap; }
.mod-tab {
  padding: .45rem 1rem;
  border: 1px solid #d1c9b5;
  border-radius: 20px;
  background: #fff;
  font-size: .88rem;
  cursor: pointer;
  color: var(--text);
  transition: background .15s, color .15s;
}
.mod-tab--active { background: var(--ocean); color: #fff; border-color: var(--ocean); }
.tab-count {
  display: inline-block;
  background: #ef4444;
  color: #fff;
  font-size: .7rem;
  font-weight: 700;
  padding: .1em .45em;
  border-radius: 10px;
  margin-left: .3rem;
  vertical-align: middle;
}
.mod-tab--active .tab-count { background: rgba(255,255,255,.3); }

/* List */
.mod-loading { padding: 3rem; text-align: center; color: var(--text-light); }
.mod-error { padding: 1rem; color: #c53030; background: #fff5f5; border-radius: 8px; }
.mod-empty { padding: 3rem; text-align: center; color: var(--text-light); }

.mod-row {
  display: grid;
  grid-template-columns: 110px 1fr 2fr 1fr 120px;
  gap: .6rem;
  align-items: center;
  padding: .9rem 1rem;
  border: 1px solid rgba(201,168,76,.15);
  border-radius: 8px;
  margin-bottom: .5rem;
  background: #fff;
  cursor: pointer;
  transition: background .1s;
}
.mod-row:hover { background: #fafaf8; }

.row-date { font-weight: 700; font-size: .88rem; color: var(--ocean); }
.row-airport { display: block; font-size: .75rem; color: var(--text-light); font-weight: 400; }
.row-meta { display: flex; flex-wrap: wrap; gap: .3rem; font-size: .78rem; }
.row-slot, .row-visa { color: var(--text-light); }
.row-notes { font-size: .83rem; color: var(--text); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.row-author { font-size: .82rem; color: var(--text); }
.row-approved-count { display: block; font-size: .72rem; color: var(--text-light); }
.row-time { font-size: .75rem; color: var(--text-light); text-align: right; }

.badge-banned { background: #fef2f2; color: #991b1b; font-size: .68rem; font-weight: 700; padding: .1em .5em; border-radius: 6px; border: 1px solid #fca5a5; }
.badge-bribe  { background: #fff5f5; color: #c53030; font-size: .72rem; font-weight: 700; padding: .1em .5em; border-radius: 6px; }

/* Detail Panel */
.panel-overlay {
  position: fixed; inset: 0;
  background: rgba(0,0,0,.4);
  z-index: 200;
}
.detail-panel {
  position: fixed;
  top: 0; right: 0; bottom: 0;
  width: min(480px, 100vw);
  background: #fff;
  z-index: 201;
  flex-direction: column;
  overflow-y: auto;
  box-shadow: -4px 0 24px rgba(0,0,0,.15);
}
.panel-close {
  position: sticky; top: 0;
  align-self: flex-end;
  margin: .8rem .8rem 0 0;
  background: none; border: none;
  font-size: 1.2rem; cursor: pointer;
  color: var(--text-light);
  z-index: 1;
}
.panel-content { padding: 0 1.5rem 1rem; flex: 1; }

.panel-report-title { font-size: 1.1rem; font-weight: 800; color: var(--ocean); margin: 0 0 .5rem; }
.panel-meta { font-size: .83rem; color: var(--text-light); margin-bottom: .8rem; }
.panel-flag { font-size: .85rem; padding: .5rem .8rem; border-radius: 8px; margin-bottom: .6rem; }
.panel-flag--customs { background: #eff6ff; color: #1d4ed8; }
.panel-flag--bribe   { background: #fff5f5; color: #c53030; }
.panel-section { margin-bottom: 1rem; }
.panel-section-title { font-size: .78rem; font-weight: 700; color: var(--ocean); text-transform: uppercase; letter-spacing: .04em; margin-bottom: .4rem; }
.panel-pre { white-space: pre-wrap; font-family: inherit; font-size: .88rem; line-height: 1.65; margin: 0; color: var(--text); }
.panel-images { display: flex; flex-wrap: wrap; gap: .5rem; margin-top: .5rem; }
.panel-img { width: 120px; height: 90px; object-fit: cover; border-radius: 6px; }
.panel-author { font-size: .82rem; color: var(--text-light); padding-top: .8rem; border-top: 1px solid rgba(201,168,76,.15); }
.panel-author strong { color: var(--text); }

.panel-actions {
  position: sticky; bottom: 0;
  display: flex; gap: .6rem; flex-wrap: wrap;
  padding: .8rem 1.5rem;
  background: #fff;
  border-top: 1px solid rgba(201,168,76,.2);
}
.action-btn {
  display: inline-flex; align-items: center;
  border: none; border-radius: 8px;
  padding: .55rem 1.1rem;
  font-size: .88rem; font-weight: 600; cursor: pointer;
  transition: opacity .15s;
}
.action-btn:hover { opacity: .85; }
.action-btn--approve { background: #166534; color: #fff; }
.action-btn--reject  { background: #ef4444; color: #fff; }
.action-btn--ban     { background: #1f2937; color: #fff; }

.panel-error {
  margin: 0 1.5rem .8rem;
  background: #fff5f5;
  border: 1px solid #fca5a5;
  color: #c53030;
  padding: .6rem .9rem;
  border-radius: 8px;
  font-size: .85rem;
}

@media (max-width: 640px) {
  .mod-row { grid-template-columns: 90px 1fr; grid-template-rows: auto auto auto; }
  .row-notes { grid-column: 1 / -1; }
  .row-time  { grid-column: 1 / -1; text-align: left; }
}
</style>
