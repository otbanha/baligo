---
export const prerender = true;
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import TopStrip from '../../components/TopStrip.astro';
import Footer from '../../components/Footer.astro';
import TripPlannerContent from '../../components/TripPlannerContent.astro';

const hreflangs = [
  { hreflang: 'zh-TW', href: 'https://gobaligo.id/trip-planner/' },
  { hreflang: 'zh-CN', href: 'https://gobaligo.id/zh-cn/trip-planner/' },
  { hreflang: 'zh-HK', href: 'https://gobaligo.id/zh-hk/trip-planner/' },
  { hreflang: 'en',    href: 'https://gobaligo.id/en/trip-planner/' },
  { hreflang: 'x-default', href: 'https://gobaligo.id/trip-planner/' },
];
---

<!doctype html>
<html lang="zh-HK">
<head>
  <BaseHead
    title="峇里島行程規劃工具｜免費個人化攻略景點推薦 2026"
    description="免費峇里島行程規劃工具，輸入旅遊風格立即獲得個人化景點攻略。分區景點、美食、活動整理清楚，適合第一次去峇里島嘅旅人。"
    hreflangs={hreflangs}
  />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "WebApplication",
        "name": "峇里島行程規劃工具",
        "description": "免費線上峇里島行程規劃工具。依照旅遊風格、天數同偏好，即時產生個人化景點攻略、分區住宿建議同推薦文章。",
        "url": "https://gobaligo.id/zh-hk/trip-planner/",
        "applicationCategory": "TravelApplication",
        "operatingSystem": "Web",
        "inLanguage": "zh-HK",
        "offers": { "@type": "Offer", "price": "0", "priceCurrency": "HKD" },
        "featureList": [
          "旅遊風格選擇（親子、蜜月、朋友、獨遊、長輩）",
          "行程草稿分析與空缺補充",
          "分區景點攻略推薦",
          "個人化住宿區域建議",
          "存成PDF分享旅伴"
        ],
        "provider": {
          "@type": "Organization",
          "name": "Go Bali Go",
          "url": "https://gobaligo.id"
        }
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "主頁", "item": "https://gobaligo.id/zh-hk/" },
          { "@type": "ListItem", "position": 2, "name": "峇里島行程規劃工具", "item": "https://gobaligo.id/zh-hk/trip-planner/" }
        ]
      },
      {
        "@type": "HowTo",
        "name": "3步驟用峇里島行程規劃工具",
        "description": "使用免費峇里島行程規劃工具，依照旅遊風格獲得個人化攻略推薦",
        "step": [
          { "@type": "HowToStep", "position": 1, "name": "選擇旅遊風格", "text": "揀你嘅同行對象、日數、想去嘅區同景點，以及大概嘅預算範圍，全程點擊操作。" },
          { "@type": "HowToStep", "position": 2, "name": "貼上行程草稿", "text": "自選：如果你已有初步行程草稿，可以貼上嚟畀系統幫你搵空缺並補充推薦。" },
          { "@type": "HowToStep", "position": 3, "name": "取得個人化推薦", "text": "系統整理出對應嘅攻略文章、景點推薦、SPA 同美食清單，可存成 PDF 分享旅伴。" }
        ]
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "峇里島自由行要幾日先夠？",
            "acceptedAnswer": { "@type": "Answer", "text": "峇里島面積比想像中大，由南部機場去烏布單程都要 1.5–2 個鐘車程，去東部或北部仲耐。建議最少安排 5 日 4 夜，扣咗頭尾搭機日，實際玩 3 日啱啱好夠走南部（庫塔/水明漾）＋烏布兩大區。如果想加埋努沙佩尼達跳島、火山日出或者東部峇里，至少 7–8 日會玩得比較舒服。少過 4 日容易困喺交通上面，玩起上嚟好趕。" }
          },
          {
            "@type": "Question",
            "name": "第一次去峇里島應該去邊啲區？",
            "acceptedAnswer": { "@type": "Answer", "text": "新手第一次嚟，最經典嘅組合係庫塔/水明漾（住南部）＋烏布（住山區）各 2–3 晚。南部近機場、Shopping 同食肆多、有沙灘，啱放鬆；烏布有梯田、瀑布、SPA、文化市集，係峇里島文化精華區。預算足夠想升級嘅話，可以將南部嗰段換成倉古（潮 Café 同衝浪）或者烏魯瓦圖（懸崖日落）。" }
          },
          {
            "@type": "Question",
            "name": "峇里島親子家庭適合住邊區？",
            "acceptedAnswer": { "@type": "Answer", "text": "親子最推薦努沙杜瓦——五星度假村集中、沙灘平緩安全、區內治安好、推 BB 車都方便。次選係沙努爾，氣氛悠閒、有海龜中心同淺水沙灘，餐廳價錢都唔貴。烏布啱大個少少嘅小朋友體驗梯田、叢林鞦韆、動物園。盡量避開庫塔市中心，車多、人雜、夜店多，唔太啱細路。" }
          },
          {
            "@type": "Question",
            "name": "峇里島蜜月情侶推薦點玩？",
            "acceptedAnswer": { "@type": "Answer", "text": "蜜月最熱門兩大區係烏布（叢林泳池 Villa、雙人 SPA、無邊際泳池）＋烏魯瓦圖（懸崖海景、Rock Bar 日落、私人沙灘）。建議烏布 3 晚配烏魯瓦圖 2–3 晚，前半段森呼吸、後半段海景奢華收尾。預算多啲可以考慮金巴蘭五星海濱度假村，或者加多一晚去吉利群島跳島浮潛。" }
          },
          {
            "@type": "Question",
            "name": "行程規劃工具點用？",
            "acceptedAnswer": { "@type": "Answer", "text": "分三個步驟：(1) 揀你嘅旅行風格（同行者、日數、想去嘅區同景點）；(2) 如果你已經有初步行程草稿，可以貼上嚟畀系統幫你搵空缺；(3) 系統會根據你揀嘅區同風格，整理出對應嘅攻略文章、景點推薦、SPA 同美食清單。全程免註冊、純前端執行，唔會儲存個人資料。" }
          },
          {
            "@type": "Question",
            "name": "規劃結果可以儲存或者分享畀旅伴？",
            "acceptedAnswer": { "@type": "Answer", "text": "可以。結果頁面右下角有「存成 PDF 分享旅伴」掣，一 click 下載成 PDF 檔，方便傳畀屋企人朋友傾。亦可以用「編輯此行程」返上一步調整選項，或者「重新規劃」清空再嚟過。建議規劃完之後存一份 PDF，出發前再對番網站最新文章確認資料。" }
          },
          {
            "@type": "Question",
            "name": "峇里島淡季旺季有咩分別？幾時去最好？",
            "acceptedAnswer": { "@type": "Answer", "text": "峇里島分得好清楚乾季（4–10 月）同雨季（11–3 月）。最佳旅遊月份係 5、6、9 月——天氣穩定、人潮比 7–8 月暑假少、價錢都抵啲。7–8 月同 12 月底跨年係旺季，酒店加價而且要提早 2–3 個月訂房。1–2 月雨季雖然平，但下晝成日有大雷雨，安排戶外行程要留彈性。香港聖誕同農曆新年價錢通常翻倍，想避開嘅話建議早一個禮拜或者遲一個禮拜出發。" }
          }
        ]
      }
    ]
  })} />
</head>
<body>
  <Header lang="zh-hk" basePath="trip-planner" />
  <TopStrip lang={'zh-hk'} />
  <TripPlannerContent lang="zh-hk" />
  <Footer lang="zh-hk" />
</body>
</html>
