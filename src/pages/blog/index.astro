---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ChatBot from '../../components/ChatBot.astro';
import TripPlannerBanner from '../../components/TripPlannerBanner.astro';
import BudgetCalculatorBanner from '../../components/BudgetCalculatorBanner.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection, render } from 'astro:content';
import featuredData from '../../featured.json';
import top5Data from '../../top5.json';

const allPromos = await getCollection('promotions');
const now = new Date();
const activePromos = allPromos.filter(p => !p.data.expiresAt || p.data.expiresAt > now);
const promosJson = JSON.stringify(activePromos.map(p => ({
  title: p.data.title,
  url: p.data.url,
  coverImage: p.data.coverImage || null,
})));

function extractFirstImage(body: string): string {
  const m = body?.match(/!\[.*?\]\((https?:\/\/[^)\s]+)\)/);
  return m ? m[1] : '';
}

// pubDate 儲存為 UTC 午夜（= Bali WITA UTC+8 早上8點）
// pubHour 是 Bali 時間（WITA = UTC+8），例如 7 = 早上7點 Bali = UTC 23:00 前一天
function getPublishTime(p): Date {
  const d = new Date(p.data.pubDate);
  if (p.data.pubHour != null) {
    d.setTime(d.getTime() + (p.data.pubHour - 8) * 3600 * 1000);
  }
  return d;
}
const isPublished = (p) =>
  p.data.pubDate && !p.data.private && getPublishTime(p) <= now;

const allPosts = (await getCollection('blog'))
  .filter(isPublished)
  .map(p => ({
    ...p,
    data: {
      ...p.data,
      pubDate: new Date(p.data.pubDate),
      heroImage: p.data.heroImage || extractFirstImage(p.body),
    }
  }))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const getCategories = (cat) => {
  if (!cat) return [];
  if (Array.isArray(cat)) return cat;
  if (typeof cat === 'string') return [cat];
  return [];
};

const categoryOrder = [
  '新手指南',
  '住宿推薦',
  '峇里島分區攻略',
  '簽證通關',
  '叫車包車',
  '家庭親子',
  '遊記分享',
  '美食景點活動',
  '新聞存檔',
];

const categoryImages: Record<string, string> = {
  '新手指南':       '/cat_pix/1.jpg',
  '住宿推薦':       '/cat_pix/2.jpg',
  '峇里島分區攻略': '/cat_pix/3.jpg',
  '簽證通關':       '/cat_pix/4.jpg',
  '叫車包車':       '/cat_pix/5.jpg',
  '家庭親子':       '/cat_pix/6.jpg',
  '遊記分享':       '/cat_pix/7.jpg',
  '美食景點活動':   '/cat_pix/8.jpg',
  '旅行技巧':       '/cat_pix/9.jpg',
};

const allCategories = [...new Set(allPosts.flatMap(p =>
  getCategories(p.data.category)
).filter(Boolean))];

const categories = [
  ...categoryOrder.filter(c => allCategories.includes(c)),
  ...allCategories.filter(c => !categoryOrder.includes(c)),
];

const categoryCounts = categories.reduce((acc, cat) => {
  acc[cat] = allPosts.filter(p => {
    const cats = getCategories(p.data.category);
    return cats.includes(cat);
  }).length;
  return acc;
}, {});

const allPostsData = allPosts
  .map(p => ({
    id: p.id,
    title: p.data.title,
    heroImage: p.data.heroImage || '',
    category: getCategories(p.data.category),
  }));

// 最新5則住宿推薦
const accommodations = allPosts
  .filter(p => getCategories(p.data.category).includes('住宿推薦'))
  .slice(0, 5)
  .map(p => ({
    id: p.id,
    title: p.data.title,
    heroImage: p.data.heroImage || '',
  }));

// 最新1則新聞存檔（含render）
const allBlogRaw = await getCollection('blog');
const baliNewsRaw = allBlogRaw
  .filter(p => {
    const cats = getCategories(p.data.category);
    return cats.includes('新聞存檔') && isPublished(p);
  })
  .sort((a, b) => getPublishTime(b) - getPublishTime(a))
  .at(0);

const { Content: BaliNewsContent } = baliNewsRaw
  ? await render(baliNewsRaw)
  : { Content: null };

// 求救箱問題（隨機顯示用）
const qaCollection = await getCollection('qa');
const qaData = qaCollection.map(q => ({ title: q.data.title }));

// Top 5 文章
const top5Posts = top5Data.articles
  .map(id => allPosts.find(p => p.id === id))
  .filter(Boolean)
  .slice(0, 6)
  .map(p => ({
    id: p.id,
    title: p.data.title,
  }));

const youtubeVideos = [
  '0fqEvAzAy9A',
  'GivvqCXp11A',
  'H5N5_UuK7TI',
  'EotdDxXHFwE',
  '7JIqxDIyDF0',
  'ePutHL_Ob1Q'
];

const socialLinks = [
  { label: 'FB 粉絲團', url: 'https://www.facebook.com/bali.guide.blog', type: 'facebook' },
  { label: '峇里島/印尼吃喝玩樂', url: 'https://www.facebook.com/groups/indonesia.travelguide', type: 'facebook' },
  { label: '峇里島旅遊', url: 'https://www.facebook.com/groups/baligo', type: 'facebook' },
  { label: 'Instagram', url: 'https://www.instagram.com/go.bali.go/', type: 'instagram' },
  { label: 'YouTube', url: 'https://www.youtube.com/@j_indonesia', type: 'youtube' },
  { label: 'Threads', url: 'https://www.threads.com/@go.bali.go', type: 'threads' },
];
---

<!doctype html>
<html lang="zh-TW">
<head>
  <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} noSuffix={true} />
  <link rel="alternate" hreflang="x-default" href="https://gobaligo.id/blog/" />
  <link rel="alternate" hreflang="zh-TW"     href="https://gobaligo.id/blog/" />
  <link rel="alternate" hreflang="zh-HK"     href="https://gobaligo.id/zh-hk/blog/" />
  <link rel="alternate" hreflang="zh-CN"     href="https://gobaligo.id/zh-cn/blog/" />
  <link rel="alternate" hreflang="en"        href="https://gobaligo.id/en/blog/" />
  <!-- 瀏覽器語言自動偵測：只在同一 session 的第一次進入時生效，?lang=tw 可強制停留 -->
  <script is:inline>
    (function() {
      // ?lang=tw：使用者主動選擇繁體中文，寫入 cookie、移除 lang param
      if (new URLSearchParams(location.search).has('lang')) {
        var p = new URLSearchParams(location.search);
        p.delete('lang');
        var qs = p.toString();
        history.replaceState(null, '', location.pathname + (qs ? '?' + qs : ''));
        document.cookie = 'gobaligo_lang=zh-tw; path=/; max-age=' + (60*60*24*365) + '; SameSite=Lax';
        sessionStorage.setItem('gobaligo_lang_checked', '1');
        return;
      }
      // 同一 session 已偵測過，不重複跳轉
      if (sessionStorage.getItem('gobaligo_lang_checked')) return;
      sessionStorage.setItem('gobaligo_lang_checked', '1');

      // 保留當前 query string（cat、page、q 等），帶到目標語言頁面
      var qs = location.search;

      // 優先尊重 cookie（使用者曾主動選擇語言）
      var cookieLang = (document.cookie.match(/(?:^|;\s*)gobaligo_lang=([^;]+)/) || [])[1];
      if (cookieLang === 'zh-tw') return;
      if (cookieLang === 'zh-cn') { window.location.replace('/zh-cn/blog/' + qs); return; }
      if (cookieLang === 'zh-hk') { window.location.replace('/zh-hk/blog/' + qs); return; }
      if (cookieLang === 'en')    { window.location.replace('/en/blog/' + qs); return; }

      // 沒有 cookie，看瀏覽器語言（檢查整個 navigator.languages 陣列）
      var langs = Array.from(navigator.languages || [navigator.language || '']).map(function(l){ return l.toLowerCase(); });
      function matchAny(fn) { return langs.some(fn); }

      // 繁體中文系列（含 zh-HK：許多 Android 手機回報 zh-HK 而非 zh-TW）→ 留在繁中
      if (matchAny(function(l){
        return l === 'zh-tw' || l === 'zh-hk' || l === 'zh-mo' ||
               l === 'zh-hant' || l.startsWith('zh-hant-');
      })) return;

      // 其他語系：只在確認是簡中或英文時才自動跳轉
      var nav = langs[0] || '';
      var dest = null;
      if (nav.startsWith('en')) dest = '/en/blog/';
      else if (nav === 'zh-cn' || nav === 'zh-hans' || nav === 'zh-sg' || nav === 'zh-my') dest = '/zh-cn/blog/';
      if (dest) window.location.replace(dest + qs);
    })();
  </script>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Go Bali Go 峇里島旅遊攻略",
    "url": "https://gobaligo.id",
    "description": SITE_DESCRIPTION,
    "inLanguage": ["zh-TW", "zh-HK", "zh-CN", "en"],
    "potentialAction": {
      "@type": "SearchAction",
      "target": { "@type": "EntryPoint", "urlTemplate": "https://www.google.com/search?sitesearch=gobaligo.id/blog&q={search_term_string}" },
      "query-input": "required name=search_term_string"
    }
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": "https://gobaligo.id/#organization",
    "name": "Go Bali Go",
    "alternateName": "Go Bali Go 峇里島旅遊攻略",
    "url": "https://gobaligo.id",
    "logo": {
      "@type": "ImageObject",
      "url": "https://gobaligo.id/favicon-32x32.png",
      "width": 32,
      "height": 32
    },
    "sameAs": [
      "https://www.facebook.com/bali.guide.blog",
      "https://www.instagram.com/go.bali.go/",
      "https://www.youtube.com/@j_indonesia",
      "https://www.threads.com/@go.bali.go"
    ],
    "areaServed": {
      "@type": "Place",
      "name": "Bali",
      "address": { "@type": "PostalAddress", "addressCountry": "ID", "addressRegion": "Bali" }
    },
    "knowsAbout": ["Bali travel", "峇里島旅遊", "住宿推薦", "簽證通關", "峇里島分區攻略"]
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "峇里島旅遊分類攻略",
    "url": "https://gobaligo.id/blog/",
    "description": "涵蓋住宿推薦、簽證通關、分區攻略、美食景點等峇里島旅遊主題分類",
    "numberOfItems": 9,
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "新手指南", "url": "https://gobaligo.id/blog/?cat=%E6%96%B0%E6%89%8B%E6%8C%87%E5%8D%97" },
      { "@type": "ListItem", "position": 2, "name": "住宿推薦", "url": "https://gobaligo.id/blog/?cat=%E4%BD%8F%E5%AE%BF%E6%8E%A8%E8%96%A6" },
      { "@type": "ListItem", "position": 3, "name": "峇里島分區攻略", "url": "https://gobaligo.id/blog/?cat=%E5%B3%87%E9%87%8C%E5%B3%B6%E5%88%86%E5%8D%80%E6%94%BB%E7%95%A5" },
      { "@type": "ListItem", "position": 4, "name": "簽證通關", "url": "https://gobaligo.id/blog/?cat=%E7%B0%BD%E8%AD%89%E9%80%9A%E9%97%9C" },
      { "@type": "ListItem", "position": 5, "name": "叫車包車", "url": "https://gobaligo.id/blog/?cat=%E5%8F%AB%E8%BB%8A%E5%8C%85%E8%BB%8A" },
      { "@type": "ListItem", "position": 6, "name": "家庭親子", "url": "https://gobaligo.id/blog/?cat=%E5%AE%B6%E5%BA%AD%E8%A6%AA%E5%AD%90" },
      { "@type": "ListItem", "position": 7, "name": "遊記分享", "url": "https://gobaligo.id/blog/?cat=%E9%81%8A%E8%A8%98%E5%88%86%E4%BA%AB" },
      { "@type": "ListItem", "position": 8, "name": "美食景點活動", "url": "https://gobaligo.id/blog/?cat=%E7%BE%8E%E9%A3%9F%E6%99%AF%E9%BB%9E%E6%B4%BB%E5%8B%95" },
      { "@type": "ListItem", "position": 9, "name": "旅行技巧", "url": "https://gobaligo.id/blog/?cat=%E6%97%85%E8%A1%8C%E6%8A%80%E5%B7%A7" }
    ]
  })} />
</head>
<body>
  <Header />

  <div class="layout">
    <aside class="sidebar" id="sidebar">
      <button class="sidebar-toggle" id="sidebar-toggle" aria-expanded="false">
        📂 文章分類 <span class="toggle-arrow">▼</span>
      </button>
      <div class="sidebar-inner" id="sidebar-inner">
      <div class="sidebar-section">
        <h3 class="sidebar-title">📂 文章分類</h3>
        <ul class="category-list">
          <li>
            <button class="category-item active" data-category="all">
              <span class="cat-name">首頁</span>
            </button>
          </li>
          {categories.map(cat => (
            <li>
              <button class="category-item" data-category={cat}>
                <span class="cat-name">{cat}</span>
                <span class="cat-count">{categoryCounts[cat]}</span>
              </button>
            </li>
          ))}
        </ul>
      </div>
      </div><!-- end sidebar-inner -->
    </aside>

    <main>

      <!-- 首頁專屬區塊（分類時隱藏） -->
      <div id="homepage-blocks">

        <TripPlannerBanner lang="zh-tw" />
        <BudgetCalculatorBanner lang="zh-tw" />

        <!-- Accommodations + Bali News -->
        <div class="top-widgets" id="top-widgets">
          <div class="widget-box">
            <h2 class="widget-title fade-in">🏨 Accommodations</h2>
            {accommodations.length > 0 ? (
              <a href="#" id="accom-link" class="accom-card">
                <div class="accom-image">
                  <img id="accom-img" src={accommodations[0].heroImage} alt="" loading="lazy" />
                </div>
                <div class="accom-body">
                  <p id="accom-title">{accommodations[0].title}</p>
                </div>
              </a>
            ) : (
              <div class="widget-empty">即將推出</div>
            )}
          </div>

          <div class="widget-box">
  <h2 class="widget-title fade-in">📰 Bali News</h2>
  {baliNewsRaw ? (
    <div class="news-scroll">
      <a href={`/blog/${baliNewsRaw.id}/`} class="news-post-date">
        {new Date(baliNewsRaw.data.pubDate).toISOString().split('T')[0]}
      </a>
      <div class="news-body">
        <BaliNewsContent />
      </div>
    </div>
  ) : (
    <div class="widget-empty">即將推出</div>
  )}
</div>
        </div>

        <!-- Top 5 熱門文章 -->
        {top5Posts.length > 0 && (
          <div class="top5-section" id="top5-section">
            <h2 class="section-title fade-in">🔥 本週熱門文章</h2>
            <ul class="top5-list" id="top5-list">
              {top5Posts.map((post, i) => (
                <li class="top5-item" data-index={i}>
                  <a href={`/blog/${post.id}/`}>
                    <span class="top5-num"></span>
                    <span class="top5-title">{post.title}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- YouTube + 求救箱 兩欄 -->
        <div class="yt-qa-row">
          <div class="youtube-section">
            <div class="youtube-player">
              <iframe
                id="yt-iframe"
                width="100%"
                height="100%"
                src=""
                title="峇里島旅遊影片"
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              ></iframe>
            </div>
          </div>
          <div class="qa-widget" id="qa-widget">
            <div class="qa-widget-header">
              <h2 class="qa-widget-title">🆘 峇里島求救箱</h2>
              <a href="/ask/" class="qa-widget-more">看全部 →</a>
            </div>
            <p class="qa-widget-desc">其他人也在問這些問題</p>
            <ul class="qa-widget-list" id="qa-widget-list"></ul>
            <a href="/ask/" class="qa-widget-cta">✉️ 我也有問題想問</a>
          </div>
        </div>

        <!-- 社群媒體 -->
        <div class="social-section">
          {socialLinks.map(s => (
            <a href={s.url} target="_blank" rel="noopener" class={`social-btn ${s.type}`}>
              {s.type === 'facebook' && (
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              )}
              {s.type === 'instagram' && (
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
              )}
              {s.type === 'youtube' && (
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M23.495 6.205a3.007 3.007 0 00-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 00.527 6.205a31.247 31.247 0 00-.522 5.805 31.247 31.247 0 00.522 5.783 3.007 3.007 0 002.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 002.088-2.088 31.247 31.247 0 00.5-5.783 31.247 31.247 0 00-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/></svg>
              )}
              {s.type === 'threads' && (
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.27 8.27 0 004.84 1.56V6.79a4.85 4.85 0 01-1.07-.1z"/></svg>
              )}
              <span>{s.label}</span>
            </a>
          ))}
        </div>

      </div>

      <!-- 分類大標題 -->
      <div id="cat-heading" style="display:none">
        <h1 id="cat-heading-text" class="cat-heading-title"></h1>
      </div>

      <!-- 編輯精選區塊 -->
      <div id="featured-section" style="display:none">
        <h2 class="section-title fade-in">⭐ 編輯精選</h2>
        <div class="featured-grid">
          {[0,1,2].map(i => (
            <a href="#" class="featured-card" data-index={i}>
              <div class="featured-image">
                <img src="" alt="" loading="lazy" />
              </div>
              <div class="featured-body">
                <span class="featured-badge">精選</span>
                <h3></h3>
              </div>
            </a>
          ))}
        </div>
      </div>

      <!-- 文章卡片 -->
      <div class="grid" id="posts-grid">
        {allPosts.map((post) => (
          <a href={`/blog/${post.id}/`} class="card fade-in" data-category={JSON.stringify(getCategories(post.data.category))}>
            <div class="card-image">
              {post.data.heroImage
                ? <img src={post.data.heroImage} alt={post.data.title} loading="lazy" />
                : <div class="card-image-placeholder"><img src="/apple-touch-icon.png" alt="Go Bali Go" /></div>
              }

            </div>
            <div class="card-body">
              <h2 class="card-title">{post.data.title}</h2>
              <p class="card-desc">{post.data.description}</p>
            </div>
          </a>
        ))}
      </div>

      <div id="pagination" class="pagination"></div>

      {activePromos.length > 0 && (
        <div id="promo-block-main">
          <div id="promo-block-index"></div>
        </div>
      )}
    </main>
  </div>

  <ChatBot />
  <Footer />
</body>

<script is:inline define:vars={{ featuredData, allPostsData, youtubeVideos, accommodations, top5Posts, qaData }}>
  window.addEventListener('DOMContentLoaded', () => {

    // Sidebar 收合（手機版）
    const sidebarToggle = document.getElementById('sidebar-toggle');
    const sidebarInner = document.getElementById('sidebar-inner');
    if (sidebarToggle && sidebarInner) {
      sidebarToggle.addEventListener('click', () => {
        const isOpen = sidebarInner.classList.toggle('open');
        sidebarToggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      });
    }

    // 初始化影片（從 API 取得，fallback 到靜態列表）
    let activeVideos = youtubeVideos;
    fetch('/api/videos').then(r => r.ok ? r.json() : null).then(data => {
      if (Array.isArray(data) && data.length > 0) activeVideos = data;
    }).catch(() => {}).finally(() => {
      const randomVideo = activeVideos[Math.floor(Math.random() * activeVideos.length)];
      document.getElementById('yt-iframe').src = `https://www.youtube.com/embed/${randomVideo}?rel=0`;
    });

    // 亂數顯示住宿
    if (accommodations.length > 0) {
      const random = accommodations[Math.floor(Math.random() * accommodations.length)];
      const link = document.getElementById('accom-link');
      const img = document.getElementById('accom-img');
      const title = document.getElementById('accom-title');
      if (link) link.href = `/blog/${random.id}/`;
      if (img) { img.src = random.heroImage; img.alt = random.title; }
      if (title) title.textContent = random.title;
    }

    // 從 KV 載入手動選定的熱門文章，亂數顯示 6 則
    fetch('/api/hot-articles').then(r => r.json()).then(data => {
      if (!Array.isArray(data) || data.length === 0) return;
      const section = document.getElementById('top5-section');
      const list = document.getElementById('top5-list');
      if (!section || !list) return;
      const shuffled = data.slice().sort(() => Math.random() - 0.5).slice(0, 6);
      list.innerHTML = shuffled.map((item, i) => {
        const localTitle = allPostsData.find(p => p.id === item.id)?.title || item.title;
        return `<li class="top5-item" data-index="${i}"><a href="/blog/${item.id}/"><span style="display:inline-block;width:20px;height:20px;flex-shrink:0;background-image:url('/favicon-32x32.png');background-size:cover;background-repeat:no-repeat;border-radius:4px"></span><span class="top5-title">${localTitle}</span></a></li>`;
      }).join('');
      section.style.display = '';
    }).catch(() => {});

    // 從 KV 動態載入精選文章（若有資料則覆蓋靜態清單）
    let dynamicFeatured = null;
    fetch('/api/featured').then(r => r.json()).then(data => {
      if (data && typeof data === 'object' && Object.keys(data).length > 0) {
        dynamicFeatured = data;
        // 若目前已在某分類，重新渲染精選
        if (currentCat && currentCat !== 'all') updateFeatured(currentCat);
      }
    }).catch(() => {});

    const POSTS_PER_PAGE = 18;
    let currentPage = 1;
    let currentCat = 'all';
    let currentQ = '';
    let filteredCards = [];

    const buttons = document.querySelectorAll('.category-item');
    const cards = document.querySelectorAll('.card');

    function updateFeatured(cat) {
      const section = document.getElementById('featured-section');
      const catHeading = document.getElementById('cat-heading');
      const catHeadingText = document.getElementById('cat-heading-text');
      if (catHeading && catHeadingText) {
        if (cat === 'all') {
          catHeading.style.display = 'none';
        } else {
          catHeadingText.textContent = cat;
          catHeading.style.display = 'block';
        }
      }
      const source = dynamicFeatured || featuredData;
      const ids = source[cat] || [];
      if (cat === 'all' || ids.length === 0) {
        section.style.display = 'none';
        return;
      }
      const matchedPosts = ids.map(id => allPostsData.find(p => p.id === id)).filter(Boolean);
      if (matchedPosts.length === 0) { section.style.display = 'none'; return; }
      // 從最多 5 篇中亂數取 3 篇
      const shuffled = matchedPosts.sort(() => Math.random() - 0.5).slice(0, 3);
      const featuredCardEls = document.querySelectorAll('.featured-card');
      featuredCardEls.forEach((card, i) => {
        if (shuffled[i]) {
          card.href = `/blog/${shuffled[i].id}/`;
          card.querySelector('h3').textContent = shuffled[i].title;
          const img = card.querySelector('img');
          if (img) { img.src = shuffled[i].heroImage; img.alt = shuffled[i].title; }
          card.style.display = 'flex';
        } else {
          card.style.display = 'none';
        }
      });
      section.style.display = 'block';
    }

    function buildUrl(cat, page, q = '') {
      const params = new URLSearchParams();
      if (cat !== 'all') params.set('cat', cat);
      if (q) params.set('q', q);
      if (page > 1) params.set('page', String(page));
      return '/blog' + (params.toString() ? '?' + params.toString() : '');
    }

    // Render cards + pagination for current state — no history side effects
    function renderCards() {
      const start = (currentPage - 1) * POSTS_PER_PAGE;
      const end = start + POSTS_PER_PAGE;
      let si = 0;
      filteredCards.forEach((card, i) => {
        if (i >= start && i < end) {
          card.classList.remove('visible');
          card.style.transitionDelay = '';
          card.style.display = 'flex';
          const delay = si++ * 0.1;
          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              card.style.transitionDelay = `${delay}s`;
              card.classList.add('visible');
            });
          });
        } else {
          card.style.display = 'none';
          card.classList.remove('visible');
          card.style.transitionDelay = '';
        }
      });
      updatePagination();
    }

    function updatePagination() {
      const totalPages = Math.ceil(filteredCards.length / POSTS_PER_PAGE);
      const pagination = document.getElementById('pagination');
      pagination.innerHTML = '';
      if (totalPages <= 1) return;

      const prev = document.createElement('button');
      prev.textContent = '← 上一頁';
      prev.className = 'page-btn';
      prev.disabled = currentPage === 1;
      prev.onclick = () => {
        currentPage--;
        window.history.pushState({ cat: currentCat, page: currentPage, q: currentQ }, '', buildUrl(currentCat, currentPage, currentQ));
        renderCards();
        window.scrollTo(0, 0);
      };
      pagination.appendChild(prev);

      const info = document.createElement('span');
      info.className = 'page-info';
      info.textContent = `第 ${currentPage} / ${totalPages} 頁`;
      pagination.appendChild(info);

      const next = document.createElement('button');
      next.textContent = '下一頁 →';
      next.className = 'page-btn';
      next.disabled = currentPage === totalPages;
      next.onclick = () => {
        currentPage++;
        window.history.pushState({ cat: currentCat, page: currentPage, q: currentQ }, '', buildUrl(currentCat, currentPage, currentQ));
        renderCards();
        window.scrollTo(0, 0);
      };
      pagination.appendChild(next);
    }

    // Apply a cat+page+q state to the UI (no history changes)
    function applyState(cat, page, q = '') {
      currentCat = cat;
      currentPage = page;
      currentQ = q;

      buttons.forEach(b => b.classList.remove('active'));
      const activeBtn = document.querySelector(`[data-category="${cat}"]`);
      if (activeBtn) activeBtn.classList.add('active');

      const homepageBlocks = document.getElementById('homepage-blocks');
      if (homepageBlocks) homepageBlocks.style.display = (cat === 'all' && !q) ? 'block' : 'none';

      const qLower = q ? q.toLowerCase() : '';
      filteredCards = [...cards].filter(card => {
        try {
          const cats = JSON.parse(card.dataset.category || '[]');
          const catList = Array.isArray(cats) ? cats : [cats];
          if (catList.includes('新聞存檔') && cat !== '新聞存檔') return false;
          if (cat !== 'all' && !catList.includes(cat)) return false;
        } catch {
          if (card.dataset.category === '新聞存檔' && cat !== '新聞存檔') return false;
          if (cat !== 'all' && card.dataset.category !== cat) return false;
        }
        if (qLower) {
          const title = (card.querySelector('.card-title')?.textContent || '').toLowerCase();
          return title.includes(qLower);
        }
        return true;
      });

      cards.forEach(card => card.style.display = 'none');
      updateFeatured(cat);
      renderCards();
    }

    // Category button click: push new history entry at page 1 (clears q)
    function filterCategory(cat) {
      window.history.pushState({ cat, page: 1, q: '' }, '', buildUrl(cat, 1));
      applyState(cat, 1, '');
      const newVideo = activeVideos[Math.floor(Math.random() * activeVideos.length)];
      const iframe = document.getElementById('yt-iframe');
      if (iframe) iframe.src = `https://www.youtube.com/embed/${newVideo}?rel=0`;
      // 手機版：選完分類後自動收合 sidebar
      if (sidebarInner && window.innerWidth <= 900) {
        sidebarInner.classList.remove('open');
        if (sidebarToggle) sidebarToggle.setAttribute('aria-expanded', 'false');
      }
    }

    buttons.forEach(btn => {
      btn.addEventListener('click', () => filterCategory(btn.dataset.category));
    });

    // Browser back/forward: restore state without pushing new history
    window.addEventListener('popstate', (e) => {
      const state = e.state;
      applyState(state?.cat || 'all', state?.page || 1, state?.q || '');
    });

    // Init: read URL params, stamp state onto current history entry, then render
    const urlParams = new URLSearchParams(window.location.search);
    const catParam = urlParams.get('cat') || 'all';
    const qParam = urlParams.get('q') || '';
    const pageParam = Math.max(1, parseInt(urlParams.get('page') || '1', 10));
    window.history.replaceState({ cat: catParam, page: pageParam, q: qParam }, '', window.location.href);
    applyState(catParam, pageParam, qParam);

  });

  // 求救箱隨機問題
  (function() {
    const list = document.getElementById('qa-widget-list');
    if (!list || !qaData || !qaData.length) return;
    const shuffled = [...qaData].sort(() => Math.random() - 0.5).slice(0, 4);
    shuffled.forEach(q => {
      const li = document.createElement('li');
      const a = document.createElement('a');
      a.href = '/ask/';
      a.textContent = q.title;
      li.appendChild(a);
      list.appendChild(li);
    });
  })();

</script>
</html>

