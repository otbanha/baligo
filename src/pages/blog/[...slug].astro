---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import { readFileSync, readdirSync } from 'fs';
import { join } from 'path';
import matter from 'gray-matter';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const allPaths: any[] = [];

  // 讀取實際檔案名，為舊檔案名生成路由
  const blogDir = join(process.cwd(), 'src/content/blog');
  const files = readdirSync(blogDir).filter(f => f.endsWith('.md') || f.endsWith('.mdx'));
  const fileNameMap = new Map<string, string>(); // slug -> 檔案名（不含副檔名）

  for (const file of files) {
    try {
      const content = readFileSync(join(blogDir, file), 'utf-8');
      const { data } = matter(content);
      const slug = data.slug || file.replace(/\.(md|mdx)$/, '');
      const fileId = file.replace(/\.(md|mdx)$/, '');
      fileNameMap.set(slug, fileId);
    } catch (e) {}
  }

  for (const post of posts) {
    const newSlug = post.data.slug || post.id;
    // 已知的實際檔名（不含副檔名）
    const fileName = fileNameMap.get(newSlug) || newSlug;
    // 只生成乾淨 slug 路由；舊日期碼網址交由 _redirects 的 301 處理，
    // 避免產生 self-canonical 的重複頁（SEO duplicate）。
    allPaths.push({ params: { slug: newSlug }, props: { entry: post, fileName } });
  }

  console.log(`✅ 生成了 ${allPaths.length} 個 blog 路由`);

  return allPaths;
}
type Props = { entry: CollectionEntry<'blog'>; fileName: string };

const { entry: post, fileName: postFileName } = Astro.props;
const { Content, headings } = await render(post);

// 使用 getStaticPaths 傳入的 fileName 直接找到正確的 .md/.mdx 檔案
const blogDir = join(process.cwd(), 'src/content/blog');
const allBlogFiles = readdirSync(blogDir);
const matchFile = allBlogFiles.find(f => f.replace(/\.mdx?$/, '') === postFileName);
const mdPath = join(blogDir, matchFile || postFileName + '.md');

let rawEmbeds: any[] = [];
let firstImage: string = post.data.heroImage || '';
let rawLineQrGuide = false;
try {
  const raw = readFileSync(mdPath, 'utf-8');
  const { data, content } = matter(raw);
  rawEmbeds = data.embeds || [];
  rawLineQrGuide = data.line_qr_guide === true;
  if (!firstImage) {
    const imgMatch = content.match(/!\[.*?\]\((https?:\/\/[^)]+)\)/);
    if (imgMatch) firstImage = imgMatch[1];
  }
} catch (e) {}

const embedMap: Record<string, {platform: string, url: string}> = {};
rawEmbeds.forEach((e: any) => {
  embedMap[e.position] = { platform: e.platform, url: e.url };
});
---

<BlogPost {...post.data} heroImage={firstImage} embedMap={embedMap} body={post.body} headings={headings} lang="zh-tw" slug={post.id} line_qr_guide={rawLineQrGuide}>
  <Content />
</BlogPost>