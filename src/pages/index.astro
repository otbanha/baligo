---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import TopStrip from '../components/TopStrip.astro';
import Footer from '../components/Footer.astro';

const SITE_URL = 'https://gobaligo.id';

const hreflangs = [
  { hreflang: 'zh-TW',     href: `${SITE_URL}/` },
  { hreflang: 'zh-CN',     href: `${SITE_URL}/zh-cn/` },
  { hreflang: 'zh-HK',     href: `${SITE_URL}/zh-hk/` },
  { hreflang: 'en',        href: `${SITE_URL}/en/` },
  { hreflang: 'x-default', href: `${SITE_URL}/` },
];

const schemaWebsite = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Gobaligo 峇里島旅遊指南",
  "alternateName": "Go Bali Go",
  "url": `${SITE_URL}/`,
  "inLanguage": ["zh-TW", "zh-CN", "zh-HK", "en"],
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": `${SITE_URL}/?q={search_term_string}`
    },
    "query-input": "required name=search_term_string"
  }
};

const schemaOrganization = {
  "@context": "https://schema.org",
  "@type": ["Organization", "LocalBusiness"],
  "name": "Gobaligo",
  "url": `${SITE_URL}/`,
  "logo": `${SITE_URL}/images/logo.png`,
  "image": `${SITE_URL}/images/og-home.jpg`,
  "description": "峇里島旅遊中文攻略網站，提供每日匯率、最新資訊、行程規劃工具、住宿推薦。涵蓋684篇文章，包括景點介紹、住宿評測、包車司機推薦、餐廳美食、旅遊工具等。",
  "areaServed": {
    "@type": "City",
    "name": "Bali"
  },
  "sameAs": [
    "https://www.youtube.com/@j_indonesia",
    "https://www.facebook.com/bali.guide.blog"
  ],
  "knowsAbout": [
    "Bali Travel",
    "Bali Tourism",
    "Bali Accommodation",
    "Bali Attractions",
    "Bali Transportation",
    "Bali Restaurants",
    "Travel Planning"
  ]
};

const schemaItemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "峇里島旅遊工具",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "行程規劃工具", "url": `${SITE_URL}/trip-planner/` },
    { "@type": "ListItem", "position": 2, "name": "預算計算器",   "url": `${SITE_URL}/bali-budget-calculator/` },
    { "@type": "ListItem", "position": 3, "name": "景點門票費用", "url": `${SITE_URL}/tickets/` },
    { "@type": "ListItem", "position": 4, "name": "攻略地圖",     "url": `${SITE_URL}/map/` },
  ]
};

const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "峇里島旅遊最佳季節是什麼時候？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "峇里島最佳旅遊季節是乾季（4月-10月），天氣晴朗，降雨量少。5月-9月是最理想的月份，但也是遊客最多的時期。如果要避開人潮，3月或10月也不錯，雖然偶有下雨但較划算。"
      }
    },
    {
      "@type": "Question",
      "name": "峇里島自由行需要多少預算？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "峇里島的預算取決於住宿和用餐選擇。背包客每天約USD 30-50，中等預算遊客USD 60-120，豪華遊客USD 200+。包括機票、住宿、食物、活動和交通。使用我們的預算計算器可獲得個性化估計。"
      }
    },
    {
      "@type": "Question",
      "name": "峇里島需要簽證嗎？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "大多數國家公民可以在到達時獲得落地簽證（VOA），費用約USD 35-75，有效期30天。部分國家可享受30天免簽入境優待。建議出發前檢查印尼駐當地大使館的最新簽證要求。"
      }
    },
    {
      "@type": "Question",
      "name": "峇里島包車還是租摩托車划算？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "包車（Rp 600,000-800,000/天）比租摩托車安全且舒適，特別是對首次訪客。摩托車租賃便宜（約Rp 50,000-100,000/天）但需駕駛經驗。對於觀光和安全考慮，包車通常更值得。查看我們的司機推薦指南獲得可靠的包車選項。"
      }
    },
    {
      "@type": "Question",
      "name": "在峇里島應該在哪裡住宿？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "熱門地區包括克塔（海灘和夜生活）、烏布（藝術和稻田）、塞米亞克（高檔設施）和烏盧瓦圖（懸崖景色）。新手遊客通常選擇克塔或烏布，因為有大量住宿選擇和旅遊設施。"
      }
    }
  ]
};
---

<html lang="zh-TW">
  <head>
    <BaseHead
      title="峇里島旅遊攻略2026｜每日匯率・峇里島新聞・行程規劃・住宿推薦 - Gobaligo"
      description="峇里島旅遊最完整中文攻略。每日更新印尼盾匯率、峇里島最新旅遊資訊，提供免費行程規劃工具、預算計算機、景點門票查詢、住宿推薦，以及叫車包車攻略。700 篇以上文章持續更新。"
      noSuffix={true}
      hreflangs={hreflangs}
      image="https://gobaligo.id/images/og-home.jpg"
    />
    <script type="application/ld+json" set:html={JSON.stringify(schemaWebsite)} />
    <script type="application/ld+json" set:html={JSON.stringify(schemaOrganization)} />
    <script type="application/ld+json" set:html={JSON.stringify(schemaItemList)} />
    <script type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} />
  </head>
  <body>
    <Header />
    <TopStrip lang={'zh-tw'} />
    <main class="homepage-main">
      <div class="loading-container">
        <div class="loading-content">
          <h1 class="loading-title">峇里島旅遊攻略2026</h1>
          <p class="loading-subtitle">正在載入最新旅遊資訊...</p>
          <div class="loading-spinner"></div>
          <p class="loading-alt"><a href="/blog/">無法自動重新導向？點此進入完整攻略</a></p>
        </div>
      </div>
    </main>
    <Footer />
    <script>
      window.addEventListener('load', () => {
        setTimeout(() => {
          window.location.replace('/blog');
        }, 800);
      });
    </script>
    <style>
      .homepage-main {
        min-height: 60vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
      }

      .loading-container {
        display: flex;
        justify-content: center;
        width: 100%;
        max-width: 600px;
      }

      .loading-content {
        text-align: center;
        width: 100%;
      }

      .loading-title {
        font-size: clamp(1.25rem, 5vw, 2rem);
        font-weight: 800;
        margin: 0 0 0.5rem 0;
        color: var(--ocean, #0a3d6b);
        line-height: 1.2;
      }

      .loading-subtitle {
        font-size: clamp(0.9rem, 4vw, 1rem);
        color: #666;
        margin: 0 0 1.5rem 0;
        line-height: 1.4;
      }

      .loading-spinner {
        width: 40px;
        height: 40px;
        border: 3px solid rgba(10, 61, 107, 0.1);
        border-top-color: var(--ocean, #0a3d6b);
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
        margin: 2rem auto 1.5rem;
      }

      @keyframes spin {
        to { transform: rotate(360deg); }
      }

      .loading-alt {
        font-size: 0.85rem;
        margin-top: 1.5rem;
      }

      .loading-alt a {
        color: var(--ocean, #0a3d6b);
        text-decoration: none;
        border-bottom: 1px solid rgba(10, 61, 107, 0.3);
        transition: all 0.15s;
      }

      .loading-alt a:hover {
        color: var(--gold, #c5a059);
        border-bottom-color: var(--gold, #c5a059);
      }

      @media (max-width: 600px) {
        .homepage-main {
          min-height: 50vh;
          padding: 1.5rem 1rem;
        }

        .loading-title {
          margin-bottom: 0.4rem;
        }

        .loading-spinner {
          width: 36px;
          height: 36px;
          margin: 1.5rem auto 1rem;
        }
      }
    </style>
  </body>
</html>
