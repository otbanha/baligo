---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import TopStrip from '../../components/TopStrip.astro';
import Footer from '../../components/Footer.astro';

const SITE_URL = 'https://gobaligo.id';

const hreflangs = [
  { hreflang: 'zh-TW',     href: `${SITE_URL}/` },
  { hreflang: 'zh-CN',     href: `${SITE_URL}/zh-cn/` },
  { hreflang: 'zh-HK',     href: `${SITE_URL}/zh-hk/` },
  { hreflang: 'en',        href: `${SITE_URL}/en/` },
  { hreflang: 'x-default', href: `${SITE_URL}/` },
];

const schemaWebsite = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Gobaligo 峇里島旅遊指南",
  "alternateName": "Go Bali Go",
  "url": `${SITE_URL}/`,
  "inLanguage": ["zh-TW", "zh-CN", "zh-HK", "en"],
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": `${SITE_URL}/?q={search_term_string}`
    },
    "query-input": "required name=search_term_string"
  }
};

const schemaOrganization = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Gobaligo",
  "url": `${SITE_URL}/`,
  "logo": `${SITE_URL}/images/logo.png`,
  "sameAs": [
    "https://www.youtube.com/@j_indonesia",
    "https://www.facebook.com/bali.guide.blog"
  ],
  "description": "Bali travel guide in Chinese — daily IDR exchange rates, latest news, trip planner, hotel recommendations"
};

const schemaItemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Bali Travel Tools",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Trip Planner",       "url": `${SITE_URL}/en/trip-planner/` },
    { "@type": "ListItem", "position": 2, "name": "Budget Calculator",  "url": `${SITE_URL}/en/bali-budget-calculator/` },
    { "@type": "ListItem", "position": 3, "name": "Ticket Prices",      "url": `${SITE_URL}/en/tickets/` },
    { "@type": "ListItem", "position": 4, "name": "Bali Travel Map",    "url": `${SITE_URL}/map/` },
  ]
};
---

<html lang="en">
  <head>
    <BaseHead
      title="Bali Travel Guide 2026 | Daily Exchange Rate, Bali News & Trip Planner - Gobaligo"
      description="The most comprehensive Chinese-language Bali travel guide. Daily IDR exchange rates, latest Bali news, free trip planner, budget calculator, ticket prices, hotel recommendations and transport guides. 686 articles updated regularly."
      noSuffix={true}
      hreflangs={hreflangs}
      image="https://gobaligo.id/images/og-home.jpg"
    />
    <script type="application/ld+json" set:html={JSON.stringify(schemaWebsite)} />
    <script type="application/ld+json" set:html={JSON.stringify(schemaOrganization)} />
    <script type="application/ld+json" set:html={JSON.stringify(schemaItemList)} />
  </head>
  <body>
    <Header lang="en" />
  <TopStrip lang={'en'} />
    <main style="min-height:60vh;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:1rem;padding:2rem;text-align:center">
      <h1 style="font-size:1.5rem;margin:0">Bali Travel Guide 2026</h1>
      <p style="color:#666;margin:0">Loading the latest travel info...</p>
    </main>
    <Footer lang="en" />
    <script>window.location.replace('/en/blog');</script>
  </body>
</html>
