---
import { getCollection, render } from 'astro:content';
import BlogPost from '../../../layouts/BlogPost.astro';
import { readFileSync, readdirSync } from 'fs';
import { join } from 'path';
import matter from 'gray-matter';

export async function getStaticPaths() {
  const blogPosts = await getCollection('blog');
  const langPosts = await getCollection('en');
  const langMap = new Map(langPosts.map(p => [p.id, p]));
  const blogMap = new Map(blogPosts.map(p => [p.id, p]));

  // Combine both collections, preferring lang collection if available
  const uniqueIds = new Set<string>();
  const paths: any[] = [];

  // Add entries from blog collection
  for (const blogPost of blogPosts) {
    const id = blogPost.id;
    uniqueIds.add(id);
    const post = langMap.get(id) ?? blogPost;
    paths.push({
      params: { slug: post.data.slug || id },
      props: { post },
    });
  }

  // Add entries from en collection that don't exist in blog collection
  for (const langPost of langPosts) {
    const id = langPost.id;
    if (!uniqueIds.has(id)) {
      paths.push({
        params: { slug: langPost.data.slug || id },
        props: { post: langPost },
      });
    }
  }

  return paths;
}

const { post } = Astro.props;
const { Content, headings } = await render(post as any);

const blogDir = join(process.cwd(), 'src/content/blog');
let rawEmbeds: any[] = [];
let firstImage: string = post.data.heroImage || '';
try {
  const files = readdirSync(blogDir);
  const matchFile = files.find(f => f.replace(/\.mdx?$/, '') === post.id);
  if (matchFile) {
    const raw = readFileSync(join(blogDir, matchFile), 'utf-8');
    const { data, content } = matter(raw);
    rawEmbeds = data.embeds || [];
    if (!firstImage) {
      const imgMatch = content.match(/!\[.*?\]\((https?:\/\/[^)]+)\)/);
      if (imgMatch) firstImage = imgMatch[1];
    }
  }
} catch (e) {}

const embedMap: Record<string, {platform: string, url: string}> = {};
rawEmbeds.forEach((e: any) => {
  embedMap[e.position] = { platform: e.platform, url: e.url };
});

// Debug: check if drivers data is available
const driverData = (post.data as any).drivers;
const isDriverGuideFlag = (post.data as any).isDriverGuide;
---

<BlogPost {...post.data} heroImage={firstImage} embedMap={embedMap} body={post.body} headings={headings} lang="en" slug={post.id} drivers={driverData} isDriverGuide={isDriverGuideFlag}>
  <Content />
</BlogPost>
