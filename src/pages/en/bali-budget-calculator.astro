const CS_OFF = 'padding:10px 12px;border-radius:8px;border:1px solid #e0ddd6;background:#fafaf8;cursor:pointer;box-sizing:border-box;';
const CS_ON  = 'padding:10px 12px;border-radius:8px;border:2px solid #1a6fa8;background:#eef5fb;cursor:pointer;box-sizing:border-box;';

function bbcSelT(el, val) {
  document.querySelectorAll('#bbc-t-opts > div').forEach(d => {
    d.style.cssText = CS_OFF;
    d.querySelectorAll('div')[1].style.color = '#999';
  });
  el.style.cssText = CS_ON;
  el.querySelectorAll('div')[1].style.color = '#1a6fa8';
  document.getElementById('bbc-vd-row').style.display = (val==='van5'||val==='van10'||val==='unsure') ? 'flex' : 'none';
  bbcCalc();
}

function bbcSelM(el, val) {
  document.querySelectorAll('#bbc-meal-opts > div').forEach(d => {
    d.style.cssText = CS_OFF;
    d.querySelectorAll('div')[1].style.color = '#999';
  });
  el.style.cssText = CS_ON;
  el.querySelectorAll('div')[1].style.color = '#1a6fa8';
  bbcCalc();
}

function bbcGetT() {
  const el = document.querySelector('#bbc-t-opts > div[style*="2px solid"]');
  return el ? el.dataset.v : 'van5';
}
function bbcGetM() {
  const el = document.querySelector('#bbc-meal-opts > div[style*="2px solid"]');
  return el ? el.dataset.v : 'balanced';
}

function bbcAttrPrice(item) {
  if (item.usdMin !== undefined) return item.usdMin===item.usdMax ? '$'+item.usdMin : '$'+item.usdMin+'–$'+item.usdMax;
  if (item.iMin === 0) return 'Free';
  const a = +(item.iMin/BBC_IDR).toFixed(2), b = +(item.iMax/BBC_IDR).toFixed(2);
  return a===b ? '$'+a : '$'+a+'–$'+b;
}

function bbcActPrice(item) {
  if (item.type==='d150') return '$150 ÷ group';
  if (item.type==='d100') return '$100 ÷ group';
  if (item.type==='kintamani'||item.type==='tubing') return 'per group';
  return item.mn===item.mx ? '$'+item.mn : '$'+item.mn+'–$'+item.mx;
}

const CHIP_OFF = 'display:flex;align-items:flex-start;gap:8px;padding:10px 12px;border-radius:8px;border:1px solid #e0ddd6;background:#fafaf8;cursor:pointer;box-sizing:border-box;';
const CHIP_ON  = 'display:flex;align-items:flex-start;gap:8px;padding:10px 12px;border-radius:8px;border:2px solid #1a6fa8;background:#eef5fb;cursor:pointer;box-sizing:border-box;';

function bbcBuildList(items, cid, priceFn) {
  const c = document.getElementById(cid);
  c.innerHTML = '';
  items.forEach(item => {
    const noteStr = item.note ? item.note + '・' : '';
    const wrap = document.createElement('div');
    wrap.style.cssText = CHIP_OFF;
    wrap.innerHTML = `
      <input type="checkbox" id="${item.id}" style="width:15px;height:15px;flex-shrink:0;margin-top:2px;accent-color:#1a6fa8;cursor:pointer;" />
      <div style="flex:1;min-width:0;">
        <div style="font-size:13px;font-weight:500;color:#1a1a1a;line-height:1.4;">${item.name}</div>
        <div class="bbc-sub-price" style="font-size:11px;color:#999;margin-top:3px;">${noteStr}${priceFn(item)}</div>
      </div>`;
    wrap.onclick = function(e) {
      if (e.target.tagName !== 'INPUT') {
        const cb = wrap.querySelector('input'); cb.checked = !cb.checked;
      }
      const on = wrap.querySelector('input').checked;
      wrap.style.cssText = on ? CHIP_ON : CHIP_OFF;
      wrap.querySelector('.bbc-sub-price').style.color = on ? '#1a6fa8' : '#999';
      bbcCalc();
    };
    c.appendChild(wrap);
  });
}

function bbcFmt(mn, mx) { mn=Math.round(mn); mx=Math.round(mx); return mn===mx ? '$'+mn : '$'+mn+'–$'+mx; }

let bbcLastRecs = [];

function bbcCalc() {
  const days  = +document.getElementById('bbc-days').value;
  const ppl   = +document.getElementById('bbc-people').value;
  const vdays = +document.getElementById('bbc-van-days').value;
  const transport = bbcGetT(), meal = bbcGetM();
  const spaN = +document.getElementById('bbc-spa-n').value || 0;
  const bcN  = +document.getElementById('bbc-bc-n').value  || 0;
  document.getElementById('bbc-tips-p').textContent = '$' + (20*days);

  let rows=[], totMin=0, totMax=0;
  function add(lbl,mn,mx,formula){rows.push({lbl,mn,mx,formula});totMin+=mn;totMax+=mx;}

  if(transport==='van5'||transport==='unsure'){const v=(40*vdays)/ppl;add('Private Car (5-seat)',v,v,`$40 × ${vdays} days ÷ ${ppl} pax = $${Math.round(v)}`);}
  else if(transport==='van10'){const v=(90*vdays)/ppl;add('Private Car (10-seat)',v,v,`$90 × ${vdays} days ÷ ${ppl} pax = $${Math.round(v)}`);}
  else if(transport==='scooter'){const v=ppl===1?6*days:(6*days)/2;add('Scooter Rental',v,v,ppl===1?`$6 × ${days} days = $${Math.round(v)}`:`$6 × ${days} days ÷ 2 (shared) = $${Math.round(v)}`);}
  else if(transport==='grab'){const v=(15*days)/ppl;add('Ride-hailing (Gojek/Grab)',v,v,`$15 × ${days} days ÷ ${ppl} pax = $${Math.round(v)}`);}

  let aMin=0,aMax=0,aCnt=0,aParts=[];
  BBC_ATTRS.forEach(item=>{
    const cb=document.getElementById(item.id);if(!cb||!cb.checked)return;
    let mn,mx;
    if(item.usdMin!==undefined){mn=item.usdMin;mx=item.usdMax;}else{mn=item.iMin/BBC_IDR;mx=item.iMax/BBC_IDR;}
    aMin+=mn;aMax+=mx;aCnt++;
    const p=(item.iMin===0&&item.usdMin===undefined)?'Free':(mn===mx?`$${+(mn).toFixed(2)}`:`$${+(mn).toFixed(2)}–$${+(mx).toFixed(2)}`);
    aParts.push(`${item.name} ${p}`);
  });
  if(aCnt>0) add(`Attraction Tickets (${aCnt})`,aMin,aMax,aParts.join('　'));

  let acMin=0,acMax=0,acCnt=0,acParts=[];
  BBC_ACTS.forEach(item=>{
    const cb=document.getElementById(item.id);if(!cb||!cb.checked)return;
    let mn=0,mx=0,f='';
    if(item.type==='d150'){mn=mx=150/ppl;f=`${item.name}: $150 ÷ ${ppl} pax = $${Math.round(mn)}`;}
    else if(item.type==='d100'){mn=mx=100/ppl;f=`${item.name}: $100 ÷ ${ppl} pax = $${Math.round(mn)}`;}
    else if(item.type==='kintamani'){mn=mx=ppl===1?100:50;f=`${item.name}: ${ppl===1?'Solo $100':'2–4 pax each $50'}`;}
    else if(item.type==='tubing'){const v=ppl===1?50:ppl===2?32:ppl<=4?25:21;mn=mx=v;f=`${item.name}: ${ppl} pax → $${v} each`;}
    else{mn=item.mn;mx=item.mx;f=mn===mx?`${item.name}: $${mn}`:`${item.name}: $${mn}–$${mx}`;}
    acMin+=mn;acMax+=mx;acCnt++;acParts.push(f);
  });
  if(spaN>0){acMin+=spaN*30;acMax+=spaN*100;acCnt++;acParts.push(`Spa ${spaN}x: $${spaN*30}–$${spaN*100}`);}
  if(bcN>0){acMin+=bcN*20;acMax+=bcN*40;acCnt++;acParts.push(`Beach/Jungle Club ${bcN}x: $${bcN*20}–$${bcN*40}`);}
  if(acCnt>0) add(`Activities (${acCnt})`,acMin,acMax,acParts.join('　'));

  const md=days-1;
  if(meal==='luxury') add('Food (Splurge)',100*md,200*md,`$100–$200 × ${md} days = $${100*md}–$${200*md}`);
  else if(meal==='balanced') add('Food (Balanced)',30*md,60*md,`$30–$60 × ${md} days = $${30*md}–$${60*md}`);
  else add('Food (Budget)',10*md,20*md,`$10–$20 × ${md} days = $${10*md}–$${20*md}`);
  add('Tips / Shopping',20*days,20*days,`$20 × ${days} days = $${20*days}`);

  const ts=bbcFmt(totMin,totMax);
  document.getElementById('bbc-total-disp').textContent=ts;
  document.getElementById('bbc-total2').textContent=ts;
  document.getElementById('bbc-breakdown').innerHTML=rows.map(r=>
    `<div style="padding:8px 0;border-bottom:1px solid #f0ede6;">
      <div style="display:flex;justify-content:space-between;align-items:baseline;">
        <span style="font-size:14px;color:#555;">${r.lbl}</span>
        <span style="font-size:14px;font-weight:600;color:#1a1a1a;white-space:nowrap;margin-left:12px;">${bbcFmt(r.mn,r.mx)}</span>
      </div>
      ${r.formula?`<div style="font-size:11px;color:#bbb;margin-top:3px;line-height:1.5;">${r.formula}</div>`:''}
    </div>`
  ).join('');

  const seen=new Set(),dynItems=[];
  BBC_ATTRS.forEach(item=>{const cb=document.getElementById(item.id);
    if(cb&&cb.checked&&item.lk&&BBC_LINKS[item.lk]&&!seen.has(item.lk)){seen.add(item.lk);dynItems.push({name:item.name,url:BBC_LINKS[item.lk]});}
  });
  BBC_ACTS.forEach(item=>{const cb=document.getElementById(item.id);
    if(cb&&cb.checked&&item.lk&&BBC_LINKS[item.lk]&&!seen.has(item.lk)){seen.add(item.lk);dynItems.push({name:item.name,url:BBC_LINKS[item.lk]});}
  });
  if(spaN>0&&!seen.has('Spa')){seen.add('Spa');dynItems.push({name:'Spa & Massage Guide',url:BBC_LINKS['Spa']});}
  bbcLastRecs=[BBC_FIXED_TOP,...dynItems,BBC_FIXED_BTM];
  document.getElementById('bbc-rec-links').innerHTML=bbcLastRecs.map(r=>
    `<a href="${r.url}" target="_blank" style="display:flex;align-items:center;justify-content:space-between;padding:9px 13px;border-radius:8px;border:1px solid #e0ddd6;text-decoration:none;background:#fafaf8;margin-bottom:0;">
      <span style="font-size:13px;color:#1a1a1a;">${r.name}</span>
      <span style="font-size:13px;color:#bbb;margin-left:8px;">→</span>
    </a>`
  ).join('');
}

function bbcReset() {
  document.getElementById('bbc-days').value='5';
  document.getElementById('bbc-people').value='2';
  document.getElementById('bbc-van-days').value='3';
  document.getElementById('bbc-spa-n').value='0';
  document.getElementById('bbc-bc-n').value='0';
  document.getElementById('bbc-vd-row').style.display='flex';
  document.querySelectorAll('#bbc-t-opts > div').forEach(d=>{
    d.style.cssText=CS_OFF; d.querySelectorAll('div')[1].style.color='#999';
  });
  const van5=document.querySelector('#bbc-t-opts > div[data-v="van5"]');
  van5.style.cssText=CS_ON; van5.querySelectorAll('div')[1].style.color='#1a6fa8';
  document.querySelectorAll('#bbc-meal-opts > div').forEach(d=>{
    d.style.cssText=CS_OFF; d.querySelectorAll('div')[1].style.color='#999';
  });
  const bal=document.querySelector('#bbc-meal-opts > div[data-v="balanced"]');
  bal.style.cssText=CS_ON; bal.querySelectorAll('div')[1].style.color='#1a6fa8';
  document.querySelectorAll('#bbc-attr-list > div, #bbc-act-list > div').forEach(wrap=>{
    const cb=wrap.querySelector('input');
    if(cb) cb.checked=false;
    wrap.style.cssText=CHIP_OFF;
    const sub=wrap.querySelector('.bbc-sub-price');
    if(sub) sub.style.color='#999';
  });
  bbcCalc();
}

function bbcPDF() {
  const days=document.getElementById('bbc-days').value;
  const ppl=document.getElementById('bbc-people').value;
  const total=document.getElementById('bbc-total-disp').textContent;
  const rowEls=[...document.querySelectorAll('#bbc-breakdown > div')];
  const rowsHTML=rowEls.map(r=>{
    const spans=r.querySelectorAll('span');
    const lbl=spans[0]?.textContent||'';
    const val=spans[1]?.textContent||'';
    const sub=r.querySelector('div[style*="11px"]');
    const formula=sub?.textContent||'';
    return `<tr><td style="padding:7px 0;color:#555;font-size:13px;vertical-align:top;border-bottom:1px solid #eee;">${lbl}${formula?`<div style="font-size:11px;color:#aaa;margin-top:2px;">${formula}</div>`:''}</td><td style="padding:7px 0;font-weight:600;font-size:13px;text-align:right;vertical-align:top;border-bottom:1px solid #eee;white-space:nowrap;">${val}</td></tr>`;
  }).join('');
  const recHTML=bbcLastRecs.map(r=>`<div style="margin:5px 0;"><a href="${r.url}" style="color:#C5A059;text-decoration:none;font-size:13px;">${r.name}</a></div>`).join('');

  const footerHTML=`<a href="https://gobaligo.id" style="display:flex;align-items:center;gap:14px;text-decoration:none;">
    <img src="https://gobaligo.id/favicon-32x32.png" width="36" height="36" style="border-radius:6px;flex-shrink:0;" />
    <div>
      <div style="font-size:17px;font-weight:700;color:#C5A059;letter-spacing:0.02em;">Go Bali Go Travel Guide</div>
      <div style="font-size:13px;color:rgba(197,160,89,0.75);margin-top:3px;">gobaligo.id</div>
    </div>
  </a>`;

  const html=`<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Bali Trip Budget</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      color: #222;
      padding-bottom: 100px;
    }
    .page-body {
      max-width: 580px;
      margin: 40px auto;
      padding: 0 24px;
    }
    .pdf-footer {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      background: #1A365D;
      padding: 16px 32px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      z-index: 999;
      min-height: 72px;
    }
    .pdf-footer-note {
      font-size: 13px;
      color: rgba(197,160,89,0.7);
      line-height: 1.7;
      text-align: right;
    }
    @media print {
      .pdf-footer {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }
      body { padding-bottom: 100px; }
    }
  </style>
</head>
<body>

  <div class="page-body">
    <h1 style="font-size:20px;font-weight:600;margin:0 0 6px;color:#1A365D;">Bali Trip Budget Estimate</h1>
    <div style="font-size:12px;color:#999;margin-bottom:6px;">Excludes flights and accommodation</div>
    <div style="font-size:12px;color:#888;margin-bottom:20px;">${days} days · ${ppl} pax · estimated cost per person</div>
    <div style="font-size:38px;font-weight:700;color:#1A365D;margin-bottom:6px;">${total} <span style="font-size:18px;font-weight:500;color:#888;">USD</span></div>
    <div style="font-size:11px;color:#aaa;margin-bottom:24px;">Rough estimate — actual spend varies by lifestyle</div>

    <div style="font-size:11px;font-weight:600;color:#888;letter-spacing:.06em;text-transform:uppercase;margin-bottom:8px;">COST BREAKDOWN</div>
    <table style="width:100%;border-collapse:collapse;margin-bottom:20px;">${rowsHTML}</table>
    <div style="display:flex;justify-content:space-between;font-size:15px;font-weight:700;padding:12px 0;border-top:2px solid #1A365D;border-bottom:1px solid #eee;margin-bottom:28px;color:#1A365D;">
      <span>Total</span><span>${total} USD</span>
    </div>

    <div style="font-size:11px;font-weight:600;color:#888;letter-spacing:.06em;text-transform:uppercase;margin-bottom:10px;">RECOMMENDED GUIDES</div>
    <div style="background:#f7f5f0;border-radius:8px;padding:14px 16px;margin-bottom:8px;">${recHTML}</div>
  </div>

  <div class="pdf-footer">
    ${footerHTML}
    <div class="pdf-footer-note">Rough estimate only\nActual costs vary</div>
  </div>

</body>
</html>`;

  const blob=new Blob([html],{type:'text/html'});
  const url=URL.createObjectURL(blob);
  const w=window.open(url,'_blank');
  if(w) setTimeout(()=>w.print(),600);
}

bbcBuildList(BBC_ATTRS,'bbc-attr-list',bbcAttrPrice);
bbcBuildList(BBC_ACTS,'bbc-act-list',bbcActPrice);
bbcCalc();
bbcFetchRate(); // async rate fetch, auto-updates on completion
</script>
