---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import TopStrip from '../../components/TopStrip.astro';
import Footer from '../../components/Footer.astro';
import BaliWeather from '../../components/BaliWeather.astro';

const SITE_URL = 'https://gobaligo.id';
const lang = 'en';
const title = 'Bali Weather Forecast 2026 | Live Temperature & 7-Day Forecast - Gobaligo';
const description = 'Live Bali weather forecast for Kuta, Ubud and Nusa Dua. Check today\'s temperature, rain probability, wind speed, UV index and 7-day outlook — plan your trip with confidence.';

const hreflangs = [
  { hreflang: 'zh-TW',     href: `${SITE_URL}/weather/` },
  { hreflang: 'zh-CN',     href: `${SITE_URL}/zh-cn/weather/` },
  { hreflang: 'zh-HK',     href: `${SITE_URL}/zh-hk/weather/` },
  { hreflang: 'en',        href: `${SITE_URL}/en/weather/` },
  { hreflang: 'x-default', href: `${SITE_URL}/weather/` },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": `${SITE_URL}/en/` },
        { "@type": "ListItem", "position": 2, "name": "Bali Weather", "item": `${SITE_URL}/en/weather/` },
      ]
    },
    {
      "@type": "WebPage",
      "@id": `${SITE_URL}/en/weather/`,
      "name": title,
      "description": description,
      "url": `${SITE_URL}/en/weather/`,
      "inLanguage": "en",
    }
  ]
};
---

<html lang="en">
  <head>
    <BaseHead
      title={title}
      description={description}
      noSuffix={true}
      hreflangs={hreflangs}
    />
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    <style>
      .weather-page {
        max-width: 760px;
        margin: 0 auto;
        padding: 1.5rem 1rem 3rem;
      }
      .weather-page h1 {
        font-size: 1.5rem;
        margin: 0 0 0.4rem;
        color: #1a1a1a;
      }
      .weather-page .subtitle {
        color: #666;
        font-size: 0.92rem;
        margin: 0 0 1.4rem;
      }
      .weather-tips {
        margin-top: 1.6rem;
        background: #f5f8ff;
        border-radius: 12px;
        padding: 1.1rem 1.3rem;
      }
      .weather-tips h2 {
        font-size: 1rem;
        margin: 0 0 0.7rem;
        color: #1a6fad;
      }
      .weather-tips ul {
        margin: 0;
        padding-left: 1.2rem;
        color: #444;
        font-size: 0.88rem;
        line-height: 1.8;
      }
      .weather-tips ul li { margin-bottom: 0.2rem; }
    </style>
  </head>
  <body>
    <Header basePath="/en" />
    <TopStrip lang={lang} />
    <main class="weather-page">
      <h1>Bali Weather Forecast</h1>
      <p class="subtitle">Live temperature · humidity · rain · UV index · 7-day forecast. Data from Open-Meteo, updated every 10 minutes.</p>

      <BaliWeather lang={lang} />

      <div class="weather-tips">
        <h2>Bali Weather Tips</h2>
        <ul>
          <li><strong>Dry Season (Apr–Oct)</strong>: 27–32°C, mostly sunny — peak travel season</li>
          <li><strong>Wet Season (Nov–Mar)</strong>: Brief afternoon showers, cooler mornings, still very travelable</li>
          <li><strong>Kuta / Seminyak</strong>: Coastal, strong sun and high UV — sunscreen essential</li>
          <li><strong>Ubud Highlands</strong>: Higher elevation, 2–4°C cooler than the coast, fresh evenings</li>
          <li><strong>Nusa Dua</strong>: South tip, calmer waves — great for snorkelling and water sports</li>
        </ul>
      </div>
    </main>
    <Footer />
  </body>
</html>
