// ── State ────────────────────────────────────────────────────────────
const state = {
  companion: '',
  days: '',
  interests: [],
  budget: '',
  areas: [],
  itinerary: '',
};

// ── Chip Selection ───────────────────────────────────────────────────
document.querySelectorAll('.chips').forEach(group => {
  const isMulti = group.classList.contains('multi');
  group.addEventListener('click', e => {
    const chip = e.target.closest('.chip');
    if (!chip) return;
    if (isMulti) {
      chip.classList.toggle('selected');
    } else {
      group.querySelectorAll('.chip').forEach(c => c.classList.remove('selected'));
      chip.classList.add('selected');
    }
  });
});

// ── Step Navigation ──────────────────────────────────────────────────
function getChipVals(id) {
  return [...document.querySelectorAll(`#${id} .chip.selected`)].map(c => c.dataset.val);
}

function setNavActive(step) {
  document.querySelectorAll('.snav-item').forEach((el, i) => {
    el.classList.toggle('active', i + 1 <= step);
    el.classList.toggle('done', i + 1 < step);
  });
}

function showStep(n) {
  document.querySelectorAll('.step').forEach((s, i) => {
    s.classList.toggle('hidden', i + 1 !== n);
  });
  setNavActive(n);
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

document.getElementById('btn-1-next').addEventListener('click', () => {
  state.companion = getChipVals('q-companion')[0] || '';
  state.days      = getChipVals('q-days')[0] || '';
  state.interests = getChipVals('q-interests');
  state.budget    = getChipVals('q-budget')[0] || '';
  showStep(2);
});

document.getElementById('btn-2-back').addEventListener('click', () => showStep(1));

document.getElementById('btn-2-next').addEventListener('click', () => {
  state.areas     = getChipVals('q-areas');
  state.itinerary = document.getElementById('q-itinerary').value.trim();
  buildResults();
  showStep(3);
});

document.getElementById('btn-restart').addEventListener('click', () => {
  // Reset all chips
  document.querySelectorAll('.chip').forEach(c => c.classList.remove('selected'));
  document.getElementById('q-itinerary').value = '';
  Object.assign(state, { companion:'', days:'', interests:[], budget:'', areas:[], itinerary:'' });
  showStep(1);
});

// ── Itinerary Analysis ───────────────────────────────────────────────
function analyzeItinerary(text) {
  if (!text) return { mentionedAreas: [], emptyDays: [] };

  const emptyKeywords = ['???','待定','tbd','空白','未定','不知道','還沒想','未排','空'];
  const mentionedAreas = new Set();
  const emptyDays = [];

  text.split('\n').forEach(line => {
    const lower = line.toLowerCase();

    for (const [key, reg] of Object.entries(REGIONS)) {
      if (reg.keywords.some(kw => lower.includes(kw.toLowerCase()))) {
        mentionedAreas.add(key);
      }
    }

    const dayMatch = line.match(/[Dd](\d+)|第\s*(\d+)\s*[天日]|[Dd]ay\s*(\d+)/);
    if (dayMatch && emptyKeywords.some(kw => lower.includes(kw.toLowerCase()))) {
      const n = dayMatch[1] ?? dayMatch[2] ?? dayMatch[3];
      emptyDays.push(`第 ${n} 天`);
    }
  });

  return { mentionedAreas: [...mentionedAreas], emptyDays };
}

// ── Recommendation Engine ────────────────────────────────────────────
function buildTargetAreas(mentionedAreas) {
  const chosen = new Set([...state.areas, ...mentionedAreas]);
  chosen.delete('undecided');

  // If nothing selected, infer from interests + companion
  if (chosen.size === 0) {
    const interestMap = {
      surf:    ['kuta','canggu'],
      culture: ['ubud','east'],
      spa:     ['ubud','seminyak'],
      food:    ['seminyak','jimbaran'],
      shop:    ['seminyak','kuta'],
      yoga:    ['ubud','canggu'],
      snorkel: ['penida','sanur'],
      beach:   ['nusadua','uluwatu'],
      night:   ['kuta','seminyak'],
      photo:   ['ubud','uluwatu'],
      kids:    ['nusadua','sanur'],
      nature:  ['ubud','east'],
    };
    state.interests.forEach(i => {
      (interestMap[i] || []).forEach(a => chosen.add(a));
    });
    if (state.companion === 'family') { chosen.add('nusadua'); chosen.add('sanur'); }
    if (state.budget === 'luxury')    { chosen.add('nusadua'); chosen.add('seminyak'); }
    if (chosen.size === 0)            { ['kuta','ubud','seminyak'].forEach(a => chosen.add(a)); }
  }

  // Days-based pruning: short trips → stay south
  const days = parseInt(state.days) || 5;
  if (days <= 3 && chosen.size > 3) {
    // Keep only top 3 by interest match
    const sorted = [...chosen].sort((a, b) => {
      const scoreA = (REGIONS[a]?.interestMatch || []).filter(i => state.interests.includes(i)).length;
      const scoreB = (REGIONS[b]?.interestMatch || []).filter(i => state.interests.includes(i)).length;
      return scoreB - scoreA;
    });
    return sorted.slice(0, 3);
  }

  return [...chosen];
}

// ── HTML Builders ────────────────────────────────────────────────────
function cardHtml({ title, url, tag }) {
  return `<a href="${url}" class="acard" target="_blank" rel="noopener">
    <span class="acard-tag">${tag}</span>
    <p class="acard-title">${title}</p>
    <span class="acard-arrow">→</span>
  </a>`;
}

function regionSectionHtml(key) {
  const r = REGIONS[key];
  if (!r) return '';
  const allCards = [
    cardHtml({ ...r.guide }),
    ...r.spots.map(s => cardHtml(s)),
  ].join('');
  return `<div class="results-section region-section">
    <h3 class="section-title region-title">
      <span class="region-emoji">${r.emoji}</span>
      ${r.name}
      <span class="region-desc">${r.desc}</span>
    </h3>
    <div class="article-grid">${allCards}</div>
  </div>`;
}

function interestSectionHtml(key) {
  const ex = INTEREST_EXTRAS[key];
  if (!ex) return '';
  const cards = ex.articles.map(a => cardHtml(a)).join('');
  return `<div class="results-section">
    <h3 class="section-title">${ex.title}</h3>
    <div class="article-grid">${cards}</div>
  </div>`;
}

// ── Route Tip ────────────────────────────────────────────────────────
// Based on: 「這樣玩居然不塞車！」8天7夜不塞車路線邏輯
// Recommended geographic flow: 機場 → 水明漾/倉古 → 沙努爾/佩尼達 → 烏布 → 庫塔/金巴蘭 → 機場
const ROUTE_FLOW = ['seminyak','canggu','nusadua','sanur','penida','east','ubud','uluwatu','jimbaran','kuta'];

function buildRouteTip(targetAreas) {
  // Only show if 2+ areas selected
  const ordered = ROUTE_FLOW.filter(a => targetAreas.includes(a));
  if (ordered.length < 2) return '';

  const steps = ordered.map(a => {
    const r = REGIONS[a];
    return `<span class="route-step">${r.emoji} ${r.name}</span>`;
  });

  return `<div class="route-tip-box">
    <div class="route-tip-label">🗺️ 建議移動順序（從機場出發，避免走回頭路）</div>
    <div class="route-flow">
      <span class="route-step route-airport">✈️ 機場</span>
      <span class="route-arrow">→</span>
      ${steps.join('<span class="route-arrow">→</span>')}
      <span class="route-arrow">→</span>
      <span class="route-step route-airport">✈️ 機場</span>
    </div>
    <div class="route-tip-note">依地理位置順向移動，塞車時間最少。詳細規劃參考：<a href="/blog/2024-03-18-65ba3bfefd89780001650f07/" target="_blank" rel="noopener">8天不塞車攻略</a></div>
  </div>`;
}

// ── Build Results ────────────────────────────────────────────────────
function buildResults() {
  const { mentionedAreas, emptyDays } = analyzeItinerary(state.itinerary);
  const targetAreas = buildTargetAreas(mentionedAreas);

  // Summary text
  const companionLabel = { solo:'個人獨旅', couple:'情侶蜜月', family:'家庭親子', friends:'朋友同行' }[state.companion] || '';
  const daysLabel = state.days ? (state.days === '8' ? '8天以上' : state.days.replace('67','6–7') + '天') : '';
  const parts = [companionLabel, daysLabel].filter(Boolean);
  document.getElementById('results-summary').textContent =
    parts.length ? `根據你的條件（${parts.join('・')}）為你整理了以下推薦：` :
    '根據你的選擇，為你整理了以下推薦：';

  // Empty day alert
  const alertEl = document.getElementById('empty-alert');
  if (emptyDays.length > 0) {
    document.getElementById('empty-alert-text').textContent =
      `行程中偵測到空缺天數（${emptyDays.join('、')}），以下分區攻略可以幫你補上！`;
    alertEl.classList.remove('hidden');
  } else {
    alertEl.classList.add('hidden');
  }

  // Region sections
  document.getElementById('region-sections').innerHTML =
    targetAreas.map(regionSectionHtml).join('');

  // Interest extras
  const interestExtraKeys = [];
  if (state.interests.includes('surf') || state.areas.includes('kuta') || state.areas.includes('canggu')) interestExtraKeys.push('surf');
  if (state.interests.includes('kids') || state.companion === 'family') interestExtraKeys.push('kids');
  if (state.interests.includes('snorkel') || state.areas.includes('penida')) interestExtraKeys.push('snorkel');
  if (state.interests.includes('nature')) interestExtraKeys.push('nature');
  // 短天數或完全沒勾選任何興趣 → 推薦懶人包
  const days = parseInt(state.days) || 5;
  if (days <= 4 || state.interests.length === 0) interestExtraKeys.push('klook');

  document.getElementById('interest-extras').innerHTML =
    [...new Set(interestExtraKeys)].map(interestSectionHtml).join('');

  // Route flow tip (based on 8-day anti-traffic logic)
  document.getElementById('route-tip').innerHTML = buildRouteTip(targetAreas);
}
</script>

