---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import TopStrip from '../components/TopStrip.astro';
import Footer from '../components/Footer.astro';
import TripPlannerContent from '../components/TripPlannerContent.astro';

const hreflangs = [
  { hreflang: 'zh-TW', href: 'https://gobaligo.id/trip-planner/' },
  { hreflang: 'zh-CN', href: 'https://gobaligo.id/zh-cn/trip-planner/' },
  { hreflang: 'zh-HK', href: 'https://gobaligo.id/zh-hk/trip-planner/' },
  { hreflang: 'en',    href: 'https://gobaligo.id/en/trip-planner/' },
  { hreflang: 'x-default', href: 'https://gobaligo.id/trip-planner/' },
];
---

<!doctype html>
<html lang="zh-TW">
<head>
  <BaseHead
    title="峇里島行程規劃工具｜個人化攻略景點推薦 2026"
    description="免費峇里島行程規劃工具，輸入旅行風格立即取得個人化景點攻略。分區景點、美食、活動整理清楚，適合第一次去峇里島的旅人。"
    hreflangs={hreflangs}
  />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "WebApplication",
        "name": "峇里島行程規劃工具",
        "description": "免費線上峇里島行程規劃工具。依照旅行風格、天數與偏好，即時產生個人化景點攻略、分區住宿建議與推薦文章。",
        "url": "https://gobaligo.id/trip-planner/",
        "applicationCategory": "TravelApplication",
        "operatingSystem": "Web",
        "inLanguage": "zh-TW",
        "offers": { "@type": "Offer", "price": "0", "priceCurrency": "TWD" },
        "featureList": [
          "旅行風格選擇（親子、蜜月、朋友、獨旅、長輩）",
          "行程草稿分析與空缺補充",
          "分區景點攻略推薦",
          "個人化住宿區域建議",
          "存成 PDF 分享旅伴"
        ],
        "provider": {
          "@type": "Organization",
          "name": "Go Bali Go",
          "url": "https://gobaligo.id"
        }
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "首頁", "item": "https://gobaligo.id/" },
          { "@type": "ListItem", "position": 2, "name": "峇里島行程規劃工具", "item": "https://gobaligo.id/trip-planner/" }
        ]
      },
      {
        "@type": "HowTo",
        "name": "3 步驟使用峇里島行程規劃工具",
        "description": "使用免費峇里島行程規劃工具，依照旅行風格獲得個人化攻略推薦",
        "step": [
          { "@type": "HowToStep", "position": 1, "name": "選擇旅行風格", "text": "選擇同行對象、天數、想做的活動與預算範圍，全程點擊操作。" },
          { "@type": "HowToStep", "position": 2, "name": "貼上行程草稿", "text": "選填：貼上你已有的行程草稿，系統自動分析空缺並補充推薦。" },
          { "@type": "HowToStep", "position": 3, "name": "取得個人化推薦", "text": "取得專屬的景點攻略、住宿區域推薦與必讀文章，可存成 PDF 共享。" }
        ]
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "峇里島自由行要幾天才夠？",
            "acceptedAnswer": { "@type": "Answer", "text": "大多數旅客選擇 5 天 4 夜到 7 天 6 夜。如果是第一次去，建議至少安排 6 天，才能同時涵蓋南部海灘（庫塔、水明漾、烏魯瓦圖）與中部文化區（烏布）兩大核心。天數少於 5 天容易走馬看花，超過 8 天則可以考慮加入努沙佩尼達、科摩多等離島行程，豐富度倍增。" }
          },
          {
            "@type": "Question",
            "name": "第一次去峇里島應該安排哪些區域？",
            "acceptedAnswer": { "@type": "Answer", "text": "新手首推「烏布＋南部沿海」的組合。烏布是峇里島的文化中心，梯田、猴子森林、聖泉寺是必訪；南部可依喜好選擇：喜歡衝浪就住庫塔，喜歡精品餐廳就選水明漾，喜歡安靜就往烏魯瓦圖或沙努爾。建議同一地區至少住 2 晚，避免每天搬行李。" }
          },
          {
            "@type": "Question",
            "name": "峇里島親子家庭適合住哪一區？",
            "acceptedAnswer": { "@type": "Answer", "text": "帶孩子旅遊首選沙努爾或努沙杜瓦。沙努爾有平靜的海灘、海龜保育中心、AeroXSpace 室內遊樂場，很適合帶幼兒；努沙杜瓦飯店集中、治安好、有 Waterbom 水上樂園，是最多親子團選擇的區域。烏布的野生動物園與泛舟也非常受孩子歡迎，適合安排 1–2 天造訪。" }
          },
          {
            "@type": "Question",
            "name": "峇里島蜜月情侶推薦怎麼玩？",
            "acceptedAnswer": { "@type": "Answer", "text": "蜜月行程首選烏魯瓦圖的懸崖私人泳池別墅，搭配火舞表演與夕陽海鮮大餐；水明漾適合浪漫晚餐與精品 SPA；烏布則有叢林泳池與 Kecak 文化表演。建議避開庫塔（較吵鬧），預算充足的話，可以在努沙佩尼達安排一日遊，天使之眼藍潟湖是極佳的蜜月打卡點。" }
          },
          {
            "@type": "Question",
            "name": "峇里島行程規劃工具怎麼使用？",
            "acceptedAnswer": { "@type": "Answer", "text": "整個流程只需 1–2 分鐘。先在步驟一選擇你的同行對象、天數、想做的活動，接著在步驟二可以選填你已有的行程草稿（直接貼上文字即可），最後點「查看推薦攻略」，系統就會根據你的條件整理出個人化的景點文章、住宿區域與注意事項清單。" }
          },
          {
            "@type": "Question",
            "name": "規劃結果可以存檔或分享給旅伴嗎？",
            "acceptedAnswer": { "@type": "Answer", "text": "可以！推薦結果頁面下方有「存成 PDF」按鈕，點擊後會開啟瀏覽器列印功能，選擇「另存 PDF」即可。PDF 裡包含你選擇的景點、推薦文章連結與 gobaligo.id 的網址，方便旅伴一起參考。也可以直接把頁面網址複製分享給朋友。" }
          },
          {
            "@type": "Question",
            "name": "峇里島淡旺季差別大嗎？什麼時候去最好？",
            "acceptedAnswer": { "@type": "Answer", "text": "峇里島全年溫暖，主要分乾季（5–9 月）與雨季（11–3 月）。乾季是旺季，天氣穩定、適合離島、戶外活動豐富，但機票與住宿較貴；雨季通常午後短暫陣雨，其餘時間依舊晴朗，物價較低、觀光客較少，SPA 與室內行程不受影響。建議第一次去選 6–8 月，有預算彈性的旅客可考慮 4 月或 10 月（性價比最高）。" }
          }
        ]
      }
    ]
  })} />
</head>
<body>
  <Header basePath="trip-planner" />
  <TopStrip lang={'zh-tw'} />
  <TripPlannerContent lang="zh-tw" />
  <Footer />
</body>
</html>
