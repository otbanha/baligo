---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="zh-TW">
<head>
  <BaseHead
    title="峇里島行程規劃工具｜個人化攻略景點推薦 2026"
    description="輸入你的旅行風格，立即獲得個人化峇里島攻略推薦。分區景點、美食、活動以區域整理清楚，適合第一次去峇里島或想補足空缺天的旅人。"
  />
</head>
<body>
  <Header />

  <main id="planner">

    <!-- ── Hero ── -->
    <div class="planner-hero">
      <div class="hero-inner">
        <div class="hero-badge">免費規劃工具</div>
        <h1>峇里島行程規劃</h1>
        <p>告訴我你的旅行風格，我幫你找到最適合的攻略與景點推薦</p>
      </div>
    </div>

    <!-- ── Wizard ── -->
    <div class="wizard-wrap">

      <!-- Steps nav -->
      <div class="steps-nav">
        <div class="snav-item active" id="snav-1">
          <span class="snav-num">1</span>
          <span class="snav-label">旅行風格</span>
        </div>
        <div class="snav-line"></div>
        <div class="snav-item" id="snav-2">
          <span class="snav-num">2</span>
          <span class="snav-label">行程草稿</span>
        </div>
        <div class="snav-line"></div>
        <div class="snav-item" id="snav-3">
          <span class="snav-num">3</span>
          <span class="snav-label">推薦攻略</span>
        </div>
      </div>

      <!-- ── Step 1: Travel Style ── -->
      <div class="step" id="step-1">
        <h2 class="step-title">你的旅行風格</h2>

        <div class="q-block">
          <div class="q-label">和誰一起去？</div>
          <div class="chips single" id="q-companion">
            <button class="chip" data-val="solo">🧍 個人獨旅</button>
            <button class="chip" data-val="couple">💑 情侶蜜月</button>
            <button class="chip" data-val="family">👨‍👩‍👧 家庭親子</button>
            <button class="chip" data-val="friends">👯 朋友同行</button>
          </div>
        </div>

        <div class="q-block">
          <div class="q-label">幾天幾夜？</div>
          <div class="chips single" id="q-days">
            <button class="chip" data-val="3">3天2夜</button>
            <button class="chip" data-val="4">4天3夜</button>
            <button class="chip" data-val="5">5天4夜</button>
            <button class="chip" data-val="67">6–7天</button>
            <button class="chip" data-val="8">8天以上</button>
          </div>
        </div>

        <div class="q-block">
          <div class="q-label">最想做什麼？<span class="q-hint">可多選</span></div>
          <div class="chips multi" id="q-interests">
            <button class="chip" data-val="beach">☀️ 海灘放鬆</button>
            <button class="chip" data-val="surf">🏄 衝浪</button>
            <button class="chip" data-val="culture">⛩️ 文化寺廟</button>
            <button class="chip" data-val="spa">💆 SPA按摩</button>
            <button class="chip" data-val="food">🍜 美食探索</button>
            <button class="chip" data-val="shop">🛍️ 購物</button>
            <button class="chip" data-val="yoga">🧘 瑜伽靈修</button>
            <button class="chip" data-val="night">🌙 夜生活</button>
            <button class="chip" data-val="kids">🧒 親子活動</button>
            <button class="chip" data-val="snorkel">🤿 浮潛潛水</button>
            <button class="chip" data-val="nature">🌿 自然健行</button>
            <button class="chip" data-val="photo">📸 網美打卡</button>
          </div>
        </div>

        <div class="q-block">
          <div class="q-label">預算感覺？</div>
          <div class="chips single" id="q-budget">
            <button class="chip" data-val="budget">💰 省錢不浪費</button>
            <button class="chip" data-val="mid">🫰 均衡舒適</button>
            <button class="chip" data-val="luxury">💎 品質優先</button>
          </div>
        </div>

        <div class="step-actions">
          <button class="btn-next" id="btn-1-next">下一步：填寫行程草稿 →</button>
        </div>
      </div>

      <!-- ── Step 2: Areas + Draft ── -->
      <div class="step hidden" id="step-2">
        <h2 class="step-title">行程草稿</h2>

        <div class="q-block">
          <div class="q-label">已想去的地區？<span class="q-hint">可多選，不確定就跳過</span></div>
          <div class="chips multi" id="q-areas">
            <button class="chip" data-val="kuta">🏖️ 庫塔/雷吉安</button>
            <button class="chip" data-val="seminyak">💅 水明漾</button>
            <button class="chip" data-val="canggu">☕ 倉古/長谷</button>
            <button class="chip" data-val="ubud">🌿 烏布</button>
            <button class="chip" data-val="jimbaran">🦞 金巴蘭</button>
            <button class="chip" data-val="uluwatu">🌅 烏魯瓦圖</button>
            <button class="chip" data-val="nusadua">🏨 努沙杜瓦</button>
            <button class="chip" data-val="sanur">⛵ 沙努爾</button>
            <button class="chip" data-val="penida">🤿 努沙佩尼達</button>
            <button class="chip" data-val="east">⛩️ 東部峇里</button>
          </div>
        </div>

        <div class="q-block">
          <div class="q-label">
            把你的草稿行程貼上來
            <span class="q-hint">選填，我幫你找出空缺和推薦景點</span>
          </div>
          <textarea
            id="q-itinerary"
            rows="9"
            placeholder="例如：
D1 晚上抵達庫塔，入住飯店，逛 Discovery Mall
D2 烏布：Tegallalang 梯田、猴子森林、烏布市場
D3 ???（不知道要幹嘛）
D4 努沙佩尼達一日遊
D5 早上 SPA，下午自由活動，晚上金巴蘭海鮮
D6 購物，下午飛回台灣"
          ></textarea>
        </div>

        <div class="step-actions">
          <button class="btn-back" id="btn-2-back">← 上一步</button>
          <button class="btn-next" id="btn-2-next">查看推薦攻略 →</button>
        </div>
      </div>

      <!-- ── Step 3: Results ── -->
      <div class="step hidden" id="step-3">

        <div class="results-header">
          <h2 class="step-title">你的個人化推薦</h2>
          <p id="results-summary" class="results-summary"></p>
        </div>

        <!-- Empty days alert -->
        <div class="empty-alert hidden" id="empty-alert">
          <span>📌</span>
          <span id="empty-alert-text"></span>
        </div>

        <!-- Dynamic region sections (JS-rendered) -->
        <div id="region-sections"></div>

        <!-- Interest-based extras (JS-rendered) -->
        <div id="interest-extras"></div>

        <!-- Route flow tip (JS-rendered) -->
        <div id="route-tip"></div>

        <!-- Always visible: 規劃前必讀 -->
        <div class="results-section">
          <h3 class="section-title">📚 規劃前必讀</h3>
          <div class="article-grid">
            <a href="/blog/2023-12-06-65708c78fd89780001f418c2/" class="acard" target="_blank" rel="noopener">
              <span class="acard-tag">新手指南</span>
              <p class="acard-title">【2026 峇里島自由行】7 步驟輕鬆規劃完美旅程</p>
              <span class="acard-arrow">→</span>
            </a>
            <a href="/blog/2025-01-07-672e2c1afd897800014c3fbc/" class="acard" target="_blank" rel="noopener">
              <span class="acard-tag">新手Q&A</span>
              <p class="acard-title">99% 遊客都在偷偷搜尋的超尷尬 41 個問題大解答</p>
              <span class="acard-arrow">→</span>
            </a>
            <a href="/blog/2024-03-18-65ba3bfefd89780001650f07/" class="acard" target="_blank" rel="noopener">
              <span class="acard-tag">行程參考</span>
              <p class="acard-title">【這樣玩居然不塞車！】8 天 7 夜爽玩峇里島全方位攻略</p>
              <span class="acard-arrow">→</span>
            </a>
            <a href="/blog/2026-02-24-65839fbafd89780001e876b5/" class="acard" target="_blank" rel="noopener">
              <span class="acard-tag">住宿選擇</span>
              <p class="acard-title">五大熱門區域比較：庫塔、水明漾、倉古、烏布怎麼選？</p>
              <span class="acard-arrow">→</span>
            </a>
            <a href="/blog/2024-03-09-65df201efd89780001994d11/" class="acard" target="_blank" rel="noopener">
              <span class="acard-tag">景點地圖</span>
              <p class="acard-title">2026 峇里島 500 個最新人氣景點一次蒐全</p>
              <span class="acard-arrow">→</span>
            </a>
          </div>
        </div>

        <!-- Always visible: 全島必看 -->
        <div class="results-section">
          <h3 class="section-title">🌏 全島必看</h3>
          <div class="article-grid">
            <a href="/blog/2019-08-19-64db6b5afd897800013a8f86/" class="acard" target="_blank" rel="noopener">
              <span class="acard-tag">美食</span>
              <p class="acard-title">峇里島必吃人氣美食清單｜必吃路邊小吃</p>
              <span class="acard-arrow">→</span>
            </a>
            <a href="/blog/2023-05-02-64db6b81fd897800013a98e3/" class="acard" target="_blank" rel="noopener">
              <span class="acard-tag">美食</span>
              <p class="acard-title">峇里島十大美食（第二版）</p>
              <span class="acard-arrow">→</span>
            </a>
            <a href="/blog/2023-01-22-64db6b7efd897800013a97ed/" class="acard" target="_blank" rel="noopener">
              <span class="acard-tag">SPA按摩</span>
              <p class="acard-title">峇里島好評SPA、到府按摩推薦大集合（以區域劃分）</p>
              <span class="acard-arrow">→</span>
            </a>
            <a href="/blog/2024-07-10-668e837dfd89780001357d06/" class="acard" target="_blank" rel="noopener">
              <span class="acard-tag">必體驗</span>
              <p class="acard-title">七大峇里島日落夕陽觀賞地點，你去過幾個？</p>
              <span class="acard-arrow">→</span>
            </a>
            <a href="/blog/2019-09-02-64db6b5cfd897800013a9015/" class="acard" target="_blank" rel="noopener">
              <span class="acard-tag">購物</span>
              <p class="acard-title">峇里島推薦必買伴手禮：零食/食品篇</p>
              <span class="acard-arrow">→</span>
            </a>
            <a href="/blog/2024-01-06-6598c6fffd89780001047d76/" class="acard" target="_blank" rel="noopener">
              <span class="acard-tag">備案</span>
              <p class="acard-title">下雨/躲太陽行程備案：60 個超強室內行程</p>
              <span class="acard-arrow">→</span>
            </a>
          </div>
        </div>

        <div class="restart-wrap">
          <button class="btn-restart" id="btn-restart">重新規劃 ↺</button>
        </div>

      </div>
    </div>
  </main>

  <Footer />
</body>
</html>

<script>
// ── Data ────────────────────────────────────────────────────────────
