@media (max-width: 600px) {
  main { padding: 1em 0.9em; }
  .title h1 { font-size: 1.25em; }
  .prose { font-size: 0.97em; line-height: 1.8; }
  .prose :global(h2:not(.tp-banner-title)) { font-size: 1.1em; }
  .prose :global(h3) { font-size: 1em; }
  .related-grid { grid-template-columns: 1fr; }

