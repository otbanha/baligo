</style>

<script>
  // H2 區塊亂數排列
  const articleBody = document.getElementById('article-body');
  if (articleBody && articleBody.dataset.shuffle === 'true') {
    const children = Array.from(articleBody.childNodes);

    // 分組：preamble（第一個 H2 之前，或 <!-- shuffle-start --> 之前的 H2 區塊）
    //       + 各 H2 區塊（隨機排列）
    //       + postamble（<!-- no-shuffle --> 標記後的 H2 及其後內容）
    //
    // 使用方式：
    //   <!-- shuffle-start -->  放在「要開始 shuffle 的 H2」之前，其前的 H2 固定在頂部
    //   <!-- no-shuffle -->     放在「要固定在底部的 H2」之前
    const preamble: ChildNode[] = [];
    const sections: ChildNode[][] = [];
    const postamble: ChildNode[] = [];
    let current: ChildNode[] | null = null;
    let noShuffleNext = false;
    let inPostamble = false;
    let shuffleStarted = false;

    for (const node of children) {
      const isComment = node.nodeType === Node.COMMENT_NODE;
      const commentText = isComment ? (node as Comment).data.trim() : '';

      // 偵測 <!-- shuffle-start --> HTML comment
      if (isComment && commentText === 'shuffle-start') {
        shuffleStarted = true;
        // 若目前有尚未進入 sections 的 H2 區塊（因為還在 preamble 等待），
        // 此 comment 本身不需要插入內容
        continue;
      }

      // 偵測 <!-- no-shuffle --> HTML comment
      if (isComment && commentText === 'no-shuffle') {
        noShuffleNext = true;
        postamble.push(node);
        continue;
      }
      const tag = (node as Element).tagName;
      // H1 在文章內文中自動觸發 postamble（固定在底部）
      if (tag === 'H1' && sections.length > 0) {
        inPostamble = true;
      }
      // <!-- no-shuffle --> 後遇到任何非空白節點都進入 postamble
      if (noShuffleNext && !inPostamble) {
        inPostamble = true;
        noShuffleNext = false;
      }
      if (inPostamble) {
        postamble.push(node);
      } else if (tag === 'H2' && shuffleStarted) {
        // shuffle-start 之後的 H2 才進入隨機區
        current = [node];
        sections.push(current);
      } else if (tag === 'H2' && !shuffleStarted) {
        // shuffle-start 之前的 H2 視為 preamble（固定）
        current = [node];
        preamble.push(node);
      } else if (current && !inPostamble) {
        if (shuffleStarted && sections.length > 0) {
          sections[sections.length - 1].push(node);
        } else {
          preamble.push(node);
        }
      } else {
        preamble.push(node);
      }
    }

    // 只有超過一個 H2 區塊才需要亂數
    if (sections.length > 1) {
      // Fisher-Yates shuffle
      for (let i = sections.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [sections[i], sections[j]] = [sections[j], sections[i]];
      }

      // 清空並重新插入（postamble 固定在最後）
      articleBody.innerHTML = '';
      for (const node of preamble) articleBody.appendChild(node);
      for (const section of sections) {
        for (const node of section) articleBody.appendChild(node);
      }
      for (const node of postamble) articleBody.appendChild(node);

      // TOC 同步：依新 H2 順序重排目錄項目（H3 跟著所屬 H2 移動）
      const tocList = document.getElementById('toc-list');
      if (tocList) {
        const shuffledIds = sections.map(s => (s[0] as Element).id).filter(Boolean);
        const h2IdSet = new Set(shuffledIds);
        // 將 TOC 項目分組：每組 = 一個 H2 <li> + 其後的 H3 <li>
        const tocItems = Array.from(tocList.children) as HTMLElement[];
        const tocGroups = new Map<string, HTMLElement[]>();
        const tocPreamble: HTMLElement[] = [];
        const tocPostamble: HTMLElement[] = [];
        let currentGroup: HTMLElement[] | null = null;
        let inTocPostamble = false;
        for (const li of tocItems) {
          // toc-h1 出現在 H2 區段之後，才視為 postamble（固定在底部）
          // H2 之前的 toc-h1（如 FAQ 標題）應保留在 preamble
          if (li.classList.contains('toc-h1') && currentGroup !== null) {
            inTocPostamble = true;
          }
          if (inTocPostamble) {
            tocPostamble.push(li);
            continue;
          }
          const href = li.querySelector('a')?.getAttribute('href') ?? '';
          const id = href.replace('#', '');
          if (li.classList.contains('toc-h2') && h2IdSet.has(id)) {
            currentGroup = [li];
            tocGroups.set(id, currentGroup);
          } else if (currentGroup) {
            currentGroup.push(li);
          } else {
            // shuffle-start 之前的 H2（preamble）固定在目錄頂部
            tocPreamble.push(li);
          }
        }
        tocList.innerHTML = '';
        tocPreamble.forEach(li => tocList.appendChild(li));
        for (const id of shuffledIds) {
          const group = tocGroups.get(id);
          if (group) group.forEach(li => tocList.appendChild(li));
        }
        tocPostamble.forEach(li => tocList.appendChild(li));
      }
    }
  }
</script>