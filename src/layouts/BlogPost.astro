---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import SEO from '../components/SEO.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import TopStrip from '../components/TopStrip.astro';
import ChatBot from '../components/ChatBot.astro';
import TripPlannerBanner from '../components/TripPlannerBanner.astro';
import RelatedMapCard from '../components/RelatedMapCard.astro';
import { getCollection } from 'astro:content';
import { enhancedTitle, enhancedDescription, COMPANION_CAT } from '../utils/seo-keywords';
import { getAvailableLangs } from '../utils/lang-availability';

type Driver = {
  name: string;
  category: string;
  languages: string[];
  specialty: string;
  contact: string;
  facebookRefs: number;
};

type Props = CollectionEntry<'blog'>['data'] & { body?: string; headings?: { depth: number; slug: string; text: string }[]; lang?: string; slug?: string; isDriverGuide?: boolean; drivers?: Driver[]; isSpaGuide?: boolean; line_qr_guide?: boolean };
const { title, description, pubDate, updatedDate, heroImage, category, embeds, embedMap = {}, body = '', headings = [], lang, slug, private: isPrivate, shuffle_h2: shuffleH2, isDriverGuide = false, drivers = [], isSpaGuide = false, line_qr_guide: lineQrGuide = false } = Astro.props;

const tocHeadings = headings.filter(h => h.depth === 1 || h.depth === 2 || h.depth === 3);
const showToc = tocHeadings.length >= 2;

// OG image：優先用 heroImage，沒有才抓文章第一張圖
function extractFirstImage(text: string): string {
  const m = text?.match(/!\[.*?\]\((https?:\/\/[^\)\s]+)\)/);
  return m ? m[1] : '';
}
const ogImage = (typeof heroImage === 'string' && heroImage) ? heroImage : extractFirstImage(body);

// Keyword-enhanced title & description for <meta> tags
const cats = Array.isArray(category) ? category : (category ? [category] : []);
const metaTitle = enhancedTitle(title, cats, lang ?? 'zh-tw');
const metaDesc  = enhancedDescription(description ?? '', cats, lang ?? 'zh-tw');

const collectionName = lang === 'en' ? 'en' : lang === 'zh-cn' ? 'zh-cn' : lang === 'zh-hk' ? 'zh-hk' : 'blog';
const allPosts = await getCollection(collectionName as any);

const CAT_EN: Record<string, string> = {
  '新手指南': "Beginner's Guide",
  '住宿推薦': 'Accommodation', '住宿推荐': 'Accommodation',
  '峇里島分區攻略': 'Area Guide', '峇里岛分区攻略': 'Area Guide',
  '簽證通關': 'Visa & Entry', '签证通关': 'Visa & Entry',
  '叫車包車': 'Transport', '叫车包车': 'Transport',
  '家庭親子': 'Family Travel', '家庭亲子': 'Family Travel',
  '遊記分享': 'Travel Stories', '游记分享': 'Travel Stories',
  '美食景點活動': 'Food & Activities', '美食景点活动': 'Food & Activities',
  '新聞存檔': 'News Archive', '新闻存档': 'News Archive',
  '旅行技巧': 'Travel Tips',
};

const CAT_ZH_CN: Record<string, string> = {
  '新手指南': '新手指南',
  '住宿推薦': '住宿推荐', '住宿推荐': '住宿推荐',
  '峇里島分區攻略': '峇里岛分区攻略', '峇里岛分区攻略': '峇里岛分区攻略',
  '簽證通關': '签证通关', '签证通关': '签证通关',
  '叫車包車': '叫车包车', '叫车包车': '叫车包车',
  '家庭親子': '家庭亲子', '家庭亲子': '家庭亲子',
  '遊記分享': '游记分享', '游记分享': '游记分享',
  '美食景點活動': '美食景点活动', '美食景点活动': '美食景点活动',
  '新聞存檔': '新闻存档', '新闻存档': '新闻存档',
};

const getCatLabel = (cat: string) => {
  if (lang === 'en') return CAT_EN[cat] ?? cat;
  if (lang === 'zh-cn') return CAT_ZH_CN[cat] ?? cat;
  return cat;
};

const blogBase = lang === 'en' ? '/en/blog' : lang === 'zh-cn' ? '/zh-cn/blog' : lang === 'zh-hk' ? '/zh-hk/blog' : '/blog';
const isZhTw = lang !== 'en' && lang !== 'zh-cn' && lang !== 'zh-hk';
const blogIndexUrl = isZhTw ? `${blogBase}/?lang=tw` : `${blogBase}/`;
const catBaseUrl   = isZhTw ? `${blogBase}/?lang=tw&cat=` : `${blogBase}?cat=`;

const canonicalUrl = `https://gobaligo.id${blogBase}/${slug}/`;

// hreflang：只輸出實際存在的語言版本，避免指向 404（壞掉的 hreflang 會干擾 Google 選擇 canonical）
const availLangs = slug ? await getAvailableLangs(slug) : new Set(['zh-tw', 'zh-hk', 'zh-cn', 'en']);
const hreflangUrls: Record<string, string> = {
  'zh-tw': `https://gobaligo.id/blog/${slug}/`,
  'zh-hk': `https://gobaligo.id/zh-hk/blog/${slug}/`,
  'zh-cn': `https://gobaligo.id/zh-cn/blog/${slug}/`,
  'en':    `https://gobaligo.id/en/blog/${slug}/`,
};
// x-default 指向最佳可用版本（優先序：zh-tw → en → zh-hk → zh-cn）
const xDefaultLang = (['zh-tw', 'en', 'zh-hk', 'zh-cn'] as const).find(l => availLangs.has(l)) ?? 'zh-tw';
const hreflangEntries = [
  { hreflang: 'zh-TW', lang: 'zh-tw' },
  { hreflang: 'zh-HK', lang: 'zh-hk' },
  { hreflang: 'zh-CN', lang: 'zh-cn' },
  { hreflang: 'en',    lang: 'en'    },
].filter(e => availLangs.has(e.lang));

const shareText = encodeURIComponent(title);
const shareUrl  = encodeURIComponent(canonicalUrl);
const shareLinks = {
  fb:      `https://www.facebook.com/sharer/sharer.php?u=${shareUrl}`,
  line:    `https://social-plugins.line.me/lineit/share?url=${shareUrl}`,
  wa:      `https://api.whatsapp.com/send?text=${shareText}%20${shareUrl}`,
  x:       `https://twitter.com/intent/tweet?url=${shareUrl}&text=${shareText}`,
  threads: `https://www.threads.net/intent/post?text=${shareText}%20${shareUrl}`,
};
const i18nShare = {
  label:    lang === 'en' ? 'Share' : lang === 'zh-cn' ? '分享' : '分享',
  copy:     lang === 'en' ? 'Copy Link' : lang === 'zh-cn' ? '复制链接' : '複製連結',
  copied:   lang === 'en' ? 'Copied!' : lang === 'zh-cn' ? '已复制！' : '已複製！',
  bookmark: lang === 'en' ? 'Bookmark' : lang === 'zh-cn' ? '收藏' : '書籤',
  bookmarked: lang === 'en' ? 'Saved!' : lang === 'zh-cn' ? '已收藏！' : '已儲存！',
};

const i18n = {
  sidebarTitle: lang === 'en' ? '📂 Categories' : lang === 'zh-cn' ? '📂 文章分类' : '📂 文章分類',
  allArticles: lang === 'en' ? 'Home' : '首頁',
  breadcrumbAll: lang === 'en' ? '← All Articles' : '← 所有文章',
  tocTitle: lang === 'en' ? '📋 Contents' : lang === 'zh-cn' ? '📋 目录' : '📋 目錄',
  tocCollapse: lang === 'en' ? 'Collapse' : '收起',
  tocExpand: lang === 'en' ? 'Expand' : lang === 'zh-cn' ? '展开' : '展開',
  relatedTitle: lang === 'en' ? '🗺️ You May Also Like' : lang === 'zh-cn' ? '🗺️ 你可能也想看' : '🗺️ 你可能也想看',
};

const categoryOrder = [
  '新手指南',
  '住宿推薦',
  '峇里島分區攻略',
  '簽證通關',
  '叫車包車',
  '家庭親子',
  '遊記分享',
  '美食景點活動',
  '新聞存檔',
];

const allCategories = [...new Set(allPosts.flatMap(p =>
  Array.isArray(p.data.category) ? p.data.category : [p.data.category]
).filter(Boolean))];

const categories = [
  ...categoryOrder.filter(c => allCategories.includes(c)),
  ...allCategories.filter(c => !categoryOrder.includes(c)),
];

const categoryCounts = categories.reduce((acc, cat) => {
  acc[cat] = allPosts.filter(p => {
    const cats = Array.isArray(p.data.category) ? p.data.category : [p.data.category];
    return cats.includes(cat);
  }).length;
  return acc;
}, {});

// 相關文章推薦：同分類優先，補足用 companion 分類（Topical Authority Siloing）
const getRandomPosts = (categoryName: string, count: number) => {
  return allPosts
    .filter(p => {
      const pCats = Array.isArray(p.data.category) ? p.data.category : [p.data.category];
      return pCats.includes(categoryName) && p.data.title !== title;
    })
    .sort(() => Math.random() - 0.5)
    .slice(0, count);
};

const primaryCat = cats[0] ?? '峇里島分區攻略';
const sameCatPosts = getRandomPosts(primaryCat, 4);
const companionCat = COMPANION_CAT[primaryCat] ?? '峇里島分區攻略';
const companionPosts = companionCat !== primaryCat
  ? getRandomPosts(companionCat, Math.max(2, 6 - sameCatPosts.length))
  : [];
const randomPosts = [...sameCatPosts, ...companionPosts].slice(0, 6);

// 促銷活動：過濾未過期的
const allPromos = await getCollection('promotions');
const now = new Date();
const activePromos = allPromos.filter(p => {
  if (!p.data.expiresAt) return true;
  const d = new Date(p.data.expiresAt);
  return isNaN(d.getTime()) || d > now;
});
const promosJson = JSON.stringify(activePromos.map(p => ({
  title: p.data.title,
  title_en: p.data.title_en || null,
  title_zh_cn: p.data.title_zh_cn || null,
  title_zh_hk: p.data.title_zh_hk || null,
  url: p.data.url,
  coverImage: p.data.coverImage || null,
})));

// Generate Person + LocalBusiness Schema for drivers (Task #3 - Schema markup for drivers)
const driverSchemas = (isDriverGuide && Array.isArray(drivers) && drivers.length > 0)
  ? drivers.map((driver) => {
      const driverSlug = driver.name.toLowerCase().replace(/\s+/g, '-');
      const driverUrl = `https://gobaligo.id/blog/${slug}/#${driverSlug}`;

      return {
        "@context": "https://schema.org",
        "@type": ["Person", "LocalBusiness"],
        "name": driver.name,
        "jobTitle": driver.category,
        "areaServed": {
          "@type": "City",
          "name": "Bali"
        },
        "knowsLanguage": driver.languages.map(lang => ({
          "@type": "Language",
          "name": lang
        })),
        "description": `${driver.name} - ${driver.category}. Specialty: ${driver.specialty}. Contact: ${driver.contact}. Recommended by ${driver.facebookRefs} community members.`,
        "url": driverUrl,
        "telephone": driver.contact,
        "priceRange": "IDR 600,000 - 800,000 per day",
        "availableLanguage": driver.languages,
        "speciality": driver.specialty,
        "expertise": "Bali private car driving",
        "ratingValue": "5",
        "reviewCount": driver.facebookRefs.toString()
      };
    })
  : [];

// Generate FAQPage Schema for SPA guides (Task #6)
const spaFaqSchema = isSpaGuide ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": lang === 'en' ? "How far in advance should I book a Bali spa?" : lang === 'zh-cn' ? "巴厘岛 SPA 需要提前多久预约？" : "峇里島 SPA 需要提前多久預約？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": lang === 'en' ? "Most highly-rated spas in Bali require advance reservations, typically 1-3 days ahead during peak season. Booking through Klook or directly with your villa concierge is recommended. Walk-in bookings may result in long waits or unavailable time slots." : lang === 'zh-cn' ? "巴厘岛大多数好评SPA需要提前预约，旺季通常需提前1-3天。建议通过 Klook 平台或别墅礼宾服务预订。临时预约可能会导致长时间等待或无法预约。" : "峇里島大多數好評 SPA 需要提前預約，旺季通常需提前 1-3 天。建議通過 Klook 平台或別墅禮賓服務預訂。臨時預約可能會導致長時間等待或無法預約。"
      }
    },
    {
      "@type": "Question",
      "name": lang === 'en' ? "What's the difference between Ubud spas and Jimbaran spas?" : lang === 'zh-cn' ? "乌布 SPA 和金巴兰 SPA 有什么区别？" : "烏布 SPA 和金巴蘭 SPA 有什麼區別？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": lang === 'en' ? "Ubud spas focus on traditional Balinese healing in forest settings with budget-friendly prices ($5-40). Jimbaran spas offer luxury oceanfront experiences with sunset therapies at higher prices ($50-200+). Choose Ubud for authentic cultural experiences and savings; Jimbaran for romantic, upscale treatments." : lang === 'zh-cn' ? "乌布SPA专注于传统峇里疗愈，森林环绕，价格亲民（$5-40）。金巴兰SPA提供海滨奢华体验，带日落疗程，价格较高（$50-200+）。选乌布体验地道文化和经济实惠；选金巴兰享受浪漫高端疗程。" : "烏布 SPA 專注於傳統峇里療愈，森林環繞，價格親民（$5-40）。金巴蘭 SPA 提供海濱奢華體驗，帶日落療程，價格較高（$50-200+）。選烏布體驗地道文化和經濟實惠；選金巴蘭享受浪漫高端療程。"
      }
    },
    {
      "@type": "Question",
      "name": lang === 'en' ? "What should I know before getting a spa treatment for the first time?" : lang === 'zh-cn' ? "第一次做 SPA 需要注意什么？" : "第一次做 SPA 需要注意什麼？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": lang === 'en' ? "Arrive 10-15 minutes early to complete check-in. Communicate your preferences and any physical concerns to the therapist. Start with a traditional 60-minute massage if unsure. Hydrate well before and after. Avoid heavy meals beforehand. Most spas require payment upfront or through your hotel. Tipping (10-15%) is appreciated. Remember not all hotels allow in-villa massage services, so confirm first." : lang === 'zh-cn' ? "提前 10-15 分钟到达完成入住。向治疗师说明偏好和任何身体问题。如不确定，先选择传统 60 分钟按摩。疗程前后充分补水。避免饱食。大多 SPA 需要提前付款或通过酒店支付。小费（10-15%）可选。注意不是所有酒店都允许到房按摩，应先确认。" : "提前 10-15 分鐘到達完成入住。向治療師說明偏好和任何身體問題。如不確定，先選擇傳統 60 分鐘按摩。療程前後充分補水。避免飽食。大多 SPA 需要提前付款或通過酒店支付。小費（10-15%）可選。注意不是所有酒店都允許到房按摩，應先確認。"
      }
    },
    {
      "@type": "Question",
      "name": lang === 'en' ? "Is massage or spa therapy better for relaxation?" : lang === 'zh-cn' ? "按摩和水疗哪个更适合放松？" : "按摩和水療哪個更適合放鬆？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": lang === 'en' ? "Traditional Balinese massage excels at releasing muscle tension and improving circulation. Water spa therapies focus on skincare and stress relief with aromatic oils. For maximum benefit, try both: start with an affordable massage in Ubud, then splurge on luxury spa treatments in Seminyak or Jimbaran. Many travelers do both during their stay." : lang === 'zh-cn' ? "传统峇里按摩擅长释放肌肉紧张和改善循环。水疗专注护肤和精油放松。为获得最佳效果，两种都试：先在乌布体验平价按摩，再在水明漾或金巴兰享受奢华疗程。很多旅客两种都做。" : "傳統峇里按摩擅長釋放肌肉緊張和改善循環。水療專注護膚和精油放鬆。為獲得最佳效果，兩種都試：先在烏布體驗平價按摩，再在水明漾或金巴蘭享受奢華療程。很多旅客兩種都做。"
      }
    },
    {
      "@type": "Question",
      "name": lang === 'en' ? "What is the typical price range for spas in Bali?" : lang === 'zh-cn' ? "巴厘岛 SPA 的价格范围是多少？" : "峇里島 SPA 的價格範圍是多少？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": lang === 'en' ? "Budget spas in rural areas cost $5-20 for traditional massage. Mid-range spas in popular areas (Ubud, Kuta, Sanur) charge $15-50 for quality treatments. Luxury spas in Seminyak, Jimbaran, and Nusa Dua range from $80-400+ for premium experiences. In-villa massage services cost $30-80 depending on service length and villa location." : lang === 'zh-cn' ? "农村地区预算SPA传统按摩$5-20。热门地区（乌布、库塔、沙努尔）中档SPA $15-50。水明漾、金巴兰、努沙杜瓦奢华SPA $80-400+。到房按摩服务$30-80（取决于服务时长和别墅位置）。" : "農村地區預算 SPA 傳統按摩 $5-20。熱門地區（烏布、庫塔、沙努爾）中檔 SPA $15-50。水明漾、金巴蘭、努沙杜瓦奢華 SPA $80-400+。到房按摩服務 $30-80（取決於服務時長和別墅位置）。"
      }
    }
  ]
} : null;
---

<html lang={lang === 'zh-cn' ? 'zh-CN' : lang === 'zh-hk' ? 'zh-HK' : lang === 'en' ? 'en' : 'zh-TW'}>
<head>
  <BaseHead
    title={metaTitle}
    description={metaDesc}
    image={ogImage || undefined}
    type="article"
    publishedTime={pubDate ? new Date(pubDate).toISOString() : undefined}
    modifiedTime={updatedDate ? new Date(updatedDate).toISOString() : (pubDate ? new Date(pubDate).toISOString() : undefined)}
  />

  {isPrivate && <meta name="robots" content="noindex,nofollow" />}

  <!-- LCP preload: fetch hero image early to reduce Largest Contentful Paint -->
  {ogImage && ogImage !== 'https://gobaligo.id/og-default.jpg' && (
    <link rel="preload" as="image" href={ogImage} fetchpriority="high" />
  )}

  <!-- 繁體中文文章：設定 session 標記，防止 /blog/ 首頁偵測瀏覽器語言後把使用者跳轉到其他語系 -->
  {(!lang || lang === 'zh-tw') && (
    <script is:inline>sessionStorage.setItem('gobaligo_lang_checked', '1');</script>
  )}

  <!-- hreflang: 只列出實際存在的語言版本，讓 Google 了解多語系關係（不指向 404） -->
  {slug && <>
    <link rel="alternate" hreflang="x-default" href={hreflangUrls[xDefaultLang]} />
    {hreflangEntries.map(e => (
      <link rel="alternate" hreflang={e.hreflang} href={hreflangUrls[e.lang]} />
    ))}
  </>}

  <!-- JSON-LD: Category-Aware Schema.org (Article + BreadcrumbList + category-specific) -->
  {slug && <SEO
    title={title}
    description={description ?? ''}
    category={category}
    body={body}
    headings={headings}
    lang={lang}
    slug={slug}
    pubDate={pubDate}
    updatedDate={updatedDate}
    heroImage={ogImage}
  />}

  <!-- JSON-LD: Driver Guide - Person + LocalBusiness Schema for each recommended driver -->
  {isDriverGuide && (
    <>
      {driverSchemas.length > 0 && driverSchemas.map((schema) => (
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
      ))}
      {driverSchemas.length === 0 && <script type="application/ld+json">{"test": "drivers data not loaded"}</script>}
    </>
  )}

  <!-- JSON-LD: SPA Guide - FAQPage Schema for SPA recommendations -->
  {isSpaGuide && spaFaqSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(spaFaqSchema)} />
  )}
</head>

<body>
  <Header lang={lang ?? 'blog'} slug={slug} />
  <TopStrip lang={lang ?? 'zh-tw'} />
  <div class="layout">

    <aside class="sidebar" data-pagefind-ignore>
      <div class="sidebar-section">
        <h3 class="sidebar-title">{i18n.sidebarTitle}</h3>
        <ul class="category-list">
          <li>
            <a href={blogIndexUrl} class="category-item">
              <span class="cat-name">{i18n.allArticles}</span>
              <span class="cat-count">{allPosts.length}</span>
            </a>
          </li>
          {categories.map(cat => (
            <li>
              <a href={`${catBaseUrl}${encodeURIComponent(cat)}`}
                 class={`category-item ${(Array.isArray(category) ? category : [category]).includes(cat) ? 'active' : ''}`}
                <span class="cat-name">{getCatLabel(cat)}</span>
                <span class="cat-count">{categoryCounts[cat]}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

    </aside>

    <main>
      <!-- Mobile 分類導覽（桌機版有 sidebar，手機版才顯示） -->
      <nav class="mobile-breadcrumb" aria-label="分類導覽">
        <a href={blogIndexUrl} class="breadcrumb-home">{i18n.breadcrumbAll}</a>
        {category && (
          <>
            <span class="breadcrumb-sep">›</span>
            <a
              href={`${catBaseUrl}${encodeURIComponent(Array.isArray(category) ? category[0] : category)}`}
              class="breadcrumb-cat"
            >
              {getCatLabel(Array.isArray(category) ? category[0] : category)}
            </a>
          </>
        )}
      </nav>

      <article {...(isPrivate ? { 'data-pagefind-ignore': true } : { 'data-pagefind-body': true })}>
        {!isPrivate && <span data-pagefind-filter={`lang:${lang ?? 'zh-tw'}`} hidden aria-hidden="true"></span>}
        <div class="prose">
          <div class="title">
            {category && <span class="article-category" data-pagefind-meta="category">{getCatLabel(Array.isArray(category) ? category[0] : category)}</span>}
            <h1>{title}</h1>
            <div class="date">
              <FormattedDate date={pubDate} />
              {updatedDate && (
                <span class="last-updated-on">· 更新於 <FormattedDate date={updatedDate} /></span>
              )}
