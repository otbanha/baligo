  <script>
  (function() {
    var section = document.getElementById('comments-section');
    if (!section) return;
    var slug    = section.dataset.slug;
    var list    = document.getElementById('comments-list');
    var form    = document.getElementById('comment-form');
    var nameEl  = document.getElementById('comment-name');
    var bodyEl  = document.getElementById('comment-content');
    var submitEl= document.getElementById('comment-submit');
    var msgEl   = document.getElementById('comment-msg');

    function formatDate(ts) {
      return new Date(ts).toLocaleDateString('zh-TW', { year: 'numeric', month: 'short', day: 'numeric' });
    }

    function renderComments(items) {
      if (!items.length) {
        list.innerHTML = '<p class="comments-empty">還沒有留言，來第一個留言吧！</p>';
        return;
      }
      list.innerHTML = items.map(function(c) {
        return '<div class="comment-item">' +
          '<div class="comment-header">' +
            '<span class="comment-name">' + c.name + '</span>' +
            '<span class="comment-date">' + formatDate(c.created_at) + '</span>' +
          '</div>' +
          '<div class="comment-body">' + c.content + '</div>' +
        '</div>';
      }).join('');
    }

    function setMsg(text, type) {
      msgEl.textContent = text;
      msgEl.className = 'comment-msg ' + type;
    }

    // Load comments
    list.innerHTML = '<p class="comments-empty">載入中⋯</p>';
    fetch('/api/comments?slug=' + encodeURIComponent(slug))
      .then(function(r) { return r.json(); })
      .then(renderComments)
      .catch(function() { list.innerHTML = '<p class="comments-empty">載入失敗</p>'; });

    // Submit
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var name    = nameEl.value.trim();
      var content = bodyEl.value.trim();
      if (name.length < 2 || content.length < 5) { setMsg('請填寫至少 2 字的姓名與 5 字的留言內容', 'err'); return; }

      submitEl.disabled = true;
      setMsg('', '');

      fetch('/api/comments', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ slug: slug, name: name, content: content }),
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.ok) {
          nameEl.value = '';
          bodyEl.value = '';
          setMsg('留言已送出！', 'ok');
          return fetch('/api/comments?slug=' + encodeURIComponent(slug))
            .then(function(r) { return r.json(); })
            .then(renderComments);
        } else {
          setMsg(data.error || '送出失敗', 'err');
        }
      })
      .catch(function() { setMsg('網路錯誤，請稍後再試', 'err'); })
      .finally(function() { submitEl.disabled = false; });
    });
  })();
  </script>

</body>
