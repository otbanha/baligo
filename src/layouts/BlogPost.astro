---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { getCollection } from 'astro:content';

type Props = CollectionEntry<'blog'>['data'];
const { title, description, pubDate, updatedDate, heroImage, category } = Astro.props;

const allPosts = await getCollection('blog');
const categories = [...new Set(allPosts.flatMap(p =>
  Array.isArray(p.data.category) ? p.data.category : [p.data.category]
).filter(Boolean))];

const categoryCounts = categories.reduce((acc, cat) => {
  acc[cat] = allPosts.filter(p => {
    const cats = Array.isArray(p.data.category) ? p.data.category : [p.data.category];
    return cats.includes(cat);
  }).length;
  return acc;
}, {});
---

<html lang="zh-TW">
<head>
  <BaseHead title={title} description={description} />
  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
</head>

<body>
  <Header />
  <div class="layout">

    <aside class="sidebar">
      <div class="sidebar-section">
        <div id="search"></div>
      </div>
      <div class="sidebar-section">
        <h3 class="sidebar-title">📂 文章分類</h3>
        <ul class="category-list">
          <li>
            <a href="/blog" class="category-item">
              <span class="cat-name">全部文章</span>
              <span class="cat-count">{allPosts.length}</span>
            </a>
          </li>
          {categories.map(cat => (
  <li>
    <a href={`/blog?cat=${encodeURIComponent(cat)}`}
       class={`category-item ${category === cat ? 'active' : ''}`}>
      <span class="cat-name">{cat}</span>
      <span class="cat-count">{categoryCounts[cat]}</span>
    </a>
  </li>
))}
        </ul>
      </div>
    </aside>

    <main>
      <article>
        <div class="hero-image">
          {heroImage && <img src={heroImage} alt={title} />}
        </div>
        <div class="prose">
          <div class="title">
            {category && <span class="article-category">{category}</span>}
            <h1>{title}</h1>
            <div class="date">
              <FormattedDate date={pubDate} />
              {updatedDate && (
                <span class="last-updated-on">· 更新於 <FormattedDate date={updatedDate} /></span>
              )}
            </div>
            <hr />
          </div>
          <slot />
        </div>
      </article>
    </main>

  </div>
  <Footer />
</body>

<script is:inline src="/pagefind/pagefind-ui.js"></script>
<script is:inline>
  window.addEventListener('DOMContentLoaded', () => {
<script>
  window.addEventListener('DOMContentLoaded', () => {
    if (window.PagefindUI) {
      new window.PagefindUI({
        element: '#search',
        showSubResults: false,
        placeholder: '搜尋文章...',
      });
    }
  });
</script>
</html>

<style>
.layout {
  display: grid;
  grid-template-columns: 260px 1fr;
  max-width: 1200px;
  margin: 0 auto;
  min-height: calc(100vh - 64px);
  align-items: start;
}

.sidebar {
  position: sticky;
  top: 64px;
  height: calc(100vh - 64px);
  overflow-y: auto;
  background: var(--white);
  border-right: 1px solid rgba(201, 168, 76, 0.2);
  padding: 1.5em 1em;
}

.sidebar::-webkit-scrollbar { width: 4px; }
.sidebar::-webkit-scrollbar-thumb {
  background: rgba(201, 168, 76, 0.3);
  border-radius: 2px;
}

.sidebar-section { margin-bottom: 1.8em; }

.sidebar-title {
  font-size: 0.85em;
  font-weight: 700;
  color: var(--ocean);
  letter-spacing: 0.05em;
  margin: 0 0 0.8em;
  padding-bottom: 0.5em;
  border-bottom: 1px solid rgba(201, 168, 76, 0.2);
}

.category-list { list-style: none; margin: 0; padding: 0; }

.category-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0.45em 0.7em;
  border-radius: 8px;
  text-decoration: none;
  color: var(--text);
  font-size: 0.88em;
  transition: all 0.15s;
  margin-bottom: 0.2em;
}

.category-item:hover {
  background: rgba(201, 168, 76, 0.1);
  color: var(--ocean);
}

.category-item.active {
  background: var(--ocean);
  color: var(--gold-light);
}

.cat-name { flex: 1; }

.cat-count {
  font-size: 0.78em;
  background: rgba(201, 168, 76, 0.15);
  color: var(--gold);
  padding: 0.1em 0.5em;
  border-radius: 10px;
  font-weight: 600;
}

.category-item.active .cat-count {
  background: rgba(255,255,255,0.15);
  color: var(--gold-light);
}

main {
  padding: 2em 2.5em;
  max-width: 780px;
}

.hero-image { margin-bottom: 1.5em; }

.hero-image img {
  width: 100%;
  height: auto;
  border-radius: 12px;
  box-shadow: var(--box-shadow);
}

.prose {
  color: var(--text);
  font-size: 1em;
  line-height: 1.9;
}

.title { margin-bottom: 1.5em; }

.article-category {
  display: inline-block;
  background: var(--gold);
  color: var(--ocean);
  font-size: 0.75em;
  font-weight: 700;
  padding: 0.2em 0.8em;
  border-radius: 20px;
  margin-bottom: 0.6em;
}

.title h1 {
  font-size: 1.6em;
  line-height: 1.4;
  font-weight: 700;
  color: var(--ocean);
  margin: 0 0 0.4em;
}

.date {
  font-size: 0.85em;
  color: var(--text-light);
  margin-bottom: 1em;
}

hr { margin: 1.2em 0 1.8em; }

.prose :global(h2) {
  font-size: 1.2em;
  font-weight: 700;
  color: var(--ocean);
  border-left: 4px solid var(--gold);
  padding-left: 0.7em;
  margin-top: 2em;
  margin-bottom: 0.8em;
  line-height: 1.4;
}

.prose :global(h3) {
  font-size: 1.05em;
  font-weight: 700;
  color: var(--ocean-light);
  margin-top: 1.5em;
  margin-bottom: 0.5em;
}

.prose :global(h4) {
  font-size: 1em;
  font-weight: 700;
  color: var(--text);
  margin-top: 1.2em;
}

@media (max-width: 900px) {
  .layout { grid-template-columns: 1fr; }
  .sidebar {
    position: static;
    height: auto;
    border-right: none;
    border-bottom: 1px solid rgba(201, 168, 76, 0.2);
  }
  main { padding: 1.5em 1em; }
}
</style>