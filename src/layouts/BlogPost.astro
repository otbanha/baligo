<script>
  // ── LINE QR 下載指南（line_qr_guide: true 的文章才啟用）──────────────
  (function () {
    const articleBody = document.getElementById('article-body');
    if (!articleBody || articleBody.dataset.qrGuide !== 'true') return;

    // ── 1. FB in-app browser 提示條 ──────────────────────────────────────
    (function injectFbBanner() {
      if (sessionStorage.getItem('fb-ib-dismissed')) return;
      if (!/FBAV|FBAN/i.test(navigator.userAgent)) return;
      const bar = document.createElement('div');
      bar.id = 'fb-ib-bar';
      bar.innerHTML =
        '<span>⚠️ 建議點右上 <b>⋯</b> → <b>用外部瀏覽器開啟</b>，存圖更順</span>' +
        '<button id="fb-ib-close" aria-label="關閉">✕</button>';
      document.body.insertBefore(bar, document.body.firstChild);
      document.getElementById('fb-ib-close')!.addEventListener('click', () => {
        bar.remove();
        sessionStorage.setItem('fb-ib-dismissed', '1');
      });
    })();

    // ── 2. 摺疊教學區塊（插在文章第一個 blockquote 之後）────────────────
    const firstBq = articleBody.querySelector('blockquote');
    if (firstBq && !articleBody.querySelector('.qr-tutorial')) {
      const details = document.createElement('details');
      details.className = 'qr-tutorial';
      details.innerHTML =
        '<summary>📱 手機如何加入司機 LINE（無法掃自己螢幕？這樣做）</summary>' +
        '<ol>' +
        '<li>點各司機下方「<strong>⬇️ 儲存 QR 圖到相簿</strong>」按鈕，或長按圖片選「儲存至相片」</li>' +
        '<li>開 <strong>LINE</strong> → 右上「＋加朋友」→ <strong>行動條碼</strong></li>' +
        '<li>掃描器右下點 <strong>相簿圖示</strong> → 選剛才存的 QR 圖 → 完成！</li>' +
        '</ol>' +
        '<p class="qr-tutorial-tip">💡 截圖整頁也可以，LINE 相簿掃描器能直接辨識畫面中的 QR Code。</p>';
      firstBq.insertAdjacentElement('afterend', details);
    }

    // ── 3. 每張圖片加「儲存 QR 圖」按鈕 ────────────────────────────────
    // .prose 是 #article-body 的外層 parent，直接用 articleBody 搜尋即可
    // requestAnimationFrame 確保 wrapImg IIFE 已執行完畢
    requestAnimationFrame(() => {
      // 只處理非 carousel 的單圖：p > div.img-wrap > img
      articleBody.querySelectorAll<HTMLImageElement>('p > div.img-wrap > img').forEach(img => {
        const para = img.closest('p')!;
        if (para.querySelector('.qr-dl-btn')) return; // 已處理過

        // 找最近的前一個 h2，取司機名
        let driverName = '';
        let sib: Element | null = para.previousElementSibling;
        while (sib) {
          if (sib.tagName === 'H2') { driverName = sib.textContent?.trim() ?? ''; break; }
          sib = sib.previousElementSibling;
        }
        // 清理特殊字元，保留中文與英文
        const safeName = driverName
          .replace(/[（）()【】《》「」*_]/g, '')
          .trim()
          .replace(/\s+/g, '-') || 'driver';

        const btn = document.createElement('button');
        btn.className = 'qr-dl-btn';
        btn.textContent = '⬇️ 儲存 QR 圖到相簿';
        btn.dataset.src = img.src;
        btn.dataset.name = safeName;

        const toast = document.createElement('span');
        toast.className = 'qr-dl-toast';

        para.insertAdjacentElement('afterend', toast);
        para.insertAdjacentElement('afterend', btn);

        btn.addEventListener('click', async () => {
          btn.disabled = true;
          btn.textContent = '處理中⋯';
          const src = btn.dataset.src!;
          const name = btn.dataset.name!;

          function showToast(msg: string, ok: boolean) {
            toast.textContent = msg;
            toast.style.color = ok ? '#2e7d32' : '#c0392b';
            toast.style.opacity = '1';
            clearTimeout((toast as any)._t);
            (toast as any)._t = setTimeout(() => { toast.style.opacity = '0'; }, 3500);
          }

          try {
            const res = await fetch(src, { mode: 'cors' });
            if (!res.ok) throw new Error('fetch-fail');
            const blob = await res.blob();
            const ext = blob.type.includes('jpeg') ? 'jpg' : 'png';
            const fileName = `${name}-line-qr.${ext}`;

            // iOS：Web Share API（分享表 → 儲存影像）
            if (typeof navigator.canShare === 'function') {
              const file = new File([blob], fileName, { type: blob.type });
              if (navigator.canShare({ files: [file] })) {
                try {
                  await navigator.share({ files: [file], title: 'LINE QR Code' });
                  showToast('✅ 請在分享選單點「儲存影像」', true);
                } catch (e: any) {
                  if (e.name !== 'AbortError') throw e;
                }
                return;
              }
            }

            // Android / Desktop：a[download]
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url; a.download = fileName;
            document.body.appendChild(a); a.click();
            setTimeout(() => { URL.revokeObjectURL(url); a.remove(); }, 1500);
            showToast('✅ 已開始下載', true);

          } catch {
            // CORS 失敗備援：新分頁開啟讓用戶長按存圖
            window.open(src, '_blank');
            showToast('請長按圖片 → 儲存至相片', false);
          } finally {
            btn.disabled = false;
            btn.textContent = '⬇️ 儲存 QR 圖到相簿';
          }
        });
      });
    });
  })();
</script>

