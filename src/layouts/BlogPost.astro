    color: var(--ocean, #5D4037);
    border-color: var(--gold, #C5A059);
    font-weight: 700;
  }
  .cat-count {
    display: none;
    font-size: 0.72em;
    background: rgba(197,160,89,0.2);
    color: rgba(232,213,163,0.85);
    padding: 0.05em 0.4em;
    border-radius: 10px;
    font-weight: 600;
  }
  .category-item.active .cat-count {
    background: rgba(93,64,55,0.25);
    color: var(--ocean, #5D4037);
