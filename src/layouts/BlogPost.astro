---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import ChatBot from '../components/ChatBot.astro';
import { getCollection } from 'astro:content';

type Props = CollectionEntry<'blog'>['data'] & { body?: string; headings?: { depth: number; slug: string; text: string }[] };
const { title, description, pubDate, updatedDate, heroImage, category, embeds, embedMap = {}, body = '', headings = [] } = Astro.props;

const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);
const showToc = tocHeadings.length >= 2;

const allPosts = await getCollection('blog');

const categoryOrder = [
  '新手指南',
  '住宿推薦',
  '峇里島分區攻略',
  '簽證通關',
  '叫車包車',
  '家庭親子',
  '遊記分享',
  '美食景點活動',
  '新聞存檔',
];

const allCategories = [...new Set(allPosts.flatMap(p =>
  Array.isArray(p.data.category) ? p.data.category : [p.data.category]
).filter(Boolean))];

const categories = [
  ...categoryOrder.filter(c => allCategories.includes(c)),
  ...allCategories.filter(c => !categoryOrder.includes(c)),
];

const categoryCounts = categories.reduce((acc, cat) => {
  acc[cat] = allPosts.filter(p => {
    const cats = Array.isArray(p.data.category) ? p.data.category : [p.data.category];
    return cats.includes(cat);
  }).length;
  return acc;
}, {});

// 亂數推薦文章
const getRandomPosts = (categoryName: string, count: number) => {
  return allPosts
    .filter(p => {
      const cats = Array.isArray(p.data.category) ? p.data.category : [p.data.category];
      return cats.includes(categoryName) && p.data.title !== title;
    })
    .sort(() => Math.random() - 0.5)
    .slice(0, count);
};

const randomArea = getRandomPosts('峇里島分區攻略', 5);
const randomAccom = getRandomPosts('住宿推薦', 4);
const randomPosts = [...randomArea, ...randomAccom].sort(() => Math.random() - 0.5).slice(0, 6);

// 促銷活動：過濾未過期的
const allPromos = await getCollection('promotions');
const now = new Date();
const activePromos = allPromos.filter(p => {
  if (!p.data.expiresAt) return true;
  const d = new Date(p.data.expiresAt);
  return isNaN(d.getTime()) || d > now;
});
const promosJson = JSON.stringify(activePromos.map(p => ({
  title: p.data.title,
  url: p.data.url,
  coverImage: p.data.coverImage || null,
})));
---

<html lang="zh-TW">
<head>
  <BaseHead title={title} description={description} />
</head>

<body>
  <Header />
  <div class="layout">

    <aside class="sidebar">
      <div class="sidebar-section">
        <h3 class="sidebar-title">📂 文章分類</h3>
        <ul class="category-list">
          <li>
            <a href="/blog" class="category-item">
              <span class="cat-name">全部文章</span>
              <span class="cat-count">{allPosts.length}</span>
            </a>
          </li>
          {categories.map(cat => (
            <li>
              <a href={`/blog?cat=${encodeURIComponent(cat)}`}
                 class={`category-item ${(Array.isArray(category) ? category : [category]).includes(cat) ? 'active' : ''}`}
                <span class="cat-name">{cat}</span>
                <span class="cat-count">{categoryCounts[cat]}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      {activePromos.length > 0 && (
        <div class="sidebar-section">
          <div id="promo-block">
            <!-- 由 JS 動態插入 -->
          </div>
        </div>
      )}
    </aside>

    <main>
      <!-- Mobile 分類導覽（桌機版有 sidebar，手機版才顯示） -->
      <nav class="mobile-breadcrumb" aria-label="分類導覽">
        <a href="/blog" class="breadcrumb-home">← 所有文章</a>
        {category && (
          <>
            <span class="breadcrumb-sep">›</span>
            <a
              href={`/blog?cat=${encodeURIComponent(Array.isArray(category) ? category[0] : category)}`}
              class="breadcrumb-cat"
            >
              {Array.isArray(category) ? category[0] : category}
            </a>
          </>
        )}
      </nav>

      <article>
        <div class="prose">
          <div class="title">
            {category && <span class="article-category">{category}</span>}
            <h1>{title}</h1>
            <div class="date">
              <FormattedDate date={pubDate} />
              {updatedDate && (
                <span class="last-updated-on">· 更新於 <FormattedDate date={updatedDate} /></span>
              )}
              <a href={`/admin/#/collections/blog/entries/${Astro.params.slug}`} class="edit-link" target="_blank" rel="noopener">✏️ 編輯文章</a>
            </div>
            <hr />
          </div>

          {showToc && (
            <nav class="toc" aria-label="文章目錄">
              <div class="toc-header">
                <span class="toc-title">📋 目錄</span>
                <button class="toc-toggle" aria-expanded="true" aria-controls="toc-list">收起</button>
              </div>
              <ol id="toc-list" class="toc-list">
                {tocHeadings.map(h => (
                  <li class={h.depth === 3 ? 'toc-h3' : 'toc-h2'}>
                    <a href={`#${h.slug}`}>{h.text}</a>
                  </li>
                ))}
              </ol>
            </nav>
          )}

          <slot />
        </div>

        <!-- 文章底部推薦 -->
        {randomPosts.length > 0 && (
          <div class="related-posts">
            <h2 class="related-title">🗺️ 你可能也想看</h2>
            <div class="related-grid">
              {randomPosts.map(post => (
                <a href={`/blog/${post.id}/`} class="related-card">
                  {post.data.heroImage && (
                    <div class="related-image">
                      <img src={post.data.heroImage} alt={post.data.title} loading="lazy" />
                    </div>
                  )}
                  <div class="related-body">
                    {post.data.category && (
                      <span class="related-cat">
                        {Array.isArray(post.data.category) ? post.data.category[0] : post.data.category}
                      </span>
                    )}
                    <p class="related-card-title">{post.data.title}</p>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}
      </article>
    </main>

  </div>

<script define:vars={{ embedMap, promosJson }}>
// 影片嵌入
window.addEventListener('load', () => {
  document.querySelectorAll('.video-placeholder').forEach(el => {
    const pos = el.getAttribute('data-position');
    const embed = embedMap[pos];
    if (!embed) return;

    let embedHtml = '';
    if (embed.platform === 'youtube') {
      const r = embed.url.match(/(?:youtube\.com\/(?:watch\?v=|shorts\/)|youtu\.be\/)([a-zA-Z0-9_-]{11})/);
      if (r) embedHtml = '<div class="video-embed"><iframe src="https://www.youtube.com/embed/' + r[1] + '" frameborder="0" allowfullscreen loading="lazy"></iframe></div>';
    } else if (embed.platform === 'instagram') {
      const r = embed.url.match(/instagram\.com\/(?:reel|p)\/([A-Za-z0-9_-]+)/);
      if (r) embedHtml = '<div class="video-embed video-embed--ig"><blockquote class="instagram-media" data-instgrm-permalink="https://www.instagram.com/p/' + r[1] + '/" data-instgrm-version="14" style="width:100%;margin:0;"></blockquote></div>';
    } else if (embed.platform === 'tiktok') {
      const r = embed.url.match(/tiktok\.com\/@[^/]+\/video\/(\d+)/);
      if (r) embedHtml = '<div class="video-embed video-embed--tt"><blockquote class="tiktok-embed" cite="' + embed.url + '" data-video-id="' + r[1] + '" style="width:100%;margin:0;"><section></section></blockquote></div>';
    }

    if (embedHtml) {
      const div = document.createElement('div');
      div.innerHTML = embedHtml;
      el.parentNode.replaceChild(div.firstChild, el);
    }
  });

  // 促銷區塊：隨機挑一個顯示
  const promos = JSON.parse(promosJson);
  if (promos.length === 0) return;

  const promo = promos[Math.floor(Math.random() * promos.length)];
  const block = document.getElementById('promo-block');
  if (!block) return;

  block.innerHTML = `
    <a href="${promo.url}" target="_blank" rel="noopener" class="promo-card">
      <div class="promo-body">
        <p class="promo-title">${promo.title}</p>
        <span class="promo-cta">查看優惠 →</span>
      </div>
      ${promo.coverImage
        ? `<div class="promo-image"><img src="${promo.coverImage}" alt="${promo.title}" loading="lazy" /></div>`
        : ''}
    </a>
  `;
});
</script>

  <ChatBot />
  <Footer />
</body>
</html>

<script>
  // TOC toggle + scroll highlight
  const tocToggle = document.querySelector('.toc-toggle') as HTMLButtonElement | null;
  const tocList = document.getElementById('toc-list');
  if (tocToggle && tocList) {
    tocToggle.addEventListener('click', () => {
      const collapsed = tocList.classList.toggle('hidden');
      tocToggle.textContent = collapsed ? '展開' : '收起';
      tocToggle.setAttribute('aria-expanded', String(!collapsed));
    });

    // Scroll spy
    const tocLinks = Array.from(tocList.querySelectorAll('a')) as HTMLAnchorElement[];
    const headingEls = tocLinks.map(a => document.getElementById(a.getAttribute('href')!.slice(1))).filter(Boolean) as HTMLElement[];

    const observer = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          tocLinks.forEach(a => a.classList.remove('active'));
          const idx = headingEls.indexOf(entry.target as HTMLElement);
          if (idx !== -1) tocLinks[idx].classList.add('active');
        }
      });
    }, { rootMargin: '0px 0px -60% 0px', threshold: 0 });

    headingEls.forEach(el => observer.observe(el));
  }
</script>

<script>
  // Page view counter — session-deduped (same tab only counts once)
  (function () {
    const slug = location.pathname.replace(/\/?$/, '/').replace(/^(?!\/)/, '/');
    if (!slug.startsWith('/blog/')) return;
    const key = '_pv' + slug;
    if (sessionStorage.getItem(key)) return;
    sessionStorage.setItem(key, '1');
    fetch('/api/pageview', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ slug }),
      keepalive: true,
    }).catch(() => {});
  })();
</script>

<style>
.layout {
  display: grid;
  grid-template-columns: 260px 1fr;
  max-width: 1200px;
  margin: 0 auto;
  min-height: calc(100vh - 64px);
  align-items: start;
}

.sidebar {
  position: sticky;
  top: 64px;
  height: calc(100vh - 64px);
  overflow-y: auto;
  background: var(--white);
  border-right: 1px solid rgba(201, 168, 76, 0.2);
  padding: 1.5em 1em;
}

.sidebar::-webkit-scrollbar { width: 4px; }
.sidebar::-webkit-scrollbar-thumb {
  background: rgba(201, 168, 76, 0.3);
  border-radius: 2px;
}

.sidebar-section { margin-bottom: 1.8em; }

.sidebar-title {
  font-size: 0.85em;
  font-weight: 700;
  color: var(--ocean);
  letter-spacing: 0.05em;
  margin: 0 0 0.8em;
  padding-bottom: 0.5em;
  border-bottom: 1px solid rgba(201, 168, 76, 0.2);
}

.category-list { list-style: none; margin: 0; padding: 0; }

.category-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0.45em 0.7em;
  border-radius: 8px;
  text-decoration: none;
  color: var(--text);
  font-size: 0.88em;
  transition: all 0.15s;
  margin-bottom: 0.2em;
}

.category-item:hover { background: rgba(201, 168, 76, 0.1); color: var(--ocean); }
.category-item.active { background: var(--ocean); color: var(--gold-light); }
.cat-name { flex: 1; }

.cat-count {
  font-size: 0.78em;
  background: rgba(201, 168, 76, 0.15);
  color: var(--gold);
  padding: 0.1em 0.5em;
  border-radius: 10px;
  font-weight: 600;
}

.category-item.active .cat-count { background: rgba(255,255,255,0.15); color: var(--gold-light); }

/* 促銷卡片 */
:global(.promo-card) {
  display: block;
  font-size: 13px;
  text-decoration: none;
  border-radius: 10px;
  overflow: hidden;
  border: 1px solid rgba(201, 168, 76, 0.3);
  transition: transform 0.2s, box-shadow 0.2s;
  background: var(--white);
}

:global(.promo-card):hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 16px rgba(10, 22, 40, 0.1);
}

:global(.promo-image) {
  aspect-ratio: 16/9;
  overflow: hidden;
  background: var(--ocean-mid);
}

:global(.promo-image) img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

:global(.promo-body) {
  padding: 0.7em 0.8em;
}

:global(.promo-title) {
  font-size: 13px !important;
  font-weight: 600;
  color: var(--ocean);
  margin: 0 0 0.4em !important;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

:global(.promo-cta) {
  font-size: 13px;
  font-weight: 700;
  color: var(--gold);
}

main {
  padding: 2em 2.5em;
  max-width: 780px;
}

.hero-image { margin-bottom: 1.5em; }
.hero-image img { width: 100%; height: auto; border-radius: 12px; box-shadow: var(--box-shadow); }

.prose { color: var(--text); font-size: 1em; line-height: 1.9; }
.title { margin-bottom: 1.5em; }

.article-category {
  display: inline-block;
  background: var(--gold);
  color: var(--ocean);
  font-size: 0.75em;
  font-weight: 700;
  padding: 0.2em 0.8em;
  border-radius: 20px;
  margin-bottom: 0.6em;
}

.title h1 { font-size: 1.6em; line-height: 1.4; font-weight: 700; color: var(--ocean); margin: 0 0 0.4em; }
.date { font-size: 0.85em; color: var(--text-light); margin-bottom: 1em; display: flex; align-items: center; gap: 0.8em; flex-wrap: wrap; }
.edit-link { font-size: 0.8em; color: var(--text-light); text-decoration: none; border: 1px solid rgba(0,0,0,0.15); border-radius: 6px; padding: 0.1em 0.5em; }
.edit-link:hover { color: var(--ocean); border-color: var(--ocean); }
hr { margin: 1.2em 0 1.8em; }

.prose :global(h2) {
  font-size: 1.2em; font-weight: 700; color: var(--ocean);
  border-left: 4px solid var(--gold); padding-left: 0.7em;
  margin-top: 2em; margin-bottom: 0.8em; line-height: 1.4;
}

.prose :global(h3) { font-size: 1.05em; font-weight: 700; color: var(--ocean-light); margin-top: 1.5em; margin-bottom: 0.5em; }
.prose :global(h4) { font-size: 1em; font-weight: 700; color: var(--text); margin-top: 1.2em; }

/* 影片嵌入 */
.prose :global(.video-embed) {
  position: relative;
  width: 100%;
  aspect-ratio: 16/9;
  margin: 1.5em 0;
  border-radius: 12px;
  overflow: hidden;
}

.prose :global(.video-embed iframe) {
  position: absolute;
  top: 0; left: 0;
  width: 100%;
  height: 100%;
}

.prose :global(.video-embed--ig),
.prose :global(.video-embed--tt) {
  aspect-ratio: unset;
  max-width: 540px;
  margin: 1.5em auto;
}

/* 推薦文章 */
.related-posts {
  margin-top: 3em;
  padding-top: 2em;
  border-top: 2px solid var(--gold);
}

.related-title {
  font-size: 1.1em;
  font-weight: 700;
  color: var(--ocean);
  margin: 0 0 1.2em;
}

.related-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1em;
}

.related-card {
  display: flex;
  flex-direction: column;
  text-decoration: none;
  color: inherit;
  border-radius: 10px;
  overflow: hidden;
  border: 1px solid rgba(201, 168, 76, 0.2);
  transition: transform 0.2s;
}

.related-card:hover { transform: translateY(-3px); box-shadow: 0 4px 16px rgba(10,22,40,0.1); }

.related-image { aspect-ratio: 16/9; overflow: hidden; background: var(--ocean-mid); }
.related-image img { width: 100%; height: 100%; object-fit: cover; }

.related-body { padding: 0.7em 0.8em; background: var(--white); flex: 1; }

.related-cat {
  font-size: 0.68em;
  font-weight: 700;
  color: var(--ocean);
  background: rgba(201, 168, 76, 0.15);
  padding: 0.1em 0.5em;
  border-radius: 10px;
  display: inline-block;
  margin-bottom: 0.3em;
}

.related-card-title {
  font-size: 0.82em;
  font-weight: 600;
  color: var(--ocean);
  margin: 0;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* TOC */
.toc {
  background: rgba(201, 168, 76, 0.07);
  border: 1px solid rgba(201, 168, 76, 0.3);
  border-left: 4px solid var(--gold);
  border-radius: 10px;
  padding: 0.9em 1.1em;
  margin-bottom: 2em;
  font-size: 0.88em;
}

.toc-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 0.6em;
}

.toc-title {
  font-weight: 700;
  color: var(--ocean);
  font-size: 0.92em;
  letter-spacing: 0.03em;
}

.toc-toggle {
  background: none;
  border: 1px solid rgba(201, 168, 76, 0.4);
  border-radius: 6px;
  color: var(--text-light);
  font-size: 0.78em;
  padding: 0.1em 0.6em;
  cursor: pointer;
  transition: all 0.15s;
}

.toc-toggle:hover { background: rgba(201, 168, 76, 0.15); color: var(--ocean); }

.toc-list {
  margin: 0;
  padding: 0;
  list-style: none;
}

.toc-list.hidden { display: none; }

.toc-h2 { padding: 0.2em 0; }
.toc-h3 { padding: 0.15em 0 0.15em 1.2em; }

.toc-h2 > a,
.toc-h3 > a {
  color: var(--ocean);
  text-decoration: none;
  line-height: 1.4;
  display: block;
  border-radius: 4px;
  padding: 0.1em 0.3em;
  transition: background 0.12s, color 0.12s;
}

.toc-h2 > a { font-weight: 600; }
.toc-h3 > a { color: var(--text-light); font-size: 0.95em; }

.toc-h2 > a:hover,
.toc-h3 > a:hover { background: rgba(201, 168, 76, 0.15); color: var(--gold); }

/* TOC active highlight */
.toc-h2 > a.active,
.toc-h3 > a.active { color: var(--gold); font-weight: 700; }

/* Prose 內容響應式 */
.prose :global(img) {
  max-width: 100%;
  height: auto;
  border-radius: 8px;
  display: block;
}

.prose :global(table) {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.9em;
}

.prose :global(th),
.prose :global(td) {
  border: 1px solid rgba(201, 168, 76, 0.3);
  padding: 0.5em 0.8em;
  text-align: left;
}

.prose :global(pre) {
  overflow-x: auto;
  border-radius: 8px;
  padding: 1em;
  font-size: 0.85em;
}

.prose :global(a) {
  word-break: break-word;
}

/* Mobile 麵包屑：桌機隱藏，手機才顯示 */
.mobile-breadcrumb {
  display: none;
}

@media (max-width: 900px) {
  .layout { grid-template-columns: 1fr; }
  .sidebar { display: none; }
  main {
    padding: 1.2em 1em;
    width: 100%;
    max-width: 100%;
  }
  .related-grid { grid-template-columns: repeat(2, 1fr); }

  .mobile-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.4em;
    padding: 0.7em 1em;
    background: rgba(201, 168, 76, 0.08);
    border-bottom: 1px solid rgba(201, 168, 76, 0.2);
    font-size: 0.85em;
    flex-wrap: wrap;
  }
  .breadcrumb-home {
    color: var(--ocean);
    font-weight: 600;
    text-decoration: none;
  }
  .breadcrumb-home:hover { text-decoration: underline; }
  .breadcrumb-sep { color: var(--text-light); }
  .breadcrumb-cat {
    color: var(--gold);
    font-weight: 600;
    text-decoration: none;
  }
  .breadcrumb-cat:hover { text-decoration: underline; }
}

@media (max-width: 600px) {
  main { padding: 1em 0.9em; }
  .title h1 { font-size: 1.25em; }
  .prose { font-size: 0.97em; line-height: 1.8; }
  .prose :global(h2) { font-size: 1.1em; }
  .prose :global(h3) { font-size: 1em; }
  .related-grid { grid-template-columns: 1fr; }

  /* 表格在小螢幕加水平捲動 */
  .prose :global(table) {
    display: block;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
}
</style>