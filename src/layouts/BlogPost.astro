---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import SEO from '../components/SEO.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import ChatBot from '../components/ChatBot.astro';
import { getCollection } from 'astro:content';

type Props = CollectionEntry<'blog'>['data'] & { body?: string; headings?: { depth: number; slug: string; text: string }[]; lang?: string; slug?: string };
const { title, description, pubDate, updatedDate, heroImage, category, embeds, embedMap = {}, body = '', headings = [], lang, slug } = Astro.props;

const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);
const showToc = tocHeadings.length >= 2;

// 若無 heroImage，抓文章內容第一張圖作為 OG image
function extractFirstImage(text: string): string {
  const m = text?.match(/!\[.*?\]\((https?:\/\/[^\)\s]+)\)/);
  return m ? m[1] : '';
}
const ogImage = (typeof heroImage === 'string' ? heroImage : '') || extractFirstImage(body);

const collectionName = lang === 'en' ? 'en' : lang === 'zh-cn' ? 'zh-cn' : lang === 'zh-hk' ? 'zh-hk' : 'blog';
const allPosts = await getCollection(collectionName as any);

const CAT_EN: Record<string, string> = {
  '新手指南': "Beginner's Guide",
  '住宿推薦': 'Accommodation', '住宿推荐': 'Accommodation',
  '峇里島分區攻略': 'Area Guide', '峇里岛分区攻略': 'Area Guide',
  '簽證通關': 'Visa & Entry', '签证通关': 'Visa & Entry',
  '叫車包車': 'Transport', '叫车包车': 'Transport',
  '家庭親子': 'Family Travel', '家庭亲子': 'Family Travel',
  '遊記分享': 'Travel Stories', '游记分享': 'Travel Stories',
  '美食景點活動': 'Food & Activities', '美食景点活动': 'Food & Activities',
  '新聞存檔': 'News Archive', '新闻存档': 'News Archive',
  '旅行技巧': 'Travel Tips',
};

const CAT_ZH_CN: Record<string, string> = {
  '新手指南': '新手指南',
  '住宿推薦': '住宿推荐', '住宿推荐': '住宿推荐',
  '峇里島分區攻略': '峇里岛分区攻略', '峇里岛分区攻略': '峇里岛分区攻略',
  '簽證通關': '签证通关', '签证通关': '签证通关',
  '叫車包車': '叫车包车', '叫车包车': '叫车包车',
  '家庭親子': '家庭亲子', '家庭亲子': '家庭亲子',
  '遊記分享': '游记分享', '游记分享': '游记分享',
  '美食景點活動': '美食景点活动', '美食景点活动': '美食景点活动',
  '新聞存檔': '新闻存档', '新闻存档': '新闻存档',
};

const getCatLabel = (cat: string) => {
  if (lang === 'en') return CAT_EN[cat] ?? cat;
  if (lang === 'zh-cn') return CAT_ZH_CN[cat] ?? cat;
  return cat;
};

const blogBase = lang === 'en' ? '/en/blog' : lang === 'zh-cn' ? '/zh-cn/blog' : lang === 'zh-hk' ? '/zh-hk/blog' : '/blog';

const i18n = {
  sidebarTitle: lang === 'en' ? '📂 Categories' : lang === 'zh-cn' ? '📂 文章分类' : '📂 文章分類',
  allArticles: lang === 'en' ? 'All Articles' : '全部文章',
  breadcrumbAll: lang === 'en' ? '← All Articles' : '← 所有文章',
  tocTitle: lang === 'en' ? '📋 Contents' : lang === 'zh-cn' ? '📋 目录' : '📋 目錄',
  tocCollapse: lang === 'en' ? 'Collapse' : '收起',
  tocExpand: lang === 'en' ? 'Expand' : lang === 'zh-cn' ? '展开' : '展開',
  relatedTitle: lang === 'en' ? '🗺️ You May Also Like' : lang === 'zh-cn' ? '🗺️ 你可能也想看' : '🗺️ 你可能也想看',
};

const categoryOrder = [
  '新手指南',
  '住宿推薦',
  '峇里島分區攻略',
  '簽證通關',
  '叫車包車',
  '家庭親子',
  '遊記分享',
  '美食景點活動',
  '新聞存檔',
];

const allCategories = [...new Set(allPosts.flatMap(p =>
  Array.isArray(p.data.category) ? p.data.category : [p.data.category]
).filter(Boolean))];

const categories = [
  ...categoryOrder.filter(c => allCategories.includes(c)),
  ...allCategories.filter(c => !categoryOrder.includes(c)),
];

const categoryCounts = categories.reduce((acc, cat) => {
  acc[cat] = allPosts.filter(p => {
    const cats = Array.isArray(p.data.category) ? p.data.category : [p.data.category];
    return cats.includes(cat);
  }).length;
  return acc;
}, {});

// 亂數推薦文章
const getRandomPosts = (categoryName: string, count: number) => {
  return allPosts
    .filter(p => {
      const cats = Array.isArray(p.data.category) ? p.data.category : [p.data.category];
      return cats.includes(categoryName) && p.data.title !== title;
    })
    .sort(() => Math.random() - 0.5)
    .slice(0, count);
};

const randomArea = getRandomPosts('峇里島分區攻略', 5);
const randomAccom = getRandomPosts('住宿推薦', 4);
const randomPosts = [...randomArea, ...randomAccom].sort(() => Math.random() - 0.5).slice(0, 6);

// 促銷活動：過濾未過期的
const allPromos = await getCollection('promotions');
const now = new Date();
const activePromos = allPromos.filter(p => {
  if (!p.data.expiresAt) return true;
  const d = new Date(p.data.expiresAt);
  return isNaN(d.getTime()) || d > now;
});
const promosJson = JSON.stringify(activePromos.map(p => ({
  title: p.data.title,
  title_en: p.data.title_en || null,
  title_zh_cn: p.data.title_zh_cn || null,
  title_zh_hk: p.data.title_zh_hk || null,
  url: p.data.url,
  coverImage: p.data.coverImage || null,
})));
---

<html lang={lang === 'zh-cn' ? 'zh-CN' : lang === 'zh-hk' ? 'zh-HK' : lang === 'en' ? 'en' : 'zh-TW'}>
<head>
  <BaseHead
    title={title}
    description={description ?? ''}
    image={ogImage || undefined}
    type="article"
    publishedTime={pubDate ? new Date(pubDate).toISOString() : undefined}
    modifiedTime={updatedDate ? new Date(updatedDate).toISOString() : (pubDate ? new Date(pubDate).toISOString() : undefined)}
  />

  <!-- hreflang: 列出全部語言版本，讓 Google 了解多語系關係 -->
  {slug && <>
    <link rel="alternate" hreflang="x-default"  href={`https://gobaligo.id/blog/${slug}/`} />
    <link rel="alternate" hreflang="zh-TW"      href={`https://gobaligo.id/blog/${slug}/`} />
    <link rel="alternate" hreflang="zh-HK"      href={`https://gobaligo.id/zh-hk/blog/${slug}/`} />
    <link rel="alternate" hreflang="zh-CN"      href={`https://gobaligo.id/zh-cn/blog/${slug}/`} />
    <link rel="alternate" hreflang="en"         href={`https://gobaligo.id/en/blog/${slug}/`} />
  </>}

  <!-- JSON-LD: Category-Aware Schema.org (Article + BreadcrumbList + category-specific) -->
  {slug && <SEO
    title={title}
    description={description ?? ''}
    category={category}
    body={body}
    headings={headings}
    lang={lang}
    slug={slug}
    pubDate={pubDate}
    updatedDate={updatedDate}
    heroImage={ogImage}
  />}
</head>

<body>
  <Header lang={lang ?? 'blog'} slug={slug} />
  <div class="layout">

    <aside class="sidebar">
      <div class="sidebar-section">
        <h3 class="sidebar-title">{i18n.sidebarTitle}</h3>
        <ul class="category-list">
          <li>
            <a href={blogBase} class="category-item">
              <span class="cat-name">{i18n.allArticles}</span>
              <span class="cat-count">{allPosts.length}</span>
            </a>
          </li>
          {categories.map(cat => (
            <li>
              <a href={`${blogBase}?cat=${encodeURIComponent(cat)}`}
                 class={`category-item ${(Array.isArray(category) ? category : [category]).includes(cat) ? 'active' : ''}`}
                <span class="cat-name">{getCatLabel(cat)}</span>
                <span class="cat-count">{categoryCounts[cat]}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      {activePromos.length > 0 && (
        <div class="sidebar-section">
          <div id="promo-block">
            <!-- 由 JS 動態插入 -->
          </div>
        </div>
      )}
    </aside>

    <main>
      <!-- Mobile 分類導覽（桌機版有 sidebar，手機版才顯示） -->
      <nav class="mobile-breadcrumb" aria-label="分類導覽">
        <a href={blogBase} class="breadcrumb-home">{i18n.breadcrumbAll}</a>
        {category && (
          <>
            <span class="breadcrumb-sep">›</span>
            <a
              href={`${blogBase}?cat=${encodeURIComponent(Array.isArray(category) ? category[0] : category)}`}
              class="breadcrumb-cat"
            >
              {getCatLabel(Array.isArray(category) ? category[0] : category)}
            </a>
          </>
        )}
      </nav>

      <article>
        <div class="prose">
          <div class="title">
            {category && <span class="article-category">{getCatLabel(Array.isArray(category) ? category[0] : category)}</span>}
            <h1>{title}</h1>
            <div class="date">
              <FormattedDate date={pubDate} />
              {updatedDate && (
                <span class="last-updated-on">· 更新於 <FormattedDate date={updatedDate} /></span>
              )}
              <a href={`/admin/#/collections/blog/entries/${Astro.params.slug}`} class="edit-link" target="_blank" rel="noopener">✏️ 編輯文章</a>
            </div>
            <hr />
          </div>

          {showToc && (
            <nav class="toc" aria-label="文章目錄">
              <div class="toc-header">
                <span class="toc-title">{i18n.tocTitle}</span>
                <button class="toc-toggle" aria-expanded="true" aria-controls="toc-list" data-collapse={i18n.tocCollapse} data-expand={i18n.tocExpand}>{i18n.tocCollapse}</button>
              </div>
              <ol id="toc-list" class="toc-list">
                {tocHeadings.map(h => (
                  <li class={h.depth === 3 ? 'toc-h3' : 'toc-h2'}>
                    <a href={`#${h.slug}`}>{h.text}</a>
                  </li>
                ))}
              </ol>
            </nav>
          )}

          <slot />
        </div>

        <!-- 文章底部推薦 -->
        {randomPosts.length > 0 && (
          <div class="related-posts">
            <h2 class="related-title">{i18n.relatedTitle}</h2>
            <div class="related-grid">
              {randomPosts.map(post => (
                <a href={`${blogBase}/${post.id}/`} class="related-card">
                  {post.data.heroImage && (
                    <div class="related-image">
                      <img src={post.data.heroImage} alt={post.data.title} loading="lazy" />
                    </div>
                  )}
                  <div class="related-body">
                    {post.data.category && (
                      <span class="related-cat">
                        {getCatLabel(Array.isArray(post.data.category) ? post.data.category[0] : post.data.category)}
                      </span>
                    )}
                    <p class="related-card-title">{post.data.title}</p>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- 熱門分區攻略快速連結 (Semantic Siloing / Internal Linking) -->
        <nav class="region-links" aria-label={lang === 'en' ? 'Popular Bali Areas' : '熱門峇里島分區'}>
          <p class="region-links-title">
            {lang === 'en' ? '🗺️ Explore Bali by Area' : lang === 'zh-cn' ? '🗺️ 峇里岛热门分区攻略' : '🗺️ 峇里島熱門分區攻略'}
          </p>
          <ul class="region-links-list">
            {[
              { area: 'Kuta',     zh: '庫塔 Kuta',     zhcn: '库塔 Kuta'     },
              { area: 'Seminyak', zh: '水明漾 Seminyak', zhcn: '水明漾 Seminyak' },
              { area: 'Canggu',   zh: '長谷/倉古/蒼古 Canggu',   zhcn: '长谷/苍古 Canggu'   },
              { area: 'Ubud',     zh: '烏布 Ubud',     zhcn: '乌布 Ubud'     },
              { area: 'Uluwatu',  zh: '烏魯瓦圖 Uluwatu', zhcn: '乌鲁瓦图 Uluwatu' },
              { area: 'Jimbaran', zh: '金巴蘭 Jimbaran', zhcn: '金巴兰 Jimbaran' },
            ].map(({ area, zh, zhcn }) => (
              <li>
                <a href={`${blogBase}?cat=${encodeURIComponent('峇里島分區攻略')}&q=${area}`}>
                  {lang === 'en' ? area : lang === 'zh-cn' ? zhcn : zh}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </article>
    </main>

  </div>

<script define:vars={{ embedMap, promosJson, lang }}>
// 影片嵌入
window.addEventListener('load', () => {
  document.querySelectorAll('.video-placeholder').forEach(el => {
    const pos = el.getAttribute('data-position');
    const embed = embedMap[pos];
    if (!embed) return;

    let embedHtml = '';
    if (embed.platform === 'youtube') {
      const r = embed.url.match(/(?:youtube\.com\/(?:watch\?v=|shorts\/)|youtu\.be\/)([a-zA-Z0-9_-]{11})/);
      if (r) embedHtml = '<div class="video-embed"><iframe src="https://www.youtube.com/embed/' + r[1] + '" frameborder="0" allowfullscreen loading="lazy"></iframe></div>';
    } else if (embed.platform === 'instagram') {
      const r = embed.url.match(/instagram\.com\/(?:reel|p)\/([A-Za-z0-9_-]+)/);
      if (r) embedHtml = '<div class="video-embed video-embed--ig"><blockquote class="instagram-media" data-instgrm-permalink="https://www.instagram.com/p/' + r[1] + '/" data-instgrm-version="14" style="width:100%;margin:0;"></blockquote></div>';
    } else if (embed.platform === 'tiktok') {
      const r = embed.url.match(/tiktok\.com\/@[^/]+\/video\/(\d+)/);
      if (r) embedHtml = '<div class="video-embed video-embed--tt"><blockquote class="tiktok-embed" cite="' + embed.url + '" data-video-id="' + r[1] + '" style="width:100%;margin:0;"><section></section></blockquote></div>';
    }

    if (embedHtml) {
      const div = document.createElement('div');
      div.innerHTML = embedHtml;
      el.parentNode.replaceChild(div.firstChild, el);
    }
  });

  // 促銷區塊：隨機挑一個顯示
  const promos = JSON.parse(promosJson);
  if (promos.length === 0) return;

  const promo = promos[Math.floor(Math.random() * promos.length)];
  const block = document.getElementById('promo-block');
  if (!block) return;

  // 依語系選標題
  const promoTitle = (lang === 'en' && promo.title_en) ? promo.title_en
    : (lang === 'zh-cn' && promo.title_zh_cn) ? promo.title_zh_cn
    : (lang === 'zh-hk' && promo.title_zh_hk) ? promo.title_zh_hk
    : promo.title;

  // 依語系本地化連結
  const promoUrl = (lang && lang !== 'zh-tw' && promo.url.startsWith('/blog/'))
    ? `/${lang}${promo.url}` : promo.url;

  const ctaText = lang === 'en' ? 'View Offer →'
    : lang === 'zh-cn' ? '查看优惠 →'
    : '查看優惠 →';

  block.innerHTML = `
    <a href="${promoUrl}" target="_blank" rel="noopener" class="promo-card">
      <div class="promo-body">
        <p class="promo-title">${promoTitle}</p>
        <span class="promo-cta">${ctaText}</span>
      </div>
      ${promo.coverImage
        ? `<div class="promo-image"><img src="${promo.coverImage}" alt="${promoTitle}" loading="lazy" /></div>`
        : ''}
    </a>
  `;
});
</script>

  <ChatBot lang={lang} />
  <Footer lang={lang} />
</body>
</html>

<script>
  // 所有文章內的外部連結自動開新視窗
  document.querySelectorAll('.prose a[href]').forEach(a => {
    const href = (a as HTMLAnchorElement).href;
    if (href && !href.startsWith(location.origin) && !href.startsWith('#')) {
      a.setAttribute('target', '_blank');
      a.setAttribute('rel', 'noopener noreferrer');
    }
  });
</script>

<script>
  // TOC toggle + scroll highlight
  const tocToggle = document.querySelector('.toc-toggle') as HTMLButtonElement | null;
  const tocList = document.getElementById('toc-list');
  if (tocToggle && tocList) {
    tocToggle.addEventListener('click', () => {
      const collapsed = tocList.classList.toggle('hidden');
      tocToggle.textContent = collapsed ? (tocToggle.dataset.expand || '展開') : (tocToggle.dataset.collapse || '收起');
      tocToggle.setAttribute('aria-expanded', String(!collapsed));
    });

    // Scroll spy
    const tocLinks = Array.from(tocList.querySelectorAll('a')) as HTMLAnchorElement[];
    const headingEls = tocLinks.map(a => document.getElementById(a.getAttribute('href')!.slice(1))).filter(Boolean) as HTMLElement[];

    const observer = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          tocLinks.forEach(a => a.classList.remove('active'));
          const idx = headingEls.indexOf(entry.target as HTMLElement);
          if (idx !== -1) tocLinks[idx].classList.add('active');
        }
      });
    }, { rootMargin: '0px 0px -60% 0px', threshold: 0 });

    headingEls.forEach(el => observer.observe(el));
  }
</script>

<script>
  // 圖片燈箱 + 浮水印包裝 + 連續圖片自動輪播
  (function () {
    // ── 燈箱 ──────────────────────────────────────────────
    function openLightbox(src: string, alt: string) {
      const overlay = document.createElement('div');
      overlay.className = 'lb-overlay';
      overlay.innerHTML = `
        <button class="lb-close" aria-label="Close">✕</button>
        <img src="${src}" alt="${alt}" class="lb-img" />
      `;
      document.body.appendChild(overlay);
      document.body.style.overflow = 'hidden';
      requestAnimationFrame(() => overlay.classList.add('lb-open'));

      const close = () => {
        overlay.classList.remove('lb-open');
        document.body.style.overflow = '';
        overlay.addEventListener('transitionend', () => overlay.remove(), { once: true });
        document.removeEventListener('keydown', onKey);
      };
      const onKey = (e: KeyboardEvent) => { if (e.key === 'Escape') close(); };
      overlay.addEventListener('click', (e) => { if (e.target === overlay) close(); });
      (overlay.querySelector('.lb-close') as HTMLElement)!.addEventListener('click', close);
      document.addEventListener('keydown', onKey);
    }

    // ── 圖片 wrapper（浮水印 + 燈箱） ────────────────────
    function wrapImg(img: HTMLImageElement) {
      if (img.closest('.img-wrap')) return;
      const wrap = document.createElement('div');
      wrap.className = 'img-wrap';
      img.parentNode!.insertBefore(wrap, img);
      wrap.appendChild(img);
      img.style.cursor = 'zoom-in';
      img.addEventListener('click', () => openLightbox(img.src, img.alt));
    }

    // ── 取出 <p> 中所有 img（忽略空白文字節點）──────────
    function getImgsOnly(el: Element): HTMLImageElement[] | null {
      const kids = Array.from(el.childNodes).filter(
        n => !(n.nodeType === 3 && !(n as Text).textContent!.trim())
      );
      if (kids.length === 0) return null;
      if (kids.every(k => (k as Element).tagName === 'IMG'))
        return kids as HTMLImageElement[];
      return null;
    }

    // ── 建立輪播（接受圖片陣列 + 要替換的元素陣列）────────
    function buildCarousel(imgs: HTMLImageElement[], toRemove: Element[]) {
      const parent = toRemove[0].parentNode!;
      const anchor = toRemove[0];
      const total = imgs.length;

      // 外框
      const carousel = document.createElement('div');
      carousel.className = 'carousel';

      // 捲動軌道
      const track = document.createElement('div');
      track.className = 'carousel-track';
      carousel.appendChild(track);

      imgs.forEach(img => {
        const slide = document.createElement('div');
        slide.className = 'carousel-slide';
        const wrap = document.createElement('div');
        wrap.className = 'img-wrap';
        img.style.cursor = 'zoom-in';
        img.addEventListener('click', () => openLightbox(img.src, img.alt));
        wrap.appendChild(img);
        slide.appendChild(wrap);
        track.appendChild(slide);
      });

      // Prev / Next 按鈕（覆蓋在圖片上）
      const prevBtn = document.createElement('button');
      prevBtn.className = 'carousel-prev';
      prevBtn.innerHTML = '&#8249;';
      prevBtn.setAttribute('aria-label', 'Previous');
      carousel.appendChild(prevBtn);

      const nextBtn = document.createElement('button');
      nextBtn.className = 'carousel-next';
      nextBtn.innerHTML = '&#8250;';
      nextBtn.setAttribute('aria-label', 'Next');
      carousel.appendChild(nextBtn);

      // Footer：點點 + 計數
      const footer = document.createElement('div');
      footer.className = 'carousel-footer';

      const dots = document.createElement('div');
      dots.className = 'carousel-dots';

      const counter = document.createElement('span');
      counter.className = 'carousel-counter';
      counter.textContent = `1 / ${total}`;

      for (let i = 0; i < total; i++) {
        const dot = document.createElement('button');
        dot.className = 'carousel-dot' + (i === 0 ? ' active' : '');
        dot.setAttribute('aria-label', `Slide ${i + 1}`);
        dot.addEventListener('click', () => goTo(i));
        dots.appendChild(dot);
      }

      footer.appendChild(dots);
      footer.appendChild(counter);
      carousel.appendChild(footer);

      // 插入並移除原來的元素
      parent.insertBefore(carousel, anchor);
      toRemove.forEach(el => el.remove());

      // ── 輪播邏輯 ──
      let current = 0;
      const allDots = Array.from(dots.querySelectorAll<HTMLButtonElement>('.carousel-dot'));

      function goTo(idx: number) {
        current = ((idx % total) + total) % total;
        track.style.transform = `translateX(-${current * 100}%)`;
        allDots.forEach((d, i) => d.classList.toggle('active', i === current));
        counter.textContent = `${current + 1} / ${total}`;
      }

      prevBtn.addEventListener('click', () => goTo(current - 1));
      nextBtn.addEventListener('click', () => goTo(current + 1));

      // 鍵盤
      carousel.setAttribute('tabindex', '0');
      carousel.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'ArrowLeft') goTo(current - 1);
        if (e.key === 'ArrowRight') goTo(current + 1);
      });

      // 觸控滑動
      let touchX = 0;
      carousel.addEventListener('touchstart', (e: TouchEvent) => {
        touchX = e.touches[0].clientX;
      }, { passive: true });
      carousel.addEventListener('touchend', (e: TouchEvent) => {
        const diff = touchX - e.changedTouches[0].clientX;
        if (Math.abs(diff) > 40) goTo(current + (diff > 0 ? 1 : -1));
      }, { passive: true });
    }

    // ── 主流程 ────────────────────────────────────────────
    const prose = document.querySelector('.prose');
    if (!prose) return;

    const visited = new WeakSet<Element>();

    Array.from(prose.querySelectorAll('p')).forEach(para => {
      if (visited.has(para)) return;

      const imgs = getImgsOnly(para);
      if (!imgs) return; // 含文字或非圖片內容 → 略過

      visited.add(para);

      if (imgs.length >= 2) {
        // 情況 A：單一 <p> 內含多張圖（無空行，最常見）
        buildCarousel(imgs, [para]);
      } else {
        // 情況 B：<p> 只有一張圖 → 往下收集連續的同類 <p>
        const group: Element[] = [para];
        let sib = para.nextElementSibling;
        while (sib) {
          const sibImgs = getImgsOnly(sib);
          if (!sibImgs || sibImgs.length !== 1) break;
          group.push(sib);
          visited.add(sib);
          sib = sib.nextElementSibling;
        }

        if (group.length >= 2) {
          // 多個單圖 <p> 連續排列（有空行）
          const allImgs = group.map(p => p.querySelector('img') as HTMLImageElement);
          buildCarousel(allImgs, group);
        } else {
          wrapImg(imgs[0]);
        }
      }
    });

    // 剩餘未包裝的圖片（inline、表格內等）
    prose.querySelectorAll<HTMLImageElement>('img').forEach(wrapImg);
  })();
</script>

<script>
  // Page view counter — session-deduped (same tab only counts once)
  (function () {
    const slug = location.pathname.replace(/\/?$/, '/').replace(/^(?!\/)/, '/');
    if (!slug.startsWith('/blog/')) return;
    const key = '_pv' + slug;
    if (sessionStorage.getItem(key)) return;
    sessionStorage.setItem(key, '1');
    fetch('/api/pageview', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ slug }),
      keepalive: true,
    }).catch(() => {});
  })();
</script>

