<script>
  // TOC toggle + scroll highlight
  const tocToggle = document.querySelector('.toc-toggle') as HTMLButtonElement | null;
  const tocList = document.getElementById('toc-list');
  if (tocToggle && tocList) {
    tocToggle.addEventListener('click', () => {
      const collapsed = tocList.classList.toggle('hidden');
      tocToggle.textContent = collapsed ? (tocToggle.dataset.expand || '展開') : (tocToggle.dataset.collapse || '收起');
      tocToggle.setAttribute('aria-expanded', String(!collapsed));
    });

    // Scroll spy
    const tocLinks = Array.from(tocList.querySelectorAll('a')) as HTMLAnchorElement[];
    const headingEls = tocLinks.map(a => document.getElementById(a.getAttribute('href')!.slice(1))).filter(Boolean) as HTMLElement[];

    const observer = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          tocLinks.forEach(a => a.classList.remove('active'));
          const idx = headingEls.indexOf(entry.target as HTMLElement);
          if (idx !== -1) tocLinks[idx].classList.add('active');
        }
      });
    }, { rootMargin: '0px 0px -60% 0px', threshold: 0 });

    headingEls.forEach(el => observer.observe(el));
  }
</script>

<script>
  // 圖片燈箱 + 浮水印包裝 + 連續圖片自動輪播
  (function () {
    // ── 燈箱 ──────────────────────────────────────────────
    function openLightbox(src: string, alt: string) {
      const overlay = document.createElement('div');
      overlay.className = 'lb-overlay';
      overlay.innerHTML = `
        <button class="lb-close" aria-label="Close">✕</button>
        <img src="${src}" alt="${alt}" class="lb-img" />
      `;
      document.body.appendChild(overlay);
      document.body.style.overflow = 'hidden';
      requestAnimationFrame(() => overlay.classList.add('lb-open'));

      const close = () => {
        overlay.classList.remove('lb-open');
        document.body.style.overflow = '';
        overlay.addEventListener('transitionend', () => overlay.remove(), { once: true });
        document.removeEventListener('keydown', onKey);
      };
      const onKey = (e: KeyboardEvent) => { if (e.key === 'Escape') close(); };
      overlay.addEventListener('click', (e) => { if (e.target === overlay) close(); });
      (overlay.querySelector('.lb-close') as HTMLElement)!.addEventListener('click', close);
      document.addEventListener('keydown', onKey);
    }

    // ── 圖片 wrapper（浮水印 + 燈箱） ────────────────────
    function wrapImg(img: HTMLImageElement) {
      if (img.closest('.img-wrap')) return;
      const wrap = document.createElement('div');
      wrap.className = 'img-wrap';
      img.parentNode!.insertBefore(wrap, img);
      wrap.appendChild(img);
      img.style.cursor = 'zoom-in';
      img.addEventListener('click', () => openLightbox(img.src, img.alt));
    }

    // ── 取出 <p> 中所有 img（忽略空白文字節點）──────────
    function getImgsOnly(el: Element): HTMLImageElement[] | null {
      const kids = Array.from(el.childNodes).filter(
        n => !(n.nodeType === 3 && !(n as Text).textContent!.trim())
      );
      if (kids.length === 0) return null;
      if (kids.every(k => (k as Element).tagName === 'IMG'))
        return kids as HTMLImageElement[];
      return null;
    }

    // ── 建立輪播（接受圖片陣列 + 要替換的元素陣列）────────
    function buildCarousel(imgs: HTMLImageElement[], toRemove: Element[]) {
      const parent = toRemove[0].parentNode!;
      const anchor = toRemove[0];
      const total = imgs.length;

      // 外框
      const carousel = document.createElement('div');
      carousel.className = 'carousel';

      // 捲動軌道
      const track = document.createElement('div');
      track.className = 'carousel-track';
      carousel.appendChild(track);

      imgs.forEach(img => {
        const slide = document.createElement('div');
        slide.className = 'carousel-slide';
        const wrap = document.createElement('div');
        wrap.className = 'img-wrap';
        img.style.cursor = 'zoom-in';
        img.addEventListener('click', () => openLightbox(img.src, img.alt));
        wrap.appendChild(img);
        slide.appendChild(wrap);
        track.appendChild(slide);

        // 直幅圖不強制撐滿寬度
        // img.decode() 強制載入並等待解碼完成，確保能讀到 naturalWidth/Height
        img.loading = 'eager';
        img.decode().then(() => {
          if (img.naturalHeight > img.naturalWidth) {
            slide.classList.add('is-vertical');
          }
        }).catch(() => {});
      });

      // Prev / Next 按鈕（覆蓋在圖片上）
      const prevBtn = document.createElement('button');
      prevBtn.className = 'carousel-prev';
      prevBtn.innerHTML = '&#8249;';
      prevBtn.setAttribute('aria-label', 'Previous');
      carousel.appendChild(prevBtn);

      const nextBtn = document.createElement('button');
      nextBtn.className = 'carousel-next';
      nextBtn.innerHTML = '&#8250;';
      nextBtn.setAttribute('aria-label', 'Next');
      carousel.appendChild(nextBtn);

      // Footer：點點 + 計數
      const footer = document.createElement('div');
      footer.className = 'carousel-footer';

      const dots = document.createElement('div');
      dots.className = 'carousel-dots';

      const counter = document.createElement('span');
      counter.className = 'carousel-counter';
      counter.textContent = `1 / ${total}`;

      for (let i = 0; i < total; i++) {
        const dot = document.createElement('button');
        dot.className = 'carousel-dot' + (i === 0 ? ' active' : '');
        dot.setAttribute('aria-label', `Slide ${i + 1}`);
        dot.addEventListener('click', () => goTo(i));
        dots.appendChild(dot);
      }

      footer.appendChild(dots);
      footer.appendChild(counter);
      carousel.appendChild(footer);

      // 插入並移除原來的元素
      parent.insertBefore(carousel, anchor);
      toRemove.forEach(el => el.remove());

      // ── 輪播邏輯 ──
      let current = 0;
      const allDots = Array.from(dots.querySelectorAll<HTMLButtonElement>('.carousel-dot'));

      function goTo(idx: number) {
        current = ((idx % total) + total) % total;
        track.style.transform = `translateX(-${current * 100}%)`;
        allDots.forEach((d, i) => d.classList.toggle('active', i === current));
        counter.textContent = `${current + 1} / ${total}`;
      }

      prevBtn.addEventListener('click', () => goTo(current - 1));
      nextBtn.addEventListener('click', () => goTo(current + 1));

      // 鍵盤
      carousel.setAttribute('tabindex', '0');
      carousel.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'ArrowLeft') goTo(current - 1);
        if (e.key === 'ArrowRight') goTo(current + 1);
      });

      // 觸控滑動
      let touchX = 0;
      carousel.addEventListener('touchstart', (e: TouchEvent) => {
        touchX = e.touches[0].clientX;
      }, { passive: true });
      carousel.addEventListener('touchend', (e: TouchEvent) => {
        const diff = touchX - e.changedTouches[0].clientX;
        if (Math.abs(diff) > 40) goTo(current + (diff > 0 ? 1 : -1));
      }, { passive: true });
    }

    // ── 主流程 ────────────────────────────────────────────
    const prose = document.querySelector('.prose');
    if (!prose) return;

    const visited = new WeakSet<Element>();

    Array.from(prose.querySelectorAll('p')).forEach(para => {
      if (visited.has(para)) return;

      const imgs = getImgsOnly(para);
      if (!imgs) return; // 含文字或非圖片內容 → 略過

      visited.add(para);

      if (imgs.length >= 2) {
        // 情況 A：單一 <p> 內含多張圖（無空行，最常見）
        buildCarousel(imgs, [para]);
      } else {
        // 情況 B：<p> 只有一張圖 → 往下收集連續的同類 <p>
        const group: Element[] = [para];
        let sib = para.nextElementSibling;
        while (sib) {
          const sibImgs = getImgsOnly(sib);
          if (!sibImgs || sibImgs.length !== 1) break;
          group.push(sib);
          visited.add(sib);
          sib = sib.nextElementSibling;
        }

        if (group.length >= 2) {
          // 多個單圖 <p> 連續排列（有空行）
          const allImgs = group.map(p => p.querySelector('img') as HTMLImageElement);
          buildCarousel(allImgs, group);
        } else {
          wrapImg(imgs[0]);
        }
      }
    });

    // 剩餘未包裝的圖片（inline、表格內等）
    prose.querySelectorAll<HTMLImageElement>('img').forEach(wrapImg);
  })();
</script>

<script>
  // 分享列：複製連結 + 書籤
  (function () {
    const BOOKMARK_KEY = 'bk';

    function getSaved(): Record<string, string> {
      try { return JSON.parse(localStorage.getItem(BOOKMARK_KEY) || '{}'); } catch { return {}; }
    }

    document.querySelectorAll<HTMLElement>('.share-bar').forEach(bar => {
      const url   = bar.dataset.url   || location.href;
      const title = bar.dataset.title || document.title;

      // 複製連結
      bar.querySelectorAll<HTMLButtonElement>('[data-action="copy"]').forEach(btn => {
        btn.addEventListener('click', async () => {
          try {
            await navigator.clipboard.writeText(url);
          } catch {
            const ta = document.createElement('textarea');
            ta.value = url; document.body.appendChild(ta);
            ta.select(); document.execCommand('copy');
            ta.remove();
          }
          const orig = btn.textContent!;
          btn.textContent = bar.dataset.copiedLabel || 'Copied!';
          btn.classList.add('copied');
          setTimeout(() => { btn.textContent = orig; btn.classList.remove('copied'); }, 1800);
        });
      });

      // 小紅書 / Instagram：複製連結
      async function copyUrlToClipboard(url: string) {
        try {
          await navigator.clipboard.writeText(url);
        } catch {
          const ta = document.createElement('textarea');
          ta.value = url; document.body.appendChild(ta);
          ta.select(); document.execCommand('copy');
          ta.remove();
        }
      }
      ['rednote', 'instagram'].forEach(action => {
        bar.querySelectorAll<HTMLButtonElement>(`[data-action="${action}"]`).forEach(btn => {
          btn.addEventListener('click', async () => {
            await copyUrlToClipboard(url);
            const orig = btn.innerHTML;
            btn.textContent = '已複製！';
            btn.classList.add('copied');
            setTimeout(() => { btn.innerHTML = orig; btn.classList.remove('copied'); }, 1800);
          });
        });
      });

      // 書籤
      bar.querySelectorAll<HTMLButtonElement>('[data-action="bookmark"]').forEach(btn => {
        const saved = getSaved();
        const isSaved = !!saved[url];
        if (isSaved) { btn.classList.add('saved'); btn.textContent = '🔖 ' + (bar.dataset.bookmarkedLabel || 'Saved!'); }

        btn.addEventListener('click', () => {
          const current = getSaved();
          if (current[url]) {
            delete current[url];
            btn.classList.remove('saved');
            btn.textContent = '🔖 ' + (bar.dataset.bookmarkLabel || 'Bookmark');
          } else {
            current[url] = title;
            btn.classList.add('saved');
            btn.textContent = '🔖 ' + (bar.dataset.bookmarkedLabel || 'Saved!');
          }
          localStorage.setItem(BOOKMARK_KEY, JSON.stringify(current));
        });
      });
    });
  })();
</script>

