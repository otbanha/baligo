    padding: 0.3em 0.85em;
    border-radius: 20px;
    border: 1px solid rgba(197,160,89,0.35);
    background: rgba(255,255,255,0.08);
    color: #e8d5a3;
    font-size: 0.83em;
    font-weight: 600;
    white-space: nowrap;
    margin-bottom: 0;
