---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import SEO from '../components/SEO.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import ChatBot from '../components/ChatBot.astro';
import TripPlannerBanner from '../components/TripPlannerBanner.astro';
import { getCollection } from 'astro:content';
import { enhancedTitle, enhancedDescription, COMPANION_CAT } from '../utils/seo-keywords';

type Props = CollectionEntry<'blog'>['data'] & { body?: string; headings?: { depth: number; slug: string; text: string }[]; lang?: string; slug?: string };
const { title, description, pubDate, updatedDate, heroImage, category, embeds, embedMap = {}, body = '', headings = [], lang, slug, private: isPrivate, shuffle_h2: shuffleH2 } = Astro.props;

const tocHeadings = headings.filter(h => h.depth === 1 || h.depth === 2 || h.depth === 3);
const showToc = tocHeadings.length >= 2;

// OG image：優先用 heroImage，沒有才抓文章第一張圖
function extractFirstImage(text: string): string {
  const m = text?.match(/!\[.*?\]\((https?:\/\/[^\)\s]+)\)/);
  return m ? m[1] : '';
}
const ogImage = (typeof heroImage === 'string' && heroImage) ? heroImage : extractFirstImage(body);

// Keyword-enhanced title & description for <meta> tags
const cats = Array.isArray(category) ? category : (category ? [category] : []);
const metaTitle = enhancedTitle(title, cats, lang ?? 'zh-tw');
const metaDesc  = enhancedDescription(description ?? '', cats, lang ?? 'zh-tw');

const collectionName = lang === 'en' ? 'en' : lang === 'zh-cn' ? 'zh-cn' : lang === 'zh-hk' ? 'zh-hk' : 'blog';
const allPosts = await getCollection(collectionName as any);

const CAT_EN: Record<string, string> = {
  '新手指南': "Beginner's Guide",
  '住宿推薦': 'Accommodation', '住宿推荐': 'Accommodation',
  '峇里島分區攻略': 'Area Guide', '峇里岛分区攻略': 'Area Guide',
  '簽證通關': 'Visa & Entry', '签证通关': 'Visa & Entry',
  '叫車包車': 'Transport', '叫车包车': 'Transport',
  '家庭親子': 'Family Travel', '家庭亲子': 'Family Travel',
  '遊記分享': 'Travel Stories', '游记分享': 'Travel Stories',
  '美食景點活動': 'Food & Activities', '美食景点活动': 'Food & Activities',
  '新聞存檔': 'News Archive', '新闻存档': 'News Archive',
  '旅行技巧': 'Travel Tips',
};

const CAT_ZH_CN: Record<string, string> = {
  '新手指南': '新手指南',
  '住宿推薦': '住宿推荐', '住宿推荐': '住宿推荐',
  '峇里島分區攻略': '峇里岛分区攻略', '峇里岛分区攻略': '峇里岛分区攻略',
  '簽證通關': '签证通关', '签证通关': '签证通关',
  '叫車包車': '叫车包车', '叫车包车': '叫车包车',
  '家庭親子': '家庭亲子', '家庭亲子': '家庭亲子',
  '遊記分享': '游记分享', '游记分享': '游记分享',
  '美食景點活動': '美食景点活动', '美食景点活动': '美食景点活动',
  '新聞存檔': '新闻存档', '新闻存档': '新闻存档',
};

const getCatLabel = (cat: string) => {
  if (lang === 'en') return CAT_EN[cat] ?? cat;
  if (lang === 'zh-cn') return CAT_ZH_CN[cat] ?? cat;
  return cat;
};

const blogBase = lang === 'en' ? '/en/blog' : lang === 'zh-cn' ? '/zh-cn/blog' : lang === 'zh-hk' ? '/zh-hk/blog' : '/blog';
const isZhTw = lang !== 'en' && lang !== 'zh-cn' && lang !== 'zh-hk';
const blogIndexUrl = isZhTw ? `${blogBase}/?lang=tw` : `${blogBase}/`;
const catBaseUrl   = isZhTw ? `${blogBase}/?lang=tw&cat=` : `${blogBase}?cat=`;

const canonicalUrl = `https://gobaligo.id${blogBase}/${slug}/`;
const shareText = encodeURIComponent(title);
const shareUrl  = encodeURIComponent(canonicalUrl);
const shareLinks = {
  fb:  `https://www.facebook.com/sharer/sharer.php?u=${shareUrl}`,
  line:`https://social-plugins.line.me/lineit/share?url=${shareUrl}`,
  wa:  `https://api.whatsapp.com/send?text=${shareText}%20${shareUrl}`,
  x:   `https://twitter.com/intent/tweet?url=${shareUrl}&text=${shareText}`,
};
const i18nShare = {
  label:    lang === 'en' ? 'Share' : lang === 'zh-cn' ? '分享' : '分享',
  copy:     lang === 'en' ? 'Copy Link' : lang === 'zh-cn' ? '复制链接' : '複製連結',
  copied:   lang === 'en' ? 'Copied!' : lang === 'zh-cn' ? '已复制！' : '已複製！',
  bookmark: lang === 'en' ? 'Bookmark' : lang === 'zh-cn' ? '收藏' : '書籤',
  bookmarked: lang === 'en' ? 'Saved!' : lang === 'zh-cn' ? '已收藏！' : '已儲存！',
};

const i18n = {
  sidebarTitle: lang === 'en' ? '📂 Categories' : lang === 'zh-cn' ? '📂 文章分类' : '📂 文章分類',
  allArticles: lang === 'en' ? 'Home' : '首頁',
  breadcrumbAll: lang === 'en' ? '← All Articles' : '← 所有文章',
  tocTitle: lang === 'en' ? '📋 Contents' : lang === 'zh-cn' ? '📋 目录' : '📋 目錄',
  tocCollapse: lang === 'en' ? 'Collapse' : '收起',
  tocExpand: lang === 'en' ? 'Expand' : lang === 'zh-cn' ? '展开' : '展開',
  relatedTitle: lang === 'en' ? '🗺️ You May Also Like' : lang === 'zh-cn' ? '🗺️ 你可能也想看' : '🗺️ 你可能也想看',
};

const categoryOrder = [
  '新手指南',
  '住宿推薦',
  '峇里島分區攻略',
  '簽證通關',
  '叫車包車',
  '家庭親子',
  '遊記分享',
  '美食景點活動',
  '新聞存檔',
];

const allCategories = [...new Set(allPosts.flatMap(p =>
  Array.isArray(p.data.category) ? p.data.category : [p.data.category]
).filter(Boolean))];

const categories = [
  ...categoryOrder.filter(c => allCategories.includes(c)),
  ...allCategories.filter(c => !categoryOrder.includes(c)),
];

const categoryCounts = categories.reduce((acc, cat) => {
  acc[cat] = allPosts.filter(p => {
    const cats = Array.isArray(p.data.category) ? p.data.category : [p.data.category];
    return cats.includes(cat);
  }).length;
  return acc;
}, {});

// 相關文章推薦：同分類優先，補足用 companion 分類（Topical Authority Siloing）
const getRandomPosts = (categoryName: string, count: number) => {
  return allPosts
    .filter(p => {
      const pCats = Array.isArray(p.data.category) ? p.data.category : [p.data.category];
      return pCats.includes(categoryName) && p.data.title !== title;
    })
    .sort(() => Math.random() - 0.5)
    .slice(0, count);
};

const primaryCat = cats[0] ?? '峇里島分區攻略';
const sameCatPosts = getRandomPosts(primaryCat, 4);
const companionCat = COMPANION_CAT[primaryCat] ?? '峇里島分區攻略';
const companionPosts = companionCat !== primaryCat
  ? getRandomPosts(companionCat, Math.max(2, 6 - sameCatPosts.length))
  : [];
const randomPosts = [...sameCatPosts, ...companionPosts].slice(0, 6);

// 促銷活動：過濾未過期的
const allPromos = await getCollection('promotions');
const now = new Date();
const activePromos = allPromos.filter(p => {
  if (!p.data.expiresAt) return true;
  const d = new Date(p.data.expiresAt);
  return isNaN(d.getTime()) || d > now;
});
const promosJson = JSON.stringify(activePromos.map(p => ({
  title: p.data.title,
  title_en: p.data.title_en || null,
  title_zh_cn: p.data.title_zh_cn || null,
  title_zh_hk: p.data.title_zh_hk || null,
  url: p.data.url,
  coverImage: p.data.coverImage || null,
})));
---

<html lang={lang === 'zh-cn' ? 'zh-CN' : lang === 'zh-hk' ? 'zh-HK' : lang === 'en' ? 'en' : 'zh-TW'}>
<head>
  <BaseHead
    title={metaTitle}
    description={metaDesc}
    image={ogImage || undefined}
    type="article"
    publishedTime={pubDate ? new Date(pubDate).toISOString() : undefined}
    modifiedTime={updatedDate ? new Date(updatedDate).toISOString() : (pubDate ? new Date(pubDate).toISOString() : undefined)}
  />

  {isPrivate && <meta name="robots" content="noindex,nofollow" />}

  <!-- LCP preload: fetch hero image early to reduce Largest Contentful Paint -->
  {ogImage && ogImage !== 'https://gobaligo.id/og-default.jpg' && (
    <link rel="preload" as="image" href={ogImage} fetchpriority="high" />
  )}

  <!-- 繁體中文文章：設定 session 標記，防止 /blog/ 首頁偵測瀏覽器語言後把使用者跳轉到其他語系 -->
  {(!lang || lang === 'zh-tw') && (
    <script is:inline>sessionStorage.setItem('gobaligo_lang_checked', '1');</script>
  )}

  <!-- hreflang: 列出全部語言版本，讓 Google 了解多語系關係 -->
  {slug && <>
    <link rel="alternate" hreflang="x-default"  href={`https://gobaligo.id/blog/${slug}/`} />
    <link rel="alternate" hreflang="zh-TW"      href={`https://gobaligo.id/blog/${slug}/`} />
    <link rel="alternate" hreflang="zh-HK"      href={`https://gobaligo.id/zh-hk/blog/${slug}/`} />
    <link rel="alternate" hreflang="zh-CN"      href={`https://gobaligo.id/zh-cn/blog/${slug}/`} />
    <link rel="alternate" hreflang="en"         href={`https://gobaligo.id/en/blog/${slug}/`} />
  </>}

  <!-- JSON-LD: Category-Aware Schema.org (Article + BreadcrumbList + category-specific) -->
  {slug && <SEO
    title={title}
    description={description ?? ''}
    category={category}
    body={body}
    headings={headings}
    lang={lang}
    slug={slug}
    pubDate={pubDate}
    updatedDate={updatedDate}
    heroImage={ogImage}
  />}
</head>

<body>
  <Header lang={lang ?? 'blog'} slug={slug} />
  <div class="layout">

    <aside class="sidebar" data-pagefind-ignore>
      <div class="sidebar-section">
        <h3 class="sidebar-title">{i18n.sidebarTitle}</h3>
        <ul class="category-list">
          <li>
            <a href={blogIndexUrl} class="category-item">
              <span class="cat-name">{i18n.allArticles}</span>
              <span class="cat-count">{allPosts.length}</span>
            </a>
          </li>
          {categories.map(cat => (
            <li>
              <a href={`${catBaseUrl}${encodeURIComponent(cat)}`}
                 class={`category-item ${(Array.isArray(category) ? category : [category]).includes(cat) ? 'active' : ''}`}
                <span class="cat-name">{getCatLabel(cat)}</span>
                <span class="cat-count">{categoryCounts[cat]}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

    </aside>

    <main>
      <!-- Mobile 分類導覽（桌機版有 sidebar，手機版才顯示） -->
      <nav class="mobile-breadcrumb" aria-label="分類導覽">
        <a href={blogIndexUrl} class="breadcrumb-home">{i18n.breadcrumbAll}</a>
        {category && (
          <>
            <span class="breadcrumb-sep">›</span>
            <a
              href={`${catBaseUrl}${encodeURIComponent(Array.isArray(category) ? category[0] : category)}`}
              class="breadcrumb-cat"
            >
              {getCatLabel(Array.isArray(category) ? category[0] : category)}
            </a>
          </>
        )}
      </nav>

      <article {...(isPrivate ? { 'data-pagefind-ignore': true } : { 'data-pagefind-body': true })}>
        {!isPrivate && <span data-pagefind-filter={`lang:${lang ?? 'zh-tw'}`} hidden aria-hidden="true"></span>}
        <div class="prose">
          <div class="title">
            {category && <span class="article-category" data-pagefind-meta="category">{getCatLabel(Array.isArray(category) ? category[0] : category)}</span>}
            <h1>{title}</h1>
            <div class="date">
              <FormattedDate date={pubDate} />
              {updatedDate && (
                <span class="last-updated-on">· 更新於 <FormattedDate date={updatedDate} /></span>
              )}
              <a href={`/admin/#/collections/blog/entries/${Astro.params.slug}`} class="edit-link" target="_blank" rel="noopener">✏️ 編輯文章</a>
            </div>
            <hr />
          </div>

          <!-- 分享列（頂部） -->
          <div class="share-bar" data-url={canonicalUrl} data-title={title} data-bookmark-label={i18nShare.bookmark} data-bookmarked-label={i18nShare.bookmarked} data-copy-label={i18nShare.copy} data-copied-label={i18nShare.copied}>
            <span class="share-label">{i18nShare.label}：</span>
            <a href={shareLinks.line} target="_blank" rel="noopener" class="share-btn share-line" aria-label="LINE">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.494.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.281.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/></svg>
              LINE
            </a>
            <a href={shareLinks.fb} target="_blank" rel="noopener" class="share-btn share-fb" aria-label="Facebook">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              Facebook
            </a>
            <a href={shareLinks.wa} target="_blank" rel="noopener" class="share-btn share-wa" aria-label="WhatsApp">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              WhatsApp
            </a>
            <a href={shareLinks.x} target="_blank" rel="noopener" class="share-btn share-x" aria-label="X (Twitter)">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              X
            </a>
            <button class="share-btn share-copy" data-action="copy">{i18nShare.copy}</button>
            <button class="share-btn share-bookmark" data-action="bookmark">🔖 {i18nShare.bookmark}</button>
          </div>

          {heroImage && heroImage !== extractFirstImage(body) && (
            <div class="hero-image">
              <img src={heroImage} alt={title} loading="eager" fetchpriority="high" />
            </div>
          )}

          {showToc && (
            <nav class="toc" aria-label="文章目錄">
              <div class="toc-header">
                <span class="toc-title">{i18n.tocTitle}</span>
                <button class="toc-toggle" aria-expanded="true" aria-controls="toc-list" data-collapse={i18n.tocCollapse} data-expand={i18n.tocExpand}>{i18n.tocCollapse}</button>
              </div>
              <ol id="toc-list" class="toc-list">
                {tocHeadings.map(h => (
                  <li class={h.depth === 1 ? 'toc-h1' : h.depth === 3 ? 'toc-h3' : 'toc-h2'}>
                    <a href={`#${h.slug}`}>{h.text}</a>
                  </li>
                ))}
              </ol>
            </nav>
          )}

          <div id="article-body" data-shuffle={shuffleH2 ? 'true' : 'false'}>
            <slot />
          </div>

          <!-- 促銷區塊 -->
          {activePromos.length > 0 && (
            <div id="promo-block-article"></div>
          )}

          <!-- Trip Planner Banner -->
          <TripPlannerBanner lang={lang === 'zh-cn' ? 'zh-cn' : lang === 'zh-hk' ? 'zh-hk' : lang === 'en' ? 'en' : 'zh-tw'} />

          <!-- 分享列（底部） -->
          <div class="share-bar share-bar--bottom" data-url={canonicalUrl} data-title={title} data-bookmark-label={i18nShare.bookmark} data-bookmarked-label={i18nShare.bookmarked} data-copy-label={i18nShare.copy} data-copied-label={i18nShare.copied}>
            <span class="share-label">{i18nShare.label}：</span>
            <a href={shareLinks.line} target="_blank" rel="noopener" class="share-btn share-line" aria-label="LINE">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.630 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.494.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.281.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/></svg>
              LINE
            </a>
            <a href={shareLinks.fb} target="_blank" rel="noopener" class="share-btn share-fb" aria-label="Facebook">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              Facebook
            </a>
            <a href={shareLinks.wa} target="_blank" rel="noopener" class="share-btn share-wa" aria-label="WhatsApp">
