---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
}
const { title, description } = Astro.props;

const pathname = Astro.url.pathname;
const currentLang = pathname.startsWith('/zh-cn/') ? 'zh-cn'
                  : pathname.startsWith('/zh-hk/') ? 'zh-hk'
                  : pathname.startsWith('/en/')    ? 'en'
                  : 'blog';
const basePath = pathname
  .replace(/^\/(zh-cn|zh-hk|en)\//, '')
  .replace(/^\//, '')
  .replace(/\/$/, '');
const htmlLang = currentLang === 'zh-cn' ? 'zh-Hans'
               : currentLang === 'en'    ? 'en'
               : 'zh-TW';
---
<!DOCTYPE html>
<html lang={htmlLang}>
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <Header lang={currentLang} basePath={basePath} />
    <main class="biz-main">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  body {
    background: #0f1410;
    color: #e8dcc8;
    min-height: 100vh;
  }

  .biz-main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1rem 4rem;
  }

  /* ── Biz card ────────────────────────────────────── */
  .biz-card {
    background: #1a2118;
    border: 1px solid #2a3526;
    border-radius: 10px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .biz-card__photo {
    width: 100%;
    height: 202px;
    background: #000;
    overflow: hidden;
    flex-shrink: 0;
  }

  .biz-card__photo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .biz-card__photo-placeholder {
    width: 100%;
    height: 100%;
    background: #111;
  }

  .biz-card__body {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .biz-card__name {
    font-size: 1.05rem;
    font-weight: 700;
    color: #f0e6cc;
    margin: 0;
    line-height: 1.3;
  }

  .biz-card__name-en {
    display: block;
    font-size: 0.8rem;
    font-weight: 400;
    color: #a09070;
    margin-top: 2px;
  }

  .biz-card__area {
    display: inline-block;
    background: rgba(201, 168, 76, 0.15);
    border: 1px solid rgba(201, 168, 76, 0.4);
    color: #c9a84c;
    font-size: 0.75rem;
    padding: 2px 8px;
    border-radius: 20px;
    width: fit-content;
  }

  .biz-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .biz-card__tag {
    background: rgba(201, 168, 76, 0.08);
    border: 1px solid #2a3526;
    color: #b0c8a0;
    font-size: 0.7rem;
    padding: 2px 7px;
    border-radius: 4px;
  }

  .biz-card__desc {
    font-size: 0.85rem;
    color: #b0a090;
    margin: 0;
    line-height: 1.5;
  }

  .biz-card__hours {
    font-size: 0.78rem;
    color: #8a9880;
    margin: 0;
  }

  .biz-card__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: auto;
    padding-top: 0.5rem;
  }

  /* ── Buttons ─────────────────────────────────────── */
  .btn {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 5px 12px;
    border-radius: 5px;
    text-decoration: none;
    transition: opacity 0.15s;
    white-space: nowrap;
  }
  .btn:hover { opacity: 0.8; }

  .btn--line { background: #06c755; color: #fff; }
  .btn--wa   { background: #25d366; color: #fff; }
  .btn--ig   { background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366); color: #fff; }
  .btn--map  { background: #4a86e8; color: #fff; }
  .btn--gold {
    background: #c9a84c;
    color: #0f1410;
    padding: 10px 28px;
    font-size: 0.95rem;
    border-radius: 6px;
  }

  /* ── Grid layouts ────────────────────────────────── */
  .biz-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  /* ── Section headers ─────────────────────────────── */
  .biz-section-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: #c9a84c;
    border-left: 3px solid #c9a84c;
    padding-left: 0.75rem;
    margin: 2rem 0 1rem;
  }

  /* ── Accordion (non-featured) ────────────────────── */
  .biz-accordion {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .biz-accordion details {
    background: #1a2118;
    border: 1px solid #2a3526;
    border-radius: 6px;
    overflow: hidden;
  }

  .biz-accordion summary {
    padding: 0.7rem 1rem;
    cursor: pointer;
    font-size: 0.9rem;
    color: #e8dcc8;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    list-style: none;
    user-select: none;
  }
  .biz-accordion summary::-webkit-details-marker { display: none; }
  .biz-accordion summary::before {
    content: '▶';
    font-size: 0.6rem;
    color: #c9a84c;
    transition: transform 0.15s;
    flex-shrink: 0;
  }
  .biz-accordion details[open] summary::before { transform: rotate(90deg); }

  .biz-accordion .detail-body {
    padding: 0.75rem 1rem 1rem;
    border-top: 1px solid #2a3526;
    font-size: 0.85rem;
    color: #b0a090;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .biz-accordion .detail-body .biz-card__actions { padding-top: 0.5rem; }

  /* ── Category nav cards ──────────────────────────── */
  .cat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 1rem;
    margin: 1.5rem 0;
  }

  .cat-card {
    background: #1a2118;
    border: 1px solid #2a3526;
    border-radius: 8px;
    padding: 1.25rem 1rem;
    text-align: center;
    text-decoration: none;
    color: #e8dcc8;
    transition: border-color 0.15s, background 0.15s;
  }
  .cat-card:hover {
    border-color: #c9a84c;
    background: #1f2b1c;
  }

  .cat-card__icon { font-size: 2rem; display: block; margin-bottom: 0.5rem; }
  .cat-card__label { font-size: 0.9rem; font-weight: 600; }

  /* ── Page hero ───────────────────────────────────── */
  .biz-hero {
    text-align: center;
    padding: 2.5rem 1rem 1.5rem;
    border-bottom: 1px solid #2a3526;
    margin-bottom: 2rem;
  }

  .biz-hero h1 {
    font-size: 1.8rem;
    font-weight: 800;
    color: #c9a84c;
    margin: 0 0 0.5rem;
  }

  .biz-hero p {
    color: #a09070;
    font-size: 0.95rem;
    margin: 0;
    max-width: 560px;
    margin-inline: auto;
  }

  /* ── Register CTA ────────────────────────────────── */
  .biz-register-cta {
    text-align: center;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid #2a3526;
  }

  .biz-register-cta p {
    color: #a09070;
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  /* ── Mobile ──────────────────────────────────────── */
  @media (max-width: 600px) {
    .biz-hero h1 { font-size: 1.4rem; }
    .cat-grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>
